#. module: M02_P0211
#: model:mail.template,body_html:M02_P0211.email_template_onboarding_welcome
msgid ""
"<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n"
"\n"
"    <div style=\"background-color: #DA291C; padding: 30px 20px; text-align: center;\">\n"
"        <h1 style=\"color: #FFC72C; margin: 0; font-size: 28px;\">McDonald's</h1>\n"
"        <p style=\"color: #fff; margin: 8px 0 0; font-size: 14px;\">Chào mừng bạn gia nhập đội ngũ!</p>\n"
"    </div>\n"
"\n"
"    <div style=\"padding: 30px 20px; background: #fff;\">\n"
"        <p>Kính chào <strong>{{ object.name }}</strong>,</p>\n"
"\n"
"        <p>Chúc mừng bạn đã được chọn tham gia vào đội ngũ <strong>McDonald's</strong>!\n"
"        Để hoàn tất quá trình onboarding, vui lòng đăng nhập vào hệ thống và nộp các giấy tờ cần thiết.</p>\n"
"\n"
"        <!-- Thông tin tài khoản -->\n"
"        <div style=\"background: #fff8e1; border: 1px solid #FFC72C; border-radius: 8px; padding: 20px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 12px; color: #DA291C;\">Thông tin tài khoản của bạn</h3>\n"
"            <table style=\"width: 100%; border-collapse: collapse;\">\n"
"                <tr>\n"
"                    <td style=\"padding: 6px 0; color: #666; width: 140px;\"><strong>Tên đăng nhập:</strong></td>\n"
"                    <td style=\"padding: 6px 0;\"><x_psm_0211_code style=\"background:#f1f1f1; padding: 3px 8px; border-radius:4px;\">{{ ctx.get('employee_login') or object.work_email or '' }}</x_psm_0211_code></td>\n"
"                </tr>\n"
"                <tr>\n"
"                    <td style=\"padding: 6px 0; color: #666;\"><strong>Mật khẩu:</strong></td>\n"
"                    <td style=\"padding: 6px 0; color: #888;\">Nhấn nút bên dưới để tự đặt mật khẩu lần đầu</td>\n"
"                </tr>\n"
"            </table>\n"
"\n"
"            <div style=\"text-align: center; margin-top: 16px;\">\n"
"                <a href=\"{{ ctx.get('signup_url') or ctx.get('base_url', '') + '/my/onboard_info' }}\" style=\"background: #DA291C; color: #fff; padding: 12px 28px;&#10;                          text-decoration: none; border-radius: 6px; font-size: 15px; font-weight: bold;\">\n"
"                    Đặt mật khẩu và đăng nhập\n"
"                </a>\n"
"            </div>\n"
"            <p style=\"color: #999; font-size: 12px; margin: 10px 0 0; text-align: center;\">\n"
"                Link co hieu luc trong 24 gio. Neu het han, lien he nhan su de duoc cap lai.\n"
"            </p>\n"
"        </div>\n"
"\n"
"        <div style=\"background: #f8f9fa; border-left: 4px solid #DA291C; padding: 15px 20px; margin: 20px 0;\">\n"
"            <strong>5 loai giay to can nop sau khi dang nhap:</strong>\n"
"            <ol style=\"margin: 10px 0 0; padding-left: 20px;\">\n"
"                <li>Anh the (Passport Photo) — JPG/PNG, toi da 5MB</li>\n"
"                <li>CCCD/CMND mat truoc — JPG/PNG/PDF</li>\n"
"                <li>CCCD/CMND mat sau — JPG/PNG/PDF</li>\n"
"                <li>Ho khau ban sao — JPG/PNG/PDF</li>\n"
"                <li>Ly lich tu phap — JPG/PNG/PDF</li>\n"
"            </ol>\n"
"        </div>\n"
"\n"
"        <p style=\"color: #666; font-size: 13px;\">\n"
"            Neu ban gap kho khan khi dang nhap, vui long lien he bo phan nhan su de duoc ho tro.\n"
"        </p>\n"
"    </div>\n"
"\n"
"    <div style=\"background: #f1f1f1; padding: 15px; text-align: center; font-size: 12px; color: #999;\">\n"
"        Email nay duoc gui tu dong tu he thong McDonald's. Vui long khong tra loi email nay.\n"
"    </div>\n"
"</div>\n"
"        "
msgstr ""

#. module: M02_P0211
#: model:mail.template,body_html:M02_P0211.email_template_onboarding_refused
msgid ""
"<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n"
"\n"
"    <div style=\"background-color: #DA291C; padding: 30px 20px; text-align: center;\">\n"
"        <h1 style=\"color: #FFC72C; margin: 0; font-size: 28px;\">McDonald's</h1>\n"
"    </div>\n"
"\n"
"    <div style=\"padding: 30px 20px; background: #fff;\">\n"
"        <p>Kinh chao <strong>{{ object.name }}</strong>,</p>\n"
"\n"
"        <p>Cam on ban da danh thoi gian tham gia vao qua trinh onboarding tai <strong>McDonald's</strong>.</p>\n"
"\n"
"        <p>Sau khi xem xet ho so, chung toi rat tiec phai thong bao rang ho so cua ban\n"
"        chua dap ung day du cac yeu cau tai thoi diem nay.</p>\n"
"\n"
"        <p>Chung toi tran trong su quan tam cua ban va chuc ban thanh cong trong tuong lai.</p>\n"
"\n"
"        <p>Tran trong,<br/><strong>Bo phan Nhan su McDonald's</strong></p>\n"
"    </div>\n"
"\n"
"    <div style=\"background: #f1f1f1; padding: 15px; text-align: center; font-size: 12px; color: #999;\">\n"
"        Email nay duoc gui tu dong tu he thong McDonald's.\n"
"    </div>\n"
"</div>\n"
"        "
msgstr ""

#. module: M02_P0211
#: model:mail.template,body_html:M02_P0211.email_template_vsattp_invite
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 14px;\">\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 14px;\">\n"
"        Kính gửi <t t-out=\"object.partner_id.name or 'Bạn'\">Bạn</t>,<br/><br/>\n"
"        <t t-if=\"object.survey_id.certification\">\n"
"            Bạn vừa nhận được lời mời tham gia một Bài kiểm tra sát hạch mới.\n"
"        </t>\n"
"        <t t-else=\"\">\n"
"            Chúng tôi đang tổ chức Bài khảo sát kiến thức và rất mong nhận được phản hồi từ bạn.\n"
"        </t>\n"
"        </p><div style=\"margin: 16px 0px 16px 0px;\">\n"
"            <a t-att-href=\"(object.get_start_url())\" t-attf-style=\"background-color: {{user.company_id.email_secondary_color or '#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: {{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; font-size:13px; font-weight: bold;\">\n"
"                <t t-if=\"object.survey_id.certification\">\n"
"                    BẮT ĐẦU BÀI KIỂM TRA\n"
"                </t>\n"
"                <t t-else=\"\">\n"
"                    BẮT ĐẦU BÀI KHẢO SÁT\n"
"                </t>\n"
"            </a>\n"
"        </div>\n"
"        <t t-if=\"object.deadline\">\n"
"            Vui lòng hoàn thành bài làm này trước ngày: <t t-out=\"format_date(object.deadline) or ''\"/>.<br/><br/>\n"
"        </t>\n"
"        <t t-if=\"object.survey_id.certification\">\n"
"            Chúc bạn hoàn thành tốt bài kiểm tra!\n"
"        </t>\n"
"        <t t-else=\"\">\n"
"            Xin trân trọng cảm ơn bạn đã hợp tác và tham gia bài khảo sát của chúng tôi.\n"
"        </t>\n"
"    \n"
"</div>\n"
"        "
msgstr ""

