<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend hr.employee form view to show is_rst_employee field -->
    <record id="view_employee_form_rst_extension" model="ir.ui.view">
        <field name="name">hr.employee.form.rst.extension</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Add is_rst_employee field to the form -->
            <xpath expr="//field[@name='employee_type']" position="after">
                <field name="is_rst_employee" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
