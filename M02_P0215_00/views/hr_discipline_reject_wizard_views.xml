<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_discipline_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.discipline.reject.wizard.form</field>
        <field name="model">hr.discipline.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối tường trình">
                <group>
                    <field name="record_id" invisible="1"/>
                    <field name="rejection_reason" widget="text" placeholder="Nhập lý do từ chối tường trình..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Xác nhận từ chối" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
