    <template id="portal_discipline_sidebar_link" inherit_id="portal_custom.portal_my_home_inherit" priority="50">
        <xpath expr="//a[@href='/my/payslips']" position="after">
            <a href="/my/disciplines" class="sidebar-link">
                <div class="app-icon-wrapper me-3 position-relative" style="background: #fff3cd; color: #856404;">
                    <i class="fa fa-exclamation-triangle" />
                    <t t-if="discipline_count > 0">
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                            <span class="visually-hidden">New alerts</span>
                        </span>
                    </t>
                </div>
                <span>Viết Bảng Tường Trình</span>
            </a>
        </xpath>
    </template>

    <template id="portal_my_home_menu_discipline" name="Portal layout : discipline entries" inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'discipline'" class="breadcrumb-item active">
                Disciplinary Records
            </li>
            <li t-if="page_name == 'discipline_form'" class="breadcrumb-item">
                <a href="/my/disciplines">Disciplinary Records</a>
            </li>
            <li t-if="page_name == 'discipline_form'" class="breadcrumb-item active">
                <t t-esc="record.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_discipline" name="Show Discipline on Portal Home" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Viết Bảng Tường Trình (Kỷ Luật)</t>
                <t t-set="url" t-value="'/my/disciplines'"/>
                <t t-set="placeholder_count" t-value="'discipline_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_disciplines" name="My Disciplinary Records">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Disciplinary Records</t>
            </t>
            
            <t t-if="not disciplines">
                <div class="alert alert-info">
                    There are no disciplinary records found in your account.
                </div>
            </t>
            <t t-if="disciplines">
                <div class="table-responsive border rounded mb-2">
                    <table class="table rounded mb-0 bg-white o_portal_my_doc_table">
                        <thead>
                            <tr class="active">
                                <th class="text-left">Details</th>
                                <th class="text-center">Reference</th>
                                <th class="text-right">Date</th>
                                <th class="text-right">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="disciplines" t-as="rec">
                                <tr>
                                    <td class="text-left">
                                        <a t-attf-href="/my/discipline/#{rec.id}">
                                            <strong><t t-esc="rec.violation_type_id.name"/></strong>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="rec.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="rec.date"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="rec.state" class="badge badge-pill badge-info"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
            <div t-if="pager" class="o_portal_pager text-center">
                <t t-call="portal.pager"/>
            </div>
        </t>
    </template>

    <template id="portal_discipline_explanation_template" name="Discipline Explanation">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="card">
                    <div class="card-header bg-warning text-white">
                        <h3>DISCIPLINARY EXPLANATION REQUEST</h3>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <p><strong>Reference:</strong> <t t-esc="record.name"/></p>
                                <p><strong>Violation Type:</strong> <t t-esc="record.violation_type_id.name"/></p>
                            </div>
                            <div class="col-6">
                                <p><strong>Date:</strong> <t t-esc="record.date"/></p>
                                <p><strong>Proposed Action:</strong> <t t-esc="record.action_id.name"/></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <p><strong>Description:</strong> <t t-esc="record.description"/></p>
                        </div>
                        
                        <hr/>
                        
                        <!-- Input Form -->
                        <form action="/my/discipline/submit" method="post" t-if="record.state == 'waiting_explanation'">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="record_id" t-att-value="record.id"/>
                            
                            <h5 class="text-secondary mt-4 mb-3">Thông tin sự việc (Do nhân viên khai báo)</h5>
                            
                            <div class="row">
                                <div class="col-md-6 form-group mb-3">
                                    <label class="form-label fw-bold">Thời gian xảy ra sự việc</label>
                                    <input type="datetime-local" class="form-control" name="incident_date_time" required="required"/>
                                </div>
                                <div class="col-md-6 form-group mb-3">
                                    <label class="form-label fw-bold">Địa điểm xảy ra sự việc</label>
                                    <input type="text" class="form-control" name="incident_location" required="required" placeholder="VD: Khu vực bếp, Quầy thu ngân..."/>
                                </div>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Người làm chứng (Nếu có)</label>
                                <input type="text" class="form-control" name="witness_names" placeholder="Tên những người chứng kiến..."/>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Tường trình diễn biến sự việc</label>
                                <textarea class="form-control" name="employee_explanation" rows="4" required="required" placeholder="Mô tả chi tiết sự việc đã xảy ra..."></textarea>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Nguyên nhân (Chủ quan/Khách quan)</label>
                                <textarea class="form-control" name="explanation_reason" rows="3" required="required" placeholder="Tại sao sự việc lại xảy ra?"></textarea>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Cam kết / Biện pháp khắc phục</label>
                                <textarea class="form-control" name="explanation_commitment" rows="3" required="required" placeholder="Tôi cam kết sẽ..."></textarea>
                            </div>
                            
                            <!-- Chữ ký điện tử -->
                            <div class="form-group mb-4">
                                <label class="form-label fw-bold">Chữ ký xác nhận <span class="text-danger">*</span></label>
                                <div class="border rounded p-3 bg-light">
                                    <canvas id="signature-pad" style="border: 1px dashed #999; background: white; width: 100%; height: 150px; touch-action: none; cursor: crosshair;"></canvas>
                                </div>
                                <input type="hidden" name="employee_signature" id="employee_signature" required="required"/>
                                <div class="mt-2 d-flex justify-content-between align-items-center">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clear-signature">
                                        <i class="fa fa-eraser"></i> Xóa chữ ký
                                    </button>
                                    <small class="text-muted">Vui lòng ký tên bằng chuột hoặc ngón tay</small>
                                </div>
                            </div>
                            
                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-warning btn-lg px-5 text-dark fw-bold" id="submit-btn">Gửi Tường Trình</button>
                            </div>
                            
                            <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                var canvas = document.getElementById('signature-pad');
                                if (!canvas) return;
                                
                                var ctx = canvas.getContext('2d');
                                var drawing = false;
                                var lastX, lastY;
                                var hasSignature = false;
                                
                                // Set canvas size
                                function resizeCanvas() {
                                    var rect = canvas.getBoundingClientRect();
                                    canvas.width = rect.width;
                                    canvas.height = 150;
                                    ctx.strokeStyle = '#000';
                                    ctx.lineWidth = 2;
                                    ctx.lineCap = 'round';
                                    ctx.lineJoin = 'round';
                                }
                                resizeCanvas();
                                window.addEventListener('resize', resizeCanvas);
                                
                                function getPos(e) {
                                    var rect = canvas.getBoundingClientRect();
                                    var x, y;
                                    if (e.touches) {
                                        x = e.touches[0].clientX - rect.left;
                                        y = e.touches[0].clientY - rect.top;
                                    } else {
                                        x = e.clientX - rect.left;
                                        y = e.clientY - rect.top;
                                    }
                                    return {x: x, y: y};
                                }
                                
                                function startDraw(e) {
                                    e.preventDefault();
                                    drawing = true;
                                    var pos = getPos(e);
                                    lastX = pos.x;
                                    lastY = pos.y;
                                }
                                
                                function draw(e) {
                                    if (!drawing) return;
                                    e.preventDefault();
                                    var pos = getPos(e);
                                    ctx.beginPath();
                                    ctx.moveTo(lastX, lastY);
                                    ctx.lineTo(pos.x, pos.y);
                                    ctx.stroke();
                                    lastX = pos.x;
                                    lastY = pos.y;
                                    hasSignature = true;
                                    updateSignatureData();
                                }
                                
                                function stopDraw() {
                                    drawing = false;
                                }
                                
                                function updateSignatureData() {
                                    var dataUrl = canvas.toDataURL('image/png');
                                    var base64 = dataUrl.split(',')[1];
                                    document.getElementById('employee_signature').value = base64;
                                }
                                
                                // Mouse events
                                canvas.addEventListener('mousedown', startDraw);
                                canvas.addEventListener('mousemove', draw);
                                canvas.addEventListener('mouseup', stopDraw);
                                canvas.addEventListener('mouseout', stopDraw);
                                
                                // Touch events
                                canvas.addEventListener('touchstart', startDraw);
                                canvas.addEventListener('touchmove', draw);
                                canvas.addEventListener('touchend', stopDraw);
                                
                                // Clear button
                                document.getElementById('clear-signature').addEventListener('click', function() {
                                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                                    document.getElementById('employee_signature').value = '';
                                    hasSignature = false;
                                });
                                
                                // Validate signature before submit
                                document.querySelector('form').addEventListener('submit', function(e) {
                                    if (!hasSignature || !document.getElementById('employee_signature').value) {
                                        e.preventDefault();
                                        alert('Vui lòng ký tên trước khi gửi tường trình!');
                                        return false;
                                    }
                                });
                            });
                            </script>
                        </form>

                        <!-- Readonly View -->
                        <div t-if="record.state != 'waiting_explanation'" class="alert alert-success mt-4">
                            <h4 class="alert-heading">Đã gửi tường trình</h4>
                            <hr/>
                            <div class="row">
                                <div class="col-md-6"><p><strong>Thời gian:</strong> <span t-field="record.incident_date_time"/></p></div>
                                <div class="col-md-6"><p><strong>Địa điểm:</strong> <span t-field="record.incident_location"/></p></div>
                            </div>
                            <p><strong>Người làm chứng:</strong> <span t-field="record.witness_names"/></p>
                            <p><strong>Nội dung sự việc:</strong></p>
                            <div class="p-2 bg-white border rounded mb-2"><span t-field="record.employee_explanation"/></div>
                            <p><strong>Nguyên nhân:</strong></p>
                            <div class="p-2 bg-white border rounded mb-2"><span t-field="record.explanation_reason"/></div>
                            <p><strong>Cam kết:</strong></p>
                            <div class="p-2 bg-white border rounded mb-3"><span t-field="record.explanation_commitment"/></div>
                            
                            <!-- Chữ ký nhân viên -->
                            <t t-if="record.employee_signature">
                                <p><strong>Chữ ký nhân viên:</strong></p>
                                <div class="p-2 bg-white border rounded text-center">
                                    <img t-att-src="'data:image/png;base64,' + (record.employee_signature.decode('utf-8') if record.employee_signature else '')" 
                                         alt="Chữ ký nhân viên" style="max-height: 100px;"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
