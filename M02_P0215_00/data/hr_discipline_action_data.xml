<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- 7. Sa thải (Termination) - Top Level -->
        <record id="action_termination" model="hr.discipline.action">
            <field name="name">Sa thải (Termination)</field>
            <field name="sequence">70</field>
            <field name="level">company</field>
            <field name="form_code">discipline</field>
            <field name="validity_months">36</field>
            <field name="improvement_period">0</field>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 6. Kéo dài nâng lương (Defer Salary Increase) -->
        <record id="action_defer_salary" model="hr.discipline.action">
            <field name="name">Kéo dài thời hạn nâng lương (Defer Salary Increase)</field>
            <field name="sequence">60</field>
            <field name="level">company</field>
             <field name="form_code">discipline</field>
            <field name="validity_months">6</field>
            <field name="improvement_period">180</field>
            <field name="next_action_id" ref="action_termination"/>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 5. Khiển trách văn bản (Written Warning) -->
        <record id="action_written_warning" model="hr.discipline.action">
            <field name="name">Khiển trách văn bản (Written Warning)</field>
            <field name="sequence">50</field>
            <field name="level">company</field>
            <field name="form_code">discipline</field>
            <field name="validity_months">3</field>
            <field name="improvement_period">90</field>
            <field name="next_action_id" ref="action_defer_salary"/>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 4. Khiển trách miệng (Verbal Warning - Company Level) -->
        <record id="action_verbal_warning" model="hr.discipline.action">
            <field name="name">Khiển trách miệng (Verbal Warning)</field>
            <field name="sequence">40</field>
            <field name="level">company</field>
            <field name="form_code">discipline</field>
            <field name="validity_months">1</field>
            <field name="improvement_period">30</field>
            <field name="next_action_id" ref="action_written_warning"/>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 3. Counselling 2nd -->
        <record id="action_counselling_2" model="hr.discipline.action">
            <field name="name">Counselling 2nd (Nhắc nhở Lần 2)</field>
            <field name="sequence">30</field>
            <field name="level">store</field>
            <field name="form_code">counselling_2</field>
            <field name="validity_months">1</field>
            <field name="improvement_period">30</field>
            <field name="next_action_id" ref="action_verbal_warning"/>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 2. Counselling 1st -->
        <record id="action_counselling_1" model="hr.discipline.action">
            <field name="name">Counselling 1st (Nhắc nhở Lần 1)</field>
            <field name="sequence">20</field>
            <field name="level">store</field>
            <field name="form_code">counselling_1</field>
            <field name="validity_months">1</field>
            <field name="improvement_period">30</field>
            <field name="next_action_id" ref="action_counselling_2"/>
            <field name="requires_finance_check" eval="False"/>
        </record>

        <!-- 1. Feedback -->
        <record id="action_feedback" model="hr.discipline.action">
            <field name="name">Feedback (Góp ý cải thiện)</field>
            <field name="sequence">10</field>
            <field name="level">store</field>
            <field name="form_code">feedback</field>
            <field name="validity_months">1</field>
            <field name="improvement_period">30</field>
            <field name="next_action_id" ref="action_counselling_1"/>
            <field name="requires_finance_check" eval="False"/>
        </record>
        
         <!-- Special: Discipline with Compensation (No fixed sequence in normal flow, manual selection likely) -->
        <record id="action_discipline_compensation" model="hr.discipline.action">
            <field name="name">Kỷ luật kèm Bồi thường vật chất</field>
            <field name="sequence">80</field>
            <field name="level">company</field>
            <field name="form_code">discipline</field>
            <field name="validity_months">36</field>
            <field name="improvement_period">30</field>
            <field name="has_penalty" eval="True"/>
            <field name="requires_finance_check" eval="True"/>
        </record>

    </data>
</odoo>
