<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_discipline_auto_archive" model="ir.cron">
        <field name="name">Discipline: Auto Archive Done Records</field>
        <field name="model_id" ref="model_hr_discipline_record"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_archive()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="cron_discipline_auto_complete" model="ir.cron">
        <field name="name">Discipline: Auto Complete Improvement</field>
        <field name="model_id" ref="model_hr_discipline_record"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_complete_improvement()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
