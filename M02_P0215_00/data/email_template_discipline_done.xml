<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_discipline_done" model="mail.template">
            <field name="name">Discipline: Improvement Completed</field>
            <field name="model_id" ref="model_hr_discipline_record"/>
            <field name="subject">Thông báo hoàn thành thời gian cải thiện - {{ object.name }}</field>
            <field name="email_from">{{ user.email_formatted }}</field>
            <field name="partner_to">{{ object.employee_id.work_contact_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Kính gửi <t t-out="object.employee_id.name"/>,
                        <br/><br/>
                        Chúc mừng bạn đã hoàn thành thời gian cải thiện theo quy định.
                        <br/>
                        Hồ sơ kỷ luật <strong><t t-out="object.name"/></strong> của bạn đã được đóng lại.
                        <br/><br/>
                        Chi tiết:
                        <ul>
                            <li><strong>Hình thức xử lý:</strong> <t t-out="object.action_id.name"/></li>
                            <li><strong>Ngày bắt đầu:</strong> <t t-out="object.improvement_start_date"/></li>
                            <li><strong>Ngày kết thúc:</strong> <t t-out="object.improvement_end_date"/></li>
                        </ul>
                        <br/>
                        Trân trọng,
                        <br/>
                        Phòng Nhân sự
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
