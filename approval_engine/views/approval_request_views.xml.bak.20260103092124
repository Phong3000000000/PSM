<?xml version="1.0" encoding="utf-8"?> <odoo> <record id="view_approval_request_tree" model="ir.ui.view"> <field name="name">approval.engine.request.tree</field> <field name="model">approval.engine.request</field> <field name="arch" type="xml"> <list> <field name="name"/> <field name="company_id"/> <field name="workflow_id"/> <field name="state"/> <field name="requester_id"/> <field name="res_model"/> <field name="res_id"/> <field name="current_step_id"/> <field name="pending_action"/> </list> </field> </record>
<record id="view_approval_request_form" model="ir.ui.view">
    <field name="name">approval.engine.request.form</field>
    <field name="model">approval.engine.request</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <field name="state" widget="statusbar"/>
                <button name="action_approve" type="object" string="Approve" class="btn-primary"
                        attrs="{'invisible': [('state','!=','waiting')]}"/>
                <button name="action_reject" type="object" string="Reject" class="btn-secondary"
                        attrs="{'invisible': [('state','!=','waiting')]}"/>
            </header>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="workflow_id"/>
                </group>
                <group>
                    <field name="requester_id"/>
                    <field name="current_step_id"/>
                    <field name="pending_action"/>
                </group>
                <group>
                    <field name="res_model"/>
                    <field name="res_id"/>
                    <field name="reject_reason" attrs="{'invisible':[('state','!=','rejected')]}"/>
                </group>

                <notebook>
                    <page string="Step Runs">
                        <field name="step_run_ids">
                            <list>
                                <field name="sequence"/>
                                <field name="step_id"/>
                                <field name="state"/>
                                <field name="parallel"/>
                                <field name="opened_on"/>
                                <field name="closed_on"/>
                            </list>
                        </field>
                    </page>
                    <page string="Chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

<record id="action_approval_requests" model="ir.actions.act_window">
    <field name="name">Approval Requests</field>
    <field name="res_model">approval.engine.request</field>
    <field name="view_mode">tree,form</field>
    <field name="context">{}</field>
</record>

<menuitem id="menu_approval_requests" name="Requests" parent="menu_approval_root"
          action="action_approval_requests" sequence="5"
          groups="approval_engine.group_approval_admin,approval_engine.group_approval_approver"/>
</odoo>