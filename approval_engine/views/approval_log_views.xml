<?xml version="1.0" encoding="utf-8"?> <odoo> <record id="view_approval_log_tree" model="ir.ui.view"> <field name="name">approval.log.tree</field> <field name="model">approval.log</field> <field name="arch" type="xml"> <list> <field name="timestamp"/> <field name="company_id"/> <field name="request_id"/> <field name="res_model"/> <field name="res_id"/> <field name="user_id"/> <field name="action"/> <field name="step_id"/> <field name="comment"/> </list> </field> </record>

<record id="view_approval_log_form" model="ir.ui.view">
    <field name="name">approval.log.form</field>
    <field name="model">approval.log</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="timestamp"/>
                    <field name="company_id"/>
                    <field name="request_id"/>
                </group>
                <group>
                    <field name="res_model"/>
                    <field name="res_id"/>
                    <field name="step_id"/>
                </group>
                <group>
                    <field name="user_id"/>
                    <field name="action"/>
                </group>
                <group>
                    <field name="comment"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_approval_logs" model="ir.actions.act_window">
    <field name="name">Approval Logs</field>
    <field name="res_model">approval.log</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem id="menu_approval_logs" name="Logs" parent="menu_approval_root"
          action="action_approval_logs" sequence="30"
          groups="approval_engine.group_approval_admin,approval_engine.group_approval_approver"/>
</odoo>