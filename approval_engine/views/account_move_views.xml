<?xml version="1.0" encoding="utf-8"?> <odoo> <!-- Add approval UI to account.move --> <record id="account_move_form_approval_engine" model="ir.ui.view"> <field name="name">account.move.form.approval.engine</field> <field name="model">account.move</field> <field name="inherit_id" ref="account.view_move_form"/> <field name="arch" type="xml"> <!-- Statusbar --> <xpath expr="//header/field[@name='state']" position="after"> <field name="approval_state" widget="statusbar" statusbar_visible="draft,waiting,approved,rejected"/> </xpath>
        <!-- Buttons -->
        <xpath expr="//header" position="inside">
            <button name="action_submit_for_approval" type="object" string="Submit for Approval"
                    class="btn-primary"
                    context="{'approval_pending_action': 'action_post'}"
                    modifiers="{'invisible': [('approval_can_submit','=',False)]}"/>

            <button name="action_approve" type="object" string="Approve" class="btn-primary"
                    modifiers="{'invisible': [('approval_can_approve','=',False)]}"/>

            <button name="action_reject" type="object" string="Reject" class="btn-secondary"
                    context="{'default_reason':'Not approved'}"
                    modifiers="{'invisible': [('approval_can_approve','=',False)]}"/>
        </xpath>

        <!-- Smart button -->
        <xpath expr="//div[@name='button_box']" position="inside">
            <button type="action" class="oe_stat_button" icon="fa-check-square-o"
                    name="%(approval_engine.action_approval_logs)d"
                    context="{'search_default_res_model': 'account.move', 'search_default_res_id': id}"
                    string="Approval Logs"/>
        </xpath>

        <!-- Show next approvers / current step -->
        <xpath expr="//sheet/group" position="after">
            <group string="Approval">
                <field name="current_step_id" readonly="1"/>
                <field name="next_approver_ids" widget="many2many_tags" readonly="1"/>
            </group>
        </xpath>
    </field>
</record>
</odoo>