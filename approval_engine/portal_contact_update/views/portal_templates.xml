<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_contact_form" name="Portal Contact Form">
        <t t-call="portal.portal_layout">
            <t t-set="title">My Personal Documents</t>
            
            <div class="container mt-3">
                <!-- Success/Error Messages -->
                <t t-if="success">
                    <div class="alert alert-success" role="alert">
                        ✅ Your documents have been uploaded successfully!
                    </div>
                </t>
                <t t-if="request.params.get('error')">
                    <div class="alert alert-danger" role="alert">
                        ❌ An error occurred. Please try again.
                    </div>
                </t>
                
                <!-- Progress Bar -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">📊 Document Completion Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar" 
                                 role="progressbar" 
                                 t-att-style="'width: ' + str(doc_status.get('completion_rate', 0)) + '%;'"
                                 t-att-aria-valuenow="doc_status.get('completion_rate', 0)"
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                <span t-esc="'%.1f' % doc_status.get('completion_rate', 0)"/>%
                            </div>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <h6>✅ Completed:</h6>
                                <ul class="list-unstyled">
                                    <t t-foreach="doc_status.get('completed', [])" t-as="doc">
                                        <li>✓ <span t-esc="doc"/></li>
                                    </t>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6>📋 Pending:</h6>
                                <ul class="list-unstyled">
                                    <t t-foreach="doc_status.get('pending', [])" t-as="doc">
                                        <li>○ <span t-esc="doc"/></li>
                                    </t>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Upload Form -->
                <form method="post" action="/my/contact/update" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    
                    <!-- 1. Passport Photo -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">📷 1. Passport Photo (Ảnh thẻ)</h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-2">
                                <t t-if="partner.passport_photo_filename">
                                    <div class="alert alert-info">
                                        Currently: <strong t-esc="partner.passport_photo_filename"/>
                                        <br/><small>Upload new file to replace</small>
                                    </div>
                                </t>
                            </div>
                            <input type="file" 
                                   name="passport_photo" 
                                   accept=".jpg,.jpeg,.png"
                                   class="form-control"/>
                            <small class="form-text text-muted">
                                Format: JPG, PNG | Max: 5MB | Required
                            </small>
                        </div>
                    </div>
                    
                    <!-- 2. ID Card -->
                    <div class="card mb-3">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0">🪪 2. ID Card (CCCD/CMND)</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <h6>Front Side (Mặt trước)</h6>
                                    <t t-if="partner.id_card_front_filename">
                                        <div class="alert alert-info">
                                            Current: <strong t-esc="partner.id_card_front_filename"/>
                                        </div>
                                    </t>
                                    <input type="file" 
                                           name="id_card_front" 
                                           accept=".jpg,.jpeg,.png,.pdf"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <h6>Back Side (Mặt sau)</h6>
                                    <t t-if="partner.id_card_back_filename">
                                        <div class="alert alert-info">
                                            Current: <strong t-esc="partner.id_card_back_filename"/>
                                        </div>
                                    </t>
                                    <input type="file" 
                                           name="id_card_back" 
                                           accept=".jpg,.jpeg,.png,.pdf"
                                           class="form-control"/>
                                </div>
                            </div>
                            <small class="form-text text-muted">
                                Format: JPG, PNG, PDF | Max: 10MB | Required
                            </small>
                        </div>
                    </div>
                    
                    <!-- 3. Household Registration -->
                    <div class="card mb-3">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0">🏠 3. Household Registration (Hộ khẩu bản sao)</h6>
                        </div>
                        <div class="card-body">
                            <t t-if="partner.household_registration_filename">
                                <div class="alert alert-info">
                                    Currently: <strong t-esc="partner.household_registration_filename"/>
                                </div>
                            </t>
                            <input type="file" 
                                   name="household_registration" 
                                   accept=".jpg,.jpeg,.png,.pdf"
                                   class="form-control"/>
                            <small class="form-text text-muted">
                                Format: JPG, PNG, PDF | Max: 10MB
                            </small>
                        </div>
                    </div>
                    
                    <!-- 4. Judicial Record -->
                    <div class="card mb-3">
                        <div class="card-header bg-warning text-dark">
                            <h6 class="mb-0">⚖️ 4. Judicial Record (Lý lịch tư pháp)</h6>
                        </div>
                        <div class="card-body">
                            <t t-if="partner.judicial_record_filename">
                                <div class="alert alert-info">
                                    Currently: <strong t-esc="partner.judicial_record_filename"/>
                                </div>
                            </t>
                            <input type="file" 
                                   name="judicial_record" 
                                   accept=".jpg,.jpeg,.png,.pdf"
                                   class="form-control"/>
                            <small class="form-text text-muted">
                                Format: JPG, PNG, PDF | Max: 10MB
                            </small>
                        </div>
                    </div>
                    
                    <!-- 5. Professional Certificates -->
                    <div class="card mb-4">
                        <div class="card-header bg-secondary text-white">
                            <h6 class="mb-0">🎓 5. Professional Certificates (Bằng cấp chuyên môn)</h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6>Main Certificate (Bằng cấp chính)</h6>
                                <t t-if="partner.professional_certificate_filename">
                                    <div class="alert alert-info">
                                        Currently: <strong t-esc="partner.professional_certificate_filename"/>
                                    </div>
                                </t>
                                <input type="file" 
                                       name="professional_certificate" 
                                       accept=".jpg,.jpeg,.png,.pdf"
                                       class="form-control"/>
                            </div>
                            <div class="mb-3">
                                <h6>Additional Certificates (Bằng cấp bổ sung)</h6>
                                <t t-if="partner.additional_certificates_filename">
                                    <div class="alert alert-info">
                                        Currently: <strong t-esc="partner.additional_certificates_filename"/>
                                    </div>
                                </t>
                                <input type="file" 
                                       name="additional_certificates" 
                                       accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                                       class="form-control"/>
                            </div>
                            <small class="form-text text-muted">
                                Format: JPG, PNG, PDF, DOC, DOCX | Max: 10MB
                            </small>
                        </div>
                    </div>
                    
                    <!-- Submit Button -->
                    <div class="text-center mb-5">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            💾 Upload All Documents
                        </button>
                    </div>
                </form>
                
                <!-- Status Links -->
                <div class="text-center">
                    <a href="/my/documents/status" class="btn btn-outline-secondary me-2">
                        📊 View Detailed Status
                    </a>
                    <a href="/my" class="btn btn-outline-secondary">
                        ← Back to Portal
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>