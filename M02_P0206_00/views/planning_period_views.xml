<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================== -->
    <!-- PLANNING PERIOD VIEWS                      -->
    <!-- ========================================== -->
    <!-- Tree View -->
    <record id="planning_period_tree" model="ir.ui.view">
        <field name="name">planning.period.tree</field>
        <field name="model">planning.period</field>
        <field name="arch" type="xml">
            <list decoration-info="state=='draft'" decoration-success="state=='open'" decoration-muted="state=='closed'">
                <field name="name" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="slot_count" />
                <field name="slot_open_count" />
                <field name="slot_filled_count" />
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-success="state=='open'" decoration-muted="state=='closed'" />
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="planning_period_form" model="ir.ui.view">
        <field name="name">planning.period.form</field>
        <field name="model">planning.period</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open" string="Mở đăng ký" type="object" class="btn-primary" invisible="state not in ['draft', 'open']" />
                    <button name="action_close" string="Đóng đăng ký" type="object" class="btn-warning" invisible="state != 'open'" />
                    <button name="action_reset_to_draft" string="Mở lại chỉnh sửa" type="object" invisible="state != 'closed'" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed" />
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_slots" type="object" class="oe_stat_button" icon="fa-calendar">
                            <div class="o_stat_info">
                                <field name="slot_count" />
                                <span class="o_stat_text">Ca làm việc</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="VD: Tuần 42/2026" />
                        </h1>
                    </div>
                    <group>
                        <group string="Thời gian">
                            <field name="date_from" />
                            <field name="date_to" />
                        </group>
                        <group string="Thống kê">
                            <field name="slot_open_count" />
                            <field name="slot_filled_count" />
                        </group>
                    </group>
                    <notebook>
                        <page name="slots" string="Ca làm việc">
                            <field name="slot_ids" mode="list">
                                <list editable="bottom" create="0">
                                    <field name="start_datetime" />
                                    <field name="end_datetime" />
                                    <field name="role_id" />
                                    <field name="resource_id" />
                                    <field name="approval_state" widget="badge" />
                                    <field name="state" />
                                </list>
                            </field>
                        </page>
                        <page name="forecasts" string="Dữ liệu Forecast">
                            <field name="forecast_ids" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="action_planning_period" model="ir.actions.act_window">
        <field name="name">Kỳ đăng ký</field>
        <field name="res_model">planning.period</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo kỳ đăng ký mới</p>
            <p>Mỗi kỳ đăng ký tương ứng với một tuần hoặc một khoảng thời gian xếp lịch.</p>
        </field>
    </record>
</odoo>
