<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================== -->
    <!-- WORKFORCE FORECAST VIEWS                   -->
    <!-- ========================================== -->
    <!-- Tree View -->
    <record id="workforce_forecast_tree" model="ir.ui.view">
        <field name="name">workforce.forecast.tree</field>
        <field name="model">workforce.forecast</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="date" />
                <field name="hour" widget="float_time" />
                <field name="projected_sales" />
                <field name="projected_gc" />
                <field name="target_gcpch" />
                <field name="trend_factor" />
                <field name="staff_needed" decoration-bf="1" />
                <field name="period_id" />
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="workforce_forecast_form" model="ir.ui.view">
        <field name="name">workforce.forecast.form</field>
        <field name="model">workforce.forecast</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Thời gian">
                            <field name="date" />
                            <field name="hour" widget="float_time" />
                            <field name="period_id" />
                        </group>
                        <group string="Dữ liệu VLH">
                            <field name="projected_sales" />
                            <field name="projected_gc" />
                        </group>
                    </group>
                    <group>
                        <group string="Tham số">
                            <field name="target_gcpch" />
                            <field name="trend_factor" />
                        </group>
                        <group string="Kết quả">
                            <field name="staff_needed" readonly="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Pivot View -->
    <record id="workforce_forecast_pivot" model="ir.ui.view">
        <field name="name">workforce.forecast.pivot</field>
        <field name="model">workforce.forecast</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="date" type="row" />
                <field name="hour" type="col" />
                <field name="staff_needed" type="measure" />
            </pivot>
        </field>
    </record>
    <!-- Action -->
    <record id="action_workforce_forecast" model="ir.actions.act_window">
        <field name="name">Dữ liệu Forecast (VLH)</field>
        <field name="res_model">workforce.forecast</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có dữ liệu Forecast</p>
            <p>Import dữ liệu VLH từ file Excel để tính toán nhu cầu nhân sự.</p>
        </field>
    </record>
</odoo>
