        <!-- ================================================ -->
        <!-- KỲ ĐĂNG KÝ - TUẦN TEST                          -->
        <!-- ================================================ -->
        <record id="period_week_open" model="planning.period">
            <field name="name">Tuần Test - Đang mở đăng ký</field>
            <field name="date_from" eval="(datetime.today()).strftime('%Y-%m-%d')" />
            <field name="date_to" eval="(datetime.today() + timedelta(days=7)).strftime('%Y-%m-%d')" />
            <field name="state">open</field>
        </record>
        <!-- ================================================ -->
        <!-- NGÀY 1 (Ngày mai) - 3 ca                        -->
        <!-- ================================================ -->
        <record id="slot_d1_morning" model="planning.slot">
            <field name="start_datetime" eval="(datetime.today() + timedelta(days=1)).replace(hour=6, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')" />
            <field name="end_datetime" eval="(datetime.today() + timedelta(days=1)).replace(hour=14, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')" />
            <field name="role_id" ref="role_fcot" />
            <field name="period_id" ref="period_week_open" />
            <field name="state">published</field>
            <field name="allocated_hours">8.0</field>
            <field name="approval_state">open</field>
        </record>

        <record id="slot_d1_afternoon" model="planning.slot">
