<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_psm_travel_hotel_list" model="ir.ui.view">
        <field name="name">x_psm_travel_hotel.list</field>
        <field name="model">x_psm_travel_hotel</field>
        <field name="arch" type="xml">
            <list string="Hotels">
                <field name="x_psm_name"/>
                <field name="x_psm_destination_id"/>
                <field name="x_psm_zone_id"/>
                <field name="x_psm_reference_price"/>
                <field name="x_psm_currency_id"/>
                <field name="x_psm_is_preferred"/>
                <field name="x_psm_active"/>
            </list>
        </field>
    </record>

    <record id="view_psm_travel_hotel_form" model="ir.ui.view">
        <field name="name">x_psm_travel_hotel.form</field>
        <field name="model">x_psm_travel_hotel</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Hotel">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="x_psm_active"/>
                    <group>
                        <group>
                            <field name="x_psm_name"/>
                            <field name="x_psm_destination_id"/>
                            <field name="x_psm_zone_id"/>
                            <field name="x_psm_address"/>
                        </group>
                        <group>
                            <field name="x_psm_reference_price"/>
                            <field name="x_psm_currency_id"/>
                            <field name="x_psm_is_preferred"/>
                            <field name="x_psm_active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="x_psm_note" placeholder="Note for admin..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_psm_travel_hotel" model="ir.actions.act_window">
        <field name="name">Hotels</field>
        <field name="res_model">x_psm_travel_hotel</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_psm_travel_hotel_view_list" model="ir.actions.act_window.view">
        <field name="sequence">10</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_psm_travel_hotel_list"/>
        <field name="act_window_id" ref="action_psm_travel_hotel"/>
    </record>

    <record id="action_psm_travel_hotel_view_form" model="ir.actions.act_window.view">
        <field name="sequence">20</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_psm_travel_hotel_form"/>
        <field name="act_window_id" ref="action_psm_travel_hotel"/>
    </record>
</odoo>
