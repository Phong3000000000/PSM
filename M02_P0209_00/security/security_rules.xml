<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <data noupdate="0">
        <!-- Module Category -->
        <record id="module_category_lnd" model="ir.module.category">
            <field name="name">LnD Development</field>
            <field name="description">Quản lý đào tạo và phát triển nhân viên</field>
            <field name="sequence">50</field>
        </record>

        <!-- Unified Privilege for L&D -->
        <!--
        <record id="privilege_lnd_development" model="res.groups.privilege">
            <field name="name">Role</field>
            <field name="category_id" ref="module_category_lnd"/>
            <field name="placeholder">No</field>
        </record>
        -->

        <!-- Crew Group -->
        <record id="group_crew" model="res.groups">
            <field name="name">Crew</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Crew member role</field>
        </record>

        <!-- Shift Manager (SM) Group -->
        <record id="group_sm" model="res.groups">
            <field name="name">Shift Manager (SM)</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Shift Manager role</field>
        </record>

        <!-- Department Manager 1 (DM1) Group -->
        <record id="group_dm1" model="res.groups">
            <field name="name">Department Manager 1 (DM1)</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Department Manager 1 role</field>
        </record>

        <!-- Department Manager 2 (DM2) Group -->
        <record id="group_dm2" model="res.groups">
            <field name="name">Department Manager 2 (DM2)</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Department Manager 2 role</field>
        </record>

        <!-- RGM (Restaurant General Manager) Group -->
        <record id="group_rgm" model="res.groups">
            <field name="name">RGM</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Restaurant General Manager role</field>
        </record>

        <!-- Trainer Group -->
        <record id="group_trainer" model="res.groups">
            <field name="name">Crew Trainer</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Crew Trainer role</field>
        </record>

        <!-- Barista Trainer Group -->
        <record id="group_barista_trainer" model="res.groups">
            <field name="name">Barista Trainer</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(3, ref('base.group_user'))]"/>
            <field name="comment">Barista Trainer role</field>
        </record>

        <!-- L&D Manager Group -->
        <record id="group_lnd_manager" model="res.groups">
            <field name="name">L&amp;D</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(4, ref('group_rgm')), (4, ref('website_slides.group_website_slides_manager')), (4, ref('hr.group_hr_manager'))]"/>
            <field name="comment">Learning and Development Manager role</field>
        </record>

        <!-- Operations Consultant (OC) Group -->
        <record id="group_oc" model="res.groups">
            <field name="name">OC</field>
            <!-- <field name="privilege_id" ref="privilege_lnd_development"/> -->
            <!-- <field name="category_id" ref="module_category_lnd"/> -->
            <field name="implied_ids" eval="[(4, ref('group_rgm')), (4, ref('hr.group_hr_manager'))]"/>
            <field name="comment">Operations Consultant role</field>
        </record>
        
        <!-- Grant Administrator ALL L&D Groups -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_crew')),
                (4, ref('group_sm')),
                (4, ref('group_dm1')),
                (4, ref('group_dm2')),
                (4, ref('group_rgm')),
                (4, ref('group_trainer')),
                (4, ref('group_barista_trainer')),
                (4, ref('group_lnd_manager')),
                (4, ref('group_oc'))
            ]"/>
        </record>
    </data>
    
    <data noupdate="1">
        <!-- Allow all internal users to CRUD slides -->
        <record id="rule_slide_slide_user_crud" model="ir.rule">
            <field name="name">Slide: internal user: crud all</field>
            <field name="model_id" ref="website_slides.model_slide_slide"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
        </record>

        <!-- Allow all internal users to CRUD slide channels -->
        <record id="rule_slide_channel_user_crud" model="ir.rule">
            <field name="name">Channel: internal user: crud all</field>
            <field name="model_id" ref="website_slides.model_slide_channel"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
        </record>

        <!-- Allow all internal users to CRUD slide channel partner (membership) -->
        <record id="rule_slide_channel_partner_user_crud" model="ir.rule">
            <field name="name">Channel Partner: internal user: crud all</field>
            <field name="model_id" ref="website_slides.model_slide_channel_partner"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
        </record>
        <!-- Allow all internal users to CRUD slide partner (completion) -->
        <record id="rule_slide_slide_partner_user_crud" model="ir.rule">
            <field name="name">Slide Partner: internal user: crud all</field>
            <field name="model_id" ref="website_slides.model_slide_slide_partner"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
        </record>
        <!-- Restrict Employee Visibility: Users see only employees in their department (Store) -->
        <record id="rule_hr_employee_store_visibility" model="ir.rule">
            <field name="name">Employee: Limit visibility to own Department/Store</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('group_trainer')), (4, ref('group_rgm')), (4, ref('group_barista_trainer'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        
        <!-- L&D Manager Full Access: See ALL employees -->
        <record id="rule_hr_employee_lnd_global" model="ir.rule">
            <field name="name">Employee: L&amp;D Manager see all</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lnd_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
        
        <!-- OC Full Access: See ALL employees -->
        <record id="rule_hr_employee_oc_global" model="ir.rule">
            <field name="name">Employee: OC see all</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_oc'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- ========================================== -->
        <!-- SOC EVALUATION RECORD RULES -->
        <!-- ========================================== -->
        
        <!-- Crew/Portal: Own Evaluations Only -->
        <record id="rule_soc_evaluation_crew_own" model="ir.rule">
            <field name="name">SOC Evaluation: Crew Own Records</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_crew')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        
        <!-- Follower Access: Anyone who receives email/notification can read/write -->
        <record id="rule_soc_evaluation_follower" model="ir.rule">
            <field name="name">SOC Evaluation: Follower Access</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">[('message_partner_ids', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Trainer: Same Department -->
        <record id="rule_soc_evaluation_trainer" model="ir.rule">
            <field name="name">SOC Evaluation: Trainer Same Department</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">['|', ('employee_id.department_id', '=', False), ('employee_id.department_id', 'child_of', user.employee_id.department_id.ids)]</field>
            <field name="groups" eval="[(4, ref('group_trainer')), (4, ref('group_barista_trainer'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- RGM: Same Department -->
        <record id="rule_soc_evaluation_rgm" model="ir.rule">
            <field name="name">SOC Evaluation: RGM Same Department</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">['|', ('employee_id.department_id', '=', False), ('employee_id.department_id', 'child_of', user.employee_id.department_id.ids)]</field>
            <field name="groups" eval="[(4, ref('group_rgm'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- OC: All Evaluations -->
        <record id="rule_soc_evaluation_oc" model="ir.rule">
            <field name="name">SOC Evaluation: OC See All</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_oc'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- L&D Manager: All Evaluations -->
        <record id="rule_soc_evaluation_lnd" model="ir.rule">
            <field name="name">SOC Evaluation: L&amp;D Manager See All</field>
            <field name="model_id" ref="model_mcd_soc_evaluation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lnd_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
