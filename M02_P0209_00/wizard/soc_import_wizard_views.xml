<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_soc_import_wizard_form" model="ir.ui.view">
        <field name="name">soc.import.wizard.form</field>
        <field name="model">soc.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import SOC Data">
                <group>
                    <field name="force_update"/>
                    <div class="alert alert-info" role="alert">
                        Click the button below to load the Initial SOC Data (112 Templates) into the system.
                        <br/>
                        <b>Force Update:</b> Check this box to re-write existing templates (useful if items are missing).
                    </div>
                </group>
                <footer>
                    <button string="Load Data Now" name="action_import_soc_data" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_soc_import_wizard" model="ir.actions.act_window">
        <field name="name">Import SOC Data</field>
        <field name="res_model">soc.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
