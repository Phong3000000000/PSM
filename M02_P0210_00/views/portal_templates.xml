<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal Home Menu Item -->
    <template id="portal_my_home_manager_schedule" name="Show Manager Schedules" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Manager Schedules</t>
                <t t-set="url" t-value="'/my/manager/schedules'"/>
                <t t-set="placeholder_count" t-value="'schedule_count'"/>
            </t>
        </xpath>
    </template>
    <!-- List View -->
    <template id="portal_my_manager_schedules" name="My Manager Schedules">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Manager Development Schedules</t>
            </t>
             
            <!-- Left Sidebar + Main Content Layout -->
            <div class="row mt-3">
                <!-- Left Sidebar -->
                <div class="col-12 col-lg-3 d-none d-lg-block">
                    <div class="card p-3 mb-3">
                        <a href="/my/home" class="btn btn-outline-primary w-100 mb-2">
                             <i class="fa fa-arrow-left me-2" /> Back to Dashboard
                        </a>
                        <hr class="my-2"/>
                        <h6 class="text-muted mb-2 small fw-bold">STATISTICS</h6>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="text-muted">Total:</span>
                             <span class="badge bg-primary rounded-pill" t-esc="schedule_count"/>
                        </div>
                    </div>
                </div>

                <!-- Main List Content -->
                <div class="col-12 col-lg-9">
                    <t t-if="not schedules">
                        <div class="text-center py-5 bg-white rounded shadow-sm">
                            <i class="fa fa-graduation-cap fa-4x text-muted mb-3" style="opacity: 0.3;"></i>
                            <h4 class="text-muted">No development schedule</h4>
                            <p class="text-muted mb-0">You have not been nominated for any Manager development program.</p>
                            <p class="text-muted small">Please contact your manager for more information.</p>
                        </div>
                    </t>
                    
                    <t t-if="schedules">
                        <div class="list-group shadow-sm">
                            <t t-foreach="schedules" t-as="schedule">
                                <a t-attf-href="/my/manager/schedule/#{schedule.id}" class="list-group-item list-group-item-action d-flex align-items-center justify-content-between p-3">
                                    <div>
                                        <h6 class="mb-1 fw-bold text-primary">
                                            <span t-field="schedule.development_type"/>
                                        </h6>
                                        <div class="small text-muted">
                                            <i class="fa fa-calendar me-1"/> <span t-field="schedule.schedule_date" t-options='{"widget": "date"}'/> 
                                            <span class="mx-2">•</span>
                                            <i class="fa fa-hashtag me-1"/> <span t-field="schedule.name"/>
                                        </div>
                                    </div>
                                    <span class="badge rounded-pill text-bg-info" t-field="schedule.state"/>
                                </a>
                            </t>
                        </div>
                        <!-- Pager -->
                        <div class="mt-3">
                            <t t-call="portal.pager"/>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- Detail View -->
    <template id="portal_manager_schedule_page" name="Manager Schedule Detail">
        <t t-call="portal.portal_layout">
             <t t-set="wrapwrap_classes" t-value="'o_portal_bg_light'"/>
            
            <!-- Breadcrumbs -->
            <div class="row mt16">
                 <div class="col-12">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/my/home">Home</a></li>
                        <li class="breadcrumb-item"><a href="/my/manager/schedules">Manager Schedules</a></li>
                        <li class="breadcrumb-item active"><span t-field="schedule.name"/></li>
                    </ol>
                 </div>
            </div>

            <div class="row">
                <!-- Left Sidebar -->
                <div class="col-12 col-lg-3 d-none d-lg-block">
                    <div class="card p-3 mb-3">
                        <a href="/my/manager/schedules" class="btn btn-outline-primary w-100 mb-2">
                             <i class="fa fa-arrow-left me-2" /> Back to list
                        </a>
                        <a href="/my/home" class="btn btn-link text-muted w-100">
                             <i class="fa fa-home me-2" /> Home
                        </a>
                        <hr class="my-2"/>
                        <h6 class="text-muted mb-2 small fw-bold">INFORMATION</h6>
                         <div class="small text-muted mb-2">
                            <i class="fa fa-user me-1"/> <span t-field="schedule.employee_id"/>
                        </div>
                        <div class="small text-muted mb-2">
                            <i class="fa fa-calendar me-1"/> <span t-field="schedule.schedule_date"/>
                        </div>
                        <div class="small text-muted">
                            <span class="badge rounded-pill bg-light text-dark border" t-field="schedule.state"/>
                        </div>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-12 col-lg-9">
                    <div class="card mb-4">
                        <div class="card-header bg-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <span t-field="schedule.development_type"/>
                                </h5>
                                <span class="badge rounded-pill text-bg-primary" t-field="schedule.state"/>
                            </div>
                        </div>
                        <div class="card-body">
                            <!-- Basic Info -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <strong>Employee:</strong> <span t-field="schedule.employee_id"/>
                                </div>
                                <div class="col-md-6">
                                    <strong>Date:</strong> <span t-field="schedule.schedule_date"/>
                                </div>
                                <div class="col-md-6">
                                    <strong>RGM:</strong> <span t-field="schedule.proposed_by_id"/>
                                </div>
                                <div class="col-md-6">
                                    <strong>OC:</strong> <span t-field="schedule.oc_id"/>
                                </div>
                            </div>
                            
                            <!-- Courses -->
                            <h6 class="border-bottom pb-2 mt-4 mb-3">Courses</h6>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <div class="p-3 border rounded bg-light">
                                        <strong>Course 1:</strong>
                                        <div t-field="schedule.course_1_name" class="mb-2"/>
                                        <t t-if="schedule.state == 'b1_course'">
                                            <t t-set="courses_employee" t-value="schedule.employee_id.user_id.id == user_id.id or request.env.user.has_group('base.group_system')"/>
                                            <form t-if="courses_employee" action="/my/manager/schedule/action" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="schedule_id" t-att-value="schedule.id"/>
                                                <input type="hidden" name="action" value="complete_b1"/>
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fa fa-check"/> Participate in Course
                                                </button>
                                            </form>
                                        </t>
                                        <span t-if="schedule.state == 'b2_rgm_eval'" class="badge bg-warning text-dark">Pending Evaluation</span>
                                        <span t-if="schedule.state not in ('draft', 'b1_course', 'b2_rgm_eval')" class="badge bg-success">Completed</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <div class="p-3 border rounded bg-light">
                                        <strong>Course 2:</strong>
                                        <div t-field="schedule.course_2_name" class="mb-2"/>
                                        <t t-if="schedule.state == 'b3_course'">
                                            <t t-set="courses_employee" t-value="schedule.employee_id.user_id.id == user_id.id or request.env.user.has_group('base.group_system')"/>
                                            <form t-if="courses_employee" action="/my/manager/schedule/action" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="schedule_id" t-att-value="schedule.id"/>
                                                <input type="hidden" name="action" value="complete_b3"/>
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fa fa-check"/> Participate in Course
                                                </button>
                                            </form>
                                        </t>
                                        <span t-if="schedule.state == 'b4_oc_eval'" class="badge bg-warning text-dark">Pending Evaluation</span>
                                        <span t-if="schedule.state not in ('draft', 'b1_course', 'b2_rgm_eval', 'b3_course', 'b4_oc_eval')" class="badge bg-success">Completed</span>
                                    </div>
                                </div>
                                <!-- LFF Course for RGM -->
                                <div class="col-md-12 mb-2" t-if="schedule.development_type == 'rgm' and schedule.state in ('b5_lff', 'b5_lff_eval', 'waiting_feedback', 'done')">
                                    <div class="p-3 border rounded bg-light">
                                        <strong>Leading For Future (LFF):</strong>
                                        <div class="mb-2">Advanced training program for future RGMs.</div>
                                        <t t-if="schedule.state == 'b5_lff'">
                                            <t t-set="courses_employee" t-value="schedule.employee_id.user_id.id == user_id.id or request.env.user.has_group('base.group_system')"/>
                                            <form t-if="courses_employee" action="/my/manager/schedule/action" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="schedule_id" t-att-value="schedule.id"/>
                                                <input type="hidden" name="action" value="complete_lff"/>
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fa fa-check"/> Participate in Course
                                                </button>
                                            </form>
                                        </t>
                                        <span t-if="schedule.state == 'b5_lff_eval'" class="badge bg-warning text-dark">Pending Evaluation</span>
                                        <span t-if="schedule.state not in ('draft', 'b1_course', 'b2_rgm_eval', 'b3_course', 'b4_oc_eval', 'b5_lff', 'b5_lff_eval')" class="badge bg-success">Completed</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Evaluation Results -->
                            <h6 class="border-bottom pb-2 mt-4 mb-3">Evaluation Results</h6>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Stage</th>
                                            <th>Result</th>
                                            <th>Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>RGM Evaluation (B2)</td>
                                            <td><span t-field="schedule.b2_result"/></td>
                                            <td><span t-field="schedule.b2_notes"/></td>
                                        </tr>
                                        <tr>
                                            <td>OC Evaluation (B4)</td>
                                            <td><span t-field="schedule.b4_result"/></td>
                                            <td><span t-field="schedule.b4_notes"/></td>
                                        </tr>
                                        <tr t-if="schedule.development_type == 'rgm'">
                                            <td>LFF Evaluation (B5)</td>
                                            <td><span t-field="schedule.b5_lff_result"/></td>
                                            <td><span t-field="schedule.b5_lff_notes"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            
                            <!-- Feedback Section -->
                             <h6 class="border-bottom pb-2 mt-4 mb-3">Feedback</h6>
                             
                             <!-- Display Existing Feedback -->
                             <div class="mb-3" t-if="schedule.lnd_feedback_status == 'done'">
                                 <div class="alert alert-success">
                                     <strong>L&amp;D Feedback:</strong>
                                     <p class="mb-0" t-field="schedule.lnd_feedback"/>
                                 </div>
                             </div>
                             
                             <div class="mb-3" t-if="schedule.employee_feedback_status == 'done'">
                                 <div class="alert alert-success">
                                     <strong>Your Feedback:</strong>
                                     <p class="mb-0" t-field="schedule.employee_feedback"/>
                                 </div>
                             </div>

                             <!-- Feedback Form for Employee -->
                             <t t-if="schedule.state == 'waiting_feedback' and schedule.employee_feedback_status == 'pending'">
                                 <t t-set="is_employee" t-value="schedule.employee_id.user_id.id == user_id.id"/>
                                 
                                 <div t-if="is_employee" class="card card-body bg-light">
                                     <h5>Submit Your Feedback</h5>
                                     <form action="/my/manager/schedule/feedback" method="post">
                                         <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                         <input type="hidden" name="schedule_id" t-att-value="schedule.id"/>
                                         <input type="hidden" name="feedback_type" value="employee"/>
                                         
                                         <div class="mb-3">
                                             <label class="form-label">Your Feedback / Comments</label>
                                             <textarea name="feedback" class="form-control" rows="4" required="required"></textarea>
                                         </div>
                                         <button type="submit" class="btn btn-primary">Submit Feedback</button>
                                     </form>
                                 </div>
                             </t>
                        </div>
                    </div>

                    <!-- Chatter -->
                    <div class="card">
                        <div class="card-header">
                            Log
                        </div>
                        <div class="card-body">
                             <div class="t_chatter">
                                <t t-call="portal.message_thread">
                                    <t t-set="object" t-value="schedule"/>
                                </t>
                            </div>
                        </div>
                     </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
