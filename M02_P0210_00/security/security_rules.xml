<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ========================================== -->
        <!-- MANAGER SCHEDULE RECORD RULES -->
        <!-- ========================================== -->
        
        <!-- Crew/Portal: Own Schedule Only -->
        <record id="rule_mcd_manager_schedule_crew_own" model="ir.rule">
            <field name="name">Manager Schedule: Crew Own Records</field>
            <field name="model_id" ref="model_mcd_manager_schedule"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_crew')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        
        <!-- Follower Access: Anyone who receives email/notification can read/write -->
        <record id="rule_mcd_manager_schedule_follower" model="ir.rule">
            <field name="name">Manager Schedule: Follower Access</field>
            <field name="model_id" ref="model_mcd_manager_schedule"/>
            <field name="domain_force">[('message_partner_ids', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- RGM: Own Proposals + Own Employee Record -->
        <record id="rule_mcd_manager_schedule_rgm" model="ir.rule">
            <field name="name">Manager Schedule: RGM Own Proposals</field>
            <field name="model_id" ref="model_mcd_manager_schedule"/>
            <field name="domain_force">['|', ('proposed_by_id.user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_rgm'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- OC: All Schedules -->
        <record id="rule_mcd_manager_schedule_oc" model="ir.rule">
            <field name="name">Manager Schedule: OC See All</field>
            <field name="model_id" ref="model_mcd_manager_schedule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_oc'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- L&D Manager: All Schedules -->
        <record id="rule_mcd_manager_schedule_lnd_global" model="ir.rule">
            <field name="name">Manager Schedule: L&amp;D Manager See All</field>
            <field name="model_id" ref="model_mcd_manager_schedule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_lnd_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- ========================================== -->
        <!-- OPS CAPACITY PROCESS RECORD RULES -->
        <!-- ========================================== -->
        
        <!-- Crew: Own Records (Read/Write for feedback) -->
        <record id="rule_mcd_ops_capacity_process_crew_own" model="ir.rule">
            <field name="name">OPS Capacity Process: Crew Own Records</field>
            <field name="model_id" ref="model_mcd_ops_capacity_process"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_crew'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        
        <!-- Follower Access: Anyone who receives email/notification can read/write -->
        <record id="rule_mcd_ops_capacity_process_follower" model="ir.rule">
            <field name="name">OPS Capacity Process: Follower Access</field>
            <field name="model_id" ref="model_mcd_ops_capacity_process"/>
            <field name="domain_force">[('message_partner_ids', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- RGM: Same Department -->
        <record id="rule_mcd_ops_capacity_process_rgm" model="ir.rule">
            <field name="name">OPS Capacity Process: RGM Same Department</field>
            <field name="model_id" ref="model_mcd_ops_capacity_process"/>
            <field name="domain_force">['|', ('employee_id.department_id', '=', False), ('employee_id.department_id', 'child_of', user.employee_id.department_id.ids)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_rgm'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- OC: All Records -->
        <record id="rule_mcd_ops_capacity_process_oc" model="ir.rule">
            <field name="name">OPS Capacity Process: OC See All</field>
            <field name="model_id" ref="model_mcd_ops_capacity_process"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_oc'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- ========================================== -->
        <!-- OPS EVALUATION RECORD RULES -->
        <!-- ========================================== -->
        
        <!-- RGM: Same Department -->
        <record id="rule_mcd_ops_evaluation_rgm" model="ir.rule">
            <field name="name">OPS Evaluation: RGM Same Department</field>
            <field name="model_id" ref="model_mcd_ops_evaluation"/>
            <field name="domain_force">['|', ('employee_id.department_id', '=', False), ('employee_id.department_id', 'child_of', user.employee_id.department_id.ids)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_rgm'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- OC: All Records -->
        <record id="rule_mcd_ops_evaluation_oc" model="ir.rule">
            <field name="name">OPS Evaluation: OC See All</field>
            <field name="model_id" ref="model_mcd_ops_evaluation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('M02_P0209_00.group_oc'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
