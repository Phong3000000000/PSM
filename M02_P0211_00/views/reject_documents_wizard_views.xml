<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reject_documents_wizard_form" model="ir.ui.view">
        <field name="name">reject.documents.wizard.form</field>
        <field name="model">reject.documents.wizard</field>
        <field name="arch" type="xml">
            <form string="Lý do từ chối hồ sơ">
                <sheet>
                    <group>
                        <field name="applicant_id" readonly="1"/>
                        <field name="reason" placeholder="Nhập lý do từ chối hồ sơ..." required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_reject"
                            string="Xác nhận từ chối"
                            type="object"
                            class="btn-danger"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
