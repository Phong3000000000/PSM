<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="psm_portal_recruitment_theme_assets" name="Portal Recruitment Theme Assets">
        <style>
            .psm-portal-recruitment {
                color: var(--foreground);
            }

            .psm-portal-recruitment .alert,
            .psm-portal-recruitment .card,
            .psm-portal-recruitment table {
                background: var(--card) !important;
                color: var(--card-foreground) !important;
                border-color: var(--border) !important;
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
            }

            .psm-portal-recruitment .text-dark,
            .psm-portal-recruitment .text-primary,
            .psm-portal-recruitment .text-secondary,
            .psm-portal-recruitment .text-danger,
            .psm-portal-recruitment h3,
            .psm-portal-recruitment h4,
            .psm-portal-recruitment h5 {
                color: var(--foreground) !important;
            }

            .psm-portal-recruitment .text-muted,
            .psm-portal-recruitment small {
                color: var(--muted-foreground) !important;
            }

            .psm-portal-recruitment .border,
            .psm-portal-recruitment .border-bottom,
            .psm-portal-recruitment .border-top,
            .psm-portal-recruitment thead th,
            .psm-portal-recruitment tbody td {
                border-color: var(--border) !important;
            }

            .psm-portal-recruitment .badge.bg-primary,
            .psm-portal-recruitment .badge.bg-success,
            .psm-portal-recruitment .badge.bg-info {
                background: var(--primary) !important;
                color: var(--primary-foreground) !important;
            }

            .psm-portal-recruitment .btn-theme-primary {
                background: var(--primary) !important;
                border-color: var(--primary) !important;
                color: var(--primary-foreground) !important;
            }
        </style>
    </template>

    <!-- Section in Portal Home -->
    <!-- Section in Portal Home (Custom for MCD) -->
    <template id="psm_portal_my_home_recruitment_custom" name="Portal My Home: Recruitment Custom" inherit_id="portal_custom.portal_my_home_inherit" priority="30">
        <!-- Sidebar (Desktop) -->
        <xpath expr="//a[@href='/my/shifts']" position="after">
            <a href="/my/jobs" class="sidebar-link" t-if="False">
                <div class="app-icon-wrapper me-3" style="background: color-mix(in srgb, var(--primary) 12%, transparent); color: var(--primary); border: 1px solid var(--border);">
                    <i class="fa fa-briefcase" />
                </div>
                <span class="d-flex align-items-center justify-content-between flex-grow-1">
                    Việc Làm Đang Tuyển
                    <t t-if="published_job_count">
                        <span class="badge rounded-pill bg-danger ms-2" t-esc="published_job_count"/>
                    </t>
                </span>
            </a>
            <a href="/my/recruitment_requests" class="sidebar-link" t-if="False">
                <div class="app-icon-wrapper me-3" style="background: color-mix(in srgb, var(--secondary) 18%, transparent); color: var(--foreground); border: 1px solid var(--border);">
                    <i class="fa fa-id-card-o" />
                </div>
                <span class="d-flex align-items-center justify-content-between flex-grow-1">
                    Yêu Cầu Tuyển Dụng
                    <t t-if="recruitment_request_count">
                        <span class="badge rounded-pill bg-danger ms-2" t-esc="recruitment_request_count"/>
                    </t>
                </span>
            </a>
        </xpath>

        <!-- App Grid (Mobile) -->
        <xpath expr="//div[hasclass('mobile-app-grid')]//a[@href='/my/shifts']" position="after">
            <a href="/my/jobs" class="mobile-app-item"  t-if="False">
                <div class="mobile-app-icon position-relative" style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: var(--primary-foreground);">
                    <i class="fa fa-briefcase" />
                    <t t-if="published_job_count">
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light p-1" style="font-size: 8px;">
                            <t t-esc="published_job_count"/>
                        </span>
                    </t>
                </div>
                <span class="mobile-app-label">Việc Làm</span>
            </a>
        </xpath>
    </template>

    <!-- Published Jobs Portal Page -->
    <template id="psm_portal_my_published_jobs" name="Published Jobs on Portal">
        <t t-call="portal.portal_layout">
            <t t-call="M02_P0205.psm_portal_recruitment_theme_assets"/>
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Việc Làm Đang Tuyển</t>
            </t>

            <div class="psm-portal-recruitment">
            <t t-if="not batches and not no_batch_lines">
                <div class="alert alert-info" role="alert">
                    Hiện chưa có vị trí nào đang tuyển dụng.
                </div>
            </t>

            <!-- Nhóm theo đợt tuyển dụng -->
            <t t-foreach="batches" t-as="batch_group">
                <div class="mb-5">
                    <!-- Tiêu đề đợt -->
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <i class="fa fa-calendar-o me-2 text-primary fa-lg"/>
                        <h4 class="mb-0 fw-bold text-primary">
                            <t t-esc="batch_group['batch'].name"/>
                        </h4>
                        <span class="ms-3 badge bg-primary rounded-pill">
                            <t t-esc="len(batch_group['lines'])"/> vị trí
                        </span>
                        <t t-if="batch_group['batch'].date_start or batch_group['batch'].date_end">
                            <small class="ms-3 text-muted">
                                <t t-if="batch_group['batch'].date_start">
                                    Từ <t t-esc="batch_group['batch'].date_start"/>
                                </t>
                                <t t-if="batch_group['batch'].date_end">
                                    đến <t t-esc="batch_group['batch'].date_end"/>
                                </t>
                            </small>
                        </t>
                    </div>

                    <!-- Danh sách vị trí trong đợt -->
                    <div class="row">
                        <t t-foreach="batch_group['lines']" t-as="line">
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title text-primary fw-bold mb-2">
                                            <i class="fa fa-briefcase me-1"/> <t t-esc="line.job_id.name"/>
                                        </h5>
                                        <t t-if="line.department_id">
                                            <p class="text-muted mb-1">
                                                <i class="fa fa-sitemap me-1"/> <t t-esc="line.department_id.name"/>
                                            </p>
                                        </t>
                                        <p class="mb-1">
                                            <i class="fa fa-users me-1 text-success"/>
                                            <span class="badge bg-success"><t t-esc="line.quantity"/> vị trí</span>
                                        </p>
                                        <t t-if="line.planned_date">
                                            <p class="text-muted mb-2">
                                                <i class="fa fa-clock-o me-1"/> Dự kiến: <t t-esc="line.planned_date"/>
                                            </p>
                                        </t>
                                        <div class="mt-auto">
                                            <a t-attf-href="/jobs/detail/#{line.id}"
                                               class="btn btn-sm w-100 btn-theme-primary"
                                               style="border-radius: 8px;">
                                                <i class="fa fa-eye me-1"/> Xem &amp; Ứng tuyển
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Tuyển dụng đột xuất (Ad-hoc) -->
            <t t-if="unplanned_requests">
                <div class="mb-5">
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <i class="fa fa-bolt me-2 text-danger fa-lg"/>
                        <h4 class="mb-0 fw-bold text-danger">Tuyển dụng đột xuất</h4>
                    </div>
                    <div class="row">
                        <t t-foreach="unplanned_requests" t-as="req">
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0 border-top border-danger border-3" style="border-radius: 12px; overflow: hidden;">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title text-danger fw-bold mb-2">
                                            <i class="fa fa-briefcase me-1"/> <t t-esc="req.job_id.name"/>
                                        </h5>
                                        <t t-if="req.department_id">
                                            <p class="text-muted mb-1">
                                                <i class="fa fa-sitemap me-1"/> <t t-esc="req.department_id.name"/>
                                            </p>
                                        </t>
                                        <p class="mb-2">
                                            <span class="badge bg-danger"><t t-esc="req.quantity"/> vị trí</span>
                                        </p>
                                        <div class="mt-auto">
                                            <a t-attf-href="/jobs/request/detail/#{req.id}"
                                               class="btn btn-sm w-100 btn-theme-primary"
                                               style="border-radius: 8px;">
                                                <i class="fa fa-eye me-1"/> Xem &amp; Ứng tuyển
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Các vị trí không thuộc đợt nào (Kế hoạch không gán batch) -->
            <t t-if="no_batch_lines">
                <div class="mb-5">
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <i class="fa fa-briefcase me-2 text-secondary fa-lg"/>
                        <h4 class="mb-0 fw-bold text-secondary">Tuyển dụng thường xuyên (Theo kế hoạch)</h4>
                    </div>
                    <div class="row">
                        <t t-foreach="no_batch_lines" t-as="line">
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title text-secondary fw-bold mb-2">
                                            <i class="fa fa-briefcase me-1"/> <t t-esc="line.job_id.name"/>
                                        </h5>
                                        <t t-if="line.department_id">
                                            <p class="text-muted mb-1">
                                                <i class="fa fa-sitemap me-1"/> <t t-esc="line.department_id.name"/>
                                            </p>
                                        </t>
                                        <p class="mb-2">
                                            <span class="badge bg-success"><t t-esc="line.quantity"/> vị trí</span>
                                        </p>
                                        <div class="mt-auto">
                                            <a t-attf-href="/jobs/detail/#{line.id}"
                                               class="btn btn-sm w-100 btn-theme-primary"
                                               style="border-radius: 8px;">
                                                <i class="fa fa-eye me-1"/> Xem &amp; Ứng tuyển
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
            </div>
        </t>
    </template>

    <!-- List View Template -->
    <template id="psm_portal_my_recruitment_requests" name="My Recruitment Requests">
        <t t-call="portal.portal_layout">
            <t t-call="M02_P0205.psm_portal_recruitment_theme_assets"/>
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Yêu Cầu Tuyển Dụng</t>
            </t>
            
            <div class="psm-portal-recruitment">
            <t t-if="not recruitment_requests">
                <div class="alert alert-warning" role="alert">
                    Bạn chưa có yêu cầu tuyển dụng nào.
                </div>
            </t>
            
            <t t-if="recruitment_requests">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Mã yêu cầu</th>
                            <th>Vị trí</th>
                            <th>Số lượng</th>
                            <th>Ngày tạo</th>
                            <th class="text-end">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="recruitment_requests" t-as="req">
                            <tr>
                                <td>
                                    <span t-field="req.name"/>
                                </td>
                                <td>
                                    <span t-field="req.job_id.name"/>
                                </td>
                                <td>
                                    <span t-field="req.quantity"/>
                                </td>
                                <td>
                                    <span t-field="req.create_date" t-options='{"widget": "date"}'/>
                                </td>
                                <td class="text-end">
                                    <span t-attf-class="badge rounded-pill #{req.state == 'done' and 'bg-success' or req.state == 'cancel' and 'bg-danger' or 'bg-info'}">
                                        <t t-esc="dict(req._fields['state'].selection).get(req.state)"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
            </div>
        </t>
    </template>
</odoo>
