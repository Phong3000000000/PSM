<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_psm_recruitment_request_approver_tree" model="ir.ui.view">
            <field name="name">x_psm_recruitment_request_approver.tree</field>
            <field name="model">x_psm_recruitment_request_approver</field>
            <field name="arch" type="xml">
                <list string="Manager Duyệt">
                    <field name="request_id" readonly="1"/>
                    <field name="department_id" readonly="1"/>
                    <field name="manager_id" readonly="1"/>
                    <field name="user_id" readonly="1"/>
                    <field name="status" widget="badge" decoration-danger="status == 'rejected'" decoration-success="status == 'approved'"/>
                    <field name="approved_date" readonly="1"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_psm_recruitment_request_approver_form" model="ir.ui.view">
            <field name="name">x_psm_recruitment_request_approver.form</field>
            <field name="model">x_psm_recruitment_request_approver</field>
            <field name="arch" type="xml">
                <form string="Manager Duyệt">
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="department_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="manager_id" readonly="1"/>
                        <field name="user_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="status"/>
                        <field name="approved_date" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="action_psm_recruitment_request_approver" model="ir.actions.act_window">
            <field name="name">Manager Duyệt</field>
            <field name="res_model">x_psm_recruitment_request_approver</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Danh sách manager duyệt yêu cầu tuyển dụng
                </p>
            </field>
        </record>
    </data>
</odoo>
