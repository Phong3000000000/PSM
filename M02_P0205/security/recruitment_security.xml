<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Restore upstream multi-company rule and remove website_published backend bypass. -->
    <function model="ir.rule" name="write">
        <value eval="[ref('hr.hr_job_comp_rule')]" />
        <value
            eval="{'domain_force': '[(\'company_id\', \'in\', company_ids + [False])]', 'name': 'Job multi company rule'}" />
    </function>

    <!-- Disable upstream broad Recruitment rules that open all jobs/applicants for recruitment users. -->
    <record id="hr_recruitment.hr_job_user_rule" model="ir.rule">
        <field name="active" eval="False"/>
    </record>

    <record id="hr_recruitment.hr_applicant_user_rule" model="ir.rule">
        <field name="active" eval="False"/>
    </record>

    <!-- Replace broad user visibility with office department-scoped rules. -->
    <record id="rule_hr_job_office_department_0205" model="ir.rule">
        <field name="name">HR Job: Office by Department (0205)</field>
        <field name="model_id" ref="hr.model_hr_job"/>
        <field name="groups" eval="[(6, 0, [ref('hr_recruitment.group_hr_recruitment_user')])]"/>
        <field name="domain_force">[('x_psm_0205_is_office_job', '=', True), ('department_id', 'in', user.employee_ids.mapped('department_id').ids)]</field>
    </record>

    <record id="rule_hr_applicant_office_department_0205" model="ir.rule">
        <field name="name">HR Applicant: Office by Department (0205)</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(6, 0, [ref('hr_recruitment.group_hr_recruitment_user')])]"/>
        <field name="domain_force">[('x_psm_0205_recruitment_type', '=', 'office'), ('department_id', 'in', user.employee_ids.mapped('department_id').ids)]</field>
    </record>

    <record id="rule_hr_department_office_department_0205" model="ir.rule">
