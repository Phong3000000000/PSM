<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Email Template: Office Survey Invitation (Step 9) -->
        <record id="email_candidate_survey_office" model="mail.template">
            <field name="name">Khảo sát ứng viên Khối Văn Phòng</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Mời thực hiện khảo sát năng lực - {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'recruitment@example.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #f4f7f6;">
    <div style="background-color: #004a99; color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0;">
        <h1 style="margin: 0; font-size: 24px;">Khảo Sát Năng Lực Ứng Viên</h1>
        <p style="margin: 10px 0 0 0; font-size: 16px;">Khối Văn Phòng - MCD</p>
    </div>

    <div style="background-color: white; padding: 30px; border-radius: 0 0 10px 10px; border: 1px solid #e1e4e8; border-top: none;">
        <p style="font-size: 16px; line-height: 1.6; color: #333;">
            Chào bạn <strong><t t-out="object.partner_name"/></strong>,
        </p>

        <p style="font-size: 16px; line-height: 1.6; color: #333;">
            Cảm ơn bạn đã quan tâm và ứng tuyển vào vị trí <strong><t t-out="object.job_id.name"/></strong>.
            Để có thêm cơ sở đánh giá mức độ phù hợp, chúng tôi kính mời bạn hoàn thành bài khảo sát năng lực dưới đây.
        </p>

        <div style="text-align: center; margin: 35px 0;">
            <a t-attf-href="{{ object.get_base_url() }}/survey/start/{{ object.survey_id.access_token }}"
               style="display: inline-block; background-color: #004a99; color: white; padding: 15px 45px;
                      text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                BẮT ĐẦU KHẢO SÁT
            </a>
            <p style="margin-top: 15px; font-size: 13px; color: #7f8c8d;">
                <i>(Vui lòng hoàn thành trong vòng 24 giờ kể từ khi nhận được email này)</i>
            </p>
        </div>

        <p style="margin-top: 25px; font-size: 14px; color: #7f8c8d;">
            Kết quả phản hồi sẽ được bảo mật và chỉ dùng cho mục đích tuyển dụng. Nếu gặp khó khăn, vui lòng phản hồi lại email này để được hỗ trợ.
        </p>

        <p style="margin-top: 30px; font-size: 16px; color: #2c3e50;">
            Trân trọng,<br/>
            <strong>Bộ phận Tuyển dụng Khối Văn Phòng</strong>
        </p>
    </div>

    <div style="text-align: center; padding: 20px; color: #bdc3c7; font-size: 12px;">
        <p>© 2026 MCD Recruitment System. All rights reserved.</p>
    </div>
</div>]]></field>
        </record>

        <!-- Step 12-14: Interview Invitation Template (legacy, not used as default stage template) -->
        <record id="email_interview_invitation_office" model="mail.template">
            <field name="name">Thư mời phỏng vấn (Tuyển dụng VP)</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Thư mời phỏng vấn - {{ ctx.get('interview_label', 'Vòng 1') }} -
                {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'noreply@recruitment.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e0e0e0; border-radius: 8px;">
    <div style="text-align: center; background-color: #004a99; color: white; padding: 20px; border-radius: 8px 8px 0 0; margin: -20px -20px 20px -20px;">
        <h2 style="margin: 0;">Thư Mời Phỏng Vấn</h2>
    </div>
    <div style="line-height: 1.6; color: #333;">
        <p>Thân gửi <strong><t t-out="object.partner_name"/></strong>,</p>
        <p>Lời đầu tiên, MCD xin cảm ơn bạn đã quan tâm đến cơ hội nghề nghiệp tại công ty. Qua hồ sơ và các bài kiểm tra sơ bộ, chúng tôi đánh giá cao tiềm năng của bạn và trân trọng mời bạn tham gia buổi phỏng vấn <strong><t t-out="ctx.get('interview_label', 'Vòng 1')"/></strong> cho vị trí <strong><t t-out="object.job_id.name"/></strong>.</p>

        <div style="background-color: #f8f9fa; padding: 20px; border-radius: 5px; margin: 20px 0;">
            <p style="margin: 0;"><strong>Thời gian:</strong> <t t-out="ctx.get('interview_date', 'Sẽ thông báo sau')"/></p>
            <p style="margin: 10px 0 0 0;"><strong>Địa điểm:</strong> <t t-out="object.company_id.partner_id.contact_address or 'Văn phòng Công ty'"/></p>
            <p style="margin: 10px 0 0 0;"><strong>Người phỏng vấn:</strong> <t t-out="ctx.get('interviewer_name', 'Hội đồng Tuyển dụng')"/></p>
        </div>

        <p>Vui lòng phản hồi email này để xác nhận tham gia hoặc đề xuất lịch khác nếu thời gian trên chưa phù hợp.</p>
        <p>Chúc bạn có buổi phỏng vấn thành công!</p>
        <p>Trân trọng,</p>
        <p><strong>Bộ phận Tuyển dụng (MCD)</strong></p>
    </div>
</div>]]></field>
        </record>

        <record id="email_interview_round2_notification" model="mail.template">
            <field name="name">Thông báo lịch phỏng vấn vòng 2 (CEO)</field>
            <field name="model_id" ref="calendar.model_calendar_event" />
            <field name="subject">Thông báo lịch phỏng vấn vòng 2 - {{
                object.applicant_id.job_id.name }}</field>
            <field name="email_from">{{ object.user_id.email_formatted or
                object.company_id.email_formatted or 'recruitment@example.com' }}</field>
            <field name="email_to">{{ object.applicant_id.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e0e0e0; border-radius: 8px;">
    <div style="text-align: center; background: #004a99; color: #ffffff; padding: 18px; border-radius: 8px 8px 0 0;">
        <h2 style="margin: 0; font-size: 18px;">Thông báo lịch phỏng vấn vòng 2</h2>
    </div>
    <div style="padding: 16px; color: #333333; line-height: 1.6;">
        <p>Thân gửi <strong><t t-out="object.applicant_id.partner_name or object.partner_id.name or 'ứng viên'"/></strong>,</p>
        <p>Chúc mừng bạn đã vượt qua vòng 1. Ban Giám đốc xin thông báo lịch phỏng vấn vòng 2 theo thông tin sau:</p>
        <p><strong>Thời gian:</strong> <t t-out="ctx.get('interview_datetime') or object.start or object.start_date or 'Đang cập nhật'"/></p>
        <p><strong>Địa điểm:</strong> <t t-out="ctx.get('interview_location') or object.location or 'Văn phòng công ty'"/></p>
        <p><strong>Người tổ chức:</strong> <t t-out="ctx.get('interview_owner') or object.user_id.name or 'CEO'"/></p>
        <p>Vui lòng phản hồi lại email này để xác nhận tham gia hoặc đề xuất thời gian khác nếu cần.</p>
        <p>Trân trọng,</p>
        <p><strong>Ban Tuyển dụng MCD</strong></p>
    </div>
</div>]]></field>
        </record>

        <record id="email_interview_round3_notification" model="mail.template">
            <field name="name">Thông báo lịch phỏng vấn vòng 3 (BOD)</field>
