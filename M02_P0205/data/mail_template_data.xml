        <record id="email_interview_round4_notification" model="mail.template">
            <field name="name">Thông báo lịch phỏng vấn vòng 4 (ABU)</field>
            <field name="model_id" ref="calendar.model_calendar_event" />
            <field name="subject">Thông báo lịch phỏng vấn vòng 4 - {{
