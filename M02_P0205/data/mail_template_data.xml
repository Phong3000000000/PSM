        <!-- Interview Slot-Choice (Dynamic for all rounds) -->
        <record id="email_interview_slot_survey" model="mail.template">
            <field name="name">Chọn lịch phỏng vấn</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Chọn lịch phỏng vấn - {{ object.x_psm_0205_mail_round_label or object.stage_id.name or 'vòng tiếp theo' }} - {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'recruitment@example.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
       style="width:100%; border-collapse:collapse; background-color:#f3f4f6; margin:0; padding:0;">
    <tr>
        <td align="center" style="padding:24px 12px;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="680"
                   style="width:680px; max-width:680px; border-collapse:collapse; background-color:#ffffff; border:1px solid #e5e7eb;">
                <!-- Header -->
                <tr>
                    <td style="padding:20px 24px; background-color:#DA291C; border-bottom:4px solid #FFC72C; 
                               font-family:Arial, sans-serif; font-size:30px; font-weight:700; 
                               line-height:1.2; color:#ffffff; text-align:center;">
                        Chọn lịch phỏng vấn - <t t-out="object.x_psm_0205_mail_round_label or object.stage_id.name or 'với chúng tôi'"/>
                    </td>
                </tr>
                <!-- Body -->
                <tr>
                    <td style="padding:24px; font-family:Arial, sans-serif; font-size:16px; line-height:1.7; color:#111827;">
                        <p style="margin:0 0 14px; font-family:Arial, sans-serif; font-size:16px; line-height:1.7; color:#111827;">
                            Chào <strong><t t-out="object.partner_name or 'ứng viên'"/></strong>,
                        </p>
                        <p style="margin:0 0 22px; font-family:Arial, sans-serif; font-size:16px; line-height:1.7; color:#111827;">
                            Cảm ơn bạn đã ứng tuyển vị trí <strong><t t-out="object.job_id.name or 'vị trí ứng tuyển'"/></strong>.
                            Vui lòng chọn một khung giờ phù hợp dưới đây để tham gia phỏng vấn <t t-out="object.x_psm_0205_mail_round_label or object.stage_id.name or 'vòng tiếp theo'"/>.
                        </p>

                        <!-- Slot table -->
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
                               style="width:100%; border-collapse:collapse; border:1px solid #e5e7eb; background-color:#ffffff;">
                            <tr>
                                <td style="padding:14px 18px; background-color:#FFF5D1; border-bottom:1px solid #e5e7eb;
                                           font-family:Arial, sans-serif; font-size:14px; color:#6b7280;" colspan="2">
                                    Khung giờ được hiển thị theo giờ địa phương của lịch hẹn.
                                </td>
                            </tr>
                            <t t-if="object.x_psm_0205_mail_has_slots">
                                <t t-raw="object.x_psm_0205_mail_slot_rows_html"/>
                            </t>
                            <t t-if="not object.x_psm_0205_mail_has_slots">
                                <tr>
                                    <td style="padding:14px 18px; font-family:Arial, sans-serif; font-size:14px; color:#6b7280;" colspan="2">
                                        Đang cập nhật
                                    </td>
                                </tr>
                            </t>
                        </table>

                        <p style="margin:24px 0 8px; font-family:Arial, sans-serif; font-size:15px; line-height:1.7; color:#111827;">
                            Sau khi bạn chọn lịch, hệ thống sẽ ghi nhận ngay và đội ngũ tuyển dụng sẽ liên hệ lại sớm nhất.
                        </p>
                        <p style="margin:0; font-family:Arial, sans-serif; font-size:15px; line-height:1.7; color:#111827;">
                            Trân trọng,<br/><strong>Bộ phận Tuyển dụng</strong>
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>]]></field>
        </record>

        <!-- Offer Letter -->
        <record id="email_offer_letter_office" model="mail.template">
            <field name="name">Thư mời nhận việc - Offer Letter (Tuyển dụng VP)</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Thư mời nhận việc - Offer Letter - {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'noreply@recruitment.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e0e0e0; border-radius: 8px;">
    <div style="text-align: center; background-color: #da291c; padding: 20px; border-radius: 8px 8px 0 0; margin: -20px -20px 20px -20px;">
        <h2 style="margin: 0; color: #ffc72c;">THƯ MỜI NHẬN VIỆC (OFFER LETTER)</h2>
    </div>
    <div style="line-height: 1.6; color: #333; margin-top: 20px;">
        <p>Thân gửi <strong><t t-out="object.partner_name"/></strong>,</p>
        <p>MCD vô cùng ấn tượng với năng lực và kinh nghiệm của bạn qua các vòng phỏng vấn vừa qua. Chúng tôi rất vui mừng mời bạn gia nhập đội ngũ MCD tại vị trí <strong><t t-out="object.job_id.name"/></strong>.</p>

        <div style="background-color: #f8f9fa; padding: 20px; border-radius: 5px; margin: 20px 0; border-left: 4px solid #da291c;">
            <p style="margin: 0;"><strong>Vị trí:</strong> <t t-out="object.job_id.name"/></p>
            <p style="margin: 10px 0 0 0;"><strong>Ngày bắt đầu dự kiến:</strong> <t t-out="object.availability or 'Sẽ thỏa thuận'"/></p>
            <p style="margin: 10px 0 0 0;"><strong>Bộ phận:</strong> <t t-out="object.department_id.name or 'Công ty'"/></p>
            <p style="margin: 10px 0 0 0;"><strong>Lương đề nghị:</strong> <t t-out="object.salary_proposed"/> VND</p>
        </div>

        <p>Chi tiết về chế độ đãi ngộ, bảo hiểm và các chính sách khác được đính kèm trong email này. Bạn vui lòng phản hồi xác nhận đồng ý nhận việc trước ngày <strong><t t-out="ctx.get('deadline_date', '3 ngày kể từ hôm nay')"/></strong>.</p>

        <p>Chúng tôi rất mong chờ được chào đón bạn tại "ngôi nhà chung" MCD!</p>
        <p>Trân trọng,</p>
        <p><strong>Ban Giám Đốc &amp; Bộ phận Tuyển dụng (MCD)</strong></p>
    </div>
</div>]]></field>
        </record>

        <!-- Internal Interviewer Slot-Choice Template: Interview 2 -->
        <record id="email_office_slot_choice_round_2" model="mail.template">
            <field name="name">Chọn lịch phỏng vấn vòng 2 (Người PV nội bộ)</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Chọn lịch phỏng vấn vòng 2 - {{ object.partner_name }} - {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'recruitment@example.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <p>Chào <strong><t t-out="object.partner_name"/></strong>,</p>
    <p>Vui lòng chọn một trong những slot phù hợp dưới đây để tham gia phỏng vấn vòng 2:</p>
      <ul>
          <t t-foreach="ctx.get('meeting_slots', [])" t-as="slot">
              <li>
                  <t t-esc="slot.get('time', 'Đang cập nhật')"/> -
                  <a t-attf-href="{{ slot.get('url', '#') }}">Chọn lịch này</a>
              </li>
          </t>
      </ul>
    <p>Cảm ơn bạn!</p>
</div>]]></field>
        </record>

        <!-- Internal Interviewer Slot-Choice Template: Interview 3 -->
        <record id="email_office_slot_choice_round_3" model="mail.template">
            <field name="name">Chọn lịch phỏng vấn vòng 3 (Người PV nội bộ)</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant" />
            <field name="subject">Chọn lịch phỏng vấn vòng 3 - {{ object.partner_name }} - {{ object.job_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or
                object.company_id.email_formatted or 'recruitment@example.com') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
