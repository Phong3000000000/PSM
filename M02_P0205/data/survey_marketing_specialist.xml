<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Survey: Marketing Specialist -->
        <record id="survey_marketing_specialist" model="survey.survey">
            <field name="title">Khảo sát năng lực - Marketing Specialist</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">70</field>
            <field name="x_psm_0205_is_pre_interview">True</field>
            <field name="users_login_required">False</field>
            <field name="description"><![CDATA[
                <p>Khảo sát nhanh nhằm đánh giá khả năng triển khai các hoạt động marketing của bạn cho vị trí Marketing Specialist.</p>
            ]]></field>
            <field name="description_done"><![CDATA[
                <p>Cảm ơn bạn đã hoàn thành khảo sát! HR sẽ phản hồi trong 3 ngày làm việc.</p>
            ]]></field>
        </record>

        <record id="mq_marketing_focus" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="title">I. Trọng tâm marketing</field>
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <record id="mq_marketing_q1" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="page_id" ref="mq_marketing_focus" />
            <field name="title">Bạn có kinh nghiệm vận hành chiến dịch nào sau đây?</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">2</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="mq_marketing_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="mq_marketing_q1" />
            <field name="value">Paid Search</field>
            <field name="answer_score">8</field>
            <field name="x_psm_0205_is_must_have">True</field>
        </record>
        <record id="mq_marketing_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="mq_marketing_q1" />
            <field name="value">Social Ads</field>
            <field name="answer_score">8</field>
            <field name="x_psm_0205_is_must_have">True</field>
        </record>
        <record id="mq_marketing_q1_a3" model="survey.question.answer">
            <field name="question_id" ref="mq_marketing_q1" />
            <field name="value">Content / Inbound</field>
            <field name="answer_score">5</field>
            <field name="x_psm_0205_is_nice_to_have">True</field>
        </record>

        <record id="mq_strategy_page" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="title">II. Chiến lược &amp; phân tích</field>
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <record id="mq_strategy_q2" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="page_id" ref="mq_strategy_page" />
            <field name="title">Thứ tự bạn ưu tiên khi lập kế hoạch chiến dịch gồm?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">11</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="mq_strategy_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="mq_strategy_q2" />
            <field name="value">Đặt KPI -> chọn kênh -> triển khai</field>
            <field name="answer_score">8</field>
            <field name="is_correct">True</field>
        </record>
        <record id="mq_strategy_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="mq_strategy_q2" />
            <field name="value">Triển khai thử -> đo lường ngay</field>
            <field name="answer_score">4</field>
        </record>

        <record id="mq_data_page" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="title">III. Dữ liệu &amp; công cụ</field>
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <record id="mq_data_q3" model="survey.question">
            <field name="survey_id" ref="survey_marketing_specialist" />
            <field name="page_id" ref="mq_data_page" />
            <field name="title">Bạn dùng công cụ nào để theo dõi hiệu quả chiến dịch?</field>
            <field name="question_type">text_box</field>
            <field name="sequence">21</field>
        </record>

    </data>
</odoo>