<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Approval Category: PIF Approval -->
        <record id="approval_category_pif" model="approval.category">
            <field name="name">PIF Approval</field>
            <field name="description">Product Information Form approval workflow</field>
            <field name="approval_minimum">4</field>
            <field name="requirer_document">required</field>
            <field name="has_date">required</field>
            <field name="has_reference">required</field>
            <field name="automated_sequence">True</field>
            <field name="sequence_code">pif.approval</field>
        </record>
        <!-- Mail Activity Type: QA Document Review -->
        <record id="mail_activity_qa_document_review" model="mail.activity.type">
            <field name="name">QA Document Review</field>
            <field name="summary">QA Document Review Required</field>
            <field name="res_model">supplier.evaluation</field>
            <field name="icon">fa-check-square-o</field>
            <field name="delay_count">3</field>
            <field name="delay_unit">days</field>
        </record>
    </data>
</odoo>