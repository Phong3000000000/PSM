                        </group>
                    </sheet>
                </form>
            </xpath>
            <!-- 4. Add PIF-specific fields in notebook -->
            <xpath expr="//notebook" position="inside">
                <page name="pif_info" string="PIF Information" invisible="not is_pif">
                    <group>
                        <group string="Product Development (Step 1)">
                            <field name="program_name" />
                            <field name="launch_date" />
                            <field name="forecast_volume" />
                        </group>
                        <group string="Supplier Evaluation (Step 14)">
                            <field name="supplier_evaluation_id" domain="[('state', '=', 'approved')]" context="{'default_evaluation_type': 'new_product'}" />
                            <field name="wrin_created" readonly="1" />
                        </group>
                    </group>
                    <group string="Approval Workflow">
                        <group string="Menu Department">
                            <field name="menu_approved_by" readonly="1" />
                            <field name="menu_approved_date" readonly="1" />
                        </group>
                        <group string="Sourcing">
                            <field name="sourcing_approved_by" readonly="1" />
                            <field name="sourcing_approved_date" readonly="1" />
                        </group>
                        <group string="Line Manager">
                            <field name="line_manager_approved_by" readonly="1" />
                            <field name="line_manager_approved_date" readonly="1" />
                        </group>
                        <group string="CEO">
                            <field name="ceo_approved_by" readonly="1" />
                            <field name="ceo_approved_date" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Add PIF filter in BOM list view -->
    <record id="mrp_bom_tree_view_inherit" model="ir.ui.view">
        <field name="name">mrp.bom.tree.inherit.sc_0402</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-info">is_pif and pif_state == 'draft'</attribute>
                <attribute name="decoration-success">is_pif and pif_state == 'approved'</attribute>
                <attribute name="decoration-warning">is_pif and pif_state in ('menu_review', 'sourcing', 'line_manager', 'ceo')</attribute>
                <attribute name="decoration-danger">is_pif and pif_state == 'rejected'</attribute>
            </xpath>
            <xpath expr="//field[@name='code']" position="after">
                <field name="is_pif" optional="show" />
                <field name="pif_state" optional="show" invisible="not is_pif" />
                <field name="program_name" optional="hide" />
            </xpath>
        </field>
    </record>
</odoo>
</file>

