<file path="views/res_partner_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. SỬA FORM VIEW: Thêm Ribbon và Statusbar -->
    <record id="view_partner_form_sc0402_vendor" model="ir.ui.view">
        <field name="name">res.partner.form.sc0402.vendor</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <!-- HEADER: Nút duyệt & Thanh trạng thái -->
            <xpath expr="//sheet" position="before">
                <header invisible="not is_company">
                    <!-- Nút duyệt chỉ hiện khi đang Draft -->
                    <button name="action_approve_vendor" string="Approve Vendor (Cấp Mã)" type="object" class="oe_highlight" invisible="x_supplier_status != 'draft'" confirm="Bạn có chắc chắn muốn duyệt và cấp mã cho NCC này?" groups="SC_0402_supplier_management.group_sourcing_user" />
                    <!-- Thanh trạng thái: Draft -> Approved -->
                    <field name="x_supplier_status" widget="statusbar" statusbar_visible="draft,approved" />
                </header>
            </xpath>
            <!-- RIBBON: Đóng dấu trạng thái cho dễ nhìn -->
            <xpath expr="//sheet/div[@name='button_box']" position="after">
                <!-- Ribbon Vàng: DRAFT / SE -->
                <widget name="web_ribbon" title="DRAFT (SE)" bg_color="bg-warning" invisible="x_supplier_status != 'draft' or is_company == False" />
                <!-- Ribbon Xanh: OFFICIAL -->
                <widget name="web_ribbon" title="OFFICIAL" bg_color="bg-success" invisible="x_supplier_status != 'approved'" />
            </xpath>
            <!-- BODY: Hiển thị mã NCC -->
            <xpath expr="//field[@name='vat']" position="after">
                <field name="x_supplier_code" readonly="1" invisible="supplier_rank == 0" />
            </xpath>
        </field>
    </record>
    <!-- 2. SỬA LIST VIEW: Thêm cột Status ra ngoài danh sách -->
    <record id="view_partner_tree_sc0402_vendor" model="ir.ui.view">
        <field name="name">res.partner.tree.sc0402.vendor</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <!-- Cột Status màu mè -->
                <field name="x_supplier_status" widget="badge" decoration-warning="x_supplier_status == 'draft'" decoration-success="x_supplier_status == 'approved'" optional="show" />
                <!-- Cột Mã NCC -->
                <field name="x_supplier_code" optional="show" />
            </xpath>
        </field>
    </record>
    <!-- 3. SỬA SEARCH VIEW: Bộ lọc -->
    <!-- 3. SỬA SEARCH VIEW: ĐÃ XÓA ĐỂ TRÁNH TRÙNG LẶP VỚI vendor_draft_views.xml -->
    <!-- Bạn xóa hẳn record id="view_res_partner_filter_sc0402" đi nhé -->
</odoo>
</file>

