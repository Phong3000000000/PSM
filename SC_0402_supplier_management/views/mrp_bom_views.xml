<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_bom_form_view_clean_ui" model="ir.ui.view">
        <field name="name">mrp.bom.form.clean.ui</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <!-- 1. Add Header: Statusbar and Buttons (before sheet) -->
            <xpath expr="//form/sheet" position="before">
                <header invisible="not is_pif">
                    <field name="is_pif" invisible="1" />
                    <button name="action_submit_for_approval" string="Submit (Menu)" type="object" class="oe_highlight" invisible="pif_state != 'draft'" />
                    <button name="action_approve_sourcing" string="Done (Sourcing)" type="object" class="oe_highlight" invisible="pif_state != 'sourcing'" />
                    <!-- B15: Menu Final Confirm after Sourcing update -->
                    <button name="action_approve_menu_final" string="Xác nhận Final (Menu B15)" type="object" class="oe_highlight" invisible="pif_state != 'menu_final'" />
                    <!-- Menu Head Approve - FINAL APPROVAL -->
                    <button name="action_approve_menu_head" string="Approve (Menu Head)" type="object" class="oe_highlight" invisible="pif_state != 'menu_head'" confirm="Menu Head approval sẽ phê duyệt BOM và tạo WRIN. Tiếp tục?" />
                    <!-- B21: Vendor Change Proposal (only on approved PIF) -->
                    <button name="action_propose_vendor_change" string="Đề xuất thay đổi NCC (B21)" type="object" class="btn-secondary" invisible="pif_state != 'approved'" confirm="Bạn có chắc muốn đề xuất thay đổi NCC? PIF sẽ cần duyệt lại." />
                    <field name="pif_state" widget="statusbar" statusbar_visible="draft,sourcing,menu_final,menu_head,approved" />
                </header>
            </xpath>
            <!-- Add Smart Button for PIF Implementation -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_pif_implementation" type="object" class="oe_stat_button" icon="fa-flask" invisible="not pif_object_id">
                    <field name="pif_object_count" string="PIF" widget="statinfo" />
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="before">
                <field name="pif_object_id" invisible="1" />
            </xpath>
            <!-- 2. Add Checkbox PIF after code field -->
            <xpath expr="//field[@name='code']" position="after">
                <field name="is_pif" widget="boolean_toggle" />
            </xpath>
            <!-- 3. CLEAN UP COMPONENTS TABLE -->
            <xpath expr="//field[@name='bom_line_ids']/list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <!-- Product column: Auto-set Raw Material -->
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="attributes">
                <attribute name="context">{'default_x_is_raw_material': True, 'default_purchase_ok': True, 'default_sale_ok': False}</attribute>
            </xpath>
            <!-- Add GRI column after Product (REMOVED - DUPLICATE) -->
            <!-- <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="after">
                <field name="gri" string="GRI" optional="show" />
            </xpath> -->
            <!-- VENDOR COLUMNS - Using product.supplierinfo directly -->
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_uom_id']" position="after">
                <!-- Helper fields for domain and state -->
                <field name="product_tmpl_id" column_invisible="1" />
                <!-- Vendor Proposals: Show all vendors as tags -->
                <field name="valid_supplierinfo_ids" string="Vendor Proposals" widget="many2many_tags" readonly="parent.pif_state in ('sourcing', 'approved')" optional="show" />
                <!-- Selected Vendor: Sourcing picks this -->
                <field name="selected_supplierinfo_id" string="Selected Vendor" options="{'no_create': True}" readonly="parent.pif_state in ('menu_final', 'menu_head', 'approved')" />
                <!-- WRIN and Cost -->
                <field name="wrin" string="WRIN" optional="show" readonly="1" />
                <field name="price_unit" string="Cost" readonly="1" widget="monetary" />
                <!-- Lead Time at end -->
                <field name="lead_time_days" string="Lead Time (Days)" optional="show" readonly="1" />
                <!-- Contract button - only when BOM approved -->
                <button name="action_create_line_contract" string="📄" type="object" title="Tạo Contract" class="btn-link" invisible="parent.pif_state != 'approved'" />
            </xpath>
            <!-- Embedded Form for BOM Line (Popup when clicking on a line) -->
            <xpath expr="//field[@name='bom_line_ids']" position="inside">
                <form>
                    <sheet>
                        <group>
                            <group string="Product">
                                <field name="product_id" />
                                <field name="product_qty" />
                                <field name="product_uom_id" />
                            </group>
                            <group string="Codes">
                                <field name="gri" readonly="1" />
                                <field name="wrin" readonly="1" />
                            </group>
                        </group>
                        <group string="Vendor Selection">
                            <group>
                                <field name="product_tmpl_id" invisible="1" />
                                <field name="valid_supplierinfo_ids" string="Available Vendors" widget="many2many_tags" readonly="1" />
                            </group>
                            <group>
                                <field name="selected_supplierinfo_id" string="Select Vendor" options="{'no_create': True}" groups="SC_0402_supplier_management.group_sourcing_user" />
                                <field name="selected_vendor_id" readonly="1" />
                                <field name="price_unit" readonly="1" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </xpath>
            <!-- 4. Add PIF-specific fields in notebook -->
            <xpath expr="//notebook" position="inside">
                <page name="pif_info" string="PIF Information" invisible="not is_pif">
                    <group>
                        <group string="Product Development (Step 1)">
                            <field name="program_name" />
                            <field name="launch_date" />
                            <field name="forecast_volume" />
                        </group>
                        <group string="Supplier Evaluation (Step 14)">
                            <field name="supplier_evaluation_id" domain="[('state', '=', 'approved')]" context="{'default_evaluation_type': 'new_product'}" />
                            <field name="wrin_created" readonly="1" />
                            <field name="finished_wrin" string="WRIN Thành phẩm" readonly="1" invisible="not wrin_created" />
                        </group>
                    </group>
                    <group string="Approval Workflow">
                        <group string="Menu Department">
                            <field name="menu_approved_by" readonly="1" />
                            <field name="menu_approved_date" readonly="1" />
                        </group>
                        <group string="Sourcing">
                            <field name="sourcing_approved_by" readonly="1" />
                            <field name="sourcing_approved_date" readonly="1" />
                        </group>
                        <group string="Line Manager">
                            <field name="line_manager_approved_by" readonly="1" />
                            <field name="line_manager_approved_date" readonly="1" />
                        </group>
                        <group string="CEO">
                            <field name="ceo_approved_by" readonly="1" />
                            <field name="ceo_approved_date" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Add PIF filter in BOM list view -->
    <record id="mrp_bom_tree_view_inherit" model="ir.ui.view">
        <field name="name">mrp.bom.tree.inherit.sc_0402</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-info">is_pif and pif_state == 'draft'</attribute>
                <attribute name="decoration-success">is_pif and pif_state == 'approved'</attribute>
                <attribute name="decoration-warning">is_pif and pif_state in ('menu_review', 'sourcing', 'line_manager', 'ceo')</attribute>
                <attribute name="decoration-danger">is_pif and pif_state == 'rejected'</attribute>
            </xpath>
            <xpath expr="//field[@name='code']" position="after">
                <field name="is_pif" optional="show" />
                <field name="pif_state" optional="show" invisible="not is_pif" />
                <field name="program_name" optional="hide" />
            </xpath>
        </field>
    </record>
</odoo>