<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit BOM Line Tree View to show McDonald's fields -->
    <record id="mrp_bom_line_tree_view_inherit" model="ir.ui.view">
        <field name="name">mrp.bom.line.tree.inherit.sc_0402</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <!-- Extend BOM lines tree view -->
            <xpath expr="//field[@name='bom_line_ids']/list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="after">
                <!-- McDonald's Fields -->
                <field name="gri" optional="show" />
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_qty']" position="after">
                <field name="conversion_rate" string="Conv. Rate" optional="show" />
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_uom_id']" position="after">
                <!-- Cost columns -->
                <field name="inventory_price" string="Unit Price" optional="show" />
                <field name="total_cost" optional="show" sum="Total Cost" />
                <field name="currency_id" column_invisible="1" />
            </xpath>
        </field>
    </record>
</odoo>