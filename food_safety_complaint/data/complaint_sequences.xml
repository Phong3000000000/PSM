<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Complaint Number -->
        <record id="seq_food_safety_complaint" model="ir.sequence">
            <field name="name">Food Safety Complaint Sequence</field>
            <field name="code">food.safety.complaint</field>
            <field name="prefix">FSC/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
