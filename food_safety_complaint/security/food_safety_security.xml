<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Security Groups -->
        <record id="group_food_safety_user" model="res.groups">
            <field name="name">Food Safety User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_food_safety_manager" model="res.groups">
            <field name="name">Food Safety Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_food_safety_user'))]"/>
        </record>

        <record id="group_food_safety_qa" model="res.groups">
            <field name="name">Food Safety QA Inspector</field>
            <field name="implied_ids" eval="[(4, ref('group_food_safety_user'))]"/>
        </record>

        <!-- Multi-company Rules -->
        <record id="food_safety_complaint_company_rule" model="ir.rule">
            <field name="name">Food Safety Complaint: Multi-company</field>
            <field name="model_id" ref="model_food_safety_complaint"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[
                '|',
                    ('company_id', '=', False),
                    ('company_id', 'in', company_ids)
            ]</field>
        </record>

    </data>
</odoo>
