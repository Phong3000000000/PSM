<odoo>
  <record id="view_move_form_inherit_psm_ai" model="ir.ui.view">
    <field name="name">account.move.form.psm.ai</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="action_psm_ai_analyze"
                string="Phân tích bằng AI (ChatGPT)"
                type="object"
                class="oe_highlight"
                modifiers="{'invisible': [('move_type','!=','in_invoice')]}"/>
      </xpath>
      <xpath expr="//sheet/notebook" position="inside">
        <page string="AI Log">
          <field name="psm_ai_last_result" nolabel="1" readonly="1"/>
        </page>
      </xpath>
    </field>
  </record>
</odoo>