<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_referral_program_form" model="ir.ui.view">
        <field name="name">employee.referral.program.form</field>
        <field name="model">employee.referral.program</field>
        <field name="arch" type="xml">
            <form string="Chương trình Giới thiệu">
                <header>
                    <button name="action_close" string="Đóng chương trình" type="object"
                        invisible="state not in ['active', 'approved']" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,approved,active,closed" />
                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>

                    <group>
                        <group string="Thông tin chương trình">
                            <field name="store_id" string="Cửa hàng / Phòng ban" />
                        </group>
                        <group string="Thời gian">
                            <field name="start_date" />
                            <field name="end_date" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Vị trí tuyển dụng" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="job_id" />
                                    <field name="positions_needed" />
                                    <field name="salary" />
                                    <field name="job_type" />
                                </list>
                            </field>
                        </page>
                        <page string="Nội dung" name="description">
                            <field name="description" />
                        </page>
                    </notebook>
                </sheet>

                <chatter />
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_referral_program_tree" model="ir.ui.view">
        <field name="name">employee.referral.program.tree</field>
        <field name="model">employee.referral.program</field>
        <field name="arch" type="xml">
            <list string="Chương trình Giới thiệu"
                decoration-success="state == 'active'"
                decoration-muted="state == 'closed'">
                <field name="name" />
                <field name="store_id" string="Cửa hàng / Phòng ban" />
                <field name="start_date" />
                <field name="end_date" />
                <field name="state" widget="badge" />
            </list>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_referral_program_search" model="ir.ui.view">
        <field name="name">employee.referral.program.search</field>
        <field name="model">employee.referral.program</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm">
                <field name="name" />
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_referral_program" model="ir.actions.act_window">
        <field name="name">Chương trình đang mở</field>
        <field name="res_model">employee.referral.program</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'active')]</field>
    </record>

    <record id="action_referral_program_all" model="ir.actions.act_window">
        <field name="name">Chương trình giới thiệu nhân sự</field>
        <field name="res_model">employee.referral.program</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False}</field>
    </record>
</odoo>