<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override Applicant Search View to Filter Stages by Recruitment Type -->
    <record id="view_applicant_filter_recruitment_type" model="ir.ui.view">
        <field name="name">hr.applicant.search.recruitment.type</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.view_crm_case_jobs_filter"/>
        <field name="arch" type="xml">
            <!-- Add filter for recruitment type -->
            <filter name="stage" position="after">
                <separator/>
                <filter string="Khối Cửa Hàng" name="recruitment_type_store" 
                        domain="[('recruitment_type', '=', 'store')]"/>
                <filter string="Khối Văn Phòng" name="recruitment_type_office" 
                        domain="[('recruitment_type', '=', 'office')]"/>
            </filter>
        </field>
    </record>
    
    <!-- Override Kanban View to Only Show Relevant Stages -->
    <record id="view_applicant_kanban_recruitment_type" model="ir.ui.view">
        <field name="name">hr.applicant.kanban.recruitment.type</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_kanban_view_applicant"/>
        <field name="arch" type="xml">
            <!-- Limit stages shown in kanban based on recruitment_type -->
            <xpath expr="//kanban" position="attributes">
                <attribute name="default_group_by">stage_id</attribute>
                <attribute name="group_create">false</attribute>
            </xpath>
        </field>
    </record>
</odoo>
