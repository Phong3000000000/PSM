<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Interview Schedule Views -->
    
    <!-- Kanban View - Hiển thị Cards cho từng cửa hàng -->
    <record id="view_interview_schedule_kanban" model="ir.ui.view">
        <field name="name">interview.schedule.kanban</field>
        <field name="model">interview.schedule</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="company_id"/>
                <field name="store_address"/>
                <field name="week_display"/>
                <field name="interview_date_1"/>
                <field name="interview_date_2"/>
                <field name="interview_date_3"/>
                <field name="state"/>
                <field name="applicant_count"/>
                <templates>
                    <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <!-- Header -->
                                <div class="o_kanban_record_top mb-3">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <i class="fa fa-building me-2"/>
                                            <field name="company_id"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle text-muted" t-if="record.store_address.raw_value">
                                            <i class="fa fa-map-marker me-1"/>
                                            <field name="store_address"/>
                                        </div>
                                        <div class="o_kanban_record_subtitle text-muted">
                                            <i class="fa fa-calendar me-1"/>
                                            Tuần: <field name="week_display"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <field name="state" widget="label_selection" 
                                            options="{'classes': {'draft': 'secondary', 'confirmed': 'success'}}"/>
                                    </div>
                                </div>
                            
                            <!-- 3 Ngày PV -->
                            <div class="container">
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-primary me-2"/>
                                        <strong>Ngày PV 1:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_1" widget="datetime"/></span>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-success me-2"/>
                                        <strong>Ngày PV 2:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_2" widget="datetime"/></span>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-info me-2"/>
                                        <strong>Ngày PV 3:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_3" widget="datetime"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_interview_schedule_form" model="ir.ui.view">
        <field name="name">interview.schedule.form</field>
        <field name="model">interview.schedule</field>
        <field name="arch" type="xml">
            <form string="Lịch Phỏng Vấn">
                <header>
                    <button name="action_confirm" 
                            string="Xác Nhận" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state == 'confirmed'"/>
                    
                    <button name="action_set_draft" 
                            string="Chuyển Về Nháp" 
                            type="object" 
                            invisible="state == 'draft'"/>
                    
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,confirmed"/>
                </header>
                
                <sheet>
                    <group>
                        <group string="Thông Tin Brand">
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="store_address" placeholder="VD: 72 Lê Thánh Tôn" invisible="1"/>
                            <field name="manager_id" readonly="1" invisible="1"/>
                        </group>
                        <group string="Thông Tin Tuần">
                            <field name="week_start_date"/>
                            <field name="week_display" readonly="1"/>
                            <field name="applicant_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="3 Slot Phỏng Vấn Trong Tuần">
                        <field name="interview_date_1"/>
                        <field name="interview_date_2"/>
                        <field name="interview_date_3"/>
                    </group>
                    
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"/> 
                        <strong>Lưu ý:</strong> Store Manager đặt 3 slot để HR gửi cho ứng viên chọn.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View - Temporarily commented for debugging -->
