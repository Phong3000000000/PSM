<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="group_store_manager" model="res.groups">
        <field name="name">Store Manager</field>
        <field name="comment">Store Manager có thể tạo lịch PV cho brand của mình</field>
    </record>

    <record id="group_operations_manager" model="res.groups">
        <field name="name">Operations Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_store_manager'))]"/>
        <field name="comment">Operations Manager duyệt lịch PV của tất cả brands</field>
    </record>

