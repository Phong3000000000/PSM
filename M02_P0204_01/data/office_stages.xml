<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <!-- Recruitment Stages for Office -->
        <record id="stage_office_new" model="hr.recruitment.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_filter" model="hr.recruitment.stage">
            <field name="name">Lọc UV</field>
            <field name="sequence">20</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_interview1" model="hr.recruitment.stage">
            <field name="name">Interview 1</field>
            <field name="sequence">30</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_interview2" model="hr.recruitment.stage">
            <field name="name">Interview 2</field>
            <field name="sequence">40</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_interview3" model="hr.recruitment.stage">
            <field name="name">Interview 3</field>
            <field name="sequence">50</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_interview4" model="hr.recruitment.stage">
            <field name="name">Interview 4</field>
            <field name="sequence">60</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_probation" model="hr.recruitment.stage">
            <field name="name">Thử việc</field>
            <field name="sequence">70</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_proposal" model="hr.recruitment.stage">
            <field name="name">Đề xuất chính thức</field>
            <field name="sequence">80</field>
            <field name="recruitment_type">office</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_office_hired" model="hr.recruitment.stage">
            <field name="name">Chính thức</field>
            <field name="sequence">90</field>
            <field name="recruitment_type">office</field>
            <field name="hired_stage">True</field>
            <field name="fold">False</field>
        </record>

</odoo>
