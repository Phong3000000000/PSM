<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <!-- Recruitment Stages for Store -->
        <record id="stage_store_new" model="hr.recruitment.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_review" model="hr.recruitment.stage">
            <field name="name">Review Tiêu chí</field>
            <field name="sequence">20</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_interview" model="hr.recruitment.stage">
            <field name="name">Interview</field>
            <field name="sequence">30</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_oje" model="hr.recruitment.stage">
            <field name="name">OJE</field>
            <field name="sequence">40</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_probation" model="hr.recruitment.stage">
            <field name="name">Thử việc</field>
            <field name="sequence">50</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_proposal" model="hr.recruitment.stage">
            <field name="name">Đề xuất chính thức (FT/PT)</field>
            <field name="sequence">60</field>
            <field name="recruitment_type">store</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_store_hired" model="hr.recruitment.stage">
            <field name="name">Chính thức</field>
            <field name="sequence">70</field>
            <field name="recruitment_type">store</field>
            <field name="hired_stage">True</field>
            <field name="fold">False</field>
        </record>

</odoo>
