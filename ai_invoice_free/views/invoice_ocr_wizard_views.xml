<odoo>
  <record id="view_invoice_ocr_wizard_form" model="ir.ui.view">
    <field name="name">invoice.ocr.wizard.form</field>
    <field name="model">invoice.ocr.wizard</field>
    <field name="arch" type="xml">
      <form string="OCR Vendor Bill">
        <group>
          <field name="attachment_id"/>
          <field name="engine"/>
          <field name="lang"/>
        </group>
        <footer>
          <button string="Extract" type="object" name="action_extract" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
