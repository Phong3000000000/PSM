<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_psm_db_connection_tree" model="ir.ui.view">
            <field name="name">psm.db.connection.tree</field>
            <field name="model">psm.db.connection</field>
            <field name="arch" type="xml">
                <list string="Kết nối cơ sở dữ liệu" sample="1">
                    <field name="name"/>
                    <field name="db_type"/>
                    <field name="host"/>
                    <field name="port"/>
                    <field name="database"/>
                    <field name="mssql_connection_type" optional="hide"/>
                    <field name="mapping_model_count"/>
                    <field name="last_connection"/>
                    <field name="active" widget="boolean_toggle"/>
                    <field name="user_id" widget="many2one_avatar_user"/>
                </list>
            </field>
        </record>

        <!-- Form View-->
        <record id="view_psm_db_connection_form" model="ir.ui.view">
            <field name="name">psm.db.connection.form</field>
            <field name="model">psm.db.connection</field>
            <field name="arch" type="xml">
                <form string="Kết nối cơ sở dữ liệu">
                    <header>
                        <button name="action_test_connection" type="object" string="Kiểm tra kết nối"
                                class="btn-primary" icon="fa-plug"/>
                        <button name="action_test_drivers" type="object" string="Kiểm tra Driver"
                                class="btn-info" icon="fa-info-circle" invisible="db_type != 'mssql'"/>
                        <button name="action_get_metadata" type="object" string="Lấy metadata"
                                class="btn-secondary" icon="fa-database"/>
                        <field name="active" widget="boolean_button"
                               options="{'terminology': {'string_true': 'Đang hoạt động', 'string_false': 'Ngừng hoạt động'}}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_mappings" type="object" class="oe_stat_button" icon="fa-sitemap">
                                <field name="mapping_model_count" widget="statinfo" string="Ánh xạ"/>
                            </button>
                        </div>

                        <widget name="web_ribbon" title="Ngừng hoạt động" bg_color="bg-danger"
                                invisible="active == True"/>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Tên kết nối..."/>
                            </h1>
                        </div>

                        <group name="connection_info" string="Thông tin kết nối">
                            <group>
                                <field name="db_type"/>
                                <field name="host"/>
                                <field name="port"/>
                            </group>
                            <group>
                                <field name="database"/>
                                <field name="username"/>
                                <field name="password" password="True"/>
                            </group>

                        </group>
                        <group name="ssl_config" string="Cấu hình SSL" invisible="db_type == 'mssql'">
                            <group>
                                <field name="use_ssl"/>
                                <field name="ssl_ca" filename="ssl_ca_filename" invisible="use_ssl == False"/>
                            </group>
                            <group>
                                <field name="ssl_cert" filename="ssl_cert_filename" invisible="use_ssl == False"/>
                                <field name="ssl_key" filename="ssl_key_filename" invisible="use_ssl == False"/>
                            </group>
                        </group>

                        <!-- MSSQL Specific Configuration -->
                        <group string="Cấu hình MSSQL" invisible="db_type != 'mssql'">
                            <group name="mssql_driver" string="Driver và Kết nối">
                                <field name="mssql_connection_type"/>
                                <field name="mssql_odbc_driver" invisible="mssql_connection_type != 'pyodbc'"/>
                                <field name="mssql_instance" placeholder="SQLEXPRESS, MSSQLSERVER"/>
                            </group>
                            <group name="mssql_security" string="Bảo mật">
                                <field name="mssql_trust_certificate"/>
                                <field name="mssql_encrypt_connection"/>
                            </group>
                        </group>

                        <!-- Connection Help for MSSQL -->
                        <div class="alert alert-info" role="alert" invisible="db_type != 'mssql'">
                            <h5>
                                <i class="fa fa-info-circle" title="Thông tin"></i>
                                Hướng dẫn kết nối MSSQL
                            </h5>
                            <p>
                                <strong>pyodbc (ODBC):</strong>
                                Sử dụng ODBC driver, ổn định và được Microsoft hỗ trợ chính thức.
                            </p>
                            <p>
                                <strong>pymssql:</strong>
                                Driver native Python, nhẹ hơn nhưng có thể có hạn chế với một số tính năng.
                            </p>
                            <br/>
                            <p>
                                <strong>Instance:</strong>
                                Nếu SQL Server sử dụng named instance (vd: SQLEXPRESS), nhập tên instance.
                            </p>
                            <p>
                                <strong>Trust Certificate:</strong>
                                Bật nếu sử dụng self-signed certificate hoặc muốn bỏ qua xác thực SSL.
                            </p>
                        </div>

                        <group>
                            <group name="advanced_options" string="Tùy chọn nâng cao">
                                <field name="connection_timeout"/>
                                <field name="additional_params" placeholder='{"charset": "utf8", "autocommit": true}'/>
                            </group>
                            <group name="assignment" string="Phân công">
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </group>
                        </group>

                        <group name="statistics" string="Thống kê" invisible="id == False">
                            <group>
                                <field name="last_connection"/>
                                <field name="connection_count"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Ánh xạ mô hình" name="mappings">
                                <field name="mapping_model_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="source_table"/>
                                        <field name="target_model_id"/>
                                        <field name="field_mapping_count"/>
                                        <field name="last_sync_date"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Test Connection" name="test_connection" invisible="db_type != 'mssql'">
                                <div class="row">
                                    <div class="col-12">
                                        <h4>Kiểm tra kết nối MSSQL</h4>
                                        <p>Sử dụng các nút bên dưới để kiểm tra kết nối và driver:</p>

                                        <div class="btn-group mb-3" role="group">
                                            <button name="action_test_connection" type="object"
                                                    string="Test Kết nối" class="btn btn-primary"/>
                                            <button name="action_test_drivers" type="object"
                                                    string="Kiểm tra Driver" class="btn btn-info"/>
                                        </div>

                                        <div class="alert alert-warning" role="alert">
                                            <h6>
                                                <i class="fa fa-exclamation-triangle" title="Cảnh báo"></i>
                                                Lưu ý khi kết nối MSSQL:
                                            </h6>
                                            <ul class="mb-0">
                                                <li>
                                                    <strong>ODBC Driver 18:</strong>
                                                    Mặc định yêu cầu mã hóa và xác thực chứng chỉ
                                                </li>
                                                <li>
                                                    <strong>TrustServerCertificate=yes:</strong>
                                                    Cần thiết nếu SQL Server dùng self-signed certificate
                                                </li>
                                                <li>
                                                    <strong>Named Instance:</strong>
                                                    Nhập tên instance nếu không phải default instance
                                                </li>
                                                <li>
                                                    <strong>Firewall:</strong>
                                                    Đảm bảo port SQL Server không bị chặn
                                                </li>
                                            </ul>
                                        </div>

                                        <h5>Chuỗi kết nối mẫu:</h5>
                                        <div class="card">
                                            <div class="card-body">
                                                <h6>ODBC (pyodbc):</h6>
                                                <code>
                                                    DRIVER={ODBC Driver 18 for SQL
                                                    Server};SERVER=localhost,1433;DATABASE=mydb;UID=sa;PWD=password;TrustServerCertificate=yes;
                                                </code>

                                                <h6 class="mt-3">Native (pymssql):</h6>
                                                <code>
                                                    mssql+pymssql://sa:password@localhost:1433/mydb
                                                </code>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_psm_db_connection_search" model="ir.ui.view">
            <field name="name">psm.db.connection.search</field>
            <field name="model">psm.db.connection</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm kết nối">
                    <field name="name" string="Tên kết nối"/>
                    <field name="host"/>
                    <field name="database"/>
                    <field name="user_id"/>
                    <filter string="Đang hoạt động" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Ngừng hoạt động" name="inactive" domain="[('active', '=', False)]"/>
                    <filter string="MySQL" name="mysql" domain="[('db_type', '=', 'mysql')]"/>
                    <filter string="PostgreSQL" name="postgresql" domain="[('db_type', '=', 'postgresql')]"/>
                    <filter string="MS SQL Server" name="mssql" domain="[('db_type', '=', 'mssql')]"/>
                    <filter string="Oracle" name="oracle" domain="[('db_type', '=', 'oracle')]"/>
                    <filter string="MariaDB" name="mariadb" domain="[('db_type', '=', 'mariadb')]"/>
                    <filter string="ODBC Connection" name="odbc" domain="[('mssql_connection_type', '=', 'pyodbc')]"/>
                    <filter string="Native Connection" name="native"
                            domain="[('mssql_connection_type', '=', 'pymssql')]"/>
                    <filter string="Kết nối của tôi" name="my_connections" domain="[('user_id', '=', uid)]"/>
                    <group>
                        <filter string="Loại CSDL" name="group_db_type" context="{'group_by': 'db_type'}"/>
                        <filter string="Kiểu kết nối MSSQL" name="group_mssql_type"
                                context="{'group_by': 'mssql_connection_type'}"/>
                        <filter string="Người phụ trách" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Công ty" name="group_company" context="{'group_by': 'company_id'}"
                                groups="base.group_multi_company"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_psm_db_connection_kanban" model="ir.ui.view">
            <field name="name">psm.db.connection.kanban</field>
            <field name="model">psm.db.connection</field>
            <field name="arch" type="xml">
                <kanban string="Kết nối cơ sở dữ liệu">
                    <field name="name"/>
                    <field name="db_type"/>
                    <field name="host"/>
                    <field name="database"/>
                    <field name="active"/>
                    <field name="mapping_model_count"/>
                    <field name="last_connection"/>
                    <field name="user_id"/>
                    <field name="mssql_connection_type"/>
                    <field name="mssql_odbc_driver"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <t t-if="record.db_type.raw_value == 'mysql'">
                                        <i class="fa fa-database text-primary" title="MySQL" style="font-size: 2em;"/>
                                    </t>
                                    <t t-elif="record.db_type.raw_value == 'postgresql'">
                                        <i class="fa fa-database text-info" title="PostgreSQL" style="font-size: 2em;"/>
                                    </t>
                                    <t t-elif="record.db_type.raw_value == 'mssql'">
                                        <i class="fa fa-database text-warning" title="MSSQL" style="font-size: 2em;"/>
                                    </t>
                                    <t t-elif="record.db_type.raw_value == 'oracle'">
                                        <i class="fa fa-database text-danger" title="Oracle" style="font-size: 2em;"/>
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-database text-muted" title="Không xác định"
                                           style="font-size: 2em;"/>
                                    </t>
                                </div>
                                <div class="o_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <span class="badge badge-pill badge-info">
                                            <field name="db_type"/>
                                        </span>
                                        <span class="badge badge-pill badge-secondary" t-if="!record.active.raw_value">
                                            Ngừng hoạt động
                                        </span>
                                        <span class="badge badge-pill badge-success"
                                              t-if="record.db_type.raw_value == 'mssql' and record.mssql_connection_type.raw_value == 'pymssql'">
                                            Native
                                        </span>
                                        <span class="badge badge-pill badge-primary"
                                              t-if="record.db_type.raw_value == 'mssql' and record.mssql_connection_type.raw_value == 'pyodbc'">
                                            ODBC
                                        </span>
                                    </div>
                                    <ul>
                                        <li>
                                            <strong>Host:</strong>
                                            <field name="host"/>:
                                            <field name="port"/>
                                        </li>
                                        <li>
                                            <strong>Database:</strong>
                                            <field name="database"/>
                                        </li>
                                        <li t-if="record.db_type.raw_value == 'mssql'">
                                            <strong>Driver:</strong>
                                            <span t-if="record.mssql_connection_type.raw_value == 'pyodbc'">
                                                <field name="mssql_odbc_driver"/>
                                            </span>
                                            <span t-if="record.mssql_connection_type.raw_value == 'pymssql'">
                                                pymssql
                                            </span>
                                        </li>
                                        <li>
                                            <strong>Ánh xạ:</strong>
                                            <field name="mapping_model_count"/>
                                            mô hình
                                        </li>
                                    </ul>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <div class="o_kanban_record_subtitle">
                                            Kết nối cuối:
                                            <field name="last_connection"/>
                                        </div>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>