<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Manual Sync Wizard Form -->
        <record id="view_psm_db_wizard_form" model="ir.ui.view">
            <field name="name">psm.db.wizard.form</field>
            <field name="model">psm.db.wizard</field>
            <field name="arch" type="xml">
                <form string="Đồng bộ thủ công">
                    <field name="state" invisible="1"/>
                    <sheet>
                        <div invisible="state != 'config'">
                            <div class="oe_title">
                                <h1>
                                    <span>Đồng bộ thủ công</span>
                                </h1>
                                <p>Cấu hình và thực hiện đồng bộ dữ liệu từ cơ sở dữ liệu ngoài</p>
                            </div>

                            <group>
                                <group string="Cấu hình cơ bản">
                                    <field name="mapping_model_id" required="1"/>
                                    <field name="sync_type"/>
                                    <field name="sync_action"/>
                                </group>
                                <group string="Tùy chọn nâng cao">
                                    <field name="batch_size"/>
                                    <field name="use_queue"/>
                                </group>
                            </group>
                            <group string="Đồng bộ tăng dần" invisible="sync_type != 'incremental'">
                                <group>
                                    <field name="incremental_field" required="sync_type == 'incremental'"
                                           placeholder="vd: last_update, modified_date, updated_at"/>
                                    <field name="last_sync_value"/>
                                </group>
                                <group>
                                    <div class="alert alert-info" role="alert" colspan="2">
                                        <strong>Đồng bộ tăng dần:</strong>
                                        <br/>
                                        • Chỉ đồng bộ bản ghi có giá trị trường tăng dần lớn hơn giá trị cuối
                                        <br/>
                                        • Nhanh hơn nhưng cần trường timestamp trong DB nguồn
                                        <br/>
                                        • Để trống "Giá trị cuối" để đồng bộ tất cả lần đầu
                                    </div>
                                </group>
                            </group>
                            <group string="Điều kiện lọc">
                                <field name="filter_where_clause"
                                       placeholder="Ví dụ: updated_date >= '2024-01-01' AND status = 'active'"/>
                            </group>
                        </div>

                        <div invisible="state != 'result'">
                            <div class="oe_title">
                                <h1>
                                    <span>Kết quả đồng bộ</span>
                                </h1>
                            </div>

                            <div class="alert alert-info" role="alert">
                                <field name="result_message"/>
                            </div>

                            <group string="Thống kê" invisible="sync_log_id == False">
                                <group>
                                    <field name="records_created" readonly="1"/>
                                    <field name="records_updated" readonly="1"/>
                                </group>
                                <group>
                                    <field name="records_failed" readonly="1"/>
                                    <field name="sync_log_id" readonly="1"/>
                                </group>
                            </group>
                        </div>
                    </sheet>
                    <footer>
                        <div invisible="state != 'config'">
                            <button name="action_sync" type="object" string="Bắt đầu đồng bộ" class="btn-primary"/>
                            <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                        </div>
                        <div invisible="state != 'result'">
                            <button name="action_view_log" type="object" string="Xem chi tiết" class="btn-primary"
                                    invisible="sync_log_id == False"/>
                            <button name="action_view_mapped_records" type="object" string="Xem bản ghi"
                                    class="btn-secondary" invisible="sync_log_id == False"/>
                            <button string="Đóng" class="btn-secondary" special="cancel"/>
                        </div>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Test Transformation Wizard -->
        <record id="view_psm_db_test_transformation_wizard_form" model="ir.ui.view">
            <field name="name">psm.db.test.transformation.wizard.form</field>
            <field name="model">psm.db.test.transformation.wizard</field>
            <field name="arch" type="xml">
                <form string="Kiểm tra chuyển đổi">
                    <sheet>
                        <div class="oe_title">
                            <h1>Kiểm tra chuyển đổi trường</h1>
                            <p>Nhập giá trị mẫu để kiểm tra cách chuyển đổi hoạt động</p>
                        </div>

                        <group>
                            <field name="field_mapping_id" readonly="1"/>
                        </group>

                        <group string="Kiểm tra">
                            <field name="test_input" placeholder="Nhập giá trị để kiểm tra..."/>
                            <field name="test_output" readonly="1" invisible="test_output == False"/>
                            <field name="test_error" readonly="1" invisible="test_error == False"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_test" type="object" string="Kiểm tra" class="btn-primary"/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Metadata Wizard -->
        <record id="view_psm_db_metadata_wizard_form" model="ir.ui.view">
            <field name="name">psm.db.metadata.wizard.form</field>
            <field name="model">psm.db.metadata.wizard</field>
            <field name="arch" type="xml">
                <form string="Thông tin Metadata">
                    <sheet>
                        <div class="oe_title">
                            <h1>Thông tin cấu trúc cơ sở dữ liệu</h1>
                        </div>

                        <group>
                            <field name="connection_id" readonly="1"/>
                        </group>

                        <field name="formatted_metadata" readonly="1" nolabel="1"/>
                        <field name="metadata" invisible="1"/>
                    </sheet>
                    <footer>
                        <button name="action_create_mapping" type="object" string="Tạo ánh xạ" class="btn-primary"/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>