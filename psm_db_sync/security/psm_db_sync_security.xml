<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Database Sync Categories -->
        <record id="module_category_psm_db_sync" model="ir.module.category">
            <field name="name">Database Sync</field>
            <field name="description">Module quản lý đồng bộ cơ sở dữ liệu</field>
            <field name="sequence">20</field>
        </record>

        <!-- Database Sync Groups -->
        <record id="group_psm_db_sync_user" model="res.groups">
            <field name="name">DB Sync: User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Người dùng có thể xem và sử dụng chức năng đồng bộ cơ bản</field>
        </record>

        <record id="group_psm_db_sync_manager" model="res.groups">
            <field name="name">DB Sync: Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_psm_db_sync_user'))]"/>
            <field name="comment">Quản lý có thể tạo và chỉnh sửa cấu hình đồng bộ</field>
        </record>

        <record id="group_psm_db_sync_admin" model="res.groups">
            <field name="name">DB Sync: Administrator</field>
            <field name="implied_ids" eval="[(4, ref('group_psm_db_sync_manager'))]"/>
            <field name="comment">Quản trị viên có toàn quyền truy cập module đồng bộ</field>
        </record>

        <!-- Record Rules -->

        <!-- DB Connection Rules -->
        <record id="rule_psm_db_connection_user" model="ir.rule">
            <field name="name">PSM DB Connection: User Access</field>
            <field name="model_id" ref="model_psm_db_connection"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_psm_db_sync_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

