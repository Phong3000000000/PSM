<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sample Database Connection -->
        <record id="demo_connection_mysql" model="psm.db.connection">
            <field name="name">Demo MySQL Connection</field>
            <field name="db_type">mysql</field>
            <field name="host">localhost</field>
            <field name="port">3306</field>
            <field name="database">demo_db</field>
            <field name="username">demo_user</field>
            <field name="password">demo_password</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <!-- Default Data Type Mappings -->
        <record id="data_type_mapping_config" model="ir.config_parameter">
            <field name="key">psm_db_sync.data_type_mappings</field>
            <field name="value">{
                "mysql": {
                    "INT": "integer",
                    "TINYINT": "boolean",
                    "SMALLINT": "integer",
                    "MEDIUMINT": "integer",
                    "BIGINT": "integer",
                    "FLOAT": "float",
                    "DOUBLE": "float",
                    "DECIMAL": "float",
                    "CHAR": "char",
                    "VARCHAR": "char",
                    "TEXT": "text",
                    "DATE": "date",
                    "DATETIME": "datetime",
                    "TIMESTAMP": "datetime",
                    "JSON": "json"
                },
                "postgresql": {
                    "integer": "integer",
                    "smallint": "integer",
                    "bigint": "integer",
                    "real": "float",
                    "double precision": "float",
                    "numeric": "float",
                    "text": "text",
                    "character varying": "char",
                    "date": "date",
                    "timestamp": "datetime",
                    "boolean": "boolean",
                    "json": "json",
                    "jsonb": "json"
                }
            }</field>
        </record>

        <!-- Default Sync Configurations -->
        <record id="sync_config_default_batch_size" model="ir.config_parameter">
            <field name="key">psm_db_sync.default_batch_size</field>
            <field name="value">100</field>
        </record>

        <record id="sync_config_default_timeout" model="ir.config_parameter">
            <field name="key">psm_db_sync.default_timeout</field>
            <field name="value">300</field>
        </record>

        <record id="sync_config_max_retries" model="ir.config_parameter">
            <field name="key">psm_db_sync.max_retries</field>
            <field name="value">3</field>
        </record>

        <!-- AI Suggestions Configuration -->
        <record id="ai_field_mapping_rules" model="ir.config_parameter">
            <field name="key">psm_db_sync.ai_field_mapping_rules</field>
            <field name="value">{
                "name_patterns": {
                    "id": ["id", "ID", "Id"],
                    "name": ["name", "title", "label", "display_name"],
                    "description": ["description", "desc", "note", "comment"],
                    "email": ["email", "e_mail", "email_address"],
                    "phone": ["phone", "telephone", "mobile", "cell"],
                    "date_created": ["created_date", "create_date", "date_created"],
                    "date_updated": ["updated_date", "update_date", "date_updated", "modified_date"],
                    "active": ["active", "is_active", "enabled", "status"]
                },
                "type_mappings": {
                    "many2one": ["_id", "_ref", "_fk"],
                    "date": ["date_", "_date"],
                    "datetime": ["datetime_", "_datetime", "timestamp"],
                    "boolean": ["is_", "has_", "_flag", "_bool"],
                    "float": ["amount", "price", "cost", "total", "subtotal"],
                    "integer": ["count", "qty", "quantity", "number"]
                }
            }</field>
        </record>

        <!-- Queue Job Configuration -->
        <record id="queue_job_channel_db_sync" model="queue.job.channel">
            <field name="name">db_sync</field>
            <field name="parent_id" ref="queue_job.channel_root"/>
        </record>

        <!-- Demo Mapping Model (for development) -->
        <record id="demo_mapping_partners" model="psm.db.mapping.model">
            <field name="name">Demo Partner Mapping</field>
            <field name="connection_id" ref="demo_connection_mysql"/>
            <field name="source_type">table</field>
            <field name="source_table">customers</field>
            <field name="target_model_id" ref="base.model_res_partner"/>
            <field name="source_key_field">id</field>
            <field name="target_key_field">id</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <!-- Demo Field Mappings -->
        <record id="demo_field_mapping_id" model="psm.db.mapping.field">
            <field name="mapping_model_id" ref="demo_mapping_partners"/>
            <field name="source_field">id</field>
            <field name="target_field">id</field>
            <field name="transformation_type">direct</field>
            <field name="is_key_field">True</field>
            <field name="sequence">1</field>
        </record>

        <record id="demo_field_mapping_name" model="psm.db.mapping.field">
            <field name="mapping_model_id" ref="demo_mapping_partners"/>
            <field name="source_field">customer_name</field>
            <field name="target_field">name</field>
            <field name="transformation_type">direct</field>
            <field name="sequence">2</field>
        </record>

        <record id="demo_field_mapping_email" model="psm.db.mapping.field">
            <field name="mapping_model_id" ref="demo_mapping_partners"/>
            <field name="source_field">email_address</field>
            <field name="target_field">email</field>
            <field name="transformation_type">direct</field>
            <field name="sequence">3</field>
        </record>

        <!-- Demo Sync Task -->
        <record id="demo_sync_task" model="psm.db.sync">
            <field name="name">Demo Partner Sync</field>
            <field name="mapping_model_id" ref="demo_mapping_partners"/>
            <field name="sync_type">full</field>
            <field name="sync_action">create_update</field>
            <field name="execution_type">manual</field>
            <field name="batch_size">50</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>

    </data>
</odoo>