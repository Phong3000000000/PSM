<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend hr.job form to add recruitment_type fields -->
    <record id="view_hr_job_form_inherit" model="ir.ui.view">
        <field name="name">hr.job.form.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="after">
                <group>
                    <field name="recruitment_type" widget="radio" options="{'horizontal': true}"/>
                    <field name="position_level" widget="radio" options="{'horizontal': true}"/>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Cấu Hình Interview/OJE" name="interview_oje_config">
                    <separator string="Biểu mẫu ứng tuyển (Website)"/>
                    <div class="x_psm_job_config_page">
                        <div class="x_psm_job_config_grid row g-3 align-items-stretch">
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-2">1. Chọn Survey</div>
                                    <label for="survey_id" string="Application Survey"/>
                                    <field name="survey_id"
                                         domain="[('x_psm_survey_usage', '=', 'pre_interview'), ('x_psm_0204_is_runtime_isolated_copy', '=', False), '|', '&amp;', ('x_psm_0204_owner_job_id', '=', False), ('x_psm_0204_owner_department_id', '=', False), '&amp;', ('x_psm_0204_owner_job_id', '=', id), ('x_psm_0204_owner_department_id', '=', department_id)]"/>
                                </div>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-2">2. Mặc định</div>
                                    <div class="d-grid gap-2 x_psm_btn_stack">
                                        <button name="action_load_default_pre_interview_template"
                                                type="object"
                                                string="Tải survey mặc định"
                                                class="btn-secondary"
                                                icon="fa-refresh"/>
                                        <div class="text-muted">&#160;</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-2">3. Survey custom</div>
                                    <div class="d-grid gap-2 x_psm_btn_stack">
                                        <button name="action_create_custom_pre_interview_survey"
                                                type="object"
                                                string="Tạo survey custom"
                                                class="btn-primary"
                                                icon="fa-copy"/>
                                        <button name="action_open_pre_interview_survey_dialog"
                                                type="object"
                                                string="Mở survey"
                                                class="btn-secondary"
                                                icon="fa-pencil-square-o"
                                                invisible="not survey_id"/>
                                        <button name="action_replace_custom_pre_interview_survey"
                                                type="object"
                                                string="Thay survey custom"
                                                class="btn-secondary"
                                                icon="fa-refresh"
                                            invisible="not survey_id or survey_id.x_psm_0204_owner_job_id != id or survey_id.x_psm_0204_owner_department_id != department_id"
                                                confirm="Survey custom hiện tại sẽ được lưu trữ (archive) và tạo mới từ survey mặc định/chung. Bạn có chắc chắn?"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div invisible="recruitment_type != 'store' or position_level != 'management'">
                            <separator string="Interview (Store Management)"/>
                            <div class="x_psm_job_config_grid row g-3 align-items-stretch">
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">1. Survey đang gắn</div>
                                        <label for="x_psm_interview_survey_id" string="Survey Interview"/>
                                        <field name="x_psm_interview_survey_id"/>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">2. Mặc định / preview</div>
                                        <div class="d-grid gap-2 x_psm_btn_stack">
                                            <button name="action_load_default_interview_template"
                                                    type="object"
                                                    string="Tải survey mặc định"
                                                    class="btn-secondary"
                                                    icon="fa-refresh"/>
                                            <button name="action_preview_interview_form"
                                                    type="object"
                                                    string="Preview Interview"
                                                    class="btn-secondary"
                                                    icon="fa-eye"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">3. Tạo survey custom</div>
                                        <div class="d-grid gap-2 x_psm_btn_stack">
                                            <button name="action_create_custom_interview_survey"
                                                    type="object"
                                                    string="Tạo survey custom"
                                                    class="btn-primary"
                                                    icon="fa-copy"/>
                                            <button name="action_open_interview_survey_dialog"
                                                    type="object"
                                                    string="Mở survey"
                                                    class="btn-secondary"
                                                    icon="fa-pencil-square-o"
                                                    invisible="not x_psm_interview_survey_id"/>
                                            <button name="action_replace_custom_interview_survey"
                                                    type="object"
                                                    string="Thay survey custom"
                                                    class="btn-secondary"
                                                    icon="fa-refresh"
                                                    invisible="not x_psm_interview_survey_id or x_psm_interview_survey_id.x_psm_0204_owner_job_id != id or x_psm_interview_survey_id.x_psm_0204_owner_department_id != department_id"
                                                    confirm="Survey Interview custom hiện tại sẽ được lưu trữ (archive) và tạo mới từ survey mặc định/chung. Bạn có chắc chắn?"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div invisible="recruitment_type != 'store'">
                            <separator string="OJE (Store - tách Staff/Management)"/>
                            <div class="x_psm_job_config_grid row g-3 align-items-stretch">
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">1. Survey đang gắn</div>
                                        <label for="x_psm_oje_survey_id" string="Survey OJE"/>
                                        <field name="x_psm_oje_survey_id"/>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">2. Mặc định / preview</div>
                                        <div class="d-grid gap-2 x_psm_btn_stack">
                                            <button name="action_load_default_oje_template"
                                                    type="object"
                                                    string="Tải survey mặc định"
                                                    class="btn-secondary"
                                                    icon="fa-refresh"/>
                                            <button name="action_preview_oje_form"
                                                    type="object"
                                                    string="Preview OJE"
                                                    class="btn-secondary"
                                                    icon="fa-eye"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="x_psm_job_config_box border rounded p-3 h-100">
                                        <div class="fw-bold mb-2">3. Tạo survey custom</div>
                                        <div class="d-grid gap-2 x_psm_btn_stack">
                                            <button name="action_create_custom_oje_survey"
                                                    type="object"
                                                    string="Tạo survey custom"
                                                    class="btn-primary"
                                                    icon="fa-copy"/>
                                            <button name="action_open_oje_survey_dialog"
                                                    type="object"
                                                    string="Mở survey"
                                                    class="btn-secondary"
                                                    icon="fa-pencil-square-o"
                                                    invisible="not x_psm_oje_survey_id"/>
                                            <button name="action_replace_custom_oje_survey"
                                                    type="object"
                                                    string="Thay survey custom"
                                                    class="btn-secondary"
                                                    icon="fa-refresh"
                                                    invisible="not x_psm_oje_survey_id or x_psm_oje_survey_id.x_psm_0204_owner_job_id != id or x_psm_oje_survey_id.x_psm_0204_owner_department_id != department_id"
                                                    confirm="Survey OJE custom hiện tại sẽ được lưu trữ (archive) và tạo mới từ survey mặc định/chung. Bạn có chắc chắn?"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </page>

                <page string="Cấu Hình Từ Chối" name="refuse_reasons">
                    <group>
                        <button name="action_load_default_refuse_reasons" 
                                type="object" 
                                string="Tải lý do mặc định" 
                                class="btn-secondary" 
                                icon="fa-refresh"
                                confirm="Hệ thống sẽ tải danh sách lý do từ chối mặc định. Bạn có chắc chắn?"/>
                    </group>
                    <field name="job_refuse_reason_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name" string="Tiêu đề (Lý do)"/>
                            <field name="reason_type"/>
                            <field name="template_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Override the Applications smart button to call action_open_applicants (object method)
         so the kanban view receives default_stage_filter_type, default_position_level in context.
         
         Parent: hr_recruitment.hr_job_survey (the view that owns button_box + all_application_count button) -->
    <record id="view_hr_job_form_inherit_applications_button" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.applications.button.custom</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.hr_job_survey"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']/button[@name='%(hr_recruitment.action_hr_job_applications)d']" position="replace">
                <button class="oe_stat_button"
                    groups="M02_P0200.GDH_RST_HR_RECRUITMENT_M"
                    icon="fa-pencil"
                    name="action_open_applicants"
                    type="object">
                    <field name="all_application_count" widget="statinfo" string="Applications"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Thêm search filter "Ẩn OdooBot" vào danh sách Job Positions -->
    <record id="view_hr_job_search_inherit" model="ir.ui.view">
        <field name="name">hr.job.search.inherit.no.bot</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_job_filter"/>
        <field name="arch" type="xml">
            <search position="inside">
                <separator/>
                <filter name="hide_odoobot"
                        string="Ẩn OdooBot"
                        domain="[('create_uid', '!=', 1)]"/>
                <filter name="my_jobs"
                        string="Do tôi tạo"
                        domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter name="filter_recruitment_store"
                    string="Khối Cửa Hàng"
                    domain="[('recruitment_type', '=', 'store')]"/>
                <filter name="filter_recruitment_office"
                    string="Khối Văn Phòng"
                    domain="[('recruitment_type', '=', 'office')]"/>
                <filter name="filter_position_staff"
                    string="Nhân Viên"
                    domain="[('position_level', '=', 'staff')]"/>
                <filter name="filter_position_management"
                    string="Quản Lý"
                    domain="[('position_level', '=', 'management')]"/>
                <separator/>
                <filter name="groupby_recruitment_type"
                    string="Nhóm theo Loại tuyển dụng"
                    context="{'group_by': 'recruitment_type'}"/>
                <filter name="groupby_position_level"
                    string="Nhóm theo Cấp bậc"
                    context="{'group_by': 'position_level'}"/>
            </search>
        </field>
    </record>

</odoo>
