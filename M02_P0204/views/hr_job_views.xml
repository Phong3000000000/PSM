<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend hr.job form to add recruitment_type fields -->
    <record id="view_hr_job_form_inherit" model="ir.ui.view">
        <field name="name">hr.job.form.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="after">
                <group>
                    <!-- Readonly: Recruitment Type and Level are set by system, not manually -->
                    <field name="recruitment_type" widget="radio" options="{'horizontal': true}" readonly="1"/>
                    <field name="position_level" widget="radio" options="{'horizontal': true}" readonly="1"/>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Interview/OJE Configuration" name="interview_oje_config">

                    <!-- ===== SECTION 1: Application Form ===== -->
                    <separator string="Application Form"/>
                    <div class="x_psm_job_config_page">
                        <div class="row g-3">
                            <!-- Survey Actions -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Survey Actions</div>
                                    <div class="d-grid gap-2 x_psm_btn_stack">
                                        <button name="action_load_default_pre_interview_template"
                                                type="object"
                                                string="Load Default"
                                                class="btn-secondary"
                                                icon="fa-refresh"
                                                confirm="This will overwrite the current custom survey content with the master template. Continue?"/>
                                        <button name="action_open_pre_interview_survey_dialog"
                                                type="object"
                                                string="Open Survey"
                                                class="btn-secondary"
                                                icon="fa-pencil-square-o"
                                                invisible="not survey_id"/>
                                    </div>
                                </div>
                            </div>
                            <!-- Current Survey -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Current Survey</div>
                                    <label for="survey_id" string="Application Survey"/>
                                    <field name="survey_id" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== SECTION 2: Interview Survey (Store Management) ===== -->
                    <div invisible="recruitment_type != 'store' or position_level != 'management'">
                        <separator string="Interview Survey"/>
                        <div class="row g-3">
                            <!-- Survey Actions -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Survey Actions</div>
                                    <div class="d-grid gap-2 x_psm_btn_stack">
                                        <button name="action_load_default_interview_template"
                                                type="object"
                                                string="Load Default"
                                                class="btn-secondary"
                                                icon="fa-refresh"
                                                confirm="This will overwrite the current Interview custom survey with the master template. Continue?"/>
                                        <button name="action_preview_interview_form"
                                                type="object"
                                                string="Preview Interview"
                                                class="btn-secondary"
                                                icon="fa-eye"/>
                                        <button name="action_open_interview_survey_dialog"
                                                type="object"
                                                string="Open Survey"
                                                class="btn-secondary"
                                                icon="fa-pencil-square-o"
                                                invisible="not x_psm_interview_survey_id"/>
                                    </div>
                                </div>
                            </div>
                            <!-- Current Survey -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Current Survey</div>
                                    <label for="x_psm_interview_survey_id" string="Interview Survey"/>
                                    <field name="x_psm_interview_survey_id" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== SECTION 3: OJE Survey (Store - Staff/Management) ===== -->
                    <div invisible="recruitment_type != 'store'">
                        <separator string="OJE (Store - Staff/Management)"/>
                        <div class="row g-3">
                            <!-- Survey Actions -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Survey Actions</div>
                                    <div class="d-grid gap-2 x_psm_btn_stack">
                                        <button name="action_load_default_oje_template"
                                                type="object"
                                                string="Load Default"
                                                class="btn-secondary"
                                                icon="fa-refresh"
                                                confirm="This will overwrite the current OJE custom survey with the master template. Continue?"/>
                                        <button name="action_preview_oje_form"
                                                type="object"
                                                string="Preview OJE"
                                                class="btn-secondary"
                                                icon="fa-eye"/>
                                        <button name="action_open_oje_survey_dialog"
                                                type="object"
                                                string="Open Survey"
                                                class="btn-secondary"
                                                icon="fa-pencil-square-o"
                                                invisible="not x_psm_oje_survey_id"/>
                                    </div>
                                </div>
                            </div>
                            <!-- Current Survey -->
                            <div class="col-12 col-md-6">
                                <div class="x_psm_job_config_box border rounded p-3 h-100">
                                    <div class="fw-bold mb-3">Current Survey</div>
                                    <label for="x_psm_oje_survey_id" string="OJE Survey"/>
                                    <field name="x_psm_oje_survey_id" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                </page>

            </xpath>
        </field>
    </record>

    <!-- Override the Applications smart button to call action_open_applicants (object method)
         so the kanban view receives default_stage_filter_type, default_position_level in context.
         
         Parent: hr_recruitment.hr_job_survey (the view that owns button_box + all_application_count button) -->
    <record id="view_hr_job_form_inherit_applications_button" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.applications.button.custom</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.hr_job_survey"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']/button[@name='%(hr_recruitment.action_hr_job_applications)d']" position="replace">
                <button class="oe_stat_button"
                    groups="M02_P0200.GDH_RST_HR_RECRUITMENT_M"
                    icon="fa-pencil"
                    name="action_open_applicants"
                    type="object">
                    <field name="all_application_count" widget="statinfo" string="Applications"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Search filters for Job Positions -->
    <record id="view_hr_job_search_inherit" model="ir.ui.view">
        <field name="name">hr.job.search.inherit.no.bot</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_job_filter"/>
        <field name="arch" type="xml">
            <search position="inside">
                <separator/>
                <filter name="hide_odoobot"
                        string="Hide OdooBot"
                        domain="[('create_uid', '!=', 1)]"/>
                <filter name="my_jobs"
                        string="Created by Me"
                        domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter name="filter_recruitment_store"
                    string="Store"
                    domain="[('recruitment_type', '=', 'store')]"/>
                <filter name="filter_recruitment_office"
                    string="Office"
                    domain="[('recruitment_type', '=', 'office')]"/>
                <filter name="filter_position_staff"
                    string="Staff"
                    domain="[('position_level', '=', 'staff')]"/>
                <filter name="filter_position_management"
                    string="Management"
                    domain="[('position_level', '=', 'management')]"/>
                <separator/>
                <filter name="groupby_recruitment_type"
                    string="Group by Recruitment Type"
                    context="{'group_by': 'recruitment_type'}"/>
                <filter name="groupby_position_level"
                    string="Group by Level"
                    context="{'group_by': 'position_level'}"/>
            </search>
        </field>
    </record>

</odoo>
