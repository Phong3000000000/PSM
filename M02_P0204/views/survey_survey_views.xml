<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="survey_survey_form_inherit_flags" model="ir.ui.view">
        <field name="name">survey.survey.form.inherit.flags</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_psm_survey_usage"/>
                <field name="x_psm_oje_scope" invisible="x_psm_survey_usage != 'oje'"/>
                <field name="x_psm_0204_owner_job_id" readonly="x_psm_0204_owner_job_id"/>
                <field name="x_psm_0204_owner_department_id" readonly="x_psm_0204_owner_job_id or x_psm_0204_owner_department_id"/>
                <field name="x_psm_0204_default_template_for" string="Master Template For" invisible="x_psm_0204_owner_job_id or x_psm_0204_owner_department_id"/>
            </xpath>
        </field>
    </record>

    <record id="survey_survey_form_inherit_question_flag_columns" model="ir.ui.view">
        <field name="name">survey.survey.form.inherit.question.flag.columns</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='question_and_page_ids']/list" position="attributes">
                <attribute name="decoration-muted">x_psm_0204_is_locked_on_custom_ui</attribute>
            </xpath>

            <xpath expr="//field[@name='question_and_page_ids']/list/field[@name='question_type']" position="after">
                <field name="x_psm_parent_survey_usage" column_invisible="True"/>
                <field name="x_psm_0204_is_custom_job_question" column_invisible="True"/>
                <field name="x_psm_0204_is_locked_on_custom_ui" column_invisible="True"/>
                <field name="is_scored_question" column_invisible="True"/>
                <field name="x_psm_show_on_webform"
                    string="On/Off"
                    widget="boolean_toggle"
                    optional="show"
                    readonly="x_psm_0204_is_locked_on_custom_ui"
                    invisible="is_page or x_psm_parent_survey_usage != 'pre_interview'"/>
                <field name="x_psm_0204_is_mandatory_correct"
                    string="Must Be Correct"
                    widget="boolean_toggle"
                    optional="show"
                    readonly="x_psm_0204_is_locked_on_custom_ui"
                    invisible="is_page or not is_scored_question"/>
                <field name="x_psm_0204_is_reject_when_wrong"
                    string="Reject If Wrong"
                    widget="boolean_toggle"
                    optional="show"
                    readonly="x_psm_0204_is_locked_on_custom_ui"
                    invisible="is_page or not is_scored_question or not x_psm_0204_is_mandatory_correct"/>
                <field name="x_psm_0204_lock_on_custom"
                    string="Lock on Custom"
                    widget="boolean_toggle"
                    optional="show"
                    readonly="x_psm_0204_is_custom_job_question or x_psm_0204_is_locked_on_custom_ui"/>
            </xpath>

            <xpath expr="//field[@name='question_and_page_ids']/list/field[@name='constr_mandatory']" position="attributes">
                <attribute name="string">Required</attribute>
                <attribute name="widget">boolean_toggle</attribute>
                <attribute name="optional">show</attribute>
                <attribute name="readonly">x_psm_0204_is_locked_on_custom_ui</attribute>
                <attribute name="invisible">is_page</attribute>
            </xpath>

            <xpath expr="//field[@name='question_and_page_ids']/list/button[@name='copy']" position="attributes">
                <attribute name="invisible">x_psm_0204_is_locked_on_custom_ui</attribute>
            </xpath>

            <!-- Reorder base constr_mandatory right after Bật/tắt without duplicating field. -->
            <xpath expr="//field[@name='question_and_page_ids']/list/field[@name='x_psm_show_on_webform']" position="after">
                <field name="constr_mandatory" position="move"/>
            </xpath>
        </field>
    </record>
</odoo>
