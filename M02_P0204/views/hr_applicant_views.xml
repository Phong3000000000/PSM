<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_applicant_application_result_popup" model="ir.ui.view">
        <field name="name">hr.applicant.application.result.popup</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <form string="Chi tiết Biểu mẫu ứng tuyển">
                <sheet>
                    <div class="alert alert-success" role="alert" invisible="application_match_result != 'passed'">
                        <i class="fa fa-check-circle me-1"/> Kết quả: Đạt. Ứng viên trả lời đúng các câu bắt buộc phải đúng.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="application_match_result != 'review'">
                        <i class="fa fa-exclamation-circle me-1"/> Kết quả: Cần xem xét. Có câu trả lời sai ở rule Phải đúng.
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="application_match_result != 'reject'">
                        <i class="fa fa-times-circle me-1"/> Kết quả: Reject ngay. Có câu sai ở rule Loại khi sai.
                    </div>

                    <separator string="Chi tiết rà soát biểu mẫu"/>
                    <div class="w-100 x_psm_application_review_block">
                        <field name="application_form_review_payload" invisible="1"/>
                        <field name="application_form_review_html" widget="html" nolabel="1" class="w-100"/>
                    </div>

                    <group string="Phần 2: Khảo sát bổ sung" invisible="not survey_user_input_id">
                        <field name="survey_user_input_id" string="Bài làm Khảo sát" readonly="1" options="{'no_open': False}"/>
                        <field name="survey_state" string="Trạng thái"/>
                        <field name="survey_scoring_success" string="Đạt yêu cầu Khảo sát?"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_open_survey_results" type="object" string="Xem Chi Tiết Khảo Sát (Phần 2)" class="btn-primary" invisible="not survey_user_input_id"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Extend HR Applicant Form -->
    <record id="view_hr_applicant_form_inherit" model="ir.ui.view">
        <field name="name">hr.applicant.form.inherit</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">




            <!-- Add Interview Invitation Button -->
        <xpath expr="//header" position="inside">
        <field name="current_stage_name" invisible="1"/>

        <button name="action_approve_survey_review"
            string="Xem xét"
            type="object"
            class="btn-success"
            groups="M02_P0200.GDH_RST_HR_RECRUITMENT_M"
            invisible="recruitment_type != 'store' or current_stage_name != 'Under Review' or application_match_result != 'review'"/>

        <button name="action_open_backend_interview_evaluation"
            string="Pass Interview"
            type="object"
            class="btn-primary"
            icon="fa-id-card-o"
            invisible="not can_backend_evaluate_interview"/>

        <button name="action_accept_stage"
            string="Chấp nhận"
            type="object"
            class="btn-success"
            icon="fa-check"
            invisible="current_stage_name != 'Offer' or position_level != 'management' or recruitment_type != 'store'"/>
        </xpath>
           

            <xpath expr="//header/button[@name='action_talent_pool_add_applicants']" position="after">
                <button name="action_open_backend_oje_evaluation"
                        string="Pass OJE"
                        type="object"
                        class="btn-primary"
                        icon="fa-clipboard"
                        invisible="not can_backend_evaluate_oje"/>
            </xpath>

            <!-- Add Brand & Survey Fields after job_id -->
            <xpath expr="//field[@name='job_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Chèn nhóm Thông tin Tuyển dụng full width ở dưới header group -->
            <xpath expr="//sheet/group[1]" position="after">
                <group string="Recruitment Information">
                    <group>
                        <field name="department_id" string="Department"
                               domain="[('id', 'in', available_department_ids)]"
                               options="{'no_create': True}"/>
                        <field name="position_level" string="Level"/>
                    </group>
                    <group>
                        <field name="recruitment_type" string="Recruitment Type"/>
                        <field name="job_id" string="Job Position"/>
                        <field name="application_source" invisible="1"/>
                        <field name="date_closed" string="Hired Date" invisible="not date_closed"/>
                        <field name="oje_evaluator_user_id" string="OJE Evaluator" invisible="recruitment_type == 'office'"/>
                    </group>
                    <field name="company_id" invisible="1"/>
                    <field name="available_department_ids" invisible="1"/>
                </group>



                <!-- Nhóm Đánh giá & Phân bổ (Evaluation, Recruiter...) -->
                <!-- MOVED TO THE BOTTOM -->
            </xpath>

            <!-- Thêm Stat Buttons cho Survey và OJE -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <!-- Nút kết quả rà soát Biểu mẫu (Phải đúng) -->
                <button name="action_show_failed_questions"
                        class="oe_stat_button" icon="fa-tasks"
                        type="object" invisible="not application_match_result">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">
                            Biểu mẫu đã làm
                        </span>
                        <span class="o_stat_value">
                            <field name="application_match_result"/>
                        </span>
                    </div>
                </button>
                <button name="action_open_oje_results"
                        class="oe_stat_button" icon="fa-clipboard"
                        type="object" invisible="not oje_evaluation_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text"><field name="oje_display_result"/></span>
                        <span class="o_stat_value"><field name="oje_display_text" readonly="1"/></span>
                    </div>
                </button>
                <button name="action_open_interview_results"
                        class="oe_stat_button" icon="fa-id-card-o"
                        type="object" invisible="not interview_evaluation_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text"><field name="interview_display_result"/></span>
                        <span class="o_stat_value"><field name="interview_display_text" readonly="1"/></span>
                    </div>
                </button>
            </xpath>

            <!-- Move detailed sections to Notebook for full-width display -->
            <xpath expr="//notebook/page[1]" position="before">
                <page string="Personal Information" name="personal_info_page">
                    <group>
                        <group string="Personal Information">
                            <field name="x_portrait_image" widget="image" class="oe_avatar" options="{'size': [90, 90]}"/>
                            <field name="x_birthday"/>
                            <field name="x_gender"/>
                            <field name="x_salutation"/>
                            <field name="x_id_document_type"/>
                            <field name="x_id_number"/>
                            <field name="x_id_issue_date"/>
                            <field name="x_id_issue_place"/>
                            <field name="x_nationality"/>
                            <field name="x_height"/>
                            <field name="x_weight"/>
                            <field name="x_hometown"/>
                            <field name="x_permanent_address"/>
                            <field name="x_current_address"/>
                        </group>
                        <group string="Education &amp; Experience">
                            <field name="x_education_level"/>
                            <field name="x_school_name"/>
                            <field name="x_years_experience"/>
                            <field name="x_current_job"/>
                            <field name="x_last_company"/>
                            <field name="x_weekend_available"/>
                            <field name="x_worked_mcdonalds"/>
                            <field name="x_referral_staff_id"/>
                            <field name="x_application_content"/>
                        </group>
                    </group>
                </page>
                <page string="Interview" name="survey_interview_details" invisible="recruitment_type == 'office'">
                    <group>
                        <group string="Application Form">
                            <field name="pre_interview_survey_id" invisible="1"/>
                            <field name="survey_url" widget="url" readonly="1" string="Form Link" invisible="survey_state == 'done'"/>
                            <field name="survey_result_url" widget="url" readonly="1" string="View Form Result" invisible="survey_state != 'done'"/>
                            <field name="survey_state"
                                   readonly="1"
                                   string="Status"
                                   invisible="not survey_user_input_id"/>

                            <field name="survey_user_input_id" invisible="1"/>
                            <field name="survey_under_review_date" readonly="1"
                                   invisible="current_stage_name != 'Under Review' or not survey_under_review_date"
                                   string="Review Deadline (24h)"/>
                        </group>
                        <group string="Interview Schedule">
                            <field name="interview_schedule_id" 
                                   domain="[('department_id', '=', department_id), ('state', '=', 'confirmed')]"
                                   options="{'no_create': True}"/>
                            <field name="invitation_sent_date" readonly="1" string="Invitation Sent Date"/>
                            <field name="interview_confirmation_state"
                                   readonly="1"
                                   string="Confirmation Status"/>
                            <field name="interview_confirmation_sent_date" readonly="1"
                                   invisible="interview_confirmation_state == 'not_sent'"
                                   string="Email Sent Date"/>
                            <field name="interview_confirmed_datetime" readonly="1"
                                   invisible="interview_confirmation_state != 'accepted'"
                                   string="Confirmed Schedule"/>
                            <field name="interview_booked_slot" readonly="1"
                                   invisible="interview_booking_status != 'booked'"
                                   string="Booked Slot"/>
                            <field name="interview_booking_status"
                                   readonly="1"
                                   string="Booking Status"/>
                        </group>
                    </group>
                </page>
                <page string="Interview Evaluation"
                      name="interview_details"
                      invisible="recruitment_type != 'store' or position_level != 'management'">
                    <field name="can_backend_evaluate_interview" invisible="1"/>

                    <group>
                        <group string="Interview Result">
                            <field name="interview_evaluation_id" readonly="1"/>
                            <field name="interview_evaluation_state"/>
                            <field name="interview_result"/>
                            <field name="interview_final_score"/>
                        </group>
                        <group string="Evaluator">
                            <field name="interview_evaluator_user_id"/>
                            <field name="interview_evaluated_by"/>
                            <field name="interview_evaluated_at"/>
                        </group>
                    </group>

                    <group string="Rejection Reason" invisible="interview_result != 'reject'">
                        <field name="interview_fail_reason" nolabel="1"/>
                    </group>
                </page>
                <page string="OJE Evaluation" name="oje_details" invisible="recruitment_type == 'office'">
                    <button name="action_open_backend_oje_evaluation"
                            string="OJE Evaluation"
                            type="object"
                            class="btn-primary"
                            invisible="not can_backend_evaluate_oje"
                            icon="fa-clipboard"/>
                    <field name="can_backend_evaluate_oje" invisible="1"/>
                    <field name="oje_template_scope" invisible="1"/>
                    <group>
                        <group string="OJE Result">
                            <field name="oje_evaluation_id" readonly="1"/>
                            <field name="oje_evaluation_state"/>
                            <field name="reject_reason" invisible="not reject_reason" readonly="1"/>
                            <field name="oje_result"/>
                        </group>
                        <group string="Evaluator">
                            <field name="oje_evaluated_by"/>
                            <field name="oje_evaluated_at"/>
                        </group>
                    </group>

                    <group string="OJE Summary - Staff" invisible="oje_template_scope != 'store_staff'">
                        <group>
                            <field name="oje_staff_decision"/>
                            <field name="oje_staff_ni_count"/>
                            <field name="oje_staff_gd_count"/>
                            <field name="oje_staff_ex_count"/>
                            <field name="oje_staff_os_count"/>
                        </group>
                        <group>
                            <field name="oje_total_score"/>
                        </group>
                    </group>

                    <group string="OJE Summary - Management" invisible="oje_template_scope != 'store_management'">
                        <group>
                            <field name="oje_management_overall_rating"/>
                        </group>
                        <group>
                            <field name="oje_total_score"/>
                        </group>
                    </group>

                    <group string="Rejection Reason" invisible="oje_result != 'fail'">
                        <field name="oje_fail_reason" nolabel="1"/>
                    </group>
                    <field name="oje_evaluation_id" invisible="1"/>
                    <notebook invisible="not oje_evaluation_id">
                        <page string="Evaluation Details">
                            <field name="oje_evaluation_id" invisible="1"/>
                            <field name="oje_evaluation_id" mode="form" readonly="1">
                                <form>
                                    <field name="line_ids">
                                        <list>
                                            <field name="name"/>
                                            <field name="field_type"/>
                                            <field name="text_value" invisible="field_type != 'text'"/>
                                            <field name="text_score" invisible="field_type != 'text'"/>
                                            <field name="checkbox_value" invisible="field_type != 'checkbox'"/>
                                            <field name="checkbox_score" invisible="field_type != 'checkbox'"/>
                                            <field name="selected_option_id" invisible="field_type != 'radio'"/>
                                            <field name="selected_option_score" invisible="field_type != 'radio'"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </page>
            </xpath>

            <xpath expr="//page[@name='oje_details']/button[@name='action_open_backend_oje_evaluation']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


            
            <!-- Filter stage_id dropdown and status bar -->
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="domain">['|', ('job_ids', '=', False), ('job_ids', '=', job_id), ('recruitment_type', '=', stage_filter_type), '|', ('office_pipeline_visible', '=', True), ('recruitment_type', '!=', 'office')]</attribute>
                <attribute name="options">{'clickable': '0', 'fold_field': 'fold'}</attribute>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="before">
                <field name="stage_filter_type" invisible="1"/>
            </xpath>

            <!-- Add Next Stage Button -->
            <!-- <xpath expr="//button[@name='create_employee_from_applicant']" position="before">
                 <button name="action_move_next_stage" string="Chuyển giai đoạn" type="object" class="oe_highlight" />
            </xpath> -->

            <!-- Ẩn các trường mặc định bị trùng lặp -->
            <xpath expr="//sheet/group/group/field[@name='email_from']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet/group/group/field[@name='partner_phone']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hiển thị Email + Phone dạng ngang ngay dưới tên Applicant -->
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <div class="ps-1 pb-2">
                    <div class="d-flex align-items-center mb-1">
                        <span class="fw-bold" style="width:72px; flex: 0 0 72px;">Email</span>
                        <div class="flex-grow-1" style="min-width:0; max-width: 45%;">
                            <field name="email_from" nolabel="1" widget="email"/>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="fw-bold" style="width:72px; flex: 0 0 72px;">Phone</span>
                        <div class="flex-grow-1" style="min-width:0; max-width: 45%;">
                            <field name="partner_phone" nolabel="1" widget="phone"/>
                        </div>
                    </div>
                </div>
            </xpath>


            <xpath expr="//sheet/group/group/field[@name='linkedin_profile']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Ẩn Evaluation/Recruiter/Interviewers/Tags ở group mặc định -->
            <xpath expr="//sheet/group/group/field[@name='priority']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet/group/group/field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet/group/group/field[@name='interviewer_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet/group/group/field[@name='categ_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet/group/group/field[@name='date_closed']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Ẩn block Properties mặc định vì các trường cá nhân đã được đưa vào tab riêng -->
            <xpath expr="//field[@name='applicant_properties']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Group Đánh giá & Phụ trách trước notebook -->
            <xpath expr="//notebook" position="before">
                <group string="Assignment" invisible="1">
                    <group>
                        <field name="priority" widget="priority" invisible="1"/>
                        <field name="user_id" string="Recruiter"/>
                        <field name="categ_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                    </group>
                    <group>
                        <field name="interviewer_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Kanban View - Disable Sample Data -->
    <record id="view_hr_applicant_kanban_no_sample" model="ir.ui.view">
        <field name="name">hr.applicant.kanban.no.sample</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_kanban_view_applicant"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//widget[@name='web_ribbon']" position="attributes">
                <attribute name="title">Reject</attribute>
            </xpath>
            <kanban position="attributes">
                <attribute name="sample">0</attribute>
            </kanban>
        </field>
    </record>

    <record id="view_hr_applicant_form_hide_send_interview_store" model="ir.ui.view">
        <field name="name">hr.applicant.form.hide.send.interview.store</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment_survey.hr_applicant_view_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_send_survey']" position="attributes">
                <attribute name="invisible">recruitment_type == 'store' or not active or not survey_id</attribute>
            </xpath>
        </field>
    </record>



</odoo>
