<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_job_apply_custom" name="Custom Application Form">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty psm-office-apply psm-unified-apply psm-store-apply-page">
                <style>
                    .psm-office-apply {
                        --mcd-yellow: var(--secondary);
                        --mcd-red: var(--primary);
                        --mcd-black: #000000;
                        --mcd-white: #ffffff;
                        --mcd-ink: var(--foreground);
                        --mcd-surface: var(--card);
                        --mcd-surface-foreground: var(--card-foreground);
                        --mcd-border: var(--border);
                        --mcd-muted: var(--muted);
                        --mcd-muted-foreground: var(--muted-foreground);
                        background:
                            radial-gradient(circle at top, rgba(255, 188, 13, 0.08), transparent 26%),
                            linear-gradient(180deg, var(--background) 0%, color-mix(in srgb, var(--background) 88%, white 12%) 100%);
                        color: var(--foreground);
                        min-height: 100vh;
                    }

                    html[data-theme='dark'] .psm-office-apply {
                        background:
                            radial-gradient(circle at top, rgba(255, 188, 13, 0.12), transparent 24%),
                            linear-gradient(180deg, #151413 0%, #1d1b19 48%, #151413 100%);
                    }

                    .psm-office-apply .hero-badge {
                        background: var(--mcd-red);
                        color: var(--mcd-yellow);
                        border: 1px solid rgba(0, 0, 0, 0.12);
                    }

                    .psm-office-apply .hero-title {
                        color: var(--foreground);
                    }

                    .psm-office-apply .hero-subtitle {
                        color: var(--mcd-muted-foreground);
                    }

                    .psm-office-apply .hero-card,
                    .psm-office-apply .survey-card,
                    .psm-office-apply .schedule-card {
                        background: var(--mcd-surface) !important;
                        color: var(--mcd-surface-foreground) !important;
                        border: 1px solid var(--mcd-border) !important;
                        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
                        backdrop-filter: blur(16px);
                        -webkit-backdrop-filter: blur(16px);
                    }

                    html[data-theme='dark'] .psm-office-apply .hero-card,
                    html[data-theme='dark'] .psm-office-apply .survey-card,
                    html[data-theme='dark'] .psm-office-apply .schedule-card {
                        background: linear-gradient(180deg, #2a2623 0%, #1b1917 100%) !important;
                        border-color: rgba(255, 255, 255, 0.08) !important;
                        color: #f5f5f4 !important;
                    }

                    .psm-office-apply .hero-card {
                        position: relative;
                        overflow: hidden;
                    }

                    .psm-office-apply .hero-card::before {
                        content: "";
                        position: absolute;
                        left: 0;
                        right: 0;
                        top: 0;
                        height: 10px;
                        background: linear-gradient(90deg, var(--mcd-red) 0 35%, var(--mcd-yellow) 35% 70%, var(--mcd-black) 70% 85%, var(--mcd-white) 85% 100%);
                    }

                    .psm-office-apply .survey-card .card-header,
                    .psm-office-apply .schedule-card .card-header {
                        background: var(--mcd-red) !important;
                        color: var(--mcd-white) !important;
                    }

                    .psm-office-apply .survey-card:not(.schedule-card) .card-header h4 {
                        color: #ffc72c !important;
                    }

                    .psm-office-apply .survey_question {
                        background: var(--mcd-muted) !important;
                        border-color: var(--mcd-border) !important;
                        color: var(--foreground);
                    }

                    html[data-theme='dark'] .psm-office-apply .survey_question {
                        background: rgba(255, 255, 255, 0.06) !important;
                        border-color: rgba(255, 255, 255, 0.08) !important;
                    }

                    .psm-office-apply .theme-muted-panel {
                        background: var(--primary);
                        border: 1px solid var(--border);
                        color: var(--mcd-white);
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
                    }

                    .psm-office-apply .theme-muted-panel .text-muted,
                    .psm-office-apply .theme-muted-panel .fw-semibold,
                    .psm-office-apply .theme-muted-panel .text-dark,
                    .psm-office-apply .theme-muted-panel p {
                        color: var(--mcd-white) !important;
                    }

                    .psm-office-apply .theme-submit-btn {
                        background-color: var(--primary);
                        border: 1px solid var(--secondary);
                        color: var(--secondary);
                        border-radius: 999px;
                        min-width: 280px;
                    }

                    .psm-office-apply .theme-submit-btn:hover {
                        background-color: var(--secondary);
                        border-color: var(--primary);
                        color: var(--secondary-foreground);
                    }

                    .psm-office-apply .theme-metric-box {
                        background: var(--primary);
                        border: 1px solid var(--border);
                        color: var(--secondary);
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
                    }

                    .psm-office-apply .form-control,
                    .psm-office-apply .form-select,
                    .psm-office-apply textarea,
                    .psm-office-apply input[type="text"],
                    .psm-office-apply input[type="email"],
                    .psm-office-apply input[type="tel"],
                    .psm-office-apply input[type="number"],
                    .psm-office-apply input[type="date"] {
                        background-color: var(--card) !important;
                        color: var(--foreground) !important;
                        border-color: var(--border) !important;
                    }

                    .psm-office-apply .form-control::placeholder,
                    .psm-office-apply .form-select::placeholder,
                    .psm-office-apply textarea::placeholder {
                        color: var(--muted-foreground) !important;
                    }

                    html[data-theme='dark'] .psm-office-apply .form-control,
                    html[data-theme='dark'] .psm-office-apply .form-select,
                    html[data-theme='dark'] .psm-office-apply textarea,
                    html[data-theme='dark'] .psm-office-apply input[type="text"],
                    html[data-theme='dark'] .psm-office-apply input[type="email"],
                    html[data-theme='dark'] .psm-office-apply input[type="tel"],
                    html[data-theme='dark'] .psm-office-apply input[type="number"],
                    html[data-theme='dark'] .psm-office-apply input[type="date"] {
                        background: #4b4743 !important;
                        color: #f5f5f4 !important;
                        border-color: #6b655f !important;
                    }

                    .psm-office-apply .slot-option .form-check-input:checked {
                        background-color: var(--primary);
                        border-color: var(--primary);
                    }

                    .psm-office-apply .psm-office-field-col .psm-office-field-shell {
                        height: 100%;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-shell {
                        display: flex;
                        flex-direction: column;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-label-area {
                        min-height: 2.55rem;
                        display: flex;
                        align-items: flex-start;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-label {
                        line-height: 1.25;
                        display: -webkit-box;
                        -webkit-box-orient: vertical;
                        -webkit-line-clamp: 2;
                        overflow: hidden;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-control-area {
                        margin-top: 0;
                    }

                    .psm-office-apply .psm-office-field-col .psm-office-field-control-area .form-control,
                    .psm-office-apply .psm-office-field-col .psm-office-field-control-area .form-select,
                    .psm-office-apply .psm-office-field-col .psm-office-field-control-area textarea {
                        font-size: 0.95rem;
                        line-height: 1.35;
                    }

                    .psm-office-apply .psm-office-field-col .psm-office-field-control-area .form-control::placeholder,
                    .psm-office-apply .psm-office-field-col .psm-office-field-control-area textarea::placeholder {
                        font-size: 0.95rem;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-control-area .form-control,
                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-control-area .form-select {
                        min-height: 2.85rem;
                    }

                    .psm-office-apply .psm-office-field-col--aligned .psm-office-field-control-area input[type="file"].form-control {
                        padding-top: 0.6rem;
                    }

                    @media (max-width: 767.98px) {
                        .psm-office-apply .psm-office-field-col--aligned .psm-office-field-shell {
                            display: block;
                            height: auto;
                        }

                        .psm-office-apply .psm-office-field-col--aligned .psm-office-field-label-area {
                            min-height: 0;
                        }

                        .psm-office-apply .psm-office-field-col--aligned .psm-office-field-control-area {
                            margin-top: 0;
                        }
                    }
                </style>

                <section class="py-5 psm-office-apply-section">
                    <div class="container psm-office-apply-container psm-store-apply-container">
                        <div class="row justify-content-center mb-4">
                            <div class="col-xl-10 col-lg-11">
                                <div class="text-center mb-4 psm-office-apply-header">
                                    <h1 class="display-6 fw-bold hero-title mb-3 psm-office-apply-title psm-store-apply-title">
                                        <t t-esc="job.name"/>
                                    </h1>
                                    <p class="lead hero-subtitle mb-0 psm-office-apply-subtitle">
                                        Hoàn tất thông tin ứng tuyển để bộ phận tuyển dụng xem xét hồ sơ của bạn.
                                    </p>
                                </div>

                                <form action="/jobs/apply/submit" method="post" class="js_website_submit_form psm-office-apply-form psm-store-apply-form psm-unified-apply-form" enctype="multipart/form-data">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="job_id" t-att-value="job.id"/>
                                    <input type="hidden" name="schedule_id" t-if="schedule" t-att-value="schedule.id"/>

                                    <div class="card hero-card psm-office-hero-card mb-4" style="border-radius: 24px;">
                                        <div class="card-body p-4 p-lg-5">
                                            <div class="row g-4 align-items-start psm-office-hero-grid">
                                                <div class="col-lg-7 psm-office-hero-main">
                                                    <div class="d-flex flex-column gap-3">
                                                        <div class="d-flex align-items-start gap-3">
                                                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: var(--secondary); color: var(--secondary-foreground);">
                                                                <i class="fa fa-briefcase"/>
                                                            </div>
                                                            <div>
                                                                <div class="text-muted small text-uppercase fw-semibold">Vị trí</div>
                                                                <div class="fw-bold text-dark"><t t-esc="job.name"/></div>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex align-items-start gap-3" t-if="job.company_id">
                                                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: var(--primary); color: var(--primary-foreground);">
                                                                <i class="fa fa-building-o"/>
                                                            </div>
                                                            <div>
                                                                <div class="text-muted small text-uppercase fw-semibold">Công ty</div>
                                                                <div class="fw-semibold text-dark"><t t-esc="job.company_id.name"/></div>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex align-items-start gap-3" t-if="job.department_id">
                                                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: var(--foreground); color: var(--background);">
                                                                <i class="fa fa-sitemap"/>
                                                            </div>
                                                            <div>
                                                                <div class="text-muted small text-uppercase fw-semibold">Phòng ban</div>
                                                                <div class="fw-semibold text-dark"><t t-esc="job.department_id.name"/></div>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex align-items-start gap-3" t-if="job.address_id">
                                                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: var(--card); color: var(--foreground); border: 1px solid var(--border);">
                                                                <i class="fa fa-map-marker"/>
                                                            </div>
                                                            <div>
                                                                <div class="text-muted small text-uppercase fw-semibold">Địa điểm</div>
                                                                <div class="fw-semibold text-dark"><t t-esc="job.address_id.display_name"/></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg-5 psm-office-hero-note-col">
                                                    <div class="rounded-4 h-100 p-4 theme-muted-panel">
                                                        <div class="small text-uppercase fw-semibold mb-2" style="color: #ffc72c;">Lưu ý</div>
                                                        <p class="mb-3">Vui lòng điền đầy đủ thông tin và đính kèm CV mới nhất để hệ thống xử lý nhanh hồ sơ ứng tuyển của bạn.</p>
                                                        <p class="mb-0" t-if="schedule">Job này đang có lịch phỏng vấn dự kiến, vui lòng chọn khung giờ phù hợp ở phần lịch bên dưới.</p>
                                                        <p class="mb-0" t-if="not schedule">Hồ sơ hợp lệ sẽ được đưa vào pipeline tuyển dụng phù hợp với vị trí này.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="alert alert-danger mb-3" t-if="error and error.get('_form')">
                                        <i class="fa fa-exclamation-triangle me-2"/>
                                        <t t-esc="error.get('_form')"/>
                                    </div>

                                    <t t-if="not apply_sections">
                                        <div class="alert alert-warning text-center shadow-sm">
                                            <h4 class="alert-heading mb-3">
                                                <i class="fa fa-exclamation-triangle me-2"/>Chưa thiết lập biểu mẫu
                                            </h4>
                                            <p class="mb-0">
                                                Vị trí này chưa có cấu hình biểu mẫu ứng tuyển trực tuyến. Vui lòng quay lại sau hoặc liên hệ bộ phận tuyển dụng.
                                            </p>
                                        </div>
                                    </t>

                                    <t t-else="">
                                        <div class="card survey-card mb-4" style="border-radius: 24px;">
                                            <div class="card-header border-0 py-3 px-4" style="border-radius: 24px 24px 0 0;">
                                                <h4 class="mb-1 fw-bold">Application / Pre-interview form</h4>
                                                <p class="mb-0 opacity-75">Vui lòng điền đầy đủ theo đúng các nhóm thông tin bên dưới.</p>
                                            </div>
                                            <div class="card-body p-4 p-lg-5 psm-store-apply-main-body">
                                                <t t-foreach="apply_sections or []" t-as="section">
                                                    <div class="mb-4 p-4 border rounded-4 survey_question psm-office-question-card" t-if="section.get('fields')">
                                                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                                                            <div>
                                                                <h5 class="fw-bold mb-2">
                                                                    <t t-esc="section.get('title')"/>
                                                                </h5>
                                                            </div>
                                                            <span class="badge rounded-pill text-bg-light border">Section</span>
                                                        </div>
                                                        <div class="row g-4 psm-office-field-grid psm-store-apply-field-grid">
                                                            <t t-foreach="section.get('fields') or []" t-as="field">
                                                                <t t-call="M02_P0204.website_job_apply_field_renderer"/>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                    </t>

                                    <div class="card survey-card schedule-card mb-4 psm-store-apply-schedule-card" t-if="schedule" style="border-radius: 24px;">
                                        <div class="card-header border-0 py-3 px-4" style="border-radius: 24px 24px 0 0;">
                                            <h4 class="mb-1 fw-bold">Planned Interview Schedule</h4>
                                            <p class="mb-0 opacity-75">Vui lòng chọn 1 khung giờ phỏng vấn phù hợp với bạn (cập nhật trực tuyến).</p>
                                        </div>
                                        <div class="card-body p-4 p-lg-5" id="interview_slots_container" t-att-data-schedule-id="schedule.id">
                                            <div class="row g-3 psm-store-slot-grid">
                                                <div class="col-md-4 mb-2 slot-option" data-slot="1" t-if="schedule.interview_date_1">
                                                    <div class="theme-metric-box rounded-4 p-3 text-center h-100 position-relative">
                                                        <input class="form-check-input position-absolute top-0 start-0 m-2" type="radio"
                                                               name="interview_slot" value="1" id="slot_1"
                                                               t-att-disabled="schedule.slot_1_remaining &lt;= 0" required="1"/>
                                                        <label class="form-check-label w-100" for="slot_1">
                                                            <div class="fw-bold mb-1">Ngày PV 1</div>
                                                            <div class="small mb-2"><t t-esc="schedule.interview_date_1_vn"/></div>
                                                            <span t-attf-class="badge #{'bg-success' if schedule.slot_1_remaining > 0 else 'bg-danger'} slot-badge" data-slot="1">
                                                                <t t-esc="schedule.slot_1_remaining"/> chỗ trống
                                                            </span>
                                                        </label>
                                                    </div>
                                                </div>

                                                <div class="col-md-4 mb-2 slot-option" data-slot="2" t-if="schedule.interview_date_2">
                                                    <div class="theme-metric-box rounded-4 p-3 text-center h-100 position-relative">
                                                        <input class="form-check-input position-absolute top-0 start-0 m-2" type="radio"
                                                               name="interview_slot" value="2" id="slot_2"
                                                               t-att-disabled="schedule.slot_2_remaining &lt;= 0" required="1"/>
                                                        <label class="form-check-label w-100" for="slot_2">
                                                            <div class="fw-bold mb-1">Ngày PV 2</div>
                                                            <div class="small mb-2"><t t-esc="schedule.interview_date_2_vn"/></div>
                                                            <span t-attf-class="badge #{'bg-success' if schedule.slot_2_remaining > 0 else 'bg-danger'} slot-badge" data-slot="2">
                                                                <t t-esc="schedule.slot_2_remaining"/> chỗ trống
                                                            </span>
                                                        </label>
                                                    </div>
                                                </div>

                                                <div class="col-md-4 mb-2 slot-option" data-slot="3" t-if="schedule.interview_date_3">
                                                    <div class="theme-metric-box rounded-4 p-3 text-center h-100 position-relative">
                                                        <input class="form-check-input position-absolute top-0 start-0 m-2" type="radio"
                                                               name="interview_slot" value="3" id="slot_3"
                                                               t-att-disabled="schedule.slot_3_remaining &lt;= 0" required="1"/>
                                                        <label class="form-check-label w-100" for="slot_3">
                                                            <div class="fw-bold mb-1">Ngày PV 3</div>
                                                            <div class="small mb-2"><t t-esc="schedule.interview_date_3_vn"/></div>
                                                            <span t-attf-class="badge #{'bg-success' if schedule.slot_3_remaining > 0 else 'bg-danger'} slot-badge" data-slot="3">
                                                                <t t-esc="schedule.slot_3_remaining"/> chỗ trống
                                                            </span>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="text-center mt-4 psm-office-apply-actions psm-store-apply-actions" t-if="apply_sections">
                                        <button type="submit" class="btn btn-lg px-5 py-3 fw-bold shadow-sm theme-submit-btn psm-office-submit-btn psm-store-apply-submit">
                                            <i class="fa fa-paper-plane me-2"/>Gửi hồ sơ ứng tuyển
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    const container = document.getElementById('interview_slots_container');
                    if (!container) return;
                    const scheduleId = container.dataset.scheduleId;

                    const busService = (window.odoo &amp;&amp; window.odoo.__session_info__ &amp;&amp; window.odoo.__session_info__.bus_service)
                        || (window.__owl__ &amp;&amp; window.__owl__.app &amp;&amp; window.__owl__.app.env &amp;&amp; window.__owl__.app.env.services &amp;&amp; window.__owl__.app.env.services.bus_service);

                    if (busService) {
                        console.log('Subscribing to interview_slots_' + scheduleId);
                        busService.addChannel('interview_slots_' + scheduleId);
                        busService.addEventListener('notification', ({ detail }) => {
                            for (const { type, payload } of detail) {
                                if (type === 'slot_update' &amp;&amp; payload.schedule_id == scheduleId) {
                                    updateSlotUI(payload);
                                }
                            }
                        });
                    }
                });

                function updateSlotUI(data) {
                    [1, 2, 3].forEach(slot => {
                        const remaining = data['slot_' + slot + '_remaining'];
                        const badge = document.querySelector(`.slot-badge[data-slot="${slot}"]`);
                        const radio = document.getElementById('slot_' + slot);
                        const option = document.querySelector(`.slot-option[data-slot="${slot}"]`);

                        if (badge) {
                            badge.textContent = remaining + ' chỗ trống';
                            if (remaining &lt;= 0) {
                                badge.classList.remove('bg-success');
                                badge.classList.add('bg-danger');
                            } else {
                                badge.classList.remove('bg-danger');
                                badge.classList.add('bg-success');
                            }
                        }

                        if (radio) {
                            if (remaining &lt;= 0) {
                                radio.disabled = true;
                                if (radio.checked) radio.checked = false;
                            } else {
                                radio.disabled = false;
                            }
                        }

                        if (option) {
                            if (remaining &lt;= 0) {
                                option.style.opacity = '0.5';
                            } else {
                                option.style.opacity = '1';
                            }
                        }
                    });
                }

                const documentTypeEl = document.getElementById('x_id_document_type');
                const documentNumberEl = document.getElementById('x_id_number');
                const documentHintEl = document.getElementById('x_id_number_hint');

                function updateDocumentValidationByType() {
                    if (!documentTypeEl || !documentNumberEl) {
                        return;
                    }

                    const isPassport = documentTypeEl.value === 'passport';
                    if (isPassport) {
                        documentNumberEl.setAttribute('pattern', '[A-Za-z0-9]{6,12}');
                        documentNumberEl.setAttribute('minlength', '6');
                        documentNumberEl.setAttribute('maxlength', '12');
                        documentNumberEl.removeAttribute('inputmode');
                        documentNumberEl.setAttribute('title', 'Hộ chiếu chỉ gồm chữ và số, độ dài từ 6 đến 12 ký tự');
                        if (documentHintEl) {
                            documentHintEl.textContent = 'Nếu chọn Hộ chiếu, vui lòng nhập chữ và số, độ dài từ 6 đến 12 ký tự.';
                        }
                    } else {
                        documentNumberEl.setAttribute('pattern', '[0-9]{12}');
                        documentNumberEl.setAttribute('minlength', '12');
                        documentNumberEl.setAttribute('maxlength', '12');
                        documentNumberEl.setAttribute('inputmode', 'numeric');
                        documentNumberEl.setAttribute('title', 'CCCD phải gồm đúng 12 chữ số');
                        if (documentHintEl) {
                            documentHintEl.textContent = 'Nếu chọn CCCD, vui lòng nhập đúng 12 chữ số.';
                        }
                    }
                }

                if (documentTypeEl &amp;&amp; documentNumberEl) {
                    updateDocumentValidationByType();
                    documentTypeEl.addEventListener('change', updateDocumentValidationByType);
                }
            </script>
        </t>
    </template>

    <template id="website_job_apply_field_renderer" name="Store Job Apply Field Renderer">
        <t t-set="field_name" t-value="field.get('name')"/>
        <t t-set="field_type" t-value="field.get('type') or 'char'"/>
        <t t-set="field_required" t-value="field.get('required')"/>
        <t t-set="field_widget" t-value="field.get('widget')"/>
        <t t-set="col_size" t-value="field.get('col_size', 6)"/>
        <t t-set="display_label" t-value="field.get('label') or field_name"/>
        <t t-set="placeholder_overrides" t-value="{
            'partner_name': 'Nhập họ và tên đầy đủ',
            'email_from': 'example@email.com',
            'partner_phone': 'Nhập số điện thoại liên hệ',
            'linkedin_profile': 'https://linkedin.com/in/your-profile',
            'x_current_job': 'Ví dụ: Digital Marketing Specialist',
            'x_birthday': 'Chọn ngày sinh',
            'x_current_address': 'Nhập địa chỉ hiện tại',
            'x_years_experience': 'Ví dụ: 3',
            'x_school_name': 'Tên trường / chuyên ngành',
            'x_id_number': 'Nhập số CCCD (12 số) hoặc hộ chiếu (6-12 ký tự chữ và số)',
            'x_last_company': 'Tên công ty gần nhất bạn làm việc',
            'x_application_content': 'Tóm tắt kinh nghiệm, điểm mạnh và lý do bạn phù hợp với vị trí này',
            'x_referral_staff_id': 'Nếu có người giới thiệu, nhập mã nhân viên tại đây',
        }"/>
        <t t-set="placeholder" t-value="field.get('placeholder') or placeholder_overrides.get(field_name) or ''"/>
        <t t-set="is_two_col_layout" t-value="str(col_size) != '12'"/>
        <t t-set="is_textarea_field" t-value="field_type in ['text', 'html']"/>
        <t t-set="apply_aligned_layout" t-value="is_two_col_layout and not is_textarea_field and field_type != 'boolean'"/>
        <div t-if="field_name and field.get('is_active', True)"
             t-attf-class="col-md-#{col_size} mb-1 psm-office-field-col #{'psm-office-field-col--aligned' if apply_aligned_layout else ''}">
            <div class="psm-office-field-shell">
                <div class="psm-office-field-label-area" t-if="field_type != 'boolean'">
                    <label class="form-label fw-bold text-dark mb-0 psm-office-field-label">
                        <t t-esc="display_label"/>
                        <span t-if="field_required" class="text-danger"> *</span>
                    </label>
                </div>

                <div class="psm-office-field-control-area">
                    <t t-if="field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image']">
                        <input
                            type="file"
                            t-att-name="field_name"
                            t-att-accept="'image/*' if field_name == 'x_portrait_image' else None"
                            t-attf-class="form-control form-control-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-required="field_required"
                        />
                    </t>

                    <t t-if="field_name == 'x_id_document_type' and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <t t-set="document_options" t-value="field.get('selection') or [{'value': 'citizen_id', 'label': 'CCCD'}, {'value': 'passport', 'label': 'Hộ chiếu'}]"/>
                        <t t-set="selected_document_type" t-value="default.get('x_id_document_type', field.get('default') or 'citizen_id') if default else (field.get('default') or 'citizen_id')"/>
                        <select
                            id="x_id_document_type"
                            t-att-name="field_name"
                            t-attf-class="form-select form-select-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-required="field_required"
                        >
                            <t t-foreach="document_options" t-as="opt">
                                <option
                                    t-att-value="opt.get('value')"
                                    t-att-selected="'selected' if str(selected_document_type) == str(opt.get('value')) else None"
                                ><t t-esc="opt.get('label')"/></option>
                            </t>
                        </select>
                    </t>

                    <t t-if="field_name == 'x_id_number' and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <input
                            type="text"
                            id="x_id_number"
                            t-att-name="field_name"
                            t-attf-class="form-control form-control-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-required="field_required"
                            pattern="[0-9]{12}"
                            minlength="12"
                            maxlength="12"
                            inputmode="numeric"
                            title="CCCD phải gồm đúng 12 chữ số"
                            t-att-placeholder="placeholder or None"
                            t-att-value="default.get(field_name, field.get('default') or '') if default else (field.get('default') or '')"
                        />
                        <small id="x_id_number_hint" class="text-muted mt-1 d-block">Nếu chọn CCCD, vui lòng nhập đúng 12 chữ số.</small>
                    </t>

                    <t t-if="field_type in ['char', 'integer', 'float', 'monetary', 'date', 'datetime'] and field_name not in ['x_id_number'] and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <t t-set="input_type"
                           t-value="'email' if field_name == 'email_from' else ('tel' if field_name == 'partner_phone' else ('number' if field_type in ['integer', 'float', 'monetary'] else ('date' if field_type == 'date' else ('datetime-local' if field_type == 'datetime' else 'text'))))"/>
                        <input
                            t-att-type="input_type"
                            t-att-name="field_name"
                            t-attf-class="form-control form-control-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-placeholder="placeholder or None"
                            t-att-required="field_required"
                            t-att-step="'any' if field_type in ['float', 'monetary'] else None"
                            t-att-value="default.get(field_name, field.get('default') or '') if default else (field.get('default') or '')"
                        />
                    </t>

                    <t t-if="field_type in ['text', 'html'] and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <textarea
                            t-att-name="field_name"
                            t-attf-class="form-control #{'is-invalid' if error and error.get(field_name) else ''}"
                            rows="4"
                            t-att-placeholder="placeholder or None"
                            t-att-required="field_required"
                        ><t t-esc="default.get(field_name, field.get('default') or '') if default else (field.get('default') or '')"/></textarea>
                    </t>

                    <t t-if="field_type == 'selection' and field_name not in ['x_id_document_type'] and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <select
                            t-att-name="field_name"
                            t-attf-class="form-select form-select-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-required="field_required"
                        >
                            <option value="">-- Chọn --</option>
                            <t t-foreach="field.get('selection') or []" t-as="opt">
                                <option
                                    t-att-value="opt.get('value')"
                                    t-att-selected="'selected' if (default and str(default.get(field_name, '')) == str(opt.get('value'))) else None"
                                ><t t-esc="opt.get('label')"/></option>
                            </t>
                        </select>
                    </t>

                    <t t-if="field_type == 'boolean' and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <div class="form-check pt-2">
                            <input
                                class="form-check-input"
                                type="checkbox"
                                t-att-name="field_name"
                                t-att-id="'checkbox_' + field_name"
                                value="1"
                                t-att-checked="'checked' if default and str(default.get(field_name, '')) in ['1', 'true', 'True'] else None"
                            />
                            <label class="form-check-label" t-att-for="'checkbox_' + field_name">
                                <t t-esc="field.get('label')"/>
                                <span t-if="field_required" class="text-danger"> *</span>
                            </label>
                        </div>
                    </t>

                    <t t-if="field_type not in ['char', 'integer', 'float', 'monetary', 'date', 'datetime', 'text', 'html', 'selection', 'boolean'] and not (field_widget == 'file' or field_name in ['x_cv_attachment', 'x_portrait_image'])">
                        <input
                            type="text"
                            t-att-name="field_name"
                            t-attf-class="form-control form-control-lg #{'is-invalid' if error and error.get(field_name) else ''}"
                            t-att-placeholder="placeholder or None"
                            t-att-required="field_required"
                            t-att-value="default.get(field_name, field.get('default') or '') if default else (field.get('default') or '')"
                        />
                    </t>

                    <div t-if="error and error.get(field_name)" class="invalid-feedback d-block">
                        <t t-esc="error.get(field_name)"/>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="website_apply_thankyou" name="Custom Thank You">
        <t t-call="website.layout">
            <div id="wrap" class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8 text-center py-5 shadow-sm rounded bg-white">
                        <div class="mb-4">
                            <i class="fa fa-check-circle text-success" style="font-size: 80px;"/>
                        </div>
                        <h1 class="fw-bolder text-success mb-3">CẢM ƠN BẠN ĐÃ ỨNG TUYỂN!</h1>
                        <p class="lead mb-4">
                            Hồ sơ của bạn cho vị trí <strong t-esc="job.name"/> đã được tiếp nhận thành công.
                        </p>
                        <div class="alert alert-info border-0 bg-light p-4 mb-4">
                            <p class="mb-0">Hệ thống đang xử lý hồ sơ ứng tuyển của bạn. Chúng tôi sẽ liên hệ sớm nhất qua email hoặc số điện thoại bạn đã cung cấp.</p>
                        </div>
                        <a href="/jobs" class="btn btn-primary btn-lg rounded-pill px-5 shadow">
                            XEM CÁC VỊ TRÍ KHÁC
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
