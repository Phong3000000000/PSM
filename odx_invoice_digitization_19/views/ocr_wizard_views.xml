<odoo>
  <data>
    <record id="view_odx_ocr_wizard_form" model="ir.ui.view">
      <field name="name">odx.ocr.wizard.form</field>
      <field name="model">odx.ocr.wizard</field>
      <field name="arch" type="xml">
        <form string="Create Invoice via OCR">
          <group>
            <field name="upload" filename="filename"/>
            <field name="filename"/>
            <field name="move_type"/>
          </group>
          <group>
            <field name="create_partner_if_missing"/>
            <field name="create_product_if_missing"/>
          </group>
          <footer>
            <button string="Process" type="object" name="action_process" class="btn-primary"/>
            <button string="Cancel" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>
  </data>
</odoo>
