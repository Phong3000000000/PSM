<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_soc_select_wizard_form" model="ir.ui.view">
        <field name="name">soc.select.wizard.form</field>
        <field name="model">soc.select.wizard</field>
        <field name="arch" type="xml">
            <form string="Add SOC">
                <sheet>
                    <group>
                        <field name="channel_id"/>
                        <field name="soc_ids"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Add" name="action_add_socs" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_soc_select_wizard" model="ir.actions.act_window">
        <field name="name">Add SOC to Course</field>
        <field name="res_model">soc.select.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_soc_select_wizard_form"/>
        <field name="target">new</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add SOCs to this course.
            </p>
        </field>
    </record>
</odoo>
