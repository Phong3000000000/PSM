<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SOC Type Views -->
    <record id="view_mcd_soc_type_tree" model="ir.ui.view">
        <field name="name">mcd.soc.type.tree</field>
        <field name="model">mcd.soc.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_mcd_soc_type" model="ir.actions.act_window">
        <field name="name">SOC Document Types</field>
        <field name="res_model">mcd.soc.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- SOC Area Views -->
    <record id="view_mcd_soc_area_tree" model="ir.ui.view">
        <field name="name">mcd.soc.area.tree</field>
        <field name="model">mcd.soc.area</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_mcd_soc_area" model="ir.actions.act_window">
        <field name="name">SOC Areas</field>
        <field name="res_model">mcd.soc.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- SOC Station Views -->
    <record id="view_mcd_soc_station_tree" model="ir.ui.view">
        <field name="name">mcd.soc.station.tree</field>
        <field name="model">mcd.soc.station</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="area_id"/>
                <field name="soc_type_ids" widget="many2many_tags"/>
                <field name="service_type" widget="badge"
                       decoration-success="service_type == 'permanent'"
                       decoration-warning="service_type == 'lto'"
                       decoration-muted="service_type == 'na'"/>
                <field name="has_initial" widget="boolean_toggle" string="Initial"/>
                <field name="has_unannounced" widget="boolean_toggle" string="Unannounced"/>
            </list>
        </field>
    </record>

    <record id="view_mcd_soc_station_form" model="ir.ui.view">
        <field name="name">mcd.soc.station.form</field>
        <field name="model">mcd.soc.station</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="area_id"/>
                        </group>
                        <group>
                            <field name="soc_type_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mcd_soc_station" model="ir.actions.act_window">
        <field name="name">SOC Stations</field>
        <field name="res_model">mcd.soc.station</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
