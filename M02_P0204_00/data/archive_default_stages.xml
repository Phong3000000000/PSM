<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Simpler approach: Just set recruitment_type='both' for existing stages -->
    <data noupdate="0">
        <!-- Update all existing stages without recruitment_type to be 'both' -->
        <record id="update_existing_stages" model="ir.cron">
            <field name="name">Update Existing Recruitment Stages</field>
            <field name="model_id" ref="hr_recruitment.model_hr_recruitment_stage"/>
            <field name="state">code</field>
            <field name="code">
                # Archive old default stages
                old_stages = env['hr.recruitment.stage'].search([
                    ('recruitment_type', '=', False)
                ])
                if old_stages:
                    old_stages.write({'active': False})
                    _logger.info(f"Archived {len(old_stages)} old recruitment stages")
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">1</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
