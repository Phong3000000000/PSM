<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ========================================
             NHÂN VIÊN (STAFF) PIPELINE
             Under Review → Survey Passed → Interview & OJE → Hired → Reject
             (New đã bị xóa vì thừa - dùng New từ store/office)
        ======================================== -->
        <record id="stage_staff_under_review" model="hr.recruitment.stage">
            <field name="name">Under Review</field>
            <field name="sequence">20</field>
            <field name="recruitment_type">staff</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_staff_survey_passed" model="hr.recruitment.stage">
            <field name="name">Survey Passed</field>
            <field name="sequence">30</field>
            <field name="recruitment_type">staff</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_staff_interview_oje" model="hr.recruitment.stage">
            <field name="name">Interview &amp; OJE</field>
            <field name="sequence">40</field>
            <field name="recruitment_type">staff</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_staff_hired" model="hr.recruitment.stage">
            <field name="name">Hired</field>
            <field name="sequence">50</field>
            <field name="recruitment_type">staff</field>
            <field name="hired_stage">True</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_staff_reject" model="hr.recruitment.stage">
            <field name="name">Reject</field>
            <field name="sequence">60</field>
            <field name="recruitment_type">staff</field>
            <field name="fold">True</field>
        </record>

        <!-- ========================================
             QUẢN LÝ (MANAGEMENT) PIPELINE
             Under Review → Survey Passed → Interview → OJE → Offer → Hired → Reject
             (New đã bị xóa vì thừa - dùng New từ store/office)
        ======================================== -->
        <record id="stage_mgmt_under_review" model="hr.recruitment.stage">
            <field name="name">Under Review</field>
            <field name="sequence">20</field>
            <field name="recruitment_type">management</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_survey_passed" model="hr.recruitment.stage">
            <field name="name">Survey Passed</field>
            <field name="sequence">30</field>
            <field name="recruitment_type">management</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_interview" model="hr.recruitment.stage">
            <field name="name">Interview</field>
            <field name="sequence">40</field>
            <field name="recruitment_type">management</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_oje" model="hr.recruitment.stage">
            <field name="name">OJE</field>
            <field name="sequence">50</field>
            <field name="recruitment_type">management</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_offer" model="hr.recruitment.stage">
            <field name="name">Offer</field>
            <field name="sequence">60</field>
            <field name="recruitment_type">management</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_hired" model="hr.recruitment.stage">
            <field name="name">Hired</field>
            <field name="sequence">70</field>
            <field name="recruitment_type">management</field>
            <field name="hired_stage">True</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_mgmt_reject" model="hr.recruitment.stage">
            <field name="name">Reject</field>
            <field name="sequence">80</field>
            <field name="recruitment_type">management</field>
            <field name="fold">True</field>
        </record>

    </data>
</odoo>
