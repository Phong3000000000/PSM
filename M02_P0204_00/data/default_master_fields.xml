            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_portrait_image" model="recruitment.application.field.master">
            <field name="field_label">Ảnh chân dung</field>
            <field name="field_name">x_portrait_image</field>
            <field name="field_type">file</field>
            <field name="section">basic_info</field>
            <field name="sequence">60</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <!-- ===== CÁC THÔNG TIN KHÁC ===== -->
        <record id="master_field_x_application_content" model="recruitment.application.field.master">
            <field name="field_label">Nội dung</field>
            <field name="field_name">x_application_content</field>
            <field name="field_type">textarea</field>
            <field name="section">other_info</field>
            <field name="sequence">10</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_birthday" model="recruitment.application.field.master">
            <field name="field_label">Ngày tháng năm sinh</field>
            <field name="field_name">x_birthday</field>
            <field name="field_type">date</field>
            <field name="section">other_info</field>
            <field name="sequence">20</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_salutation" model="recruitment.application.field.master">
            <field name="field_label">Danh xưng</field>
            <field name="field_name">x_salutation</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">30</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_gender" model="recruitment.application.field.master">
            <field name="field_label">Giới tính (Gender)</field>
            <field name="field_name">x_gender</field>
            <field name="field_type">select</field>
            <field name="section">other_info</field>
            <field name="sequence">40</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>
        <record id="master_field_x_gender_opt_male" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_gender"/>
            <field name="sequence">1</field>
            <field name="value">male</field>
            <field name="name">Nam (Male)</field>
        </record>
        <record id="master_field_x_gender_opt_female" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_gender"/>
            <field name="sequence">2</field>
            <field name="value">female</field>
            <field name="name">Nữ (Female)</field>
        </record>
        <record id="master_field_x_gender_opt_nd" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_gender"/>
            <field name="sequence">3</field>
            <field name="value">not_display</field>
            <field name="name">Không hiển thị (Not display)</field>
        </record>

        <record id="master_field_x_id_number" model="recruitment.application.field.master">
            <field name="field_label">Số CMT/Căn cước/Hộ chiếu (Social security number/Passport)</field>
            <field name="field_name">x_id_number</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">50</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_id_issue_date" model="recruitment.application.field.master">
