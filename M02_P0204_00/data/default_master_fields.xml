<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ===== THÔNG TIN CƠ BẢN ===== -->
        <record id="master_field_partner_name" model="recruitment.application.field.master">
            <field name="field_label">Họ &amp; tên bạn</field>
            <field name="field_name">partner_name</field>
            <field name="field_type">text</field>
            <field name="section">basic_info</field>
            <field name="sequence">10</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_email_from" model="recruitment.application.field.master">
            <field name="field_label">Địa chỉ email</field>
            <field name="field_name">email_from</field>
            <field name="field_type">email</field>
            <field name="section">basic_info</field>
            <field name="sequence">20</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_attachment" model="recruitment.application.field.master">
            <field name="field_label">CV của bạn</field>
            <field name="field_name">attachment</field>
            <field name="field_type">file</field>
            <field name="section">basic_info</field>
