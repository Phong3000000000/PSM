            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_partner_phone" model="recruitment.application.field.master">
            <field name="field_label">Số điện thoại</field>
            <field name="field_name">partner_phone</field>
            <field name="field_type">tel</field>
            <field name="section">basic_info</field>
            <field name="sequence">40</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_current_job" model="recruitment.application.field.master">
            <field name="field_label">Công việc hiện tại của bạn</field>
            <field name="field_name">x_current_job</field>
