            <field name="field_name">x_id_issue_date</field>
            <field name="field_type">date</field>
            <field name="section">other_info</field>
            <field name="sequence">60</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_id_issue_place" model="recruitment.application.field.master">
            <field name="field_label">Nơi cấp CMT/Căn cước/Hộ chiếu</field>
            <field name="field_name">x_id_issue_place</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">70</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_permanent_address" model="recruitment.application.field.master">
            <field name="field_label">Địa chỉ thường trú</field>
            <field name="field_name">x_permanent_address</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">80</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_education_level" model="recruitment.application.field.master">
            <field name="field_label">Trình độ học vấn (Education)</field>
            <field name="field_name">x_education_level</field>
            <field name="field_type">select</field>
            <field name="section">other_info</field>
            <field name="sequence">90</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>
        <record id="master_field_x_education_opt_1" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">1</field><field name="value">no_degree</field><field name="name">Chưa tốt nghiệp (No degree)</field>
        </record>
        <record id="master_field_x_education_opt_2" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">2</field><field name="value">high_school</field><field name="name">Phổ thông (High school)</field>
        </record>
        <record id="master_field_x_education_opt_3" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">3</field><field name="value">vocational</field><field name="name">Trung cấp</field>
        </record>
        <record id="master_field_x_education_opt_4" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">4</field><field name="value">college</field><field name="name">Cao đẳng (College)</field>
        </record>
        <record id="master_field_x_education_opt_5" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">5</field><field name="value">university</field><field name="name">Đại học (University/Academy)</field>
        </record>
        <record id="master_field_x_education_opt_6" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">6</field><field name="value">master</field><field name="name">Thạc sỹ (Master)</field>
        </record>
        <record id="master_field_x_education_opt_7" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">7</field><field name="value">phd</field><field name="name">Tiến sỹ (PhD)</field>
        </record>
        <record id="master_field_x_education_opt_8" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">8</field><field name="value">postgraduate</field><field name="name">Sau đại học (Postgraduate)</field>
        </record>
        <record id="master_field_x_education_opt_9" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_education_level"/>
            <field name="sequence">9</field><field name="value">others</field><field name="name">Khác (Others)</field>
        </record>

        <record id="master_field_x_school_name" model="recruitment.application.field.master">
            <field name="field_label">Tên trường Đại học/Cao Đẳng/Trung Cấp (University/Academy)</field>
            <field name="field_name">x_school_name</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">100</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_hometown" model="recruitment.application.field.master">
            <field name="field_label">Nguyên quán</field>
            <field name="field_name">x_hometown</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">110</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_current_address" model="recruitment.application.field.master">
            <field name="field_label">Địa chỉ hiện tại (Current Address)</field>
            <field name="field_name">x_current_address</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">120</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_years_experience" model="recruitment.application.field.master">
            <field name="field_label">Số năm kinh nghiệm</field>
            <field name="field_name">x_years_experience</field>
            <field name="field_type">number</field>
            <field name="section">other_info</field>
            <field name="sequence">130</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_height" model="recruitment.application.field.master">
            <field name="field_label">Chiều cao</field>
            <field name="field_name">x_height</field>
            <field name="field_type">number</field>
            <field name="section">other_info</field>
            <field name="sequence">140</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_weight" model="recruitment.application.field.master">
            <field name="field_label">Cân nặng</field>
            <field name="field_name">x_weight</field>
            <field name="field_type">number</field>
            <field name="section">other_info</field>
            <field name="sequence">150</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_nationality" model="recruitment.application.field.master">
            <field name="field_label">Quốc tịch</field>
            <field name="field_name">x_nationality</field>
            <field name="field_type">text</field>
            <field name="section">other_info</field>
            <field name="sequence">160</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="False"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

        <!-- ===== CÂU HỎI BỔ SUNG ===== -->
        <record id="master_field_x_weekend_available" model="recruitment.application.field.master">
            <field name="field_label">Có thể làm việc cuối tuần và Lễ Tết?</field>
            <field name="field_name">x_weekend_available</field>
            <field name="field_type">select</field>
            <field name="section">supplementary_question</field>
            <field name="sequence">10</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="is_answer_must_match_default" eval="True"/>
            <!-- <field name="expected_answer">yes</field> -->
            <field name="recruitment_scope">store</field>
        </record>
        <record id="master_field_x_weekend_opt_yes" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_weekend_available"/>
            <field name="sequence">1</field>
            <field name="value">yes</field>
            <field name="name">Có</field>
        </record>
        <record id="master_field_x_weekend_opt_no" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_weekend_available"/>
            <field name="sequence">2</field>
            <field name="value">no</field>
            <field name="name">Không</field>
        </record>

        <record id="master_field_x_weekend_available" model="recruitment.application.field.master">
            <field name="expected_answer">yes</field>
        </record>

        <record id="master_field_x_worked_mcdonalds" model="recruitment.application.field.master">
            <field name="field_label">Đã từng làm việc tại McDonald's VN chưa?</field>
            <field name="field_name">x_worked_mcdonalds</field>
            <field name="field_type">select</field>
            <field name="section">supplementary_question</field>
            <field name="sequence">20</field>
            <field name="col_size">6</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>
        <record id="master_field_x_worked_mcd_opt_yes" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_worked_mcdonalds"/>
            <field name="sequence">1</field>
            <field name="value">yes</field>
            <field name="name">Rồi</field>
        </record>
        <record id="master_field_x_worked_mcd_opt_no" model="recruitment.application.field.master.option">
            <field name="master_field_id" ref="master_field_x_worked_mcdonalds"/>
            <field name="sequence">2</field>
            <field name="value">no</field>
            <field name="name">Chưa</field>
        </record>

        <!-- ===== CÂU HỎI NỘI BỘ ===== -->
        <record id="master_field_x_last_company" model="recruitment.application.field.master">
            <field name="field_label">Công ty gần nhất của bạn là gì?</field>
            <field name="field_name">x_last_company</field>
            <field name="field_type">text</field>
            <field name="section">internal_question</field>
            <field name="sequence">10</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="True"/>
            <field name="recruitment_scope">both</field>
        </record>

        <record id="master_field_x_referral_staff_id" model="recruitment.application.field.master">
            <field name="field_label">Nếu bạn được giới thiệu từ Nhân viên McDonald's Vietnam, hãy để lại Mã giới thiệu tại đây (Staff ID)</field>
            <field name="field_name">x_referral_staff_id</field>
            <field name="field_type">text</field>
            <field name="section">internal_question</field>
            <field name="sequence">20</field>
            <field name="col_size">12</field>
            <field name="is_active_default" eval="True"/>
            <field name="is_required_default" eval="False"/>
            <field name="recruitment_scope">both</field>
        </record>

    </data>
</odoo>
