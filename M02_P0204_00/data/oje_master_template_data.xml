    <!-- ==================== STORE MANAGEMENT TEMPLATE ==================== -->
    <record id="oje_template_store_management" model="recruitment.oje.template">
        <field name="name">Store Management - OJE Activity Guide</field>
        <field name="scope">store_management</field>
        <field name="version">1.0</field>
        <field name="active">True</field>
        <field name="intro_html"><![CDATA[
            <h4>OJE ACTIVITY GUIDE &amp; EVALUATION FORM</h4>
            <p>Áp dụng cho đánh giá ứng viên quản lý tại khối cửa hàng theo chuẩn OJE nội bộ.</p>
        ]]></field>
    </record>

    <record id="oje_template_mgmt_section_customer" model="recruitment.oje.template.section">
        <field name="template_id" ref="M02_P0204_00.oje_template_store_management"/>
        <field name="name">CUSTOMER SATISFACTION ORIENTED</field>
        <field name="sequence">10</field>
        <field name="section_kind">management_dimension</field>
        <field name="objective_text">To see if candidate realizes the importance of the customer to our business and if he/she has what it takes to keep the customer satisfied.</field>
        <field name="hint_html"><![CDATA[
            <p>Focus on how courteous and friendly the candidate is with customers. See if he/she gives them full attention and listens thoroughly to what they are saying and the candidate's comfort level doing this.</p>
        ]]></field>
        <field name="behavior_html"><![CDATA[
            <ul>
                <li>Ask questions to understand customer needs</li>
                <li>Listen to the customers</li>
                <li>Greet customers promptly and courteously</li>
                <li>Apologize for misunderstanding, inconveniences, or mistakes</li>
                <li>Take action to correct customer complaints</li>
                <li>Thank the customers</li>
                <li>Respond to customer's problem</li>
            </ul>
        ]]></field>
    </record>

    <record id="oje_template_mgmt_line_customer_1" model="recruitment.oje.template.line">
        <field name="section_id" ref="M02_P0204_00.oje_template_mgmt_section_customer"/>
        <field name="sequence">10</field>
        <field name="line_kind">management_task</field>
        <field name="question_text">Go out to the lobby with the candidate and ask him/her to talk to at least 3 different customers about how they like their food and service. Before starting, coach him/her on good questions to ask and how to respond to a complaint or negative comments.</field>
    </record>
    <record id="oje_template_mgmt_line_customer_2" model="recruitment.oje.template.line">
        <field name="section_id" ref="M02_P0204_00.oje_template_mgmt_section_customer"/>
        <field name="sequence">20</field>
        <field name="line_kind">management_task</field>
        <field name="question_text">Have the candidate handle a minor customer complaint on cold fries or incomplete order. Observe how he/she interacts with the customer.</field>
    </record>

    <record id="oje_template_mgmt_section_problem" model="recruitment.oje.template.section">
        <field name="template_id" ref="M02_P0204_00.oje_template_store_management"/>
        <field name="name">PROBLEM SOLVING</field>
        <field name="sequence">20</field>
        <field name="section_kind">management_dimension</field>
        <field name="objective_text">To evaluate candidate's thinking process in solving a problem taking into consideration resources, constraints and if possible, McDonald's values.</field>
        <field name="hint_html"><![CDATA[
            <p>Provide some layman type problems which put him first in customers shoes and then as a manager dealing with the problem.</p>
        ]]></field>
        <field name="behavior_html"><![CDATA[
            <ul>
                <li>Recognize the need to obtain more information in unclear/unfamiliar situations</li>
                <li>Recognize problems in the restaurant and suggest solutions</li>
                <li>Take action or make a decision to address/solve a problem</li>
                <li>Ask appropriate questions of others</li>
                <li>Investigate problems thoroughly</li>
            </ul>
        ]]></field>
    </record>

    <record id="oje_template_mgmt_line_problem_1" model="recruitment.oje.template.line">
        <field name="section_id" ref="M02_P0204_00.oje_template_mgmt_section_problem"/>
        <field name="sequence">10</field>
        <field name="line_kind">management_task</field>
        <field name="question_text">Make an assignment to the candidate that he/she is to tell you about any problems they see and any suggestions for improvements they have through the shift.</field>
    </record>
    <record id="oje_template_mgmt_line_problem_2" model="recruitment.oje.template.line">
        <field name="section_id" ref="M02_P0204_00.oje_template_mgmt_section_problem"/>
        <field name="sequence">20</field>
        <field name="line_kind">management_task</field>
        <field name="question_text">After explaining what to look for on a travel path, take one with the candidate. Ask him/her to point out problems and allow candidate to execute travel paths on their own.</field>
    </record>
    <record id="oje_template_mgmt_line_problem_3" model="recruitment.oje.template.line">
        <field name="section_id" ref="M02_P0204_00.oje_template_mgmt_section_problem"/>
        <field name="sequence">30</field>
        <field name="line_kind">management_task</field>
        <field name="question_text">During the travel path, have the candidate make out a TO-DO List. Evaluate the candidate on how he/she prioritizes and gets things accomplished.</field>
    </record>

    <record id="oje_template_mgmt_section_leadership" model="recruitment.oje.template.section">
        <field name="template_id" ref="M02_P0204_00.oje_template_store_management"/>
        <field name="name">LEADERSHIP &amp; COACHING</field>
        <field name="sequence">30</field>
        <field name="section_kind">management_dimension</field>
        <field name="objective_text">To see candidate's ability to interact with store members and apply interpersonal skills and flexible management styles depending on the task.</field>
        <field name="hint_html"><![CDATA[
            <ul>
                <li>Do not use all the activities described below on the first day of the OJE.</li>
                <li>Provide some scenarios and elicit a response from candidate with real-life situations.</li>
            </ul>
        ]]></field>
        <field name="behavior_html"><![CDATA[
            <ul>
                <li>State the problem/situation clearly</li>
                <li>Seek the person's input</li>
                <li>Give clear explanations</li>
                <li>Point out the importance of good performance</li>
                <li>Maintain the person's self-esteem</li>
                <li>Teach by example when appropriate</li>
                <li>Check for understanding</li>
                <li>Praise the person when appropriate</li>
            </ul>
        ]]></field>
    </record>

    <record id="oje_template_mgmt_line_leadership_1" model="recruitment.oje.template.line">
