<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Disable obsolete hr.job inherited views from legacy versions before loading current views. -->
        <function model="hr.job" name="_x_psm_deactivate_legacy_hr_job_views"/>

        <!-- Migrate wrongly bootstrapped hired event rules to module congratulations template. -->
        <function model="hr.job" name="_x_psm_migrate_hired_email_rules_to_module_template"/>

        <!-- Backfill missing hired_part_time event rules for legacy jobs that already have email config. -->
        <function model="hr.job" name="_x_psm_backfill_hired_part_time_email_rules"/>

        <!-- ================================================
             AUTO CLEANUP: Chạy tự động khi install/upgrade
             Xóa stages thừa: 'both', 'New' staff/mgmt, duplicates
        ================================================ -->
        <function model="hr.recruitment.stage" name="_auto_cleanup_redundant_stages"/>

        <!-- Archive obsolete manual cleanup server action kept from older versions. -->
        <function model="hr.recruitment.stage" name="_x_psm_archive_obsolete_stage_cleanup_server_action"/>
    </data>
</odoo>
