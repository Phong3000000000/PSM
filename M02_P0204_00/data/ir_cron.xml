<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_job_templates" model="ir.cron">
            <field name="name">Tuyển Dụng: Tự động đồng bộ Job Templates</field>
            <field name="model_id" ref="hr.model_hr_job"/>
            <field name="state">code</field>
            <field name="code">model.ensure_department_templates()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>
        <record id="ir_cron_auto_create_next_week_schedules" model="ir.cron">
            <field name="name">Tuyển Dụng: Tự động tạo lịch phỏng vấn tuần mới</field>
            <field name="model_id" ref="model_interview_schedule"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_create_next_week_schedules()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
