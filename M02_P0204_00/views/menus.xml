<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu đơn giản - không auto-create -->
    <!-- Cho phép nhóm Vận Hành thấy Menu Tuyển Dụng gốc -->
    <record id="hr_recruitment.menu_hr_recruitment_root" model="ir.ui.menu">
        <field name="group_ids" eval="[(4, ref('M02_P0204_00.group_gdh_ops_0204_mgr')), (4, ref('M02_P0204_00.group_gdh_ops_0204_crw'))]"/>
    </record>

    <menuitem 
        id="menu_interview_schedule"
        name="Lịch phỏng vấn dự kiến"
        parent="hr_recruitment.menu_hr_recruitment_root"
        action="action_psm_interview_schedule"
        sequence="15"/>

    <!-- Cho phép nhóm Vận Hành thấy Menu Cấu hình Tuyển Dụng (và giữ lại cho nhóm mặc định) -->
    <record id="hr_recruitment.menu_hr_recruitment_configuration" model="ir.ui.menu">
        <field name="group_ids" eval="[(4, ref('M02_P0204_00.group_gdh_ops_0204_mgr')), (4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
    </record>
    
    <!-- Cho phép nhóm Vận Hành thấy Menu Cấu hình Job Positions -->
    <record id="hr_recruitment.menu_hr_recruitment_config_jobs" model="ir.ui.menu">
        <field name="group_ids" eval="[(4, ref('M02_P0204_00.group_gdh_ops_0204_mgr')), (4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
    </record>

    <record id="action_master_survey_templates" model="ir.actions.act_window">
        <field name="name">Master Survey</field>
        <field name="res_model">survey.survey</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['&amp;', '&amp;', ('x_psm_0204_owner_job_id', '=', False), ('x_psm_0204_owner_department_id', '=', False), '|', ('x_psm_0204_default_template_for', '!=', False), ('x_psm_default_template_for', '!=', False)]</field>
        <field name="context">{'default_x_psm_0204_owner_job_id': False, 'default_x_psm_0204_owner_department_id': False}</field>
    </record>

    <menuitem
        id="menu_master_survey_templates"
        name="Master Survey"
        parent="hr_recruitment.menu_hr_recruitment_configuration"
        action="action_master_survey_templates"
        groups="M02_P0204_00.group_gdh_ops_0204_mgr,survey.group_survey_user,hr_recruitment.group_hr_recruitment_manager"
        sequence="25"/>

</odoo>
