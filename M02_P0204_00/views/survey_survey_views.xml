<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="survey_survey_form_inherit_flags" model="ir.ui.view">
        <field name="name">survey.survey.form.inherit.flags</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="is_pre_interview" widget="boolean_toggle"/>
                <field name="is_oje_evaluation" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
