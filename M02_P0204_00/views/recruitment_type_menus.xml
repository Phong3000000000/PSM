<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Job Positions Hierarchy -->
    
    <!-- Parent Menu -->
    <menuitem
        id="menu_recruitment_type"
        name="Loại Tuyển Dụng"
        parent="hr_recruitment.menu_hr_recruitment_root"
        sequence="10"/>

    <!-- ========================================
         DANH SÁCH YÊU CẦU TUYỂN DỤNG (RGM REVIEW)
    ======================================== -->
    <record id="action_job_approval_requests" model="ir.actions.act_window">
        <field name="name">DS Yêu cầu tuyển dụng</field>
        <field name="res_model">job.approval.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ('draft', 'submitted', 'rejected', 'approved'))]</field>
        <field name="context">{}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('M02_P0204_00.view_job_approval_request_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('M02_P0204_00.view_job_approval_request_form')})
        ]"/>
    </record>

    <menuitem
        id="menu_job_approval_requests"
        name="DS Yêu cầu tuyển dụng"
        parent="hr_recruitment.menu_hr_recruitment_root"
        action="action_job_approval_requests"
        sequence="11"
        groups="hr_recruitment.group_hr_recruitment_user,hr_recruitment.group_hr_recruitment_manager"/>
    
    <!-- ========================================
          KHỐI CỬA HÀNG - Job Positions  
          Click on job opens applicants kanban by default
     ======================================== -->
    <record id="action_job_positions_store" model="ir.actions.act_window">
        <field name="name">Khối Cửa Hàng</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('hr_recruitment.view_hr_job_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr.view_hr_job_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr.view_hr_job_form')})
        ]"/>
        <field name="domain">[('recruitment_type', '=', 'store')]</field>
        <field name="context">{
            'default_recruitment_type': 'store',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo vị trí tuyển dụng cho khối cửa hàng
            </p>
            <p>Click vào job position để xem ứng viên</p>
        </field>
    </record>
    
    <menuitem
        id="menu_job_positions_store"
        name="Khối Cửa Hàng"
        parent="menu_recruitment_type"
        action="action_job_positions_store"
        sequence="10"/>
    
    <!-- ========================================
          KHỐI VĂN PHÒNG - Job Positions
     ======================================== -->
    <record id="action_job_positions_office" model="ir.actions.act_window">
        <field name="name">Khối Văn Phòng</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="hr_recruitment.view_hr_job_kanban"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('hr_recruitment.view_hr_job_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr.view_hr_job_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr.view_hr_job_form')})
        ]"/>
        <field name="domain">[('recruitment_type', '=', 'office')]</field>
        <field name="context">{'default_recruitment_type': 'office'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo vị trí tuyển dụng cho khối văn phòng</p>
        </field>
    </record>

    <menuitem
        id="menu_job_positions_office"
        name="Khối Văn Phòng"
        parent="menu_recruitment_type"
        action="action_job_positions_office"
        sequence="15"/>

    <!-- ========================================
          NHÂN VIÊN (STAFF) - Job Positions
     ======================================== -->
    <record id="action_job_positions_staff" model="ir.actions.act_window">
        <field name="name">Nhân Viên</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="hr_recruitment.view_hr_job_kanban"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('hr_recruitment.view_hr_job_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr.view_hr_job_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr.view_hr_job_form')})
        ]"/>
        <field name="domain">[('position_level', '=', 'staff')]</field>
        <field name="context">{'default_recruitment_type': 'office', 'default_position_level': 'staff'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo vị trí tuyển dụng cho nhân viên</p>
        </field>
    </record>

    <menuitem
        id="menu_job_positions_staff"
        name="Nhân Viên"
        parent="menu_recruitment_type"
        action="action_job_positions_staff"
        sequence="20"/>

    <!-- ========================================
          QUẢN LÝ (MANAGEMENT) - Job Positions
     ======================================== -->
    <record id="action_job_positions_management" model="ir.actions.act_window">
        <field name="name">Quản Lý</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="hr_recruitment.view_hr_job_kanban"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('hr_recruitment.view_hr_job_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr.view_hr_job_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr.view_hr_job_form')})
        ]"/>
        <field name="domain">[('position_level', '=', 'management')]</field>
        <field name="context">{'default_recruitment_type': 'office', 'default_position_level': 'management'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo vị trí tuyển dụng cho quản lý</p>
        </field>
    </record>

    <menuitem
        id="menu_job_positions_management"
        name="Quản Lý"
        parent="menu_recruitment_type"
        action="action_job_positions_management"
        sequence="30"/>
</odoo>
