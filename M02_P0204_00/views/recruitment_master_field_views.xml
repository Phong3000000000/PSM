<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===== FORM VIEW ===== -->
    <record id="recruitment_application_field_master_view_form" model="ir.ui.view">
        <field name="name">recruitment.application.field.master.view.form</field>
        <field name="model">recruitment.application.field.master</field>
        <field name="arch" type="xml">
            <form string="Cấu hình trường mặc định">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group string="Thông tin cơ bản">
                            <field name="field_label"/>
                            <field name="field_name"/>
                            <field name="field_type"/>
                            <field name="section"/>
                            <field name="col_size"/>
                        </group>
                        <group string="Mặc định khi load vào Job">
                            <field name="sequence"/>
                            <field name="recruitment_scope" widget="radio"/>
                            <field name="is_active_default" widget="boolean_toggle"/>
                            <field name="is_required_default" widget="boolean_toggle"/>
                            <separator string="Cấu hình Phải đúng"/>
                            <field name="is_answer_must_match_default" widget="boolean_toggle"
                                   string="Phải đúng"
                                   invisible="field_type not in ('select', 'radio', 'checkbox')"/>
                            <field name="auto_reject_if_wrong_default" widget="boolean_toggle"
                                string="Loại khi sai"
                                invisible="field_type not in ('select', 'radio', 'checkbox')"/>
                            <!-- UI bridge: select/radio chọn từ option -->
                            <field name="expected_answer_option_id"
                                   string="Đáp án phải đúng"
                                   invisible="not is_answer_must_match_default or field_type not in ('select', 'radio')"/>
                            <!-- UI bridge: checkbox chọn Có/Không -->
                            <field name="expected_answer_checkbox"
                                   string="Đáp án phải đúng"
                                   invisible="not is_answer_must_match_default or field_type != 'checkbox'"/>
                            <!-- Giữ expected_answer ẩn để lưu dữ liệu kỹ thuật -->
                            <field name="expected_answer" invisible="1"/>
                        </group>
                    </group>
                    <notebook invisible="field_type not in ('select', 'radio')">
                        <page string="Lựa chọn (Options)" name="options">
                            <field name="option_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===== LIST VIEW ===== -->
    <record id="recruitment_application_field_master_view_list" model="ir.ui.view">
        <field name="name">recruitment.application.field.master.view.list</field>
        <field name="model">recruitment.application.field.master</field>
        <field name="arch" type="xml">
            <list string="Trường mặc định biểu mẫu">
                <field name="sequence" widget="handle"/>
                <field name="field_label"/>
                <field name="field_name"/>
                <field name="field_type"/>
                <field name="section"/>
                <field name="recruitment_scope"/>
                <field name="is_active_default" widget="boolean_toggle" string="Mặc định Bật"/>
                <field name="is_required_default" widget="boolean_toggle" string="Mặc định Bắt buộc"/>
                    <field name="is_answer_must_match_default" widget="boolean_toggle" string="Phải đúng"
                       invisible="field_type not in ('select', 'radio', 'checkbox')"/>
                    <field name="auto_reject_if_wrong_default" widget="boolean_toggle" string="Loại khi sai"
                       invisible="field_type not in ('select', 'radio', 'checkbox')"/>
                <field name="expected_answer" optional="hide"/>
                <field name="col_size" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ===== SEARCH VIEW ===== -->
    <record id="recruitment_application_field_master_view_search" model="ir.ui.view">
        <field name="name">recruitment.application.field.master.view.search</field>
        <field name="model">recruitment.application.field.master</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm trường">
                <field name="field_label" string="Nhãn"/>
                <field name="field_name" string="Tên trường"/>
            </search>
        </field>
    </record>

    <!-- ===== ACTION WINDOW ===== -->
    <record id="action_recruitment_application_field_master" model="ir.actions.act_window">
        <field name="name">Trường mặc định biểu mẫu ứng tuyển</field>
        <field name="res_model">recruitment.application.field.master</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo trường mặc định đầu tiên
            </p>
            <p>
                Đây là nguồn trường mặc định toàn hệ thống cho Biểu mẫu Ứng tuyển.
                Mỗi Job Position sẽ load các trường này khi bấm "Tải lại từ cấu hình mặc định".
            </p>
        </field>
    </record>

</odoo>
