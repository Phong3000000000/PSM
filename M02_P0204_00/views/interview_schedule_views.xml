<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Interview Schedule Views -->
    
    <!-- Kanban View - Hiển thị Cards cho từng cửa hàng -->
    <record id="view_interview_schedule_kanban" model="ir.ui.view">
        <field name="name">interview.schedule.kanban</field>
        <field name="model">interview.schedule</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="company_id"/>
                <field name="department_id"/>
                <field name="store_address"/>
                <field name="week_display"/>
                <field name="interview_date_1"/>
                <field name="interview_date_2"/>
                <field name="interview_date_3"/>
                <field name="max_candidates_slot_1"/>
                <field name="max_candidates_slot_2"/>
                <field name="max_candidates_slot_3"/>
                <field name="slot_1_remaining"/>
                <field name="slot_2_remaining"/>
                <field name="slot_3_remaining"/>
                <field name="state"/>
                <field name="applicant_count"/>
                <templates>
                    <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <!-- Header -->
                                <div class="o_kanban_record_top mb-3">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <i class="fa fa-sitemap me-2"/>
                                            <field name="department_id"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle text-muted">
                                            <i class="fa fa-calendar me-1"/>
                                            Tuần: <field name="week_display"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <field name="state" widget="label_selection" 
                                            options="{'classes': {'draft': 'secondary', 'confirmed': 'success'}}"/>
                                    </div>
                                </div>
                            
                            <!-- 3 Ngày PV -->
                            <div class="container">
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-users text-warning me-2"/>
                                        <strong>Tối đa:</strong>
                                        PV1 <field name="max_candidates_slot_1"/> |
                                        PV2 <field name="max_candidates_slot_2"/> |
                                        PV3 <field name="max_candidates_slot_3"/>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-primary me-2"/>
                                        <strong>Ngày PV 1:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_1_vn"/></span>
                                        <div class="ms-4 text-muted">Còn lại: <field name="slot_1_remaining"/></div>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-success me-2"/>
                                        <strong>Ngày PV 2:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_2_vn"/></span>
                                        <div class="ms-4 text-muted">Còn lại: <field name="slot_2_remaining"/></div>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-12">
                                        <i class="fa fa-calendar-check text-info me-2"/>
                                        <strong>Ngày PV 3:</strong><br/>
                                        <span class="ms-4"><field name="interview_date_3_vn"/></span>
                                        <div class="ms-4 text-muted">Còn lại: <field name="slot_3_remaining"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_interview_schedule_form" model="ir.ui.view">
        <field name="name">interview.schedule.form</field>
        <field name="model">interview.schedule</field>
        <field name="arch" type="xml">
            <form string="Lịch Phỏng Vấn">
                <header>
                    <button name="action_confirm" 
                            string="Xác Nhận" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state == 'confirmed'"/>
                    
                    <button name="action_set_draft" 
                            string="Chuyển Về Nháp" 
                            type="object" 
                            invisible="state == 'draft'"/>
                    
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,confirmed"/>
                </header>
                
                <sheet>
                    <group>
                        <group string="Thông Tin Chi Tiết">
                            <field name="department_id" options="{'no_create': True}"/>
                            <field name="company_id" invisible="1"/>
                            <field name="store_address" placeholder="VD: 72 Lê Thánh Tôn" invisible="1"/>
                            <field name="manager_id" readonly="1" invisible="1"/>
                            <field name="create_uid" string="Do ai tạo" readonly="1" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Thông Tin Tuần">
                            <field name="week_start_date"/>
                            <field name="week_display" readonly="1"/>
                            <field name="applicant_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="3 Slot Phỏng Vấn Trong Tuần">
                        <field name="interview_date_1_vn" invisible="not interview_date_1"/>
                        <field name="interview_date_1" string="Sửa Ngày PV 1" invisible="state == 'confirmed'"/>
                        <field name="interview_date_2_vn" invisible="not interview_date_2"/>
                        <field name="interview_date_2" string="Sửa Ngày PV 2" invisible="state == 'confirmed'"/>
                        <field name="interview_date_3_vn" invisible="not interview_date_3"/>
                        <field name="interview_date_3" string="Sửa Ngày PV 3" invisible="state == 'confirmed'"/>
                        <field name="max_candidates_slot_1"/>
                        <field name="max_candidates_slot_2"/>
                        <field name="max_candidates_slot_3"/>
                        <field name="slot_1_remaining" readonly="1"/>
                        <field name="slot_2_remaining" readonly="1"/>
                        <field name="slot_3_remaining" readonly="1"/>
                    </group>
                    
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"/> 
                        <strong>Lưu ý:</strong> Store Manager đặt 3 slot để HR gửi cho ứng viên chọn.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_interview_schedule" model="ir.actions.act_window">
        <field name="name">Lịch Phỏng Vấn Dự Kiến</field>
        <field name="res_model">interview.schedule</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_interview_schedule_kanban')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_interview_schedule_form')}),
        ]"/>
        <field name="context">{'ensure_company_schedules': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo lịch phỏng vấn cho cửa hàng
            </p>
            <p>
                Store Manager đặt 3 ngày trong tuần có thể phỏng vấn.<br/>
                HR sẽ gửi email cho ứng viên với 3 ngày này.
            </p>
        </field>
    </record>

    <!-- XML ID alias: action chuẩn hóa theo quy ước mới, giữ nguyên record gốc -->
    <record id="alias_action_psm_interview_schedule" model="ir.model.data">
        <field name="module">M02_P0204_00</field>
        <field name="name">action_psm_interview_schedule</field>
        <field name="model">ir.actions.act_window</field>
        <field name="res_id" eval="ref('action_interview_schedule')"/>
        <field name="noupdate" eval="1"/>
    </record>
</odoo>
