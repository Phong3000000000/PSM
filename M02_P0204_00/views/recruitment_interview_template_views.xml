<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_recruitment_interview_template_tree" model="ir.ui.view">
        <field name="name">recruitment.interview.template.tree</field>
        <field name="model">recruitment.interview.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="version"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_recruitment_interview_template_form" model="ir.ui.view">
        <field name="name">recruitment.interview.template.form</field>
        <field name="model">recruitment.interview.template</field>
        <field name="arch" type="xml">
            <form string="Mau Interview mac dinh">
                <header>
                    <button name="action_preview_interview_form"
                            type="object"
                            string="Preview"
                            class="btn-primary"
                            icon="fa-eye"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="version"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group>
                        <field name="intro_html" widget="html"/>
                    </group>

                    <field name="section_ids" nolabel="1">
                        <list decoration-muted="not is_active">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="line_count" string="So cau"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </list>
                        <form string="Section Interview">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="sequence"/>
                                    </group>
                                    <group>
                                        <field name="is_active" widget="boolean_toggle"/>
                                    </group>
                                </group>

                                <field name="line_ids" nolabel="1">
                                    <list editable="bottom" decoration-muted="not is_active">
                                        <field name="sequence" widget="handle"/>
                                        <field name="display_type"/>
                                        <field name="label"/>
                                        <field name="question_text"/>
                                        <field name="is_required" widget="boolean_toggle"/>
                                        <field name="is_active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </sheet>
                        </form>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_recruitment_interview_template" model="ir.actions.act_window">
        <field name="name">Mau Interview mac dinh</field>
        <field name="res_model">recruitment.interview.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
