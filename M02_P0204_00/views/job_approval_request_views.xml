<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Tree View cho Danh Sách Yêu Cầu Tuyển Dụng -->
    <record id="view_job_approval_request_tree" model="ir.ui.view">
        <field name="name">job.approval.request.tree</field>
        <field name="model">job.approval.request</field>
        <field name="arch" type="xml">
            <list string="Yêu cầu tuyển dụng" default_order="create_date desc">
                <field name="name"/>
                <field name="department_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="no_of_recruitment"/>
                <field name="requester_user_id" string="Người Yêu Cầu" widget="many2one_avatar_user"/>
                <field name="approver_user_id" string="Người Duyệt" widget="many2one_avatar_user" optional="show"/>
                <field name="create_date" string="Ngày Yêu Cầu" widget="date"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'submitted'" 
                       decoration-success="state == 'approved'" 
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Form View cho Yêu Cầu Tuyển Dụng -->
    <record id="view_job_approval_request_form" model="ir.ui.view">
        <field name="name">job.approval.request.form</field>
        <field name="model">job.approval.request</field>
        <field name="arch" type="xml">
            <form string="Yêu Cầu Tuyển Dụng">
                <header>
                    <button name="action_submit_approval" string="Gửi Yêu Cầu Duyệt" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Phê Duyệt" type="object" class="btn-success" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Từ Chối" type="object" class="btn-danger" invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ví dụ: Cửa hàng trưởng..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="requester_user_id" string="Người Yêu Cầu" widget="many2one_avatar_user" readonly="1"/>
                            <field name="approver_user_id" string="Người Duyệt" widget="many2one_avatar_user" readonly="1"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="no_of_recruitment"/>
                        </group>
                        <group>
                            <field name="recruitment_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="position_level" widget="radio" options="{'horizontal': true}"/>
                            <field name="job_id" invisible="not job_id"/>
                            <field name="reject_reason" invisible="state != 'rejected'" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_job_approval_request_search" model="ir.ui.view">
        <field name="name">job.approval.request.search</field>
        <field name="model">job.approval.request</field>
        <field name="arch" type="xml">
            <search string="Yêu cầu">
                <field name="name"/>
                <field name="department_id"/>
                <field name="requester_user_id"/>
                <field name="approver_user_id"/>
                <separator/>
                <filter string="Cần tôi duyệt" name="my_approvals" domain="[('approver_user_id', '=', uid)]"/>
            </search>
        </field>
    </record>

</odoo>
