<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_recruitment_stage_form_inherit" model="ir.ui.view">
        <field name="name">hr.recruitment.stage.form.inherit</field>
        <field name="model">hr.recruitment.stage</field>
        <field name="inherit_id" ref="hr_recruitment.hr_recruitment_stage_form"/>
        <field name="arch" type="xml">
            <field name="job_ids" position="after">
                <field name="recruitment_type" widget="radio"/>
                <group string="Cấu hình gửi Email Mặc định">
                    <field name="candidate_email_enabled"/>
                    <field name="candidate_email_template_id" invisible="not candidate_email_enabled" required="candidate_email_enabled"/>
                </group>
            </field>
        </field>
    </record>
    
    <record id="hr_recruitment_stage_tree_inherit" model="ir.ui.view">
        <field name="name">hr.recruitment.stage.tree.inherit</field>
        <field name="model">hr.recruitment.stage</field>
        <field name="inherit_id" ref="hr_recruitment.hr_recruitment_stage_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="recruitment_type" widget="badge" decoration-success="recruitment_type == 'store'" decoration-info="recruitment_type == 'office'"/>
            </field>
        </field>
    </record>
</odoo>
