<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_create_job_templates_wizard_form" model="ir.ui.view">
        <field name="name">create.job.templates.wizard.form</field>
        <field name="model">create.job.templates.wizard</field>
        <field name="arch" type="xml">
            <form string="Tạo hr.job Templates">
                <group>
                    <field name="recruitment_type"/>
                    <field name="position_level"/>
                </group>
                <footer>
                    <button name="action_create_templates" string="Tạo Templates" type="object" class="btn-primary"/>
                    <button name="action_create_all_templates" string="Tạo Tất Cả Templates" type="object" class="btn-secondary"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_create_job_templates_wizard" model="ir.actions.act_window">
        <field name="name">Tạo hr.job Templates</field>
        <field name="res_model">create.job.templates.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- XML ID alias: action chuẩn hóa theo quy ước mới, giữ nguyên record gốc -->
    <record id="alias_action_psm_create_job_templates_wizard" model="ir.model.data">
        <field name="module">M02_P0204_00</field>
        <field name="name">action_psm_create_job_templates_wizard</field>
        <field name="model">ir.actions.act_window</field>
        <field name="res_id" eval="ref('action_create_job_templates_wizard')"/>
        <field name="noupdate" eval="1"/>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_create_job_templates_wizard"
        name="Tạo Job Templates"
        parent="hr_recruitment.menu_hr_recruitment_root"
        action="action_psm_create_job_templates_wizard"
        sequence="5"
        groups="hr_recruitment.group_hr_recruitment_manager"/>
</odoo>
