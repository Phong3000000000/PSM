    <!-- DEACTIVATE the default global multi-company rule for hr.applicant -->
    <!-- This is necessary because global rules cannot be overridden by non-global rules -->
    <record id="hr_recruitment.hr_applicant_comp_rule" model="ir.rule">
        <field name="active" eval="False"/>
    </record>

    <!-- NEW: Multi-company rule for hr.applicant - applies to all users by default -->
    <!-- Users can only see applicants from their allowed companies OR applicants with no company -->
    <record id="hr_applicant_comp_rule_custom" model="ir.rule">
        <field name="name">Applicant multi company rule (Custom)</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field eval="True" name="global"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
    </record>

    <!-- OVERRIDE for HR Recruitment User: Restrict to Department -->
    <record id="rule_hr_applicant_user_all" model="ir.rule">
        <field name="name">HR Applicant User: Department Visibility</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        <field name="domain_force">['|', '|', '|', '|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.mapped('department_id').ids), ('department_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.parent_id.manager_id.user_id', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

    <!-- For Interviewer group - restrict to their assigned applicants only -->
    <record id="rule_hr_applicant_interviewer" model="ir.rule">
        <field name="name">HR Applicant: Interviewer Access</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_interviewer'))]"/>
        <!-- FIX: Removed company_id domain to prevent full company access for Store Managers -->
        <field name="domain_force">['|', ('interviewer_ids', 'in', user.id), ('create_uid', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- NEW: Multi-department rule for hr.applicant for Store/Ops Managers -->
    <record id="rule_hr_applicant_department_hierarchy" model="ir.rule">
        <field name="name">HR Applicant: Department Hierarchy Visibility</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('group_gdh_ops_0204_crw')), (4, ref('group_gdh_ops_0204_mgr'))]"/>
        <field name="domain_force">['|', '|', '|', '|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.mapped('department_id').ids), ('department_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.parent_id.manager_id.user_id', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- NEW: Multi-department rule for hr.department -->
    <record id="rule_hr_department_hierarchy" model="ir.rule">
        <field name="name">HR Department: Hierarchy Visibility</field>
        <field name="model_id" ref="hr.model_hr_department"/>
        <field name="groups" eval="[(4, ref('group_gdh_ops_0204_crw')), (4, ref('group_gdh_ops_0204_mgr'))]"/>
        <!-- Cho phép thấy phòng ban của mình, phòng ban mình làm quản lý, và các phòng ban con của nó -->
        <field name="domain_force">['|', '|', '|', ('id', 'in', user.employee_ids.mapped('department_id').ids), ('manager_id.user_id', '=', user.id), ('parent_id.manager_id.user_id', '=', user.id), ('parent_id.parent_id.manager_id.user_id', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- NEW: Multi-department rule for hr.employee restricted to hr_recruitment_user -->
    <!-- GLOBAL RULE: Restrict hr.employee to department UNLESS user is HR Manager -->
    <record id="rule_hr_employee_global_department" model="ir.rule">
        <field name="name">HR Employee: Global Department Visibility</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- GLOBAL RULE: Restrict hr.job to department UNLESS user is HR Manager -->
    <record id="rule_hr_job_global_department" model="ir.rule">
        <field name="name">HR Job: Global Department Visibility</field>
        <field name="model_id" ref="hr.model_hr_job"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

</odoo>
