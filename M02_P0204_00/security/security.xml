<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="group_store_manager" model="res.groups">
        <field name="name">Store Manager</field>
        <!-- Imply basic Interviewer access so they can use Recruitment app -->
        <field name="implied_ids" eval="[(4, ref('hr_recruitment.group_hr_recruitment_interviewer'))]"/>
        <field name="comment">Store Manager có thể tạo lịch PV cho brand của mình</field>
    </record>

    <!-- XML ID alias: dùng tên chuẩn mới nhưng giữ nguyên record gốc để tránh tạo trùng khi upgrade -->
    <record id="alias_group_gdh_ops_0204_crw" model="ir.model.data">
        <field name="module">M02_P0204_00</field>
        <field name="name">group_gdh_ops_0204_crw</field>
        <field name="model">res.groups</field>
        <field name="res_id" eval="ref('group_store_manager')"/>
        <field name="noupdate" eval="1"/>
    </record>

    <record id="group_operations_manager" model="res.groups">
        <field name="name">Operations Manager (RGM/DM)</field>
        <field name="implied_ids" eval="[(4, ref('group_gdh_ops_0204_crw')), (4, ref('survey.group_survey_user'))]"/>
        <field name="comment">Operations Manager quản lý nhiều lịch PV và yêu cầu tuyển dụng, khảo sát</field>
    </record>

    <!-- XML ID alias: dùng tên chuẩn mới nhưng giữ nguyên record gốc để tránh tạo trùng khi upgrade -->
    <record id="alias_group_gdh_ops_0204_mgr" model="ir.model.data">
        <field name="module">M02_P0204_00</field>
        <field name="name">group_gdh_ops_0204_mgr</field>
        <field name="model">res.groups</field>
        <field name="res_id" eval="ref('group_operations_manager')"/>
        <field name="noupdate" eval="1"/>
    </record>

    <!-- Record Rules -->
    
    <!-- Interview Schedule Visibility Rule (For Store Manager / Operations Manager) -->
    <!-- Users can only see schedules for Departments they manage or belong to (including child departments) -->
    <record id="rule_interview_schedule_department_hierarchy" model="ir.rule">
        <field name="name">Interview Schedule: Department Hierarchy Visibility</field>
        <field name="model_id" ref="model_interview_schedule"/>
        <field name="groups" eval="[(4, ref('group_gdh_ops_0204_crw')), (4, ref('group_gdh_ops_0204_mgr'))]"/>
        <field name="domain_force">['|', '|', '|', '|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.mapped('department_id').ids), ('department_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.parent_id.manager_id.user_id', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

    <!-- HR/Recruitment users can only see their department's schedules -->
    <record id="rule_interview_schedule_hr_all" model="ir.rule">
        <field name="name">Interview Schedule: HR Department Visibility</field>
        <field name="model_id" ref="model_interview_schedule"/>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        <field name="domain_force">['|', '|', '|', '|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.mapped('department_id').ids), ('department_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.manager_id.user_id', '=', user.id), ('department_id.parent_id.parent_id.manager_id.user_id', '=', user.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

    <!-- HR/Recruitment Managers see all schedules -->
    <record id="rule_interview_schedule_hr_manager_all" model="ir.rule">
        <field name="name">Interview Schedule: HR Manager All Visibility</field>
        <field name="model_id" ref="model_interview_schedule"/>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

