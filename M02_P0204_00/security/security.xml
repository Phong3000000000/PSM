    <!-- DEACTIVATE the default global multi-company rule for hr.job -->
    <!-- Fix: Website frontend forces company_ids to only website's company, -->
    <!-- blocking access to hr.job records from other companies (403 error) -->
    <!-- <record id="hr.hr_job_comp_rule" model="ir.rule">
        <field name="active" eval="False"/>
    </record> -->

    <!-- Custom rule: Job Positions accessible from all companies -->
    <!-- <record id="hr_job_comp_rule_custom" model="ir.rule">
        <field name="name">Job multi company rule (Custom - All Companies)</field>
        <field name="model_id" ref="hr.model_hr_job"/>
        <field eval="True" name="global"/>
        <field name="domain_force">[(1, '=', 1)]</field>
