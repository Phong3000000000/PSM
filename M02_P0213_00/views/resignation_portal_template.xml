                    border-color: rgba(255, 255, 255, 0.08);
                    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.35);
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-commit-panel-intro,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-commit-panel-intro {
                    color: #d6d3d1;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-commit-item,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-commit-item {
                    background: rgba(255, 255, 255, 0.04);
                    border-color: rgba(255, 255, 255, 0.08);
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-commit-item-text,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-commit-item-text {
                    color: #f5f5f4;
                }
            </style>
            <div id="wrap" class="container mt-4 psm-ops-resignation-portal">
                <div class="card p-4 shadow-sm">
                    <h3 class="mb-4">
                        <i class="fa fa-sign-out text-danger me-2"/>
                        Gửi yêu cầu nghỉ việc
                    </h3>

                    <t t-if="success or (resignation_request and resignation_request.request_status in ['pending', 'approved', 'done'])">
                        <div class="mb-4">
                            <div t-if="resignation_request.request_status == 'pending'" class="alert alert-info">
                                <i class="fa fa-clock-o me-2"/> <strong>Đã gửi yêu cầu:</strong> Đơn của bạn đang chờ quản lý <strong><t t-esc="resignation_request.x_psm_0213_employee_id.parent_id.name"/></strong> phê duyệt.
                            </div>
                            <div t-elif="resignation_request.request_status == 'approved'" class="alert alert-success">
                                <i class="fa fa-check-circle me-2"/> <strong>Đã phê duyệt:</strong> Đơn nghỉ việc đã được chấp thuận. Vui lòng hoàn thành các đầu việc bên dưới.
                            </div>
                            <div t-elif="resignation_request.request_status == 'done'" class="alert alert-primary">
                                <i class="fa fa-flag-checkered me-2"/> <strong>Hoàn tất:</strong> Quy trình nghỉ việc của bạn đã hoàn thành. Chúc bạn thành công trên chặng đường mới!
                            </div>
                        </div>

                            <!-- Checkbox Checklist for Portal Users -->
                        <div t-if="survey_url or activities" class="mt-4 mb-4">
                            <h4 class="text-primary mb-4">
                                <i class="fa fa-list-check me-2"/>Danh sách công việc của bạn
                            </h4>
                            
                            <!-- Exit Survey Highlight -->
                            <div t-if="survey_url" class="card border-primary mb-4 shadow-sm bg-light theme-survey-card">
                                <div class="card-body d-flex justify-content-between align-items-center p-3">
                                    <div>
                                        <h5 class="card-title text-primary fw-bold mb-1 theme-survey-title"><i class="fa fa-wpforms me-2"/>Khảo sát Nghỉ việc (Exit Interview)</h5>
                                        <p class="card-text small text-muted mb-0">Vui lòng hoàn thành khảo sát này trước ngày nghỉ chính thức.</p>
                                    </div>
                                    <a t-att-href="survey_url" target="_blank" class="btn btn-primary d-flex align-items-center shadow-sm">
                                        Làm khảo sát <i class="fa fa-external-link ms-2"/>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="row g-3">
                                <t t-foreach="activities" t-as="activity">
                                    <div class="col-12">
                                        <div t-attf-class="card border-0 shadow-sm h-100 theme-task-card #{'theme-task-card-inactive' if not activity.active else ''}" style="border-left: 4px solid #dee2e6 !important;">
                                            <t t-if="activity.active">
                                                <t t-set="border_color" t-value="'#0d6efd' if activity.user_id == request.env.user else '#6c757d'"/>
                                                <div t-attf-style="position: absolute; left: -4px; top: 0; bottom: 0; width: 4px; background-color: #{border_color}; border-radius: 4px 0 0 4px;"/>
                                            </t>
                                            
                                            <div class="card-body p-2 px-3">
                                                <div class="d-flex justify-content-between align-items-start mb-1">
                                                    <!-- Title (Left) -->
                                                    <div class="flex-grow-1">
                                                        <h6 t-attf-class="fw-bold mb-0 #{'text-muted text-decoration-line-through' if not activity.active else 'text-dark'}">
                                                            <t t-esc="activity.summary or activity.activity_type_id.name"/>
                                                        </h6>
                                                    </div>

                                                    <!-- Deadline & Action (Unified Unit) -->
                                                    <div class="d-flex align-items-center flex-shrink-0 ms-2" style="min-height: 24px;">
                                                        <div class="d-flex align-items-center rounded-pill px-2 py-1 theme-task-meta">
                                                            <!-- Deadline Label -->
                                                            <small t-if="activity.date_deadline" t-attf-class="fw-normal mb-0 #{'text-danger fw-bold' if activity.state == 'overdue' and activity.active else 'text-dark'}" style="font-size: 0.75rem; white-space: nowrap;">
                                                                <i class="fa fa-calendar-check-o me-1"/>Hạn: <t t-esc="activity.date_deadline"/>
                                                            </small>

                                                            <!-- Small Separator if both exist -->
                                                            <div t-if="activity.date_deadline and (not activity.active or (activity.user_id == request.env.user and activity.active))" class="mx-2" style="width: 1px; height: 10px; background-color: #dee2e6;"/>

                                                            <!-- Action: Done Button -->
                                                            <t t-if="activity.user_id == request.env.user and activity.active">
                                                                <form action="/my/resignation/ops/activity/done" method="post" class="m-0 d-inline">
                                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                                    <input type="hidden" name="activity_id" t-att-value="activity.id"/>
                                                                    <button type="submit" class="btn p-0 text-success fw-bold border-0 d-flex align-items-center" style="font-size: 0.75rem; transition: transform 0.2s;">
                                                                        <i class="fa fa-check me-1"/>Xác nhận thực hiện
                                                                    </button>
                                                                </form>
                                                            </t>

                                                            <!-- Action: Done Icon -->
                                                            <t t-if="not activity.active">
                                                                <div class="text-success d-flex align-items-center">
                                                                    <i class="fa fa-check-circle" style="font-size: 0.9rem;"/>
                                                                </div>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Description -->
                                                <div t-if="activity.note" t-attf-class="small mb-2 #{'text-muted' if not activity.active else 'text-dark'}" style="line-height: 1.5; padding-right: 40px; font-weight: 450;">
                                                    <t t-out="activity.note"/>
                                                </div>
                                                
                                                <!-- Responsible Badge -->
                                                <div t-if="activity.user_id != request.env.user" class="d-flex">
                                                    <span class="badge rounded-pill fw-normal px-2 py-1 theme-task-owner">
                                                        <i class="fa fa-user-o me-1"/> Phụ trách: <t t-esc="activity.user_id.name"/>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="text-center mt-5">  
                            <a href="/my" class="btn btn-secondary">
                                <i class="fa fa-arrow-left me-2"/>Quay lại Portal
                            </a>
                        </div>
                    </t>
                    <t t-else="">
                        <t t-if="not employee">
                            <div class="alert alert-danger mt-4 mb-4">
                                <i class="fa fa-warning me-2"/>
                                <strong>Lỗi:</strong> Không tìm thấy thông tin nhân viên liên kết với tài khoản này. Vui lòng liên hệ bộ phận IT hoặc HR.
                            </div>
                        </t>

                        <form action="/my/resignation/submit" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <!-- Biểu ngữ -->
                        <div class="text-center mb-4">
                            <h4 class="fw-bold text-uppercase mb-0">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <h5 class="fw-bold mb-1">Độc lập - Tự do - Hạnh phúc</h5>
                            <hr class="mx-auto" style="width: 200px; border-top: 2px solid #000;"/>
                            <h3 class="fw-bold mt-3">ĐƠN XIN NGHỈ VIỆC</h3>
                        </div>
                        
                        <!-- Thông tin nhân viên -->
                        <h5 class="text-primary mt-3 mb-3">
                            <i class="fa fa-user me-2"/>Thông tin nhân viên
                        </h5>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Họ tên nhân viên</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.name or partner.name" 
                                    readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày sinh</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.birthday or 'N/A'" 
                                    readonly="1"/>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Quốc tịch</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.country_id.name or 'N/A'" 
                                    readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">CCCD</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.identification_id or 'N/A'" 
                                    readonly="1"/>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phòng ban</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.department_id.name or 'N/A'" 
                                    readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Chức vụ</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.job_id.name or 'N/A'" 
                                    readonly="1"/>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Line Manager</label>
                                    <input type="text" class="form-control bg-light" 
                                        t-att-value="employee.parent_id.name or 'Chưa có Line Manager'" 
                                        readonly="1"/>
                                    <input type="hidden" name="approver_user_id" 
                                        t-att-value="employee.parent_id.user_id.id"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email công việc</label>
                                <input type="text" class="form-control bg-light" 
                                    t-att-value="employee.work_email or 'N/A'" 
                                    readonly="1"/>
                            </div>
                        </div>

                        
                        <p class="mt-4 mb-4" style="font-size: 1rem;">
                            Nay tôi làm đơn này, kính xin quý công ty cho tôi được nghỉ việc.
                        </p>

                        <h5 class="text-primary mt-4 mb-3">
                            <i class="fa fa-edit me-2"/>Thông tin nghỉ việc
                        </h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày nghỉ dự kiến</label>
                                <input type="date"
                                    name="resignation_date"
                                    class="form-control"
                                    required="required"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Loại nghỉ việc</label>
                                <select name="resignation_type_id" class="form-select" required="required">
                                    <option value="">-- Chọn loại nghỉ việc --</option>
                                    <t t-foreach="resignation_types" t-as="resignation_type">
                                        <option t-att-value="resignation_type.id">
                                            <t t-esc="resignation_type.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mô tả lý do nghỉ việc</label>
                            <textarea name="resignation_reason"
                                class="form-control"
                                rows="4"
                                placeholder="Vui lòng nhập mô tả chi tiết cho lý do nghỉ việc đã chọn"
                                required="required"/>
                        </div>
                        
                        <!-- Lý do nghỉ việc -->
                        <h5 class="text-primary mt-4 mb-3">
                            <i class="fa fa-shield me-2"/>Xác nhận và cam kết
                        </h5>

                        <!-- Quy định và cam kết -->
                        <div class="mt-4 mb-4 theme-commit-panel">
                            <div class="px-4 py-3" style="background: linear-gradient(90deg, #8f2635 0%, #b4462b 100%); color: #fff7f2;">
                                <div style="font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.9;">Bước xác nhận cuối</div>
                                <div class="fw-semibold" style="font-size: 1.1rem;">Vui lòng đọc kỹ các điều khoản trước khi gửi yêu cầu nghỉ việc</div>
                            </div>
                            <div class="p-4 p-md-4">
                                <p class="mb-4 theme-commit-panel-intro" style="font-size: 0.98rem; line-height: 1.8;">
                                    Nội dung dưới đây giữ nguyên ý nghĩa cam kết hiện tại, chỉ được trình bày lại rõ ràng hơn để bạn dễ đọc và xác nhận.
                                </p>
                                <div class="d-flex flex-column gap-3">
                                    <div class="d-flex align-items-start gap-3 p-3 theme-commit-item">
                                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; border-radius: 50%; background: #8f2635; color: #fff; font-weight: 700;">1</div>
                                        <div class="theme-commit-item-text"><strong>Tuân thủ quy trình nghỉ việc</strong> của công ty và các trách nhiệm, chế độ thanh toán khi chấm dứt hợp đồng lao động, bao gồm nhưng không giới hạn quy định hoàn trả đồng phục, tài sản, quyết toán lương, nhận sổ/tờ rời BHXH &amp; Quyết định nghỉ việc.</div>
                                    </div>
                                    <div class="d-flex align-items-start gap-3 p-3 theme-commit-item">
                                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; border-radius: 50%; background: #8f2635; color: #fff; font-weight: 700;">2</div>
                                        <div class="theme-commit-item-text"><strong>Nếu chấm dứt làm việc trước thời hạn cho phép</strong>, công ty có quyền khấu trừ vào bất kỳ khoản thanh toán nào của tôi một khoản tương ứng với số ngày nghỉ trước hạn.</div>
                                    </div>
                                    <div class="d-flex align-items-start gap-3 p-3 theme-commit-item">
                                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; border-radius: 50%; background: #8f2635; color: #fff; font-weight: 700;">3</div>
                                        <div class="theme-commit-item-text"><strong>Cho phép Công ty lưu trữ Dữ liệu cá nhân</strong> sau khi các bên kết thúc mối quan hệ lao động, hoặc sau khi các bên chấm dứt hợp đồng là năm (5) năm, tùy trường hợp pháp luật yêu cầu một thời gian dài hơn.</div>
                                    </div>
                                    <div class="d-flex align-items-start gap-3 p-3 theme-commit-item">
                                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; border-radius: 50%; background: #8f2635; color: #fff; font-weight: 700;">4</div>
                                        <div class="theme-commit-item-text"><strong>Cam kết bảo mật thông tin</strong> theo Thỏa thuận Bảo mật thông tin đã ký tại thời điểm ký kết hợp đồng lao động với công ty, cũng như các thông tin mật hoặc thông tin cần bảo mật mà cá nhân có được trong quá trình làm việc tại công ty.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Alert -->
                        <div class="alert alert-warning mt-4">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            <strong>Lưu ý:</strong> Sau khi gửi yêu cầu, Line Manager của bạn sẽ nhận được thông báo 
                            và xem xét yêu cầu nghỉ việc. Bạn sẽ được thông báo kết quả qua email.
                        </div>
                        
                        <!-- Buttons -->
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-danger btn-lg" t-att-disabled="'disabled' if not employee else None">
                                <i class="fa fa-paper-plane me-2"/>Gửi yêu cầu nghỉ việc
                            </button>
                            <a href="/my" class="btn btn-secondary btn-lg">
                                <i class="fa fa-arrow-left me-2"/>Quay lại
                            </a>
                        </div>
                    </form>
                    </t>
                </div>
            </div>
        </t>
    </template>



</odoo>

