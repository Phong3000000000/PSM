                    color: #f5f5f4 !important;
                    border-color: #6b655f !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .bg-light,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .bg-light {
                    background: #3a3632 !important;
                    color: #f5f5f4 !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive,
                html[data-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .card-body,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .card-body {
                    background: color-mix(in srgb, var(--card, #1f1b18) 88%, var(--background, #151413) 12%) !important;
                    color: var(--muted-foreground, #d6d3d1) !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive h6,
