                html[data-theme='dark'] .psm-ops-resignation-portal input[type="text"],
                html[data-theme='dark'] .psm-ops-resignation-portal input[type="date"],
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .form-control,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .form-select,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal input[type="text"],
                html[data-bs-theme='dark'] .psm-ops-resignation-portal input[type="date"] {
