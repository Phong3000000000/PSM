                html[data-bs-theme='dark'] .psm-ops-resignation-portal .fw-semibold,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal h3,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal h4,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal h5,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal h6,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal label,
