                html[data-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .theme-task-owner,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive h6,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .text-muted,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive small,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .badge,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-task-card-inactive .theme-task-owner {
                    color: var(--muted-foreground, #d6d3d1) !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-survey-card,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-survey-card {
                    background: color-mix(in srgb, var(--card, #1f1b18) 90%, var(--background, #151413) 10%) !important;
                    border-color: color-mix(in srgb, var(--primary, #da291c) 30%, rgba(255, 255, 255, 0.08)) !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-survey-card .text-primary,
                html[data-theme='dark'] .psm-ops-resignation-portal .theme-survey-title,
                html[data-theme='dark'] .psm-ops-resignation-portal .theme-survey-card .card-text,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-survey-card .text-primary,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-survey-title,
                html[data-bs-theme='dark'] .psm-ops-resignation-portal .theme-survey-card .card-text {
                    color: #f5f5f4 !important;
                }

                html[data-theme='dark'] .psm-ops-resignation-portal .theme-commit-panel,
