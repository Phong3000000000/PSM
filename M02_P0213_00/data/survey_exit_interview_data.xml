<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- ========================================= -->
        <!-- EXIT INTERVIEW SURVEY - Khảo sát nghỉ việc -->
        <!-- ========================================= -->

        <record id="psm_0213_survey_exit_interview" model="survey.survey">
            <field name="title">Khảo sát nghỉ việc - Exit Interview</field>
            <field name="survey_type">survey</field>
            <field name="access_mode">public</field>
            <field name="users_can_go_back">True</field>
            <field name="questions_layout">page_per_section</field>
            <field name="progression_mode">number</field>
            <field name="is_attempts_limited">False</field>
        </record>

        <!-- ========================================= -->
        <!-- SECTION 1: Thông tin chung -->
        <!-- ========================================= -->
        <record id="survey_exit_section_1" model="survey.question">
            <field name="title">Phần 1: Thông tin chung</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <!-- Q1: Thời gian làm việc -->
        <record id="survey_exit_q1" model="survey.question">
            <field name="title">1. Thời gian làm việc của bạn tại McDonald's Việt Nam</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">2</field>
            <field name="question_type">simple_choice</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="survey_exit_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q1" />
            <field name="value">Thời gian làm việc &lt; 90 ngày</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q1" />
            <field name="value">Thời gian làm việc &gt; 90 ngày</field>
            <field name="sequence">2</field>
        </record>

        <!-- ========================================= -->
        <!-- SECTION 2: Lý do nghỉ việc -->
        <!-- ========================================= -->
        <record id="survey_exit_section_2" model="survey.question">
            <field name="title">Phần 2: Lý do nghỉ việc</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <!-- Q2: Lý do nghỉ việc (multiple choice) -->
        <record id="survey_exit_q2" model="survey.question">
            <field name="title">2. Lý do khiến bạn nghỉ làm việc tại McDonald's Việt Nam (chọn 2-3
                lý do):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">11</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="survey_exit_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q2" />
            <field name="value">Lương thưởng, phúc lợi (thu nhập, giờ công, lịch làm, đồng phục)</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q2" />
            <field name="value">Môi trường làm việc (Sự gắn kết, hỗ trợ, công bằng, máy móc, văn
                hóa)</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q2_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q2" />
            <field name="value">Cơ hội thăng tiến, chương trình đào tạo (định hướng, đào tạo, kết
                quả công việc, sự thăng tiến)</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q2_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q2" />
            <field name="value">Yếu tố khách quan</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q2_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q2" />
            <field name="value">Vấn đề cá nhân</field>
            <field name="sequence">5</field>
        </record>

        <!-- Q3: Lý do quan trọng nhất -->
        <record id="survey_exit_q3" model="survey.question">
            <field name="title">3. Chọn 1 lý do quan trọng nhất khiến bạn nghỉ việc tại McDonald's
                Việt Nam:</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">12</field>
            <field name="question_type">simple_choice</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="survey_exit_q3_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q3" />
            <field name="value">Lương thưởng, phúc lợi</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q3_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q3" />
            <field name="value">Môi trường làm việc</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q3_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q3" />
            <field name="value">Cơ hội thăng tiến, chương trình đào tạo</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q3_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q3" />
            <field name="value">Yếu tố khách quan</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q3_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q3" />
            <field name="value">Vấn đề cá nhân</field>
            <field name="sequence">5</field>
        </record>

        <!-- ========================================= -->
        <!-- SECTION 3: Chi tiết lý do - Lương thưởng -->
        <!-- ========================================= -->
        <record id="survey_exit_section_3" model="survey.question">
            <field name="title">Phần 3: Chi tiết lý do nghỉ việc</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <!-- Q4a: Chi tiết - Lương thưởng, phúc lợi -->
        <record id="survey_exit_q4a" model="survey.question">
            <field name="title">4a. Lương thưởng, phúc lợi (chọn các lý do liên quan):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">21</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">False</field>
        </record>
        <record id="survey_exit_q4a_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Thu nhập tại McDonald's không đáp ứng được nhu cầu cá nhân hoặc
                không cạnh tranh so với công ty khác</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q4a_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Tôi không được ghi nhận đủ ngày công theo lịch làm việc thực tế</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q4a_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Tôi không thường xuyên được ghi nhận khi hoàn thành công việc thông
                qua (Điểm Bravo, Thank you card, BOG,…)</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q4a_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Không được cung cấp đủ thông tin về chính sách, khen thưởng phúc lợi
                rõ ràng, minh bạch</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q4a_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Lịch làm việc không sắp xếp được các công việc cá nhân như (lịch
                học, lịch thực tập, gia đình, con cái)</field>
            <field name="sequence">5</field>
        </record>
        <record id="survey_exit_q4a_a6" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Chính sách khen thưởng và phúc lợi chưa tương xứng với công sức và
                đóng góp của tôi</field>
            <field name="sequence">6</field>
        </record>
        <record id="survey_exit_q4a_a7" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Giảm giờ công dẫn đến giảm thu nhập</field>
            <field name="sequence">7</field>
        </record>
        <record id="survey_exit_q4a_a8" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4a" />
            <field name="value">Khối lượng công việc quá tải và cường độ công việc cao gây áp lực
                lớn</field>
            <field name="sequence">8</field>
        </record>

        <!-- Q4b: Chi tiết - Môi trường làm việc -->
        <record id="survey_exit_q4b" model="survey.question">
            <field name="title">4b. Môi trường làm việc (chọn các lý do liên quan):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">22</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">False</field>
        </record>
        <record id="survey_exit_q4b_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Không nhận được sự hỗ trợ từ đồng nghiệp, quản lý trong công việc</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q4b_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Môi trường làm việc thiếu đoàn kết, kỹ năng làm việc nhóm kém, khó
                hòa nhập với đội ngũ</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q4b_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Quản lý lạm dụng quyền lực, thiếu minh bạch và không công bằng trong
                phân chia công việc cũng như đánh giá kết quả</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q4b_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Không nhận được sự tôn trọng từ đồng nghiệp, quản lý (phân biệt đối
                xử về giới tính, tuổi tác, ngôn ngữ giao tiếp,…)</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q4b_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Tôi cảm thấy môi trường làm việc không an toàn (máy móc thiết bị,
                tiếp xúc với dầu mỡ, hóa chất tẩy rửa,…)</field>
            <field name="sequence">5</field>
        </record>
        <record id="survey_exit_q4b_a6" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4b" />
            <field name="value">Tôi không được lắng nghe và thể hiện quan điểm/ ý kiến cá nhân</field>
            <field name="sequence">6</field>
        </record>

        <!-- Q4c: Chi tiết - Cơ hội thăng tiến -->
        <record id="survey_exit_q4c" model="survey.question">
            <field name="title">4c. Cơ hội thăng tiến, chương trình đào tạo (chọn các lý do liên
                quan):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">23</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">False</field>
        </record>
        <record id="survey_exit_q4c_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Tôi không nhận được sự giúp đỡ hoặc nhận xét/ đánh giá từ quản lý
                trong công việc và phát triển định hướng nghề nghiệp</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q4c_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Tôi không hiểu rõ về lộ trình và nội dung đào tạo</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q4c_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Quản lý không hỗ trợ giải quyết khi tôi gặp khó khăn trong công việc</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q4c_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Kết quả công việc và sự đóng góp không được ghi nhận một cách công
                bằng và khách quan</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q4c_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Không được định hướng rõ ràng về lộ trình thăng tiến</field>
            <field name="sequence">5</field>
        </record>
        <record id="survey_exit_q4c_a6" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Tốc độ thăng tiến chậm</field>
            <field name="sequence">6</field>
        </record>
        <record id="survey_exit_q4c_a7" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Chương trình đào tạo chưa giúp tôi nhanh chóng thích nghi với công
                việc và môi trường làm việc</field>
            <field name="sequence">7</field>
        </record>
        <record id="survey_exit_q4c_a8" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4c" />
            <field name="value">Chương trình đào tạo không thường xuyên cập nhật và phù hợp với các
                xu hướng mới</field>
            <field name="sequence">8</field>
        </record>

        <!-- Q4d: Chi tiết - Vấn đề cá nhân -->
        <record id="survey_exit_q4d" model="survey.question">
            <field name="title">4d. Vấn đề cá nhân (chọn các lý do liên quan):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">24</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">False</field>
        </record>
        <record id="survey_exit_q4d_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Bản thân muốn có thời gian tiếp tục đi học hoặc đi thực tập để nâng
                cao chuyên môn</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q4d_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Do vi phạm, bị kỉ luật trong công việc, nhà hàng yêu cầu nghỉ</field>
            <field name="sequence">2</field>
        </record>
        <record id="survey_exit_q4d_a3" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Lịch học không sắp xếp được để có thể đi làm</field>
            <field name="sequence">3</field>
        </record>
        <record id="survey_exit_q4d_a4" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Tốt nghiệp và tìm công việc khác đúng ngành</field>
            <field name="sequence">4</field>
        </record>
        <record id="survey_exit_q4d_a5" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Thay đổi định hướng công việc</field>
            <field name="sequence">5</field>
        </record>
        <record id="survey_exit_q4d_a6" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Đi thực tập</field>
            <field name="sequence">6</field>
        </record>
        <record id="survey_exit_q4d_a7" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Đang có vướng bận về gia đình cần thời gian dài để giải quyết</field>
            <field name="sequence">7</field>
        </record>
        <record id="survey_exit_q4d_a8" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Thực hiện nghĩa vụ quân sự</field>
            <field name="sequence">8</field>
        </record>
        <record id="survey_exit_q4d_a9" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Thay đổi nơi ở (định cư, về quê, điều chuyển nơi ở,…)</field>
            <field name="sequence">9</field>
        </record>
        <record id="survey_exit_q4d_a10" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Vị trí cửa hàng quá xa</field>
            <field name="sequence">10</field>
        </record>
        <record id="survey_exit_q4d_a11" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Không có phương tiện đi lại làm việc</field>
            <field name="sequence">11</field>
        </record>
        <record id="survey_exit_q4d_a12" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Sức khỏe bản thân không đảm bảo được tính chất công việc nặng nhọc</field>
            <field name="sequence">12</field>
        </record>
        <record id="survey_exit_q4d_a13" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Không phù hợp, không thích nghi được với môi trường và công việc</field>
            <field name="sequence">13</field>
        </record>
        <record id="survey_exit_q4d_a14" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4d" />
            <field name="value">Bị tai nạn rủi ro không thể đi làm được</field>
            <field name="sequence">14</field>
        </record>

        <!-- Q4e: Chi tiết - Yếu tố khách quan -->
        <record id="survey_exit_q4e" model="survey.question">
            <field name="title">4e. Yếu tố khách quan (chọn các lý do liên quan):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
            <field name="sequence">25</field>
            <field name="question_type">multiple_choice</field>
            <field name="constr_mandatory">False</field>
        </record>
        <record id="survey_exit_q4e_a1" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4e" />
            <field name="value">Nhà hàng đóng cửa</field>
            <field name="sequence">1</field>
        </record>
        <record id="survey_exit_q4e_a2" model="survey.question.answer">
            <field name="question_id" ref="survey_exit_q4e" />
            <field name="value">Thay đổi mô hình kinh doanh</field>
            <field name="sequence">2</field>
        </record>

        <!-- Q4f: Lý do khác -->
        <record id="survey_exit_q4f" model="survey.question">
            <field name="title">4f. Lý do khác (nếu có):</field>
            <field name="survey_id" ref="psm_0213_survey_exit_interview" />
