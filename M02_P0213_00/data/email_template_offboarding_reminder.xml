<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Email Template for Offboarding Reminder -->
        <record id="psm_0213_email_template_offboarding_reminder" model="mail.template">
            <field name="name">Nhắc nhở hoàn thành thủ tục nghỉ việc</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="subject">REMINDER: Bạn còn thủ tục nghỉ việc chưa hoàn thành</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="email_to">{{ object.request_owner_id.partner_id.email }}</field>
            <field name="body_html"><![CDATA[
<div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif;">
    <table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #F7F7F7; width: 100%;">
        <tr>
            <td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 16px; background-color: #FFFFFF; border: 1px solid #E1E1E1; border-radius: 3px;">
                    <tr>
                        <td style="padding: 20px 24px;">
                            <h2 style="color: #DA291C; margin-bottom: 20px;">Nhắc nhở thủ tục nghỉ việc</h2>
                            
                            <p style="margin-bottom: 16px;">Kính gửi <strong>{{ object.request_owner_id.name }}</strong>,</p>
                            
                            <p style="margin-bottom: 16px;">Hệ thống ghi nhận bạn vẫn còn các thủ tục/hoạt động bàn giao chưa hoàn thành trong quy trình nghỉ việc.</p>
                            
                            <p style="margin-bottom: 16px;">Vui lòng kiểm tra và hoàn tất sớm nhất có thể.</p>
                            
                            <p style="margin-bottom: 0; color: #333333;">
                                Trân trọng,<br/>
                                <strong>Phòng Nhân sự</strong><br/>
                                McDonald's Việt Nam
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</div>
]]></field>
            <field name="lang">{{ object.request_owner_id.lang }}</field>
            <field name="auto_delete">True</field>
        </record>
    </data>
</odoo>
