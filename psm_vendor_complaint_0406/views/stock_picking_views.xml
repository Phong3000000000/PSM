<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit stock picking form to add claim count button -->
    <!-- Note: QIP status column moved to SC_0405_purchase_extend -->
    <record id="view_picking_form_inherit_claim_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.claim.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Add claim count smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_vendor_complaints" type="object" 
                        class="oe_stat_button" icon="fa-exclamation-triangle"
                        invisible="vendor_complaint_count == 0">
                    <field name="vendor_complaint_count" widget="statinfo" string="Claims"/>
                </button>
            </xpath>
            
            <!-- Add original ordered qty column to operations table -->
            <!-- Shows PO quantity even after validate changes demand -->
            <xpath expr="//field[@name='move_ids']//field[@name='product_uom_qty']" position="before">
                <field name="po_ordered_qty" string="SL Đặt từ PO" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
