<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vendor Complaint Form View -->
    <record id="view_vendor_complaint_form" model="ir.ui.view">
        <field name="name">vendor.complaint.form</field>
        <field name="model">vendor.complaint</field>
        <field name="arch" type="xml">
            <form string="Vendor Complaint">
                <header>
                    <button name="action_submit" string="Submit Complaint" type="object" invisible="state != 'draft'" class="oe_highlight" />
                    <!-- Nút cho QA (Bước 5, 6) -->
                    <button name="action_qa_propose" string="QA Confirm &amp; Propose" type="object" invisible="state != 'qa_review'" class="oe_highlight" groups="stock.group_stock_user" />
                    <!-- Nút cho FSC (Bước 7, 8, 9) -->
                    <button name="action_fsc_approve" string="Duyệt và gửi phiếu giao bù cho NCC" type="object" invisible="state != 'fsc_review'" class="oe_highlight" icon="fa-check" groups="stock.group_stock_manager" />
                    <button name="action_fsc_reject" string="Từ chối (Trả hàng/Hủy)" type="object" invisible="state != 'fsc_review'" groups="stock.group_stock_manager" />
                    <button name="action_close" string="Đóng Complaint" type="object" invisible="state not in ('approved', 'rejected')" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,qa_review,fsc_review,approved,closed" />
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_transfers" type="object" class="oe_stat_button" icon="fa-truck" invisible="picking_count == 0">
                            <field name="picking_count" string="Phiếu Giao Bù" widget="statinfo" />
                        </button>
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="invoice_count == 0">
                            <field name="invoice_count" string="Hóa đơn" widget="statinfo" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="picking_id" readonly="1" />
                            <field name="partner_id" readonly="1" />
                            <field name="warehouse_id" readonly="1" />
                        </group>
                        <group>
                            <field name="complaint_type" required="1" readonly="state != 'draft'" />
                            <field name="complaint_date" readonly="1" />
                            <!-- Hiển thị phiếu giao bù nếu có -->
                            <field name="backorder_id" string="Phiếu Giao Bù" readonly="1" />
                            <field name="user_id" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="line_ids" nolabel="1" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id" />
                                    <field name="ordered_qty" />
                                    <field name="received_qty" />
                                    <field name="variance_qty" />
                                    <field name="uom_id" />
                                    <field name="reason" />
                                </list>
                            </field>
                        </page>
                        <page string="Review Notes">
                            <group>
                                <group string="QA &amp; FSC Input">
                                    <field name="qa_notes" placeholder="QA đánh giá mức độ lỗi tại đây..." readonly="state not in ('draft', 'qa_review')" />
                                    <field name="fsc_notes" placeholder="FSC ghi chú quyết định tại đây..." readonly="state != 'fsc_review'" />
                                </group>
                                <group string="Chứng từ (Bắt buộc khi duyệt)">
                                    <!-- Đặt ở đây để FSC dễ thấy khi duyệt -->
                                    <field name="vendor_agreement_attachment" filename="vendor_agreement_filename" widget="binary" />
                                    <field name="vendor_agreement_filename" invisible="1" />
                                </group>
                            </group>
                            <group string="Vendor Feedback">
                                <field name="vendor_response" placeholder="Phản hồi từ NCC..." nolabel="1" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <!-- Vendor Complaint Tree View -->
    <record id="view_vendor_complaint_tree" model="ir.ui.view">
        <field name="name">vendor.complaint.tree</field>
        <field name="model">vendor.complaint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="picking_id" />
                <field name="partner_id" />
                <field name="complaint_type" />
                <field name="state" decoration-info="state == 'qa_review'" decoration-warning="state == 'fsc_review'" decoration-success="state == 'approved'" decoration-muted="state == 'closed'" />
            </list>
        </field>
    </record>

    <record id="action_vendor_complaint" model="ir.actions.act_window">
        <field name="name">Vendor Complaints</field>
        <field name="res_model">vendor.complaint</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vendor_complaint_root" name="Vendor Complaints" parent="stock.menu_stock_root" sequence="50" />

    <menuitem id="menu_vendor_complaint_all" name="All Complaints" parent="menu_vendor_complaint_root" action="action_vendor_complaint" sequence="10" />
</odoo>