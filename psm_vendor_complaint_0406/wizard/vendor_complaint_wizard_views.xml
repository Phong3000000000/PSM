<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form -->
    <record id="view_vendor_complaint_wizard_form" model="ir.ui.view">
        <field name="name">vendor.complaint.wizard.form</field>
        <field name="model">vendor.complaint.wizard</field>
        <field name="arch" type="xml">
            <form string="Phiếu hàng thiếu/thừa - Chờ xử lý (Bước 1)">
                <group>
                    <group>
                        <field name="picking_id" readonly="1" />
                        <field name="partner_id" readonly="1" />
                    </group>
                    <group>
                        <field name="complaint_type" required="1" />
                    </group>
                </group>
                <group string="Products with Variance">
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom">
                            <!-- QUAN TRỌNG: Thêm force_save="1" để lưu dữ liệu readonly -->
                            <field name="product_id" readonly="1" force_save="1" />
                            <field name="ordered_qty" readonly="1" force_save="1" />
                            <field name="received_qty" readonly="1" force_save="1" />
                            <field name="variance_qty" readonly="1" force_save="1" decoration-danger="variance_qty &lt; 0" decoration-success="variance_qty &gt; 0" />
                            <field name="uom_id" readonly="1" force_save="1" />
                            <field name="reason" placeholder="Reason for variance..." />
                        </list>
                    </field>
                </group>
                <group>
                    <field name="notes" placeholder="Additional notes..." />
                </group>
                <footer>
                    <button name="action_create_complaint" string="Create Complaint &amp; Continue" type="object" class="btn-primary" />
                    <button name="action_skip_and_validate" string="Skip &amp; Validate" type="object" class="btn-secondary" />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>