<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== PIVOT VIEW ==================== -->
    <record id="business_trip_report_view_pivot" model="ir.ui.view">
        <field name="name">business.trip.report.pivot</field>
        <field name="model">business.trip.report</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích công tác" sample="1">
                <field name="department_id" type="col"/>
                <field name="date_start" interval="month" type="row"/>
                <field name="nbr" type="measure"/>
                <field name="estimated_hotel_cost" type="measure"/>
                <field name="hotel_nights" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ==================== GRAPH VIEW ==================== -->
    <record id="business_trip_report_view_graph" model="ir.ui.view">
        <field name="name">business.trip.report.graph</field>
        <field name="model">business.trip.report</field>
        <field name="arch" type="xml">
            <graph string="Phân tích công tác" type="bar" sample="1">
                <field name="date_start" interval="month"/>
                <field name="nbr" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="business_trip_report_view_list" model="ir.ui.view">
        <field name="name">business.trip.report.list</field>
        <field name="model">business.trip.report</field>
        <field name="arch" type="xml">
            <list string="Phân tích công tác" create="false" edit="false">
                <field name="name"/>
                <field name="request_owner_id" widget="many2one_avatar_user"/>
                <field name="employee_id" optional="show"/>
                <field name="department_id"/>
                <field name="category_id" optional="hide"/>
                <field name="date_start" string="Ngày bắt đầu"/>
                <field name="date_end" string="Ngày kết thúc" optional="show"/>
                <field name="destination_province_id" optional="show"/>
                <field name="hotel_nights" optional="show" sum="Tổng số đêm"/>
                <field name="estimated_hotel_cost" optional="show" sum="Tổng chi phí"/>
                <field name="request_status" widget="badge"
                    decoration-info="request_status == 'new'"
                    decoration-warning="request_status == 'pending'"
                    decoration-success="request_status in ('approved', 'completed')"
                    decoration-danger="request_status == 'refused'"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="business_trip_report_view_search" model="ir.ui.view">
        <field name="name">business.trip.report.search</field>
        <field name="model">business.trip.report</field>
        <field name="arch" type="xml">
            <search string="Phân tích công tác">
                <field name="name"/>
                <field name="request_owner_id"/>
                <field name="department_id"/>
                <field name="destination_province_id"/>

                <!-- Bộ lọc trạng thái -->
                <filter string="Đã duyệt" name="filter_approved"
                    domain="[('request_status', '=', 'approved')]"/>
                <filter string="Chờ duyệt" name="filter_pending"
                    domain="[('request_status', '=', 'pending')]"/>
                <filter string="Hoàn thành" name="filter_completed"
                    domain="[('request_status', '=', 'completed')]"/>
                <separator/>

                <!-- Bộ lọc theo ngày -->
                <filter string="Ngày bắt đầu" name="filter_date_start" date="date_start" default_period="year"/>
                <separator/>

                <!-- Group By -->
                <group>
                    <filter string="Nhân viên" name="groupby_employee"
                        context="{'group_by': 'employee_id'}"/>
                    <filter string="Phòng ban" name="groupby_department"
                        context="{'group_by': 'department_id'}"/>
                    <filter string="Tỉnh/TP đích" name="groupby_province"
                        context="{'group_by': 'destination_province_id'}"/>
                    <filter string="Trạng thái" name="groupby_status"
                        context="{'group_by': 'request_status'}"/>
                    <filter string="Công ty" name="groupby_company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
                    <separator/>
                    <filter string="Năm" name="groupby_year"
                        context="{'group_by': 'date_start:year'}"/>
                    <filter string="Quý" name="groupby_quarter"
                        context="{'group_by': 'date_start:quarter'}"/>
                    <filter string="Tháng" name="groupby_month"
                        context="{'group_by': 'date_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="business_trip_report_action" model="ir.actions.act_window">
        <field name="name">Báo cáo công tác</field>
        <field name="res_model">business.trip.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="business_trip_report_view_search"/>
        <field name="context">{'search_default_filter_date_start': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu yêu cầu công tác
            </p>
            <p>
                Báo cáo phân tích số lượng yêu cầu công tác theo năm, tháng, phòng ban và nhân viên.
            </p>
        </field>
    </record>

    <!-- ==================== MENU ==================== -->
    <menuitem
        id="business_trip_report_menu"
        parent="approvals.approvals_menu_manager"
        name="Báo cáo công tác"
        action="business_trip_report_action"
        sequence="30"/>

</odoo>
