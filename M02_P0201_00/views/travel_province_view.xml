<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->
    <record id="travel_province_action" model="ir.actions.act_window">
        <field name="name">Provinces / Cities</field>
        <field name="res_model">travel.province</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Tree -->
    <record id="travel_province_view_tree" model="ir.ui.view">
        <field name="name">travel.province.view.list</field>
        <field name="model">travel.province</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="travel_province_view_form" model="ir.ui.view">
        <field name="name">travel.province.view.form</field>
        <field name="model">travel.province</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_travel_province"
        name="Provinces / Cities"
        parent="approvals.approvals_menu_config"
        action="travel_province_action"
        sequence="30"/>
</odoo>
