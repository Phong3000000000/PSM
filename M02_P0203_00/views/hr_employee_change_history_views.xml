<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_hr_employee_change_history_tree" model="ir.ui.view">
        <field name="name">hr.employee.change.history.tree</field>
        <field name="model">hr.employee.change.history</field>
        <field name="arch" type="xml">
            <list string="Employee Change History" create="false" edit="false" delete="false">
                <field name="change_date" string="Date"/>
                <field name="employee_id"/>
                <field name="field_label" string="Field"/>
                <field name="old_value" string="Old Value"/>
                <field name="new_value" string="New Value"/>
                <field name="changed_by_id" string="Changed By"/>
                <field name="approval_request_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_employee_change_history_form" model="ir.ui.view">
        <field name="name">hr.employee.change.history.form</field>
        <field name="model">hr.employee.change.history</field>
        <field name="arch" type="xml">
            <form string="Change History Detail" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="field_label" readonly="1"/>
                            <field name="change_date" readonly="1"/>
                            <field name="changed_by_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="approval_request_id" readonly="1"/>
                            <field name="change_type" readonly="1"/>
                            <field name="field_name" readonly="1"/>
                        </group>
                    </group>
                    <group string="Change Details">
                        <group>
                            <field name="old_value" readonly="1"/>
                        </group>
                        <group>
                            <field name="new_value" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hr_employee_change_history_search" model="ir.ui.view">
        <field name="name">hr.employee.change.history.search</field>
        <field name="model">hr.employee.change.history</field>
        <field name="arch" type="xml">
            <search string="Search Change History">
                <field name="employee_id"/>
                <field name="field_label"/>
                <field name="changed_by_id"/>
                <filter string="Employee" name="groupby_employee" context="{'group_by': 'employee_id'}"/>
                <filter string="Field Label" name="groupby_field_label" context="{'group_by': 'field_label'}"/>
                <filter string="Change Date" name="groupby_change_date" context="{'group_by': 'change_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_employee_change_history" model="ir.actions.act_window">
        <field name="name">Employee Change History</field>
        <field name="res_model">hr.employee.change.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_employee_change_history_search"/>
        <field name="context">{'search_default_groupby_change_date': 1, 'search_default_groupby_employee': 2, 'search_default_groupby_field_label': 3}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No change history found
            </p>
            <p>
                Change history will be created automatically when employee information is updated through approval requests.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem 
        id="menu_hr_employee_change_history"
        name="Change History"
        parent="approvals.approvals_menu_root"
        action="action_hr_employee_change_history"
        sequence="100"/>

</odoo>
