<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mic_assignment_matrix.Main" owl="1">
        <div class="o_mic_assignment_matrix h-100 flex-column overflow-hidden">
            <!-- Control Panel -->
            <div class="o_control_panel">
                <div class="o_cp_left">
                    <h2 class="m-0 fw-bold text-white">Quản Lý MIC Matrix</h2>
                    <div class="d-flex align-items-center gap-2">
                        <span>Cửa hàng:</span>
                        <select class="form-select w-auto" t-on-change="onChangePos">
                            <t t-foreach="state.posConfigs" t-as="pos" t-key="pos.id">
                                <option t-att-value="pos.id" t-att-selected="pos.id == state.currentPosId">
                                    <t t-esc="pos.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span>Tháng:</span>
                        <select class="form-select w-auto" t-on-change="onChangeMonth">
                            <t t-foreach="state.months" t-as="m" t-key="m.value">
                                <option t-att-value="m.value" t-att-selected="m.value == state.currentMonth">
                                    <t t-esc="m.label"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span>Năm:</span>
                        <select class="form-select w-auto" t-on-change="onChangeYear">
                            <t t-foreach="state.years" t-as="y" t-key="y">
                                <option t-att-value="y" t-att-selected="y == state.currentYear">
                                    <t t-esc="y"/>
                                </option>
                            </t>
                        </select>
                    </div>
                </div>
                <div class="o_cp_buttons">
                    <button class="btn btn-secondary-mcd" t-on-click="onRefresh">
                        <i class="fa fa-refresh me-1"/> Làm mới
                    </button>
                    <button class="btn btn-secondary-mcd" t-on-click="onSyncPlanning">
                        <i class="fa fa-refresh me-1"/> Sync Planning
                    </button>
                    <button class="btn btn-primary-mcd" t-on-click="onGenerateLogs">
                        <i class="fa fa-magic me-1"/> Generate Logs
                    </button>
                </div>
            </div>

            <!-- Matrix Container -->
            <div class="o_matrix_container overflow-auto flex-grow-1 position-relative">
                <div t-if="state.isLoading" class="o_loading_overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-black-50" style="z-index: 100;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <table class="table table-dark table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="o_day_cell">Ngày</th>
                            <t t-foreach="state.shifts" t-as="shift" t-key="shift.id">
                                <th><t t-esc="shift.name"/></th>
                            </t>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.matrix" t-as="row" t-key="row.date">
                            <tr>
                                <td class="o_day_cell">
                                    <div class="fw-bold"><t t-esc="getDateLabel(row.date)"/></div>
                                    <div class="text-muted small"><t t-esc="row.day_name"/></div>
                                </td>
                                <t t-foreach="state.shifts" t-as="shift" t-key="shift.id">
                                    <t t-set="cell" t-value="row.shifts[shift.id]"/>
                                    <td t-if="cell" 
                                        class="o_shift_cell" 
                                        t-att-class="{
                                            'o_empty': !cell.mic_id,
                                            'o_brush_active': isBrushActive(row.date, shift.id)
                                        }"
                                        t-on-click="() => this.onCellClick(row, shift)"
                                        t-on-mouseenter="() => this.onCellMouseEnter(row, shift)">
                                        
                                        <div class="o_cell_content" t-if="!state.brushMode">
                                            <select class="form-select form-select-sm border-0 bg-transparent text-center text-primary fw-bold" 
                                                    t-on-change="(ev) => this.onCellSelectMic(ev, cell)">
                                                <option value="0">-- Trống --</option>
                                                <t t-foreach="state.managers" t-as="mgr" t-key="mgr.id">
                                                    <option t-att-value="mgr.id" t-att-selected="mgr.id == cell.mic_id">
                                                        <t t-esc="mgr.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                        <div t-else="" class="o_brush_area w-100 h-100 d-flex flex-column align-items-center justify-content-center">
                                            <div t-if="cell.mic_id" class="o_mic_name d-flex align-items-center justify-content-center gap-1">
                                                <i class="fa fa-user-circle-o"/>
                                                <t t-esc="cell.mic_name"/>
                                            </div>
                                            <div t-else="" class="text-muted small">
                                                <i class="fa fa-plus-circle me-1 opacity-50"/> <i>Click/Quét...</i>
                                            </div>
                                        </div>
                                        
                                        <div class="o_shift_info">
                                            <t t-esc="cell.shift_name"/>
                                        </div>
                                        
                                        <div t-if="cell.conflict" class="o_conflict_badge">
                                            <i t-if="cell.conflict == 'leave'" class="fa fa-calendar-times-o" t-att-title="getConflictTitle(cell.conflict)"/>
                                            <i t-else="" class="fa fa-exclamation-triangle" t-att-title="getConflictTitle(cell.conflict)"/>
                                        </div>
                                    </td>
                                    <td t-else="" class="bg-black-25 opacity-25">
                                        <span class="small">N/A</span>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Floating Sidebar for MIC Selection & Brush -->
            <div class="o_mic_toolbar">
                <h4 class="mb-2 fw-bold text-uppercase" style="font-size: 10px; letter-spacing: 1px;">Sắp Xếp MIC</h4>
                
                <div class="o_mic_selector">
                    <span>Chọn MIC dự phòng:</span>
                    <select class="form-select mt-1" t-on-change="onSelectActiveMic">
                        <option value="0">-- Chọn MIC --</option>
                        <t t-foreach="state.managers" t-as="mgr" t-key="mgr.id">
                            <option t-att-value="mgr.id" t-att-selected="mgr.id == state.activeMicId">
                                <t t-esc="mgr.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <div class="o_brush_toggle mt-2" t-att-class="{'active': state.brushMode}" t-on-click="toggleBrushMode">
                    <span><i class="fa fa-paint-brush me-2"/> Chế độ Brush</span>
                    <span t-esc="state.brushMode ? 'ON' : 'OFF'"/>
                </div>

                <div class="o_quick_actions mt-3">
                    <button class="btn btn-outline-light btn-sm w-100 mb-2" t-on-click="onFillDown">
                        <i class="fa fa-arrow-down me-2"/> Fill Down Ngày Này
                    </button>
                    <button class="btn btn-outline-light btn-sm w-100" t-on-click="onClearMonth">
                        <i class="fa fa-trash me-2"/> Xóa Trắng Tháng
                    </button>
                </div>
                
                <div t-if="state.isLoading" class="mt-2 text-warning small text-center">
                    <i class="fa fa-spinner fa-spin me-1"/> Đang lưu...
                </div>
            </div>
        </div>
    </t>
</templates>
