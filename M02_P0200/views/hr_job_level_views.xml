<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================== -->
    <!-- Tree View: Job Level                      -->
    <!-- ========================================== -->
    <record id="view_hr_job_level_tree" model="ir.ui.view">
        <field name="name">hr.job.level.tree</field>
        <field name="model">hr.job.level</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="grade_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ========================================== -->
    <!-- Form View: Job Level                      -->
    <!-- ========================================== -->
    <record id="view_hr_job_level_form" model="ir.ui.view">
        <field name="name">hr.job.level.form</field>
        <field name="model">hr.job.level</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="grade_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================== -->
    <!-- Action + Menu                              -->
    <!-- ========================================== -->
    <record id="action_hr_job_level" model="ir.actions.act_window">
        <field name="name">Job Levels</field>
        <field name="res_model">hr.job.level</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Job Level
            </p>
        </field>
    </record>

    <menuitem id="menu_hr_job_level"
              name="Job Levels"
              parent="M02_P0200.menu_hr_job_position_default_categ"
              action="action_hr_job_level"
              sequence="20"/>

</odoo>
