<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================ -->
    <!-- RESTAURANT AREA                  -->
    <!-- ================================ -->

    <record id="view_restaurant_area_tree" model="ir.ui.view">
        <field name="name">restaurant.area.tree</field>
        <field name="model">restaurant.area</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_area_form" model="ir.ui.view">
        <field name="name">restaurant.area.form</field>
        <field name="model">restaurant.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Khu Vực Nhỏ">
                            <field name="positioning_area_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_area" model="ir.actions.act_window">
        <field name="name">Khu Vực Lớn</field>
        <field name="res_model">restaurant.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================ -->
    <!-- RESTAURANT POSITIONING AREA      -->
    <!-- ================================ -->

    <record id="view_restaurant_positioning_area_tree" model="ir.ui.view">
        <field name="name">restaurant.positioning.area.tree</field>
        <field name="model">restaurant.positioning.area</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="area_id"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_positioning_area_form" model="ir.ui.view">
        <field name="name">restaurant.positioning.area.form</field>
        <field name="model">restaurant.positioning.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="area_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Các Station">
                            <field name="station_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="menu_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_positioning_area" model="ir.actions.act_window">
        <field name="name">Khu Vực Nhỏ</field>
        <field name="res_model">restaurant.positioning.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================ -->
    <!-- RESTAURANT STATION               -->
    <!-- ================================ -->

    <record id="view_restaurant_station_tree" model="ir.ui.view">
        <field name="name">restaurant.station.tree</field>
        <field name="model">restaurant.station</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="positioning_area_id"/>
                <field name="menu_type"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_station_form" model="ir.ui.view">
        <field name="name">restaurant.station.form</field>
        <field name="model">restaurant.station</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="positioning_area_id"/>
                            <field name="menu_type"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_station" model="ir.actions.act_window">
        <field name="name">Station</field>
        <field name="res_model">restaurant.station</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================ -->
    <!-- RESTAURANT SHIFT (CA LÀM)       -->
    <!-- ================================ -->

    <record id="view_restaurant_shift_tree" model="ir.ui.view">
        <field name="name">restaurant.shift.tree</field>
        <field name="model">restaurant.shift</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_shift_form" model="ir.ui.view">
        <field name="name">restaurant.shift.form</field>
        <field name="model">restaurant.shift</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_shift" model="ir.actions.act_window">
        <field name="name">Ca Làm Việc</field>
        <field name="res_model">restaurant.shift</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================ -->
    <!-- MENU CẤU HÌNH NHÀ HÀNG          -->
    <!-- ================================ -->

    <menuitem id="menu_restaurant_config_root"
              name="Cấu Hình Nhà Hàng"
              parent="point_of_sale.menu_point_config_product"
              sequence="20"/>

    <menuitem id="menu_restaurant_area"
              name="Khu Vực Lớn"
              parent="menu_restaurant_config_root"
              action="action_restaurant_area"
              sequence="1"/>

    <menuitem id="menu_restaurant_positioning_area"
              name="Khu Vực Nhỏ"
              parent="menu_restaurant_config_root"
              action="action_restaurant_positioning_area"
              sequence="2"/>

    <menuitem id="menu_restaurant_station"
              name="Station"
              parent="menu_restaurant_config_root"
              action="action_restaurant_station"
              sequence="3"/>

    <menuitem id="menu_restaurant_shift"
              name="Ca Làm Việc"
              parent="menu_restaurant_config_root"
              action="action_restaurant_shift"
              sequence="4"/>

</odoo>
