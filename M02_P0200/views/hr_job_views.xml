<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Mở rộng form view hr.job: thêm code + level -->
    <record id="view_hr_job_form_inherit_level" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.level</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <field name="department_id" position="after">
                <field name="code"/>
                <field name="name_ll"/>
                <field name="level_id"/>
                <field name="job_default_id"/>
            </field>
        </field>
    </record>

    <!-- Mở rộng tree view hr.job: thêm code + level -->
    <record id="view_hr_job_tree_inherit_level" model="ir.ui.view">
        <field name="name">hr.job.tree.inherit.level</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_tree"/>
        <field name="arch" type="xml">
            <field name="department_id" position="after">
                <field name="code"/>
                <field name="name_ll"/>
                <field name="level_id"/>
                <field name="job_default_id"/>
            </field>
        </field>
    </record>

</odoo>
