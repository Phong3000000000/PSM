<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================== -->
    <!-- Wizard Form View                           -->
    <!-- ========================================== -->
    <record id="view_shift_log_generate_wizard_form" model="ir.ui.view">
        <field name="name">shift.log.generate.wizard.form</field>
        <field name="model">shift.log.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Shift Log Cả Tháng">
                <group>
                    <field name="available_pos_config_ids" invisible="1"/>
                    <field name="pos_config_ids" widget="many2many_tags"/>
                    <field name="month"/>
                    <field name="year"/>
                </group>
                <footer>
                    <button name="action_generate" type="object"
                            string="Generate" class="btn-primary"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ========================================== -->
    <!-- Action to Open Wizard                      -->
    <!-- ========================================== -->
    <record id="action_shift_log_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Shift Log Cả Tháng</field>
        <field name="res_model">shift.log.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
