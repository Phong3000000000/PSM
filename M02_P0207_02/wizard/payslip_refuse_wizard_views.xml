<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payslip_refuse_wizard_view_form" model="ir.ui.view">
        <field name="name">payslip.refuse.wizard.form</field>
        <field name="model">payslip.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Payslip">
                <field name="payslip_id" invisible="1"/>
                <group>
                    <field name="payslip_id" readonly="1" invisible="not payslip_id"/>
                    <field name="reason" placeholder="Nhập lý do từ chối..." required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_refuse"
                            string="Confirm Refuse"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

