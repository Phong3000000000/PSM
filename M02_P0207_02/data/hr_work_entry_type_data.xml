<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============================================================
             15 LOẠI CÔNG (WORK ENTRY TYPES)
             Nguồn: 6. Cấu hình Loại công.docx
             Payroll → Configuration → Work Entry Types
        ============================================================ -->

        <!-- 1. AL - Annual Leave 12 (Nghỉ phép năm, 12 ngày) -->
        <record id="work_entry_type_AL" model="hr.work.entry.type">
            <field name="name">Annual Leave 12</field>
            <field name="code">AL</field>
            <field name="is_leave">True</field>
            <field name="color">10</field>
        </record>

        <!-- 2. AL14 - Annual Leave 14 (Nghỉ phép năm, 14 ngày) -->
        <record id="work_entry_type_AL14" model="hr.work.entry.type">
            <field name="name">Annual Leave 14</field>
            <field name="code">AL14</field>
            <field name="is_leave">True</field>
            <field name="color">10</field>
        </record>

        <!-- 3. AL18 - Annual Leave 18 (Nghỉ phép năm, 18 ngày) -->
        <record id="work_entry_type_AL18" model="hr.work.entry.type">
            <field name="name">Annual Leave 18</field>
            <field name="code">AL18</field>
            <field name="is_leave">True</field>
            <field name="color">10</field>
        </record>

