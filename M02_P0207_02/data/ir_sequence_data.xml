<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Attendance Sheet -->
        <record id="seq_hr_attendance_sheet" model="ir.sequence">
            <field name="name">Attendance Sheet</field>
            <field name="code">hr.attendance.sheet</field>
            <field name="prefix">AS/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Payment Authorization -->
        <record id="seq_payment_authorization" model="ir.sequence">
            <field name="name">Payment Authorization</field>
            <field name="code">payment.authorization</field>
            <field name="prefix">UNC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>

