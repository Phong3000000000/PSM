        <!-- ==================== PIT ==================== -->
        <record id="hr_salary_rule_pit" model="hr.salary.rule">
            <field name="name">Thuế Thu Nhập Cá Nhân (PIT)</field>
            <field name="sequence" eval="600"/>
            <field name="code">PIT</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
dependents = inputs.NPT.amount if inputs.NPT else 0
giam_tru = 15000000 + (dependents * 6200000)
taxable_income = categories.BASIC + categories.ALW
taxable_after_deduct = taxable_income - giam_tru
if taxable_after_deduct &lt; 0:
    taxable_after_deduct = 0

tax = 0
if taxable_after_deduct &lt;= 10000000:
    tax = taxable_after_deduct * 0.05
elif taxable_after_deduct &lt;= 30000000:
    tax = (taxable_after_deduct - 10000000) * 0.1 + 500000
elif taxable_after_deduct &lt;= 60000000:
    tax = (taxable_after_deduct - 30000000) * 0.2 + 2500000
elif taxable_after_deduct &lt;= 100000000:
    tax = (taxable_after_deduct - 60000000) * 0.3 + 8500000
else:
    tax = (taxable_after_deduct - 100000000) * 0.35 + 20500000

result = -tax
            </field>
        </record>

