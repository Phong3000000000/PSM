        <!-- ==================== Lương cơ bản ==================== -->
        <record id="hr_salary_rule_basic_custom" model="hr.salary.rule">
            <field name="name">Lương cơ bản</field>
            <field name="sequence" eval="100"/>
            <field name="code">BASIC</field>
            <field name="category_id" ref="hr_payroll.BASIC"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Giả định worked_days.WORK100.number_of_days chứa Total Full Payable Days
payable_days = worked_days.WORK100.number_of_days if worked_days.WORK100 else 0
daily_salary = contract.wage / 26  # F_DailySalary theo mốc 26 ngày công
result = payable_days * daily_salary
            </field>
        </record>

