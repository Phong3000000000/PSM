        <record id="CATEGORY_NON_TAX" model="hr.salary.rule.category">
            <field name="name">Thu nhập Không chịu thuế</field>
            <field name="code">NON_TAX</field>
        </record>

        <record id="structure_type_fb_retail" model="hr.payroll.structure.type">
