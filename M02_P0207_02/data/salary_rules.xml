amt_role = inputs.INP_BONUS_ROLE.amount if inputs.INP_BONUS_ROLE else 0
amt_perf = inputs.INP_BONUS_PERF.amount if inputs.INP_BONUS_PERF else 0
amt_rgm = inputs.INP_BONUS_RGM.amount if inputs.INP_BONUS_RGM else 0
amt_tsi = inputs.INP_BONUS_TSI.amount if inputs.INP_BONUS_TSI else 0
result = amt_role + amt_perf + amt_rgm + amt_tsi
