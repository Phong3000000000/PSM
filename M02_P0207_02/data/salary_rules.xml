        <!-- ==================== Khấu trừ BHXH/BHYT/BHTN ==================== -->
        <record id="hr_salary_rule_bhxh" model="hr.salary.rule">
            <field name="name">Trừ BHXH (8%)</field>
            <field name="sequence" eval="310"/>
            <field name="code">BHXH</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">python</field>
            <field name="condition_python">
unpaid_days = worked_days.UNPAID.number_of_days if worked_days.UNPAID else 0
result = not contract.is_probation and unpaid_days &lt;= 13
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
cap_bhxh = 46800000
salary_base = contract.wage if contract.wage &lt; cap_bhxh else cap_bhxh
result = -(salary_base * 0.08)
            </field>
        </record>

