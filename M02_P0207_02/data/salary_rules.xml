        <record id="rule_appendix_concurrent" model="hr.salary.rule">
            <field name="name">Phụ cấp Kiêm nhiệm (Từ Phụ lục)</field>
            <field name="sequence" eval="201"/>
            <field name="code">ALW_CONCURRENT</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Tìm Phụ lục gắn với Hợp đồng hiện tại
appendix = contract.env['hr.contract.appendix'].search([('contract_id', '=', contract.id)], limit=1)
result = appendix.allowance_concurrent if appendix else 0
            </field>
        </record>

        <record id="rule_appendix_housing" model="hr.salary.rule">
            <field name="name">Phụ cấp Nhà ở (Từ Phụ lục)</field>
            <field name="sequence" eval="202"/>
            <field name="code">ALW_HOUSING_FIXED</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
appendix = contract.env['hr.contract.appendix'].search([('version_id', '=', contract.id)], limit=1)
result = appendix.allowance_housing if appendix else 0
            </field>
        </record>

        <record id="hr_salary_rule_attendance_allowance" model="hr.salary.rule">
            <field name="name">Phụ cấp Chuyên cần</field>
            <field name="sequence" eval="200"/>
            <field name="code">ATT_ALLOW</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = True</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
allowance = 0
level = contract.scale_of_level

if contract.code_location == 'region_1':
    if level in ['6', '7']:
        allowance = 500000
    elif level in ['1', '3', '4', '5']:
        allowance = 1000000
    elif level == '2':
        allowance = 700000
elif contract.code_location == 'region_2':
    if level in ['6', '7']:
        allowance = 400000
    elif level in ['1', '3', '4', '5']:
        allowance = 800000
    elif level == '2':
        allowance = 600000

result = allowance
            </field>
        </record>

        <record id="hr_salary_rule_night_allowance" model="hr.salary.rule">
            <field name="name">Phụ cấp Ca đêm</field>
            <field name="sequence" eval="210"/>
            <field name="code">NIGHT_ALLOW</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="struct_id" ref="structure_time_attendance"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
allowance = 0
dept_name = contract.employee_id.department_id.name

if dept_name in ['Bến Thành', 'Đa Kao', 'Hồ Gươm']:
    allowance = 300000
elif dept_name in ['Trần Não', 'Quận 7']:
    allowance = 200000

result = allowance
            </field>
        </record>

