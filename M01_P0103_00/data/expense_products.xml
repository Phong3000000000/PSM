<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Flight Ticket Product Template -->
        <record id="product_template_expense_flight" model="product.template">
            <field name="name">Flight Ticket</field>
            <field name="can_be_expensed">True</field>
            <field name="type">service</field>
            <field name="list_price">0</field>
            <field name="standard_price">0</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
        </record>
        
        <!-- Hotel Product Template -->
        <record id="product_template_expense_hotel" model="product.template">
            <field name="name">Hotel</field>
            <field name="can_be_expensed">True</field>
            <field name="type">service</field>
            <field name="list_price">0</field>
            <field name="standard_price">0</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
        </record>

        <!-- Flight Product Variant -->
        <record id="product_expense_flight" model="product.product">
            <field name="product_tmpl_id" ref="product_template_expense_flight"/>
        </record>

        <!-- Hotel Product Variant -->
        <record id="product_expense_hotel" model="product.product">
            <field name="product_tmpl_id" ref="product_template_expense_hotel"/>
        </record>
    </data>
</odoo>
