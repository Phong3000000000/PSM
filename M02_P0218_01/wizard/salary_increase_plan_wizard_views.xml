<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View for Salary Increase Plan Lines -->
    <record id="view_salary_increase_plan_line_list" model="ir.ui.view">
        <field name="name">salary.increase.plan.line.list</field>
        <field name="model">salary.increase.plan.line</field>
        <field name="arch" type="xml">
            <list string="Salary Increase Plan" create="0" delete="1" editable="bottom">
                <header>
                    <!-- <button name="action_generate_plan"
                            string="Generate Plan"
                            type="object"
                            class="btn-primary"/> -->
                    <button name="action_submit_to_approval"
                            string="Submit to Approval"
                            type="object"
                            class="btn-success"
                            groups="hr_appraisal.group_hr_appraisal_manager"
                            display="always"
                            />
                </header>
                <field name="employee_id" readonly="1"/>
                <field name="department_id" readonly="1"/>
                <field name="job_id" readonly="1"/>
                <field name="performance_rating" readonly="1"/>
                <field name="assessment_note" readonly="1"/>
                <field name="increase_percentage" widget="percentage" readonly="1"/>
                <field name="increase_percentage_final" widget="percentage" optional="show"/>
                <field name="plan_type" readonly="1" optional="hide"/>
                <field name="create_date" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- Form View (for detail view if needed) -->
    <record id="view_salary_increase_plan_line_form" model="ir.ui.view">
        <field name="name">salary.increase.plan.line.form</field>
        <field name="model">salary.increase.plan.line</field>
        <field name="arch" type="xml">
            <form string="Salary Increase Plan Line">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group>
                            <field name="performance_rating" readonly="1"/>
                            <field name="assessment_note" readonly="1"/>
                            <field name="increase_percentage" widget="percentage" readonly="1"/>
                            <field name="increase_percentage_final" widget="percentage"/>
                            <field name="plan_type" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Server action to generate plan -->
    <record id="action_server_generate_salary_plan" model="ir.actions.server">
        <field name="name">Generate Salary Increase Plan</field>
        <field name="model_id" ref="model_salary_increase_plan_line"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_generate_plan()
        </field>
    </record>

    <!-- Action for menu -->
    <record id="action_salary_increase_plan_line" model="ir.actions.act_window">
        <field name="name">Salary Increase Plan</field>
        <field name="res_model">salary.increase.plan.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('plan_type', '=', 'ops')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Click "Generate Salary Increase Plan" button to create the plan
            </p>
            <p>
                The plan will show recommended salary increases based on performance ratings.
            </p>
        </field>
    </record>

</odoo>
