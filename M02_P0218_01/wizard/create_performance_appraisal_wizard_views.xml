<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Wizard Form View -->
    <record id="view_create_performance_appraisal_wizard_form" model="ir.ui.view">
        <field name="name">create.performance.appraisal.wizard.form</field>
        <field name="model">create.performance.appraisal.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Performance Manager OPS Appraisals">
                <group>
                    <group>
                        <field name="department_id" 
                               domain="[('block_id.code', '=', 'OPS')]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="date_close"/>
                    </group>
                    <group>
                        <field name="appraisal_template_id" 
                               options="{'no_create': True, 'no_open': True}"/>
                        <!-- <field name="survey_ids" 
                               widget="many2many_tags"
                               options="{'no_create': True}"/> -->
                    </group>
                </group>
                <footer>
                    <button name="action_create_appraisals" 
                            string="Create Appraisals" 
                            type="object" 
                            class="btn-primary" 
                            data-hotkey="q"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel" 
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_create_performance_appraisal_wizard" model="ir.actions.act_window">
        <field name="name">Create Performance Appraisals (OPS)</field>
        <field name="res_model">create.performance.appraisal.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_create_performance_appraisal_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="hr_appraisal.model_hr_appraisal"/>
    </record>

</odoo>
