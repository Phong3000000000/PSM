<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_salary_increase_config_tree" model="ir.ui.view">
        <field name="name">salary.increase.config.tree</field>
        <field name="model">salary.increase.config</field>
        <field name="arch" type="xml">
            <list string="Salary Increase Configuration">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="rating_from"/>
                <field name="rating_to"/>
                <field name="increase_percentage" widget="percentage"/>
                <field name="department_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_salary_increase_config_form" model="ir.ui.view">
        <field name="name">salary.increase.config.form</field>
        <field name="model">salary.increase.config</field>
        <field name="arch" type="xml">
            <form string="Salary Increase Configuration">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g., Exceptional Performance"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Performance Rating Range">
                            <field name="rating_from"/>
                            <field name="rating_to"/>
                        </group>
                        <group string="Salary Adjustment">
                            <field name="increase_percentage" widget="percentage"/>
                        </group>
                    </group>
                    <group>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_salary_increase_config_search" model="ir.ui.view">
        <field name="name">salary.increase.config.search</field>
        <field name="model">salary.increase.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_salary_increase_config" model="ir.actions.act_window">
        <field name="name">Salary Increase Configuration</field>
        <field name="res_model">salary.increase.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Salary Increase Configuration
            </p>
            <p>
                Configure salary increase percentages based on performance rating ranges.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_salary_increase_config"
        name="Salary Increase Config"
        parent="hr_appraisal.menu_hr_appraisal_configuration"
        action="action_salary_increase_config"
        sequence="50"/>

</odoo>
