<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit List View to add score field -->
    <record id="hr_appraisal_note_view_tree_inherit" model="ir.ui.view">
        <field name="name">hr.appraisal.note.list.inherit</field>
        <field name="model">hr.appraisal.note</field>
        <field name="inherit_id" ref="hr_appraisal.hr_appraisal_note_view_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="score"/>
            </field>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_appraisal_note" model="ir.actions.act_window">
        <field name="name">Appraisal Note</field>
        <field name="res_model">hr.appraisal.note</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Appraisal Note
            </p>
            <p>
                Configure appraisal notes with score thresholds for rating levels.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_hr_appraisal_note"
        name="Appraisal Note"
        parent="hr_appraisal.menu_hr_appraisal_configuration"
        action="action_hr_appraisal_note"
        sequence="55"/>

</odoo>
