<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_salary_increase_approved" model="mail.template">
            <field name="name">Salary Increase Approved - Notification to Employee</field>
            <field name="model_id" ref="model_salary_increase_plan_line"/> <field name="subject">Thông báo điều chỉnh lương - {{ object.employee_id.name }}</field>
            <field name="partner_to">{{ object.employee_id.user_id.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0; padding: 0; font-family: Arial, sans-serif; font-size: 14px; line-height: 1.6; color: #333;">
                    <div style="max-width: 600px; margin: 20px auto; background-color: #ffffff; border: 1px solid #e0e0e0;">
                        <div style="background-color: #0066cc; padding: 20px; text-align: center;">
                            <h2 style="color: #ffffff; margin: 0; font-size: 20px;">Thông Báo Điều Chỉnh Lương</h2>
                        </div>
                        
                        <div style="padding: 30px;">
                            <p style="margin-bottom: 15px;">Kính gửi Anh/Chị <strong><t t-out="object.employee_id.name"/></strong>,</p>
                            
                            <p style="margin-bottom: 15px;">Phòng Nhân sự trân trọng thông báo và chúc mừng Anh/Chị</p>
                            
                            <p style="margin-bottom: 15px;">
                                Kết quả đánh giá hiệu suất làm việc 
                                <strong>
                                    <t t-if="object.appraisal_id and object.appraisal_id.date_close">
                                        <t t-out="object.appraisal_id.date_close.strftime('%m/%Y')"/>
                                    </t>
                                    <t t-else="">
                                        năm nay
                                    </t>
                                </strong> 
                                của Anh/Chị đã hoàn tất và được phê duyệt chính thức theo quy trình của Công ty.
                            </p>
                            
                            <p style="margin-bottom: 15px;">Dựa trên kết quả đánh giá này, Công ty đã quyết định điều chỉnh mức lương cho Anh/Chị như sau:</p>
                            
                            <div style="background-color: #f8f9fa; border-left: 4px solid #0066cc; padding: 20px; margin: 20px 0;">
                                <h3 style="margin-top: 0; margin-bottom: 15px; color: #0066cc; font-size: 16px;">Thông tin tóm tắt:</h3>
                                <ul style="list-style: none; padding-left: 0; margin: 0;">
                                    <li style="margin-bottom: 10px;">
                                        <strong>• Chu kỳ đánh giá:</strong> 
                                        <t t-if="object.appraisal_id and object.appraisal_id.date_close">
                                            <t t-out="object.appraisal_id.date_close.strftime('%m/%Y')"/>
                                        </t>
                                        <t t-else="">
                                            Năm nay
                                        </t>
                                    </li>
                                    <li style="margin-bottom: 10px;">
                                        <strong>• Kết quả xếp loại:</strong> 
                                        <span style="color: #28a745; font-weight: bold;">
                                            <t t-out="object.assessment_note or 'N/A'"/>
                                        </span>
                                    </li>
                                    <li style="margin-bottom: 10px;">
                                        <strong>• Mức điều chỉnh lương:</strong> 
                                        <span style="color: #dc3545; font-weight: bold; font-size: 18px;">
                                            +<t t-out="'%.2f' % (object.increase_percentage_final * 100)"/>%
                                        </span>
                                    </li>
                                    <li style="margin-bottom: 10px;">
                                        <strong>• Thời điểm áp dụng:</strong> 
                                        <t t-if="object.approval_request_id and object.approval_request_id.date_confirmed">
                                            <t t-out="(object.approval_request_id.date_confirmed + datetime.timedelta(days=30)).strftime('%d/%m/%Y')"/>
                                        </t>
                                        <t t-else="">
                                            Sẽ được thông báo sau
                                        </t>
                                    </li>
                                </ul>
                            </div>
                            
                            <p style="margin-bottom: 15px;">
                                Quyết định trên là sự ghi nhận cho những nỗ lực, tinh thần trách nhiệm và đóng góp tích cực của Anh/Chị trong suốt thời gian vừa qua. Công ty trân trọng những giá trị mà Anh/Chị đã và đang mang lại.
                            </p>
                            
                            <p style="margin-bottom: 15px;">
                                Anh/Chị vui lòng đăng nhập hệ thống để xem chi tiết nội dung đánh giá và thông tin liên quan.
                            </p>
                            
                            <p style="margin-bottom: 15px;">
                                Một lần nữa, xin chúc mừng Anh/Chị và chúc Anh/Chị tiếp tục gặt hái nhiều thành công trong chặng đường sắp tới cùng Công ty.
                            </p>
                            
                            <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0;">
                                <p style="margin-bottom: 5px;"><strong>Trân trọng,</strong></p>
                                <p style="margin-bottom: 5px;">Phòng Nhân sự</p>
                                <p style="margin-bottom: 0; color: #0066cc; font-weight: bold;"><t t-out="user.company_id.name"/></p>
                            </div>
                        </div>
                        
                        <div style="background-color: #f8f9fa; padding: 15px; text-align: center; font-size: 12px; color: #666;">
                            <p style="margin: 0;">Email này được gửi tự động từ hệ thống. Vui lòng không trả lời email này.</p>
                        </div>
                    </div>
                </div>
            </field>
        </record>
    </data>
</odoo>