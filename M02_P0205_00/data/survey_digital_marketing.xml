            <field name="answer_score">7</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q8_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q8" />
            <field name="value">Ngay lập tức, đã có sẵn framework chuẩn</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_nice_to_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>

        <record id="sq_digital_mkt_q9" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s4" />
            <field name="title">Bạn đánh giá thế nào về việc phối hợp giữa marketing - sales và ops?</field>
            <field name="question_type">text_box</field>
            <field name="sequence">32</field>
            <field name="constr_mandatory">False</field>
        </record>

    </data>
</odoo>
