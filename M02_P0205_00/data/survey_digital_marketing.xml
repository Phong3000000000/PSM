<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            ============================================================
            KHẢO SÁT NĂNG LỰC - Digital Marketing Consultant
            Scoring: Must Have >= 80% → tự động PASS
            ============================================================
        -->

        <record id="survey_digital_marketing" model="survey.survey">
            <field name="title">Khảo sát năng lực - Digital Marketing Consultant</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">80</field>
            <field name="is_pre_interview">True</field>
            <field name="users_login_required">False</field>
            <field name="description"><![CDATA[
                <p>Chào bạn! Mục tiêu bài khảo sát này là đánh giá tư duy chiến lược và kỹ thuật của bạn cho vai trò <strong>Digital Marketing Consultant</strong>.</p>
                <p>Không có đáp án đúng/sai tuyệt đối. Hãy phản ánh đúng kinh nghiệm và cách bạn tiếp cận các kênh kỹ thuật số.</p>
                <p>⏱ Thời gian dự kiến: <strong>5–8 phút</strong>.</p>
            ]]></field>
            <field name="description_done"><![CDATA[
                <p>✅ <strong>Cảm ơn bạn đã hoàn thành bài khảo sát!</strong></p>
                <p>Chúng tôi sẽ phản hồi trong vòng <strong>3 ngày làm việc</strong> nếu hồ sơ phù hợp.</p>
                <p>Nếu cần hỗ trợ, liên hệ HR để được giải đáp.</p>
            ]]></field>
        </record>

        <!-- Section 1: Experience &amp; Focus -->
        <record id="sq_digital_mkt_s1" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="title">I. Kinh nghiệm &amp; Trọng tâm</field>
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <record id="sq_digital_mkt_q1" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s1" />
            <field name="title">Bạn có bao nhiêu năm làm chiến dịch Digital/Performance Marketing?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">2</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_digital_mkt_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q1" />
            <field name="value">Chưa từng làm chiến dịch (sẵn sàng học)</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q1" />
            <field name="value">Dưới 1 năm</field>
            <field name="answer_score">4</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q1_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q1" />
            <field name="value">1–3 năm</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_digital_mkt_q1_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q1" />
            <field name="value">Trên 3 năm</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">4</field>
        </record>

        <record id="sq_digital_mkt_q2" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s1" />
            <field name="title">Bạn đã trực tiếp triển khai hoặc tư vấn kênh nào sau đây? (Chọn tất
                cả phù hợp)</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">3</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_digital_mkt_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q2" />
            <field name="value">Paid Search (Google Ads, Microsoft Ads)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q2" />
            <field name="value">Social Ads (Facebook, TikTok, LinkedIn)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q2_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q2" />
            <field name="value">Email Marketing / Automation</field>
            <field name="answer_score">6</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_digital_mkt_q2_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q2" />
            <field name="value">CRM/Retention/Onboarding Flow</field>
            <field name="answer_score">5</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">4</field>
        </record>
        <record id="sq_digital_mkt_q2_a5" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q2" />
            <field name="value">Chưa thực chiến kênh nào</field>
            <field name="answer_score">0</field>
            <field name="sequence">5</field>
        </record>

        <!-- Section 2: Strategy &amp; Analytics -->
        <record id="sq_digital_mkt_s2" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="title">II. Chiến lược &amp; Phân tích</field>
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <record id="sq_digital_mkt_q3" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s2" />
            <field name="title">Khi xây chiến dịch, bạn bắt đầu từ phần nào?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">11</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_digital_mkt_q3_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q3" />
            <field name="value">Chỉ tối ưu kênh hiện tại (Ads, social...)</field>
            <field name="answer_score">2</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q3_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q3" />
            <field name="value">Phân tích dữ liệu, xác định insight trước</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q3_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q3" />
            <field name="value">Họp brainstorm ý tưởng, rồi mới chọn công cụ</field>
            <field name="answer_score">6</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>

        <record id="sq_digital_mkt_q4" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s2" />
            <field name="title">Bạn theo dõi KPIs nào để đánh giá chiến dịch?</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">12</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_digital_mkt_q4_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q4" />
            <field name="value">ROAS / CVR / CPA</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q4_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q4" />
            <field name="value">Chỉ nhìn lượt xem/like/traffic</field>
            <field name="answer_score">3</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q4_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q4" />
            <field name="value">Chỉ quan tâm đến CPM/CPV</field>
            <field name="answer_score">4</field>
            <field name="sequence">3</field>
        </record>

        <record id="sq_digital_mkt_q5" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s2" />
            <field name="title">Bạn có kinh nghiệm dùng analytics/BI (Looker, Power BI, GA4) để báo
                cáo không?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">13</field>
        </record>
        <record id="sq_digital_mkt_q5_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q5" />
            <field name="value">Không</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q5_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q5" />
            <field name="value">Có dùng dashboard cơ bản (GA/Facebook)</field>
            <field name="answer_score">6</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q5_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q5" />
            <field name="value">Tạo báo cáo/automate data từ nhiều nguồn</field>
            <field name="answer_score">10</field>
            <field name="is_correct">True</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- Section 3: Quảng cáo &amp; Nội dung -->
        <record id="sq_digital_mkt_s3" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="title">III. Quảng cáo &amp; Nội dung</field>
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <record id="sq_digital_mkt_q6" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s3" />
            <field name="title">Bạn có kinh nghiệm tối ưu nội dung landing page / copywriting cho
                chuyển đổi?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">21</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_digital_mkt_q6_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q6" />
            <field name="value">Không, chỉ làm đúng kênh quảng cáo</field>
            <field name="answer_score">2</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q6_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q6" />
            <field name="value">Thường xuyên đề xuất A/B test nội dung</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q6_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q6" />
            <field name="value">Lập kế hoạch nội dung dài hạn cho brand/social</field>
            <field name="answer_score">6</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>

        <record id="sq_digital_mkt_q7" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s3" />
            <field name="title">Bạn đã triển khai automation/kịch bản nurturing nào?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">22</field>
        </record>
        <record id="sq_digital_mkt_q7_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q7" />
            <field name="value">Chưa từng</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_digital_mkt_q7_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q7" />
            <field name="value">Từng triển khai 1-2 kịch bản đơn giản</field>
            <field name="answer_score">6</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_digital_mkt_q7_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_digital_mkt_q7" />
            <field name="value">Thiết kế luồng phễu toàn diện, bao gồm scoring/trigger</field>
            <field name="answer_score">10</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- Section 4: Cam kết -->
        <record id="sq_digital_mkt_s4" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="title">IV. Cam kết &amp; Tư duy</field>
            <field name="is_page">True</field>
            <field name="sequence">30</field>
        </record>

        <record id="sq_digital_mkt_q8" model="survey.question">
            <field name="survey_id" ref="survey_digital_marketing" />
            <field name="page_id" ref="sq_digital_mkt_s4" />
            <field name="title">Bạn cần bao lâu để bắt đầu 1 dự án marketing mới?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">31</field>
            <field name="constr_mandatory">True</field>
