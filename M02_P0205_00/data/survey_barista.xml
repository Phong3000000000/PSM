<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            ============================================================
            KHẢO SÁT NĂNG LỰC - BARISTA
            Dành cho ứng viên ứng tuyển vị trí Barista / Nhân viên pha chế
            Scoring: Must Have >= 80% → tự động PASS
            ============================================================
        -->

        <record id="survey_barista" model="survey.survey">
            <field name="title">Khảo Sát Năng Lực - Barista</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">80</field>
            <field name="is_pre_interview">True</field>
            <field name="users_login_required">False</field>
            <field name="description"><![CDATA[
                <p>Xin chào! Chúng tôi rất vui vì bạn quan tâm đến vị trí <strong>Barista</strong> tại công ty.</p>
                <p>Bài khảo sát này giúp chúng tôi hiểu rõ hơn về kinh nghiệm và kỹ năng của bạn.
                Không có câu trả lời đúng hay sai hoàn toàn — hãy chọn đáp án phù hợp nhất với bạn.</p>
                <p>⏱ Thời gian dự kiến: <strong>5–10 phút</strong>.</p>
            ]]></field>
            <field name="description_done"><![CDATA[
                <p>✅ <strong>Cảm ơn bạn đã hoàn thành bài khảo sát!</strong></p>
                <p>Chúng tôi sẽ liên hệ với bạn trong vòng <strong>3 ngày làm việc</strong>.</p>
                <p>Nếu có thắc mắc, vui lòng liên hệ bộ phận HR.</p>
            ]]></field>
        </record>

        <!-- ==================== SECTION 1: KINH NGHIỆM ==================== -->
        <record id="sq_barista_s1" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="title">I. Kinh Nghiệm &amp; Nền Tảng</field>
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <!-- Q1: Kinh nghiệm pha chế -->
        <record id="sq_barista_q1" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s1" />
            <field name="title">Bạn có bao nhiêu kinh nghiệm làm Barista / pha chế đồ uống?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">2</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q1" />
            <field name="value">Chưa có kinh nghiệm (sẵn sàng học)</field>
            <field name="answer_score">0</field>
            <field name="is_must_have">False</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q1" />
            <field name="value">Dưới 6 tháng</field>
            <field name="answer_score">5</field>
            <field name="is_must_have">False</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q1_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q1" />
            <field name="value">6 tháng – 1 năm</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_barista_q1_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q1" />
            <field name="value">Trên 1 năm</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">4</field>
        </record>

        <!-- Q2: Loại đồ uống biết pha -->
        <record id="sq_barista_q2" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s1" />
            <field name="title">Bạn có thể pha những loại đồ uống nào? (Chọn tất cả phù hợp)</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">3</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q2" />
            <field name="value">Cà phê espresso cơ bản (Americano, Latte, Cappuccino)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q2" />
            <field name="value">Đồ uống đá xay / Frappuccino</field>
            <field name="answer_score">5</field>
            <field name="is_must_have">False</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q2_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q2" />
            <field name="value">Trà / Trà sữa</field>
            <field name="answer_score">4</field>
            <field name="is_must_have">False</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_barista_q2_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q2" />
            <field name="value">Cocktail / Mocktail</field>
            <field name="answer_score">3</field>
            <field name="is_must_have">False</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">4</field>
        </record>
        <record id="sq_barista_q2_a5" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q2" />
            <field name="value">Chưa biết pha loại nào</field>
            <field name="answer_score">0</field>
            <field name="sequence">5</field>
        </record>

        <!-- ==================== SECTION 2: KỸ NĂNG & THÁI ĐỘ ==================== -->
        <record id="sq_barista_s2" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="title">II. Kỹ Năng Nghề &amp; Thái Độ Làm Việc</field>
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <!-- Q3: Vệ sinh an toàn thực phẩm -->
        <record id="sq_barista_q3" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s2" />
            <field name="title">Bạn hiểu về quy tắc vệ sinh an toàn thực phẩm khi pha chế đến mức
                nào?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">11</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q3_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q3" />
            <field name="value">Chưa biết, cần được đào tạo</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q3_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q3" />
            <field name="value">Biết cơ bản (rửa tay, vệ sinh dụng cụ)</field>
            <field name="answer_score">6</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q3_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q3" />
            <field name="value">Nắm rõ quy trình và thực hành hàng ngày</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- Q4: Phục vụ khách hàng -->
        <record id="sq_barista_q4" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s2" />
            <field name="title">Khi khách hàng phàn nàn về đồ uống, bạn sẽ làm gì?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">12</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q4_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q4" />
            <field name="value">Xin lỗi và cố gắng giải thích tại sao</field>
            <field name="answer_score">3</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q4_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q4" />
            <field name="value">Xin lỗi và hỏi quản lý quyết định</field>
            <field name="answer_score">6</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q4_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q4" />
            <field name="value">Xin lỗi chân thành, đề nghị làm lại hoặc đổi sản phẩm phù hợp cho
                khách</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_barista_q4_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q4" />
            <field name="value">Không biết xử lý, bỏ qua</field>
            <field name="answer_score">0</field>
            <field name="sequence">4</field>
        </record>

        <!-- Q5: Tốc độ làm việc cao điểm -->
        <record id="sq_barista_q5" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s2" />
            <field name="title">Bạn xử lý ra sao khi quán đông khách, nhiều order cùng lúc?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">13</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q5_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q5" />
            <field name="value">Tôi dễ bị áp lực và chậm lại</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q5_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q5" />
            <field name="value">Tôi cố gắng nhưng đôi khi bị nhầm order</field>
            <field name="answer_score">4</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q5_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q5" />
            <field name="value">Tôi ưu tiên theo thứ tự, giữ bình tĩnh và đảm bảo chất lượng</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- ==================== SECTION 3: THỜI GIAN & CAM KẾT ==================== -->
        <record id="sq_barista_s3" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="title">III. Thời Gian Làm Việc &amp; Cam Kết</field>
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <!-- Q6: Ca làm việc -->
        <record id="sq_barista_q6" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s3" />
            <field name="title">Bạn có thể làm ca nào? (Chọn tất cả phù hợp)</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">21</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q6_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q6" />
            <field name="value">Ca sáng (6:00 – 14:00)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q6_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q6" />
            <field name="value">Ca chiều (14:00 – 22:00)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q6_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q6" />
            <field name="value">Cuối tuần &amp; ngày lễ</field>
            <field name="answer_score">5</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">3</field>
        </record>
        <record id="sq_barista_q6_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q6" />
            <field name="value">Linh hoạt theo yêu cầu</field>
            <field name="answer_score">10</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">4</field>
        </record>

        <!-- Q7: Thời gian có thể bắt đầu -->
        <record id="sq_barista_q7" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s3" />
            <field name="title">Bạn có thể bắt đầu làm việc khi nào?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">22</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_barista_q7_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q7" />
            <field name="value">Sau 1 tháng trở lên</field>
            <field name="answer_score">3</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q7_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q7" />
            <field name="value">Trong vòng 2 tuần</field>
            <field name="answer_score">7</field>
            <field name="is_must_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q7_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q7" />
            <field name="value">Ngay lập tức / trong vòng 1 tuần</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
            <field name="is_nice_to_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- ==================== SECTION 4: THÊM THÔNG TIN ==================== -->
        <record id="sq_barista_s4" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="title">IV. Thông Tin Bổ Sung</field>
            <field name="is_page">True</field>
            <field name="sequence">30</field>
        </record>

        <!-- Q8: Kỹ năng nghệ thuật pha chế -->
        <record id="sq_barista_q8" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s4" />
            <field name="title">Bạn có kỹ năng Latte Art (vẽ hình trên bề mặt cà phê) không?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">31</field>
        </record>
        <record id="sq_barista_q8_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q8" />
            <field name="value">Không</field>
            <field name="answer_score">0</field>
            <field name="sequence">1</field>
        </record>
        <record id="sq_barista_q8_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q8" />
            <field name="value">Biết cơ bản (trái tim, lá)</field>
            <field name="answer_score">5</field>
            <field name="is_nice_to_have">True</field>
            <field name="sequence">2</field>
        </record>
        <record id="sq_barista_q8_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_barista_q8" />
            <field name="value">Thành thạo nhiều mẫu phức tạp</field>
            <field name="answer_score">10</field>
            <field name="is_nice_to_have">True</field>
            <field name="is_correct">True</field>
            <field name="sequence">3</field>
        </record>

        <!-- Q9: Câu hỏi mở - Động lực -->
        <record id="sq_barista_q9" model="survey.question">
            <field name="survey_id" ref="survey_barista" />
            <field name="page_id" ref="sq_barista_s4" />
            <field name="title">Điều gì khiến bạn muốn trở thành Barista tại công ty chúng tôi? (Trả
                lời ngắn gọn)</field>
            <field name="question_type">text_box</field>
            <field name="sequence">32</field>
            <field name="constr_mandatory">False</field>
        </record>

    </data>
</odoo>