<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="survey_marketing_consultant" model="survey.survey">
            <field name="title">Khảo sát năng lực - Marketing Consultant</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">80</field>
            <field name="is_pre_interview">True</field>
            <field name="description"><![CDATA[
                <p>Đây là khảo sát đánh giá kiến thức và kinh nghiệm tư vấn chiến dịch marketing đa kênh.</p>
            ]]></field>
            <field name="description_done"><![CDATA[
                <p>Cảm ơn bạn đã hoàn thành khảo sát. HR sẽ phản hồi trong 3 ngày làm việc.</p>
            ]]></field>
        </record>

        <record id="sq_consult_1_section" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="title">I. Kinh nghiệm tư vấn campaign</field>
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <record id="sq_consult_q1" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="page_id" ref="sq_consult_1_section" />
            <field name="title">Bạn đã từng tư vấn ngành nào sau đây?</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">2</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_consult_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q1" />
            <field name="value">B2B</field>
            <field name="answer_score">7</field>
            <field name="is_must_have">True</field>
        </record>
        <record id="sq_consult_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q1" />
            <field name="value">B2C</field>
            <field name="answer_score">7</field>
            <field name="is_must_have">True</field>
        </record>
        <record id="sq_consult_q1_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q1" />
            <field name="value">E-commerce</field>
            <field name="answer_score">8</field>
            <field name="is_correct">True</field>
        </record>
        <record id="sq_consult_q1_a4" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q1" />
            <field name="value">SaaS</field>
            <field name="answer_score">8</field>
            <field name="is_correct">True</field>
        </record>

        <record id="sq_consult_analytics" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="title">II. Chiến lược &amp; phân tích</field>
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <record id="sq_consult_q2" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="page_id" ref="sq_consult_analytics" />
            <field name="title">Bạn ưu tiên chuẩn hóa quy trình nào đầu tiên?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">11</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_consult_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q2" />
            <field name="value">Định vị insight → KPI → Plan</field>
            <field name="answer_score">10</field>
            <field name="is_must_have">True</field>
        </record>
        <record id="sq_consult_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_consult_q2" />
            <field name="value">Triển khai nhanh trước rồi đo</field>
            <field name="answer_score">3</field>
        </record>

        <record id="sq_consult_tools" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="title">III. Tools và báo cáo</field>  <!-- no amp needed -->
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <record id="sq_consult_q3" model="survey.question">
            <field name="survey_id" ref="survey_marketing_consultant" />
            <field name="page_id" ref="sq_consult_tools" />
            <field name="title">Bạn dùng công cụ nào để báo cáo hiệu quả?</field>
            <field name="question_type">text_box</field>
            <field name="sequence">21</field>
        </record>

    </data>
</odoo>