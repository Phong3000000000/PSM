<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ensure Applications action defaults to office stages -->
        <record id="crm_case_categ0_act_job" model="ir.actions.act_window">
            <field name="name">Applications</field>
            <field name="res_model">hr.applicant</field>
            <field name="domain">[('recruitment_type', '=', 'office')]</field>
            <field name="context">{'search_default_applicants': 1, 'default_recruitment_type':
                'office'}</field>
        </record>

        <!-- keep fallback menu items to the same action but filter by recruitment type -->
        <record id="menu_applications_office" model="ir.ui.menu">
            <field name="parent_id" ref="menu_crm_case_categ0_act_job" />
            <field name="action" ref="crm_case_categ0_act_job" />
        </record>

    </data>
</odoo>