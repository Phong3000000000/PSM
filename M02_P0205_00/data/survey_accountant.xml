<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="survey_accountant" model="survey.survey">
            <field name="title">Khảo sát năng lực - Accountant</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">75</field>
            <field name="is_pre_interview">True</field>
            <field name="users_login_required">False</field>
            <field name="description"><![CDATA[
                <p>Khảo sát kiểm tra hiểu biết về quy trình kế toán tài chính cùng khả năng xử lý báo cáo.</p>
            ]]></field>
            <field name="description_done"><![CDATA[
                <p>Cảm ơn bạn đã hoàn thành khảo sát. HR sẽ phản hồi trong vòng 3 ngày làm việc.</p>
            ]]></field>
        </record>

        <record id="sq_accountant_knowledge" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="title">I. Kiến thức kế toán</field>
            <field name="is_page">True</field>
            <field name="sequence">1</field>
        </record>

        <record id="sq_accountant_q1" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="page_id" ref="sq_accountant_knowledge"/>
            <field name="title">Bạn đã làm báo cáo tài chính theo chuẩn nào?</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">2</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_accountant_q1_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_accountant_q1"/>
            <field name="value">Vietnamese Accounting Standards (VAS)</field>
            <field name="answer_score">8</field>
            <field name="is_must_have">True</field>
        </record>
        <record id="sq_accountant_q1_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_accountant_q1"/>
            <field name="value">IFRS</field>
            <field name="answer_score">7</field>
            <field name="is_nice_to_have">True</field>
        </record>
        <record id="sq_accountant_q1_a3" model="survey.question.answer">
            <field name="question_id" ref="sq_accountant_q1"/>
            <field name="value">Chưa làm báo cáo tài chính</field>
            <field name="answer_score">0</field>
        </record>

        <record id="sq_accountant_process" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="title">II. Quy trình &amp; kiểm tra</field>
            <field name="is_page">True</field>
            <field name="sequence">10</field>
        </record>

        <record id="sq_accountant_q2" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="page_id" ref="sq_accountant_process"/>
            <field name="title">Bạn ưu tiên xử lý việc nào trước khi khóa sổ tháng?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">11</field>
            <field name="constr_mandatory">True</field>
        </record>
        <record id="sq_accountant_q2_a1" model="survey.question.answer">
            <field name="question_id" ref="sq_accountant_q2"/>
            <field name="value">Đối chiếu dư tài khoản ngân hàng và công nợ</field>
            <field name="answer_score">9</field>
            <field name="is_correct">True</field>
        </record>
        <record id="sq_accountant_q2_a2" model="survey.question.answer">
            <field name="question_id" ref="sq_accountant_q2"/>
            <field name="value">Lập báo cáo cho ban lãnh đạo</field>
            <field name="answer_score">5</field>
        </record>

        <record id="sq_accountant_tools" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="title">III. Công cụ &amp; tự động hóa</field>
            <field name="is_page">True</field>
            <field name="sequence">20</field>
        </record>

        <record id="sq_accountant_q3" model="survey.question">
            <field name="survey_id" ref="survey_accountant"/>
            <field name="page_id" ref="sq_accountant_tools"/>
            <field name="title">Bạn dùng phần mềm kế toán nào?</field>
            <field name="question_type">text_box</field>
            <field name="sequence">21</field>
        </record>

    </data>
</odoo>
