<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron to remind Line Manager after 1 minute (for test) -->
        <record id="ir_cron_psm_remind_line_manager" model="ir.cron">
            <field name="name">Recruitment Plan: Remind Line Manager</field>
            <field name="model_id" ref="model_x_psm_recruitment_plan" />
            <field name="state">code</field>
            <field name="code">model._cron_remind_manager()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True" />
        </record>

        <!-- Cron to check monthly notification -->
        <record id="ir_cron_psm_monthly_recruitment_notification" model="ir.cron">
            <field name="name">Recruitment Plan: Monthly Notification</field>
            <field name="model_id" ref="model_x_psm_recruitment_plan" />
            <field name="state">code</field>
            <field name="code">model._cron_check_monthly_notification()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True" />
        </record>
        <!-- Cron to automatically publish jobs when Batch starts -->
        <record id="ir_cron_psm_auto_publish_batches" model="ir.cron">
            <field name="name">Recruitment Batch: Auto Publish Jobs on Start Date</field>
            <field name="model_id" ref="model_x_psm_recruitment_batch" />
            <field name="state">code</field>
            <field name="code">model._cron_auto_publish_approved_batches()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>
