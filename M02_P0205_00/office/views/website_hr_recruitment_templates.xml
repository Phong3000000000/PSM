<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- NOTE: Thank-you page overwrite has been removed.
             The unified thank-you is now handled by M02_P0204_00.
             Kept: detail_custom_fields template and interview slot templates. -->

    <!-- Override job detail page: render từ fields thay vì website_description khi đã có data -->
    <template id="detail_custom_fields" inherit_id="website_hr_recruitment.detail">
        <xpath expr="//div[@t-field='job.website_description']" position="replace">
            <t t-if="job.job_intro or job.responsibilities or job.must_have or job.nice_to_have or job.whats_great">
                <!-- Mô tả công việc + ratings (giữ ratings phần bên phải) -->
                <section class="pt32">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8 pb32" itemprop="description">
                                <t t-if="job.job_intro">
                                    <t t-foreach="job.job_intro.splitlines()" t-as="line">
                                        <p t-if="line.strip()" class="lead" t-esc="line"/>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Responsibilities / Must Have / Nice to have -->
                <section class="s_comparisons pt24 pb24 bg-200">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-4 pt16 pb16">
                                <div class="card text-bg-primary">
                                    <h4 class="card-header">Responsibilities</h4>
                                    <ul class="list-group list-group-flush" itemprop="responsibilities">
                                        <t t-if="job.responsibilities">
                                            <t t-foreach="job.responsibilities.splitlines()" t-as="item">
                                                <li t-if="item.strip()" class="list-group-item" t-esc="item"/>
                                            </t>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-lg-4 pt16 pb16">
                                <div class="card text-bg-primary">
                                    <h4 class="card-header">Must Have</h4>
                                    <ul class="list-group list-group-flush" itemprop="skills">
                                        <t t-if="job.must_have">
                                            <t t-foreach="job.must_have.splitlines()" t-as="item">
                                                <li t-if="item.strip()" class="list-group-item" t-esc="item"/>
                                            </t>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-lg-4 pt16 pb16">
                                <div class="card text-bg-primary">
                                    <h4 class="card-header">Nice to have</h4>
                                    <ul class="list-group list-group-flush">
                                        <t t-if="job.nice_to_have">
                                            <t t-foreach="job.nice_to_have.splitlines()" t-as="item">
                                                <li t-if="item.strip()" class="list-group-item" t-esc="item"/>
                                            </t>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- What's great in the job? -->
                <t t-if="job.whats_great">
                    <section class="s_comparisons pt24 pb24">
                        <div class="container">
                            <div class="row align-items-center">
                                <div class="col-sm-12 pb40">
                                    <h2>What's great in the job?</h2>
                                    <br/>
                                    <ul class="lead">
                                        <t t-foreach="job.whats_great.splitlines()" t-as="item">
                                            <li t-if="item.strip()" t-esc="item"/>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </section>
                </t>
            </t>
            <t t-else="">
                <!-- Fallback: render website_description gốc -->
                <div t-field="job.website_description"/>
            </t>
        </xpath>
    </template>

    <template id="interview_slot_confirm" name="Interview Slot Confirm">
        <t t-call="website.layout">
            <div id="wrap" style="background:#f5f5f5; padding:48px 16px 72px;">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8 col-lg-9">
                            <div style="background:#FFFFFF; border-radius:28px; overflow:hidden; box-shadow:0 20px 45px rgba(0,0,0,0.08);">
                                <div style="display:flex; min-height:18px;">
                                    <div style="flex:1; background:#FFC72C;"></div>
                                    <div style="flex:1; background:#DA291C;"></div>
                                    <div style="flex:1; background:#000000;"></div>
                                    <div style="flex:1; background:#FFFFFF;"></div>
                                </div>

                                <div style="padding:42px 40px 36px; font-family:Arial, sans-serif; color:#111111;">
                                    <div style="display:inline-flex; align-items:center; justify-content:center; width:78px; height:78px; border-radius:50%; background:#FFC72C; color:#000000; font-size:40px; font-weight:700; margin-bottom:20px;">
                                        ✓
                                    </div>

                                    <h1 style="margin:0 0 12px; font-family:Arial, sans-serif; font-size:48px; line-height:1.05; font-weight:800; color:#000000;">
                                        Đã ghi nhận lịch phỏng vấn
                                    </h1>

                                    <p style="margin:0 0 28px; font-family:Arial, sans-serif; font-size:20px; line-height:1.6; color:#3f3f46;">
                                        Cảm ơn bạn đã xác nhận khung giờ phỏng vấn. Đội ngũ tuyển dụng sẽ liên hệ lại với bạn trong thời gian sớm nhất.
                                    </p>

                                    <div style="border:1px solid #ececec; border-radius:22px; overflow:hidden; background:#fffdf8;">
                                        <div style="padding:18px 24px; background:#000000; color:#FFFFFF; font-family:Arial, sans-serif; font-size:15px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase;">
                                            Thông tin đã xác nhận
                                        </div>

                                        <div style="padding:24px;">
                                            <div style="display:flex; flex-wrap:wrap; gap:18px;">
                                                <div style="flex:1 1 220px; padding:18px 20px; border-radius:18px; background:#FFFFFF; border:1px solid #ececec;">
                                                    <div style="font-family:Arial, sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#DA291C; margin-bottom:10px;">
                                                        Ứng viên
                                                    </div>
                                                    <div style="font-family:Arial, sans-serif; font-size:26px; line-height:1.3; font-weight:700; color:#000000;">
                                                        <t t-out="applicant.partner_name"/>
                                                    </div>
                                                </div>

                                                <div style="flex:1 1 220px; padding:18px 20px; border-radius:18px; background:#FFFFFF; border:1px solid #ececec;">
                                                    <div style="font-family:Arial, sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#DA291C; margin-bottom:10px;">
                                                        Thời gian
                                                    </div>
                                                    <div style="font-family:Arial, sans-serif; font-size:26px; line-height:1.3; font-weight:700; color:#000000;">
                                                        <t t-out="event_start_display"/>
                                                    </div>
                                                </div>
                                            </div>

                                            <div style="margin-top:22px; padding:18px 20px; border-radius:18px; background:#FFF4CC; border-left:6px solid #FFC72C;">
                                                <div style="font-family:Arial, sans-serif; font-size:16px; line-height:1.7; color:#2d2d2d;">
                                                    Vị trí ứng tuyển:
                                                    <strong><t t-out="applicant.job_id.name or 'Đang cập nhật'"/></strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div style="margin-top:28px; font-family:Arial, sans-serif; font-size:16px; line-height:1.8; color:#3f3f46;">
                                        Nếu cần thay đổi lịch hoặc có thêm câu hỏi, bạn có thể phản hồi lại email tuyển dụng để được hỗ trợ.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="interview_slot_invalid" name="Interview Slot Invalid">
        <t t-call="website.layout">
            <div id="wrap" class="container mt32 mb32">
                <div class="row">
                    <div class="col-lg-8 offset-lg-2 text-center">
                        <h2>Lien ket khong hop le</h2>
                        <p>Vui long kiem tra lai email hoac lien he bo phan tuyen dung.</p>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="office_job_apply_custom" name="Office Job Apply Custom">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5" style="background: linear-gradient(180deg, #f7f9fc 0%, #eef3f8 100%);">
                    <div class="container">
                        <div class="row justify-content-center mb-4">
                            <div class="col-xl-10 col-lg-11">
                                <div class="text-center mb-4">
                                    <span class="badge rounded-pill text-bg-light border px-3 py-2 mb-3">Office Recruitment</span>
                                    <h1 class="display-6 fw-bold text-dark mb-3">
                                        <t t-esc="job.name"/>
                                    </h1>
                                    <p class="lead text-muted mb-0">
                                        Hoàn tất thông tin ứng tuyển để bộ phận tuyển dụng xem xét hồ sơ của bạn.
                                    </p>
                                </div>

                                <t t-if="not form_fields">
                                    <div class="alert alert-warning text-center shadow-sm">
                                        <h4 class="alert-heading mb-3">
                                            <i class="fa fa-exclamation-triangle me-2"/>Chưa thiết lập biểu mẫu
                                        </h4>
                                        <p class="mb-0">
                                            Vị trí này chưa được thiết lập biểu mẫu ứng tuyển trực tuyến. Vui lòng quay lại sau hoặc liên hệ bộ phận nhân sự để được hỗ trợ.
                                        </p>
                                    </div>
                                </t>

                                <t t-else="">
                                    <form t-att-action="submit_url" method="post" class="js_website_submit_form" enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="job_id" t-att-value="job.id"/>
                                        <input type="hidden" name="apply_origin" t-att-value="apply_origin"/>
                                        <input type="hidden" name="recruitment_type" value="office"/>
                                        <input type="hidden" name="line_id" t-if="source_context.get('line_id')" t-att-value="source_context['line_id']"/>
                                        <input type="hidden" name="request_id" t-if="source_context.get('request_id')" t-att-value="source_context['request_id']"/>
                                        <input type="hidden" name="schedule_id" t-if="schedule" t-att-value="schedule.id"/>

                                        <div class="card border-0 shadow-sm mb-4" style="border-radius: 24px;">
                                            <div class="card-body p-4 p-lg-5">
                                                <div class="row g-4 align-items-start">
                                                    <div class="col-lg-7">
                                                        <div class="d-flex flex-column gap-3">
                                                            <div class="d-flex align-items-start gap-3">
                                                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: #e8f0ff; color: #0d6efd;">
                                                                    <i class="fa fa-briefcase"/>
                                                                </div>
                                                                <div>
                                                                    <div class="text-muted small text-uppercase fw-semibold">Vị trí</div>
                                                                    <div class="fw-bold text-dark"><t t-esc="job.name"/></div>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex align-items-start gap-3" t-if="job.company_id">
                                                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: #eefaf2; color: #198754;">
                                                                    <i class="fa fa-building-o"/>
                                                                </div>
                                                                <div>
                                                                    <div class="text-muted small text-uppercase fw-semibold">Công ty</div>
                                                                    <div class="fw-semibold text-dark"><t t-esc="job.company_id.name"/></div>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex align-items-start gap-3" t-if="job.department_id">
                                                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: #fff4e8; color: #fd7e14;">
                                                                    <i class="fa fa-sitemap"/>
                                                                </div>
                                                                <div>
                                                                    <div class="text-muted small text-uppercase fw-semibold">Phòng ban</div>
                                                                    <div class="fw-semibold text-dark"><t t-esc="job.department_id.name"/></div>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex align-items-start gap-3" t-if="job.address_id">
                                                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: #f5ecff; color: #6f42c1;">
                                                                    <i class="fa fa-map-marker"/>
                                                                </div>
                                                                <div>
                                                                    <div class="text-muted small text-uppercase fw-semibold">Địa điểm</div>
                                                                    <div class="fw-semibold text-dark"><t t-esc="job.address_id.display_name"/></div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-5">
                                                        <div class="rounded-4 border h-100 p-4" style="background: #fafcff;">
                                                            <div class="small text-uppercase fw-semibold text-muted mb-2">Lưu ý</div>
                                                            <p class="text-muted mb-3">
                                                                Vui lòng điền đầy đủ thông tin và đính kèm CV mới nhất. Hồ sơ hợp lệ sẽ được chuyển thẳng vào quy trình tuyển dụng văn phòng.
                                                            </p>
                                                            <p class="text-muted mb-3">
                                                                Hồ sơ sẽ được xử lý qua hệ thống tuyển dụng dùng chung để bảo đảm lưu trữ applicant và khảo sát thống nhất.
                                                            </p>
                                                            <p class="text-muted mb-0" t-if="job.contract_type_id">
                                                                <strong>Loại hợp đồng:</strong> <t t-esc="job.contract_type_id.name"/>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="alert alert-primary border-0 rounded-4 mt-4 mb-0" t-if="source_context.get('source_title')">
                                                    <div class="small text-uppercase fw-semibold mb-1">Nguồn tuyển dụng</div>
                                                    <div class="fw-bold">
                                                        <t t-esc="source_context['source_title']"/>
                                                    </div>
                                                    <div class="text-muted" t-if="source_context.get('source_subtitle')">
                                                        <t t-esc="source_context['source_subtitle']"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <t t-foreach="office_form_sections" t-as="section">
                                            <div class="card border-0 shadow-sm mb-4" style="border-radius: 24px;">
                                                <div class="card-header border-0 text-white py-3 px-4" t-att-style="section['header_style']">
                                                    <h4 class="mb-1 fw-bold">
                                                        <t t-esc="section['title']"/>
                                                    </h4>
                                                    <p class="mb-0 opacity-75" t-if="section.get('description')">
                                                        <t t-esc="section['description']"/>
                                                    </p>
                                                </div>
                                                <div class="card-body p-4 p-lg-5">
                                                    <div class="row g-4">
                                                        <t t-foreach="section['items']" t-as="item">
                                                            <t t-call="M02_P0205_00.office_job_apply_field_renderer"/>
                                                        </t>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>

                                        <div class="card border-0 shadow-sm mb-4" style="border-radius: 24px;" t-if="office_survey_questions">
                                            <div class="card-header border-0 text-white py-3 px-4" style="background: linear-gradient(135deg, #166534, #22c55e); border-radius: 24px 24px 0 0;">
                                                <h4 class="mb-1 fw-bold">5. Bài khảo sát năng lực</h4>
                                                <p class="mb-0 opacity-75">Phần khảo sát giúp hệ thống và đội tuyển dụng đánh giá mức độ phù hợp của hồ sơ với vị trí office bạn đang ứng tuyển.</p>
                                            </div>
                                            <div class="card-body p-4 p-lg-5">
                                                <div class="row g-3 mb-4">
                                                    <div class="col-md-4">
                                                        <div class="rounded-4 border h-100 p-3 bg-light">
                                                            <div class="text-muted small text-uppercase fw-semibold">Số câu hỏi</div>
                                                            <div class="fs-3 fw-bold text-dark"><t t-esc="len(office_survey_questions)"/></div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="rounded-4 border h-100 p-3 bg-light">
                                                            <div class="text-muted small text-uppercase fw-semibold">Câu bắt buộc</div>
                                                            <div class="fs-3 fw-bold text-dark"><t t-esc="mandatory_office_question_count"/></div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="rounded-4 border h-100 p-3 bg-light">
                                                            <div class="text-muted small text-uppercase fw-semibold">Lưu ý</div>
                                                            <div class="fw-semibold text-dark">Trả lời trung thực và theo kinh nghiệm thực tế</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="alert alert-success border-0 rounded-4 mb-4">
                                                    Vui lòng hoàn tất đầy đủ các câu hỏi bắt buộc. Kết quả khảo sát sẽ được lưu cùng hồ sơ ứng tuyển của bạn.
                                                </div>
                                                <t t-foreach="office_survey_questions" t-as="question_item">
                                                    <t t-set="question" t-value="question_item['question']"/>
                                                    <div class="mb-4 p-4 border rounded-4 bg-light survey_question" t-att-data-question-type="question.question_type">
                                                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                                                            <div class="d-flex align-items-start gap-3">
                                                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0" style="width: 40px; height: 40px; background: #0f172a;">
                                                                    <t t-esc="question_item['number']"/>
                                                                </div>
                                                                <div>
                                                                    <h5 class="fw-bold mb-2">
                                                                        <t t-esc="question.title"/>
                                                                        <span t-if="question.is_mandatory_correct" class="text-danger">*</span>
                                                                    </h5>
                                                                    <p class="text-muted mb-0" t-if="question_item['helper_text']">
                                                                        <t t-esc="question_item['helper_text']"/>
                                                                    </p>
                                                                </div>
                                                            </div>
                                                            <span class="badge rounded-pill text-bg-light border">
                                                                <t t-esc="question_item['type_label']"/>
                                                            </span>
                                                        </div>
                                                        <div class="question_input">
                                                            <t t-if="question.question_type == 'char_box'">
                                                                <input type="text" t-att-name="'question_' + str(question.id)" class="form-control form-control-lg" t-att-required="question.is_mandatory_correct"/>
                                                            </t>
                                                            <t t-if="question.question_type == 'text_box'">
                                                                <textarea t-att-name="'question_' + str(question.id)" class="form-control" rows="4" t-att-required="question.is_mandatory_correct"/>
                                                            </t>
                                                            <t t-if="question.question_type == 'numerical_box'">
                                                                <input type="number" step="any" t-att-name="'question_' + str(question.id)" class="form-control form-control-lg" t-att-required="question.is_mandatory_correct"/>
                                                            </t>
                                                            <t t-if="question.question_type == 'date'">
                                                                <input type="date" t-att-name="'question_' + str(question.id)" class="form-control form-control-lg" t-att-required="question.is_mandatory_correct"/>
                                                            </t>
                                                            <t t-if="question.question_type == 'simple_choice'">
                                                                <div class="d-flex flex-column gap-2">
                                                                    <t t-foreach="question.suggested_answer_ids" t-as="answer">
                                                                        <div class="form-check mb-2">
                                                                            <input class="form-check-input" type="radio"
                                                                                t-att-name="'question_' + str(question.id)"
                                                                                t-att-id="'answer_' + str(answer.id)"
                                                                                t-att-value="answer.id"
                                                                                t-att-required="question.is_mandatory_correct"/>
                                                                            <label class="form-check-label" t-att-for="'answer_' + str(answer.id)">
                                                                                <t t-esc="answer.value"/>
                                                                            </label>
                                                                        </div>
                                                                    </t>
                                                                </div>
                                                            </t>
                                                            <t t-if="question.question_type == 'multiple_choice'">
                                                                <div class="d-flex flex-column gap-2">
                                                                    <t t-foreach="question.suggested_answer_ids" t-as="answer">
                                                                        <div class="form-check mb-2">
                                                                            <input class="form-check-input" type="checkbox"
                                                                                t-att-name="'question_' + str(question.id) + '[]'"
                                                                                t-att-id="'answer_' + str(answer.id)"
                                                                                t-att-value="answer.id"/>
                                                                            <label class="form-check-label" t-att-for="'answer_' + str(answer.id)">
                                                                                <t t-esc="answer.value"/>
                                                                            </label>
                                                                        </div>
                                                                    </t>
                                                                </div>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>

                                        <div class="text-center mt-4">
                                            <button type="submit" class="btn btn-lg px-5 py-3 text-white fw-bold shadow-sm" style="background-color: #0f172a; border-radius: 999px; min-width: 280px;">
                                                Gửi hồ sơ ứng tuyển
                                            </button>
                                        </div>
                                    </form>
                                </t>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="office_job_apply_field_renderer" name="Office Job Apply Field Renderer">
        <div t-if="item['field'].is_active" t-attf-class="col-md-#{item['field'].col_size} mb-1">
            <label class="form-label fw-bold text-dark">
                <t t-esc="item['display_label']"/>
                <span t-if="item['field'].is_required" class="text-danger"> *</span>
            </label>
            <p class="form-text mt-0 mb-2 text-muted" t-if="item.get('help_text')">
                <t t-esc="item['help_text']"/>
            </p>

            <t t-if="item['field'].field_type in ['text', 'email', 'tel', 'number', 'date']">
                <input t-att-type="item['field'].field_type if item['field'].field_type != 'text' else 'text'"
                    t-att-name="item['field'].field_name"
                    class="form-control form-control-lg"
                    t-att-placeholder="item.get('placeholder') or None"
                    t-att-required="item['field'].is_required"/>
            </t>

            <t t-if="item['field'].field_type == 'textarea'">
                <textarea t-att-name="item['field'].field_name"
                    class="form-control"
                    rows="4"
                    t-att-placeholder="item.get('placeholder') or None"
                    t-att-required="item['field'].is_required"/>
            </t>

            <t t-if="item['field'].field_type == 'select'">
                <select t-att-name="item['field'].field_name"
                    class="form-select form-select-lg"
                    t-att-required="item['field'].is_required">
                    <option value="">-- Chọn --</option>
                    <t t-foreach="item['field'].get_selection_list()" t-as="opt">
                        <option t-att-value="opt['value']" t-esc="opt['label']"/>
                    </t>
                </select>
            </t>

            <t t-if="item['field'].field_type == 'radio'">
                <div class="d-flex flex-column gap-2 pt-1">
                    <t t-foreach="item['field'].get_selection_list()" t-as="opt">
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                t-att-name="item['field'].field_name"
                                t-att-id="'radio_' + item['field'].field_name + '_' + opt['value']"
                                t-att-value="opt['value']"
                                t-att-required="item['field'].is_required"/>
                            <label class="form-check-label" t-att-for="'radio_' + item['field'].field_name + '_' + opt['value']">
                                <t t-esc="opt['label']"/>
                            </label>
                        </div>
                    </t>
                </div>
            </t>

            <t t-if="item['field'].field_type == 'checkbox'">
                <div class="form-check pt-2">
                    <input class="form-check-input" type="checkbox"
                        t-att-name="item['field'].field_name"
                        t-att-id="'checkbox_' + item['field'].field_name"
                        value="1"/>
                    <label class="form-check-label" t-att-for="'checkbox_' + item['field'].field_name">
                        <t t-esc="item['display_label']"/>
                    </label>
                </div>
            </t>

            <t t-if="item['field'].field_type == 'file'">
                <input type="file" t-att-name="item['field'].field_name"
                    class="form-control form-control-lg"
                    t-att-accept="'image/*' if item['field'].field_name == 'x_portrait_image' else ''"
                    t-att-required="item['field'].is_required"/>
            </t>
        </div>
    </template>

</odoo>
