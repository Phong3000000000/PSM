<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Job Application Form (Public) -->
    <template id="job_apply_template" name="Ứng tuyển công việc">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5" style="background-color: #f8f9fa;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-lg overflow-hidden">
                                    <div class="card-header border-0 p-4 text-center text-white" style="background: linear-gradient(135deg, #004a99, #007bff);">
                                        <h2 class="mb-0 fw-bold">Ứng Tuyển Công Việc</h2>
                                        <p class="mb-0 mt-2 opacity-75">
                                            <t t-esc="job.name"/>
                                            <t t-if="request_rec"> (Tuyển dụng đột xuất)</t>
                                        </p>
                                    </div>

                                    <div class="card-body p-4 p-md-5 bg-white">
                                        <div class="alert alert-info border-0 shadow-sm mb-4" style="background-color: #e9ecef;">
                                            <div class="d-flex">
                                                <div class="flex-shrink-0 me-3">
                                                    <i class="fa fa-briefcase fa-2x text-primary"></i>
                                                </div>
                                                <div class="flex-grow-1 text-dark">
                                                    <strong>Vị trí:</strong> <t t-esc="job.name"/><br/>
                                                    <strong>Công ty:</strong> <t t-esc="job.company_id.name"/><br/>
                                                    <t t-if="batch">
                                                        <strong>Đợt:</strong> <t t-esc="batch.name"/><br/>
                                                    </t>
                                                    <t t-if="job.address_id">
                                                        <strong>Địa điểm:</strong> <t t-esc="job.address_id.name"/>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>

                                        <t t-if="error">
                                            <div class="alert alert-danger shadow-sm mb-4">
                                                <strong>Lỗi:</strong> <t t-esc="msg or 'Có lỗi xảy ra, vui lòng thử lại.'"/>
                                            </div>
                                        </t>

                                        <form action="/jobs/submit" method="POST" enctype="multipart/form-data">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <t t-if="line">
                                                <input type="hidden" name="line_id" t-att-value="line.id"/>
                                            </t>
                                            <t t-if="request_rec">
                                                <input type="hidden" name="request_id" t-att-value="request_rec.id"/>
                                            </t>

                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-user text-muted"></i></span>
                                                        <input type="text" name="name" class="form-control bg-light border-start-0" required="required" placeholder="Nguyễn Văn A"/>
                                                    </div>
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-envelope text-muted"></i></span>
                                                        <input type="email" name="email" class="form-control bg-light border-start-0" required="required" placeholder="email@example.com"/>
                                                    </div>
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-phone text-muted"></i></span>
                                                        <input type="tel" name="phone" class="form-control bg-light border-start-0" required="required" placeholder="0123 456 789"/>
                                                    </div>
                                                </div>

                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">Ngày sinh <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-calendar text-muted"></i></span>
                                                        <input type="date" name="birthdate" class="form-control bg-light border-start-0" required="required"/>
                                                    </div>
                                                </div>

                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Địa chỉ cư trú <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-map-marker text-muted"></i></span>
                                                        <input type="text" name="address" class="form-control bg-light border-start-0" required="required" placeholder="Quận/Huyện, Thành phố"/>
                                                    </div>
                                                </div>

                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Kinh nghiệm làm việc <span class="text-danger">*</span></label>
                                                    <textarea name="experience" class="form-control bg-light" rows="3" required="required" placeholder="Mô tả tóm tắt kinh nghiệm làm việc liên quan..."></textarea>
                                                </div>

                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Tải lên CV (PDF, DOCX) <span class="text-danger">*</span></label>
                                                    <input type="file" name="cv_file" class="form-control bg-light" accept=".pdf,.doc,.docx" required="required"/>
                                                    <div class="form-text mt-1 text-mutedSmall">Vui lòng tải lên file định dạng PDF hoặc Word, dung lượng tối đa 10MB.</div>
                                                </div>

                                                <div class="col-12 mt-5">
                                                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm py-3 transition hover-translate-y" style="background-color: #004a99; border: none; border-radius: 8px;">
                                                        GỬI HỒ SƠ ỨNG TUYỂN
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>

                                    <div class="card-footer bg-light border-0 p-4 text-center">
                                        <p class="mb-0 text-muted small">© 2026 MCD Recruitment System. Cảm ơn bạn đã quan tâm.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <style>
                    .hover-translate-y:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
                    }
                    .transition {
                        transition: all 0.3s ease;
                    }
                    .form-control:focus {
                        background-color: #fff !important;
                        border-color: #004a99;
                        box-shadow: 0 0 0 0.25rem rgba(0, 74, 153, 0.1);
                    }
                    .input-group-text {
                        color: #6c757d;
                    }
                </style>
            </div>
        </t>
    </template>

    <!-- Thank You Page -->
    <template id="job_thankyou_template" name="Cảm ơn ứng tuyển">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5 bg-white" style="min-height: 60vh; display: flex; align-items: center;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-6 text-center">
                                <div class="mb-4 animate__animated animate__zoomIn">
                                    <div class="bg-success d-inline-flex align-items-center justify-content-center rounded-circle shadow-lg" style="width: 100px; height: 100px;">
                                        <i class="fa fa-check text-white fa-4x"></i>
                                    </div>
                                </div>
                                <h1 class="fw-bold mb-3 text-dark">Đăng Ký Thành Công!</h1>
                                <p class="lead text-muted mb-5">
                                    Hồ sơ của bạn đã được gửi tới bộ phận Tuyển dụng.<br/>
                                    Chúng tôi sẽ xem xét và liên hệ với bạn trong thời gian sớm nhất.
                                </p>
                                <div class="d-flex gap-3 justify-content-center">
                                    <a href="/" class="btn btn-outline-primary btn-lg px-4 fw-bold">Về Trang Chủ</a>
                                    <a href="/my/home" class="btn btn-primary btn-lg px-4 fw-bold shadow-sm" style="background-color: #004a99; border: none;">Vào Portal</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="office_job_public_list" name="Office Jobs Public List">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5" style="background: linear-gradient(180deg, #f7f9fc 0%, #eef3f8 100%);">
                    <div class="container">
                        <div class="row justify-content-center mb-4">
                            <div class="col-xl-9 text-center">
                                <span class="badge rounded-pill text-bg-light border px-3 py-2 mb-3">Office Recruitment</span>
                                <h1 class="display-5 fw-bold text-dark mb-3">Cơ Hội Nghề Nghiệp Khối Văn Phòng</h1>
                                <p class="lead text-muted mb-0">
                                    Danh sách các vị trí office đang mở tuyển và đã sẵn sàng nhận hồ sơ ứng tuyển.
                                </p>
                            </div>
                        </div>

                        <t t-if="not batches and not no_batch_lines and not unplanned_requests">
                            <div class="alert alert-info border-0 shadow-sm text-center" role="alert">
                                Hiện chưa có vị trí office nào đang mở tuyển công khai.
                            </div>
                        </t>

                        <t t-foreach="batches" t-as="batch_group">
                            <div class="mb-5">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-3 pb-2 border-bottom">
                                    <span class="badge rounded-pill" style="background-color: #004a99;">Đợt tuyển dụng</span>
                                    <h3 class="mb-0 fw-bold text-dark">
                                        <t t-esc="batch_group['batch'].name"/>
                                    </h3>
                                    <span class="text-muted">
                                        <t t-esc="len(batch_group['lines'])"/> vị trí
                                    </span>
                                </div>
                                <div class="row g-4">
                                    <t t-foreach="batch_group['lines']" t-as="line">
                                        <div class="col-md-6 col-xl-4">
                                            <div class="card border-0 shadow-sm h-100" style="border-radius: 18px;">
                                                <div class="card-body d-flex flex-column p-4">
                                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                                        <h4 class="h5 fw-bold text-dark mb-0">
                                                            <t t-esc="line.job_id.name"/>
                                                        </h4>
                                                        <span class="badge rounded-pill text-bg-light border">
                                                            <t t-esc="line.quantity"/> vị trí
                                                        </span>
                                                    </div>
                                                    <p class="text-muted mb-2" t-if="line.job_id.company_id">
                                                        <i class="fa fa-building-o me-1"/>
                                                        <t t-esc="line.job_id.company_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-2" t-if="line.department_id">
                                                        <i class="fa fa-sitemap me-1"/>
                                                        <t t-esc="line.department_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-2" t-if="line.job_id.address_id">
                                                        <i class="fa fa-map-marker me-1"/>
                                                        <t t-esc="line.job_id.address_id.display_name"/>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="line.job_id.contract_type_id">
                                                        <i class="fa fa-id-badge me-1"/>
                                                        <t t-esc="line.job_id.contract_type_id.name"/>
                                                    </p>
                                                    <p class="text-muted small mb-3" t-if="line.job_id.job_intro or line.job_id.description">
                                                        <t t-esc="(line.job_id.job_intro or line.job_id.description or '').strip()[:160]"/>
                                                        <t t-if="len((line.job_id.job_intro or line.job_id.description or '').strip()) &gt; 160">...</t>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="line.planned_date">
                                                        <i class="fa fa-calendar me-1"/>
                                                        Thời gian dự kiến: <t t-esc="line.planned_date"/>
                                                    </p>
                                                    <div class="mt-auto">
                                                        <a t-attf-href="/jobs/detail/#{line.id}" class="btn w-100 text-white fw-semibold" style="background-color: #004a99; border-radius: 10px;">
                                                            Xem chi tiết và ứng tuyển
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <t t-if="unplanned_requests">
                            <div class="mb-5">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-3 pb-2 border-bottom">
                                    <span class="badge rounded-pill text-bg-danger">Đột xuất</span>
                                    <h3 class="mb-0 fw-bold text-dark">Tuyển dụng office đột xuất</h3>
                                </div>
                                <div class="row g-4">
                                    <t t-foreach="unplanned_requests" t-as="req">
                                        <div class="col-md-6 col-xl-4">
                                            <div class="card border-0 shadow-sm h-100" style="border-radius: 18px;">
                                                <div class="card-body d-flex flex-column p-4">
                                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                                        <h4 class="h5 fw-bold text-dark mb-0">
                                                            <t t-esc="req.job_id.name"/>
                                                        </h4>
                                                        <span class="badge rounded-pill text-bg-danger">
                                                            <t t-esc="req.quantity"/> vị trí
                                                        </span>
                                                    </div>
                                                    <p class="text-muted mb-2" t-if="req.job_id.company_id">
                                                        <i class="fa fa-building-o me-1"/>
                                                        <t t-esc="req.job_id.company_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="req.department_id">
                                                        <i class="fa fa-sitemap me-1"/>
                                                        <t t-esc="req.department_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-2" t-if="req.job_id.address_id">
                                                        <i class="fa fa-map-marker me-1"/>
                                                        <t t-esc="req.job_id.address_id.display_name"/>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="req.job_id.contract_type_id">
                                                        <i class="fa fa-id-badge me-1"/>
                                                        <t t-esc="req.job_id.contract_type_id.name"/>
                                                    </p>
                                                    <p class="text-muted small mb-3" t-if="req.job_id.job_intro or req.job_id.description">
                                                        <t t-esc="(req.job_id.job_intro or req.job_id.description or '').strip()[:160]"/>
                                                        <t t-if="len((req.job_id.job_intro or req.job_id.description or '').strip()) &gt; 160">...</t>
                                                    </p>
                                                    <div class="mt-auto">
                                                        <a t-attf-href="/jobs/request/detail/#{req.id}" class="btn w-100 text-white fw-semibold" style="background-color: #b42318; border-radius: 10px;">
                                                            Xem chi tiết và ứng tuyển
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <t t-if="no_batch_lines">
                            <div class="mb-5">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-3 pb-2 border-bottom">
                                    <span class="badge rounded-pill text-bg-secondary">Thường xuyên</span>
                                    <h3 class="mb-0 fw-bold text-dark">Tuyển dụng office theo kế hoạch</h3>
                                </div>
                                <div class="row g-4">
                                    <t t-foreach="no_batch_lines" t-as="line">
                                        <div class="col-md-6 col-xl-4">
                                            <div class="card border-0 shadow-sm h-100" style="border-radius: 18px;">
                                                <div class="card-body d-flex flex-column p-4">
                                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                                        <h4 class="h5 fw-bold text-dark mb-0">
                                                            <t t-esc="line.job_id.name"/>
                                                        </h4>
                                                        <span class="badge rounded-pill text-bg-light border">
                                                            <t t-esc="line.quantity"/> vị trí
                                                        </span>
                                                    </div>
                                                    <p class="text-muted mb-2" t-if="line.job_id.company_id">
                                                        <i class="fa fa-building-o me-1"/>
                                                        <t t-esc="line.job_id.company_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="line.department_id">
                                                        <i class="fa fa-sitemap me-1"/>
                                                        <t t-esc="line.department_id.name"/>
                                                    </p>
                                                    <p class="text-muted mb-2" t-if="line.job_id.address_id">
                                                        <i class="fa fa-map-marker me-1"/>
                                                        <t t-esc="line.job_id.address_id.display_name"/>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="line.job_id.contract_type_id">
                                                        <i class="fa fa-id-badge me-1"/>
                                                        <t t-esc="line.job_id.contract_type_id.name"/>
                                                    </p>
                                                    <p class="text-muted small mb-3" t-if="line.job_id.job_intro or line.job_id.description">
                                                        <t t-esc="(line.job_id.job_intro or line.job_id.description or '').strip()[:160]"/>
                                                        <t t-if="len((line.job_id.job_intro or line.job_id.description or '').strip()) &gt; 160">...</t>
                                                    </p>
                                                    <p class="text-muted mb-3" t-if="line.planned_date">
                                                        <i class="fa fa-calendar me-1"/>
                                                        Thời gian dự kiến: <t t-esc="line.planned_date"/>
                                                    </p>
                                                    <div class="mt-auto">
                                                        <a t-attf-href="/jobs/detail/#{line.id}" class="btn w-100 text-white fw-semibold" style="background-color: #495057; border-radius: 10px;">
                                                            Xem chi tiết và ứng tuyển
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
