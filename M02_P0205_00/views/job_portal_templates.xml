<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Job Application Form (Public) -->
    <template id="job_apply_template" name="Ứng tuyển công việc">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5" style="background-color: #f8f9fa;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-lg overflow-hidden">
                                    <div class="card-header border-0 p-4 text-center text-white" style="background: linear-gradient(135deg, #004a99, #007bff);">
                                        <h2 class="mb-0 fw-bold">Ứng Tuyển Công Việc</h2>
                                        <p class="mb-0 mt-2 opacity-75">
                                            <t t-esc="job.name"/> 
                                            <t t-if="request_rec"> (Tuyển dụng đột xuất)</t>
                                        </p>
                                    </div>
                                    
                                    <div class="card-body p-4 p-md-5 bg-white">
                                        <div class="alert alert-info border-0 shadow-sm mb-4" style="background-color: #e9ecef;">
                                            <div class="d-flex">
                                                <div class="flex-shrink-0 me-3">
                                                    <i class="fa fa-briefcase fa-2x text-primary"></i>
                                                </div>
                                                <div class="flex-grow-1 text-dark">
                                                    <strong>Vị trí:</strong> <t t-esc="job.name"/><br/>
                                                    <strong>Công ty:</strong> <t t-esc="job.company_id.name"/><br/>
                                                    <t t-if="batch">
                                                        <strong>Đợt:</strong> <t t-esc="batch.name"/><br/>
                                                    </t>
                                                    <t t-if="job.address_id">
                                                        <strong>Địa điểm:</strong> <t t-esc="job.address_id.name"/>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>

                                        <t t-if="error">
                                            <div class="alert alert-danger shadow-sm mb-4">
                                                <strong>Lỗi:</strong> <t t-esc="msg or 'Có lỗi xảy ra, vui lòng thử lại.'"/>
                                            </div>
                                        </t>
                                        
                                        <form action="/jobs/submit" method="POST" enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <t t-if="line">
                                                <input type="hidden" name="line_id" t-att-value="line.id"/>
                                            </t>
                                            <t t-if="request_rec">
                                                <input type="hidden" name="request_id" t-att-value="request_rec.id"/>
                                            </t>

                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-user text-muted"></i></span>
                                                        <input type="text" name="name" class="form-control bg-light border-start-0" required="required" placeholder="Nguyễn Văn A"/>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-envelope text-muted"></i></span>
                                                        <input type="email" name="email" class="form-control bg-light border-start-0" required="required" placeholder="email@example.com"/>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-phone text-muted"></i></span>
                                                        <input type="tel" name="phone" class="form-control bg-light border-start-0" required="required" placeholder="0123 456 789"/>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">Ngày sinh <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-calendar text-muted"></i></span>
                                                        <input type="date" name="birthdate" class="form-control bg-light border-start-0" required="required"/>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Địa chỉ cư trú <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-light border-end-0"><i class="fa fa-map-marker text-muted"></i></span>
                                                        <input type="text" name="address" class="form-control bg-light border-start-0" required="required" placeholder="Quận/Huyện, Thành phố"/>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Kinh nghiệm làm việc <span class="text-danger">*</span></label>
                                                    <textarea name="experience" class="form-control bg-light" rows="3" required="required" placeholder="Mô tả tóm tắt kinh nghiệm làm việc liên quan..."></textarea>
                                                </div>
                                                
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">Tải lên CV (PDF, DOCX) <span class="text-danger">*</span></label>
                                                    <input type="file" name="cv_file" class="form-control bg-light" accept=".pdf,.doc,.docx" required="required"/>
                                                    <div class="form-text mt-1 text-mutedSmall">Vui lòng tải lên file định dạng PDF hoặc Word, dung lượng tối đa 10MB.</div>
                                                </div>
                                                
                                                <div class="col-12 mt-5">
                                                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm py-3 transition hover-translate-y" style="background-color: #004a99; border: none; border-radius: 8px;">
                                                        GỬI HỒ SƠ ỨNG TUYỂN
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    
                                    <div class="card-footer bg-light border-0 p-4 text-center">
                                        <p class="mb-0 text-muted small">© 2026 MCD Recruitment System. Cảm ơn bạn đã quan tâm.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <style>
                    .hover-translate-y:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
                    }
                    .transition {
                        transition: all 0.3s ease;
                    }
                    .form-control:focus {
                        background-color: #fff !important;
                        border-color: #004a99;
                        box-shadow: 0 0 0 0.25rem rgba(0, 74, 153, 0.1);
                    }
                    .input-group-text {
                        color: #6c757d;
                    }
                </style>
            </div>
        </t>
    </template>
    
    <!-- Thank You Page -->
    <template id="job_thankyou_template" name="Cảm ơn ứng tuyển">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5 bg-white" style="min-height: 60vh; display: flex; align-items: center;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-6 text-center">
                                <div class="mb-4 animate__animated animate__zoomIn">
                                    <div class="bg-success d-inline-flex align-items-center justify-content-center rounded-circle shadow-lg" style="width: 100px; height: 100px;">
                                        <i class="fa fa-check text-white fa-4x"></i>
                                    </div>
                                </div>
                                <h1 class="fw-bold mb-3 text-dark">Đăng Ký Thành Công!</h1>
                                <p class="lead text-muted mb-5">
                                    Hồ sơ của bạn đã được gửi tới bộ phận Tuyển dụng.<br/>
                                    Chúng tôi sẽ xem xét và liên hệ với bạn trong thời gian sớm nhất.
                                </p>
                                <div class="d-flex gap-3 justify-content-center">
                                    <a href="/" class="btn btn-outline-primary btn-lg px-4 fw-bold">Về Trang Chủ</a>
                                    <a href="/my/home" class="btn btn-primary btn-lg px-4 fw-bold shadow-sm" style="background-color: #004a99; border: none;">Vào Portal</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
