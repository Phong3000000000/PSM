<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_psm_approval_request_form_inherit_recruitment" model="ir.ui.view">
            <field name="name">approval.request.form.inherit.psm.recruitment</field>
            <field name="model">approval.request</field>
            <field name="inherit_id" ref="approvals.approval_request_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//div[@class='o_not_full oe_button_box' and @name='button_box']" position="inside">
                    <button name="action_open_psm_recruitment_request"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-external-link"
                        invisible="not x_psm_0205_recruitment_request_id">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">Mở yêu cầu gốc</span>
                        </div>
                    </button>
                </xpath>

                <xpath expr="//page[@name='description']/field[@name='reason']" position="before">
                    <field name="x_psm_0205_recruitment_request_id" invisible="1" />
                    <group invisible="not x_psm_0205_recruitment_request_id">
                        <group>
                            <field name="x_psm_0205_department_id" readonly="1" />
                            <field name="x_psm_0205_recruitment_block" readonly="1" />
                        </group>
                        <group>
                            <field name="x_psm_0205_request_type" readonly="1" />
                            <field name="x_psm_0205_total_quantity" readonly="1" />
                            <field name="x_psm_0205_request_line_count" readonly="1" />
                        </group>
                    </group>
                    <separator string="Lý do tuyển dụng" invisible="not x_psm_0205_recruitment_request_id" />
                </xpath>

                <xpath expr="//page[@name='description']/field[@name='reason']" position="replace">
                    <field name="x_psm_0205_reason" readonly="1" nolabel="1"
                        invisible="not x_psm_0205_recruitment_request_id" />
                    <field name="reason" nolabel="1" invisible="x_psm_0205_recruitment_request_id" />
                </xpath>

                <xpath expr="//page[@name='approvers']" position="before">
                    <page string="Chi tiết yêu cầu" name="x_psm_0205_request_details"
                        invisible="not x_psm_0205_recruitment_request_id">
                        <field name="x_psm_0205_has_request_lines" invisible="1" />
                        <field name="x_psm_0205_request_line_ids" readonly="1" invisible="not x_psm_0205_has_request_lines">
                            <list create="0" edit="0" delete="0">
                                <field name="display_position_name" string="Vị trí tuyển dụng" />
                                <field name="position_level" />
                                <field name="work_location_id" string="Job Location" />
                                <field name="recruitment_block" />
                                <field name="department_id" />
                                <field name="quantity" />
                                <field name="reason" string="Ghi chú/Mô tả" optional="show" />
                            </list>
                        </field>
                        <field name="x_psm_0205_detail_fallback_html" readonly="1" nolabel="1" widget="html"
                            invisible="x_psm_0205_has_request_lines or not x_psm_0205_recruitment_request_id" />
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
