<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================ -->
    <!-- DEPARTMENT BLOCK                 -->
    <!-- ================================ -->

    <record id="view_department_block_tree" model="ir.ui.view">
        <field name="name">department.block.tree</field>
        <field name="model">department.block</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_department_block_form" model="ir.ui.view">
        <field name="name">department.block.form</field>
        <field name="model">department.block</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_department_block" model="ir.actions.act_window">
        <field name="name">Khối Phòng Ban</field>
        <field name="res_model">department.block</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo khối phòng ban mới
            </p>
        </field>
    </record>

    <menuitem id="menu_department_block"
              name="Khối Phòng Ban"
              parent="hr.menu_human_resources_configuration"
              action="action_department_block"
              sequence="5"/>

</odoo>
