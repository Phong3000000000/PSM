<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== APPROVALS PAGE (Line Manager Portal) ========== -->
    <template id="portal_approvals_page" name="Portal Approvals Page">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <!-- Header -->
                <div class="social-card p-4 mb-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h3 class="mb-1">
                                <i class="fa fa-check-square-o me-2 text-warning"/>
                                Duyệt yêu cầu
                            </h3>
                            <p class="text-muted mb-0">
                                Xin chào <strong t-esc="employee.name"/>, bạn có 
                                <strong t-esc="len(pending_shifts) + len(pending_requests) + len(pending_leaves)"/> yêu cầu chờ duyệt từ
                                <strong t-esc="len(subordinates)"/> nhân viên.
                            </p>
                        </div>
                        <a href="/my/home" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-2"/>Quay lại
                        </a>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-lg-8">
                        <!-- Pending Shifts Section -->
                        <t t-if="pending_shifts">
                            <div class="social-card p-4 mb-4">
                                <h5 class="mb-3 text-success">
                                    <i class="fa fa-calendar me-2"/>
                                    Ca làm việc chờ duyệt (<t t-esc="len(pending_shifts)"/>)
                                </h5>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nhân viên</th>
                                                <th>Ca làm việc</th>
                                                <th>Ngày</th>
                                                <th>Giờ</th>
                                                <th class="text-end">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="pending_shifts" t-as="slot">
                                                <tr t-att-data-slot-id="slot.id" class="shift-row">
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar-sm rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                                                <i class="fa fa-user"/>
                                                            </div>
                                                            <span t-esc="slot.resource_id.name"/>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span t-if="slot.role_id" t-esc="slot.role_id.name" class="badge bg-info"/>
                                                        <span t-else="">-</span>
                                                    </td>
                                                    <td>
                                                        <t t-esc="slot.start_datetime" t-options="{'widget': 'date', 'format': 'dd/MM/yyyy'}"/>
                                                    </td>
                                                    <td>
                                                        <t t-esc="slot.start_datetime" t-options="{'widget': 'datetime', 'format': 'HH:mm'}"/> - 
                                                        <t t-esc="slot.end_datetime" t-options="{'widget': 'datetime', 'format': 'HH:mm'}"/>
                                                    </td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-success btn-sm js_approve_shift me-1"
                                                                t-att-data-slot-id="slot.id">
                                                            <i class="fa fa-check"/> Duyệt
                                                        </button>
                                                        <button type="button" class="btn btn-outline-danger btn-sm js_reject_shift"
                                                                t-att-data-slot-id="slot.id">
                                                            <i class="fa fa-times"/> Từ chối
                                                        </button>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <!-- Pending Leaves Section -->
                        <t t-if="pending_leaves">
                            <div class="social-card p-4 mb-4 border-start border-4 border-warning">
                                <h5 class="mb-3 text-warning">
                                    <i class="fa fa-bed me-2"/>
                                    Nghỉ phép chờ duyệt (<t t-esc="len(pending_leaves)"/>)
                                </h5>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nhân viên</th>
                                                <th>Loại</th>
                                                <th>Thời gian</th>
                                                <th class="text-end">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="pending_leaves" t-as="lv">
                                                <tr t-att-data-leave-id="lv.id" class="leave-row">
                                                    <td>
                                                        <div class="fw-bold" t-esc="lv.employee_id.name"/>
                                                        <div class="small text-muted" t-esc="lv.employee_id.department_id.name"/>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-warning text-dark" t-esc="lv.holiday_status_id.name"/>
                                                        <div class="small text-muted mt-1" t-esc="lv.name"/>
                                                    </td>
                                                    <td>
                                                        <t t-esc="lv.date_from" t-options="{'widget': 'date', 'format': 'dd/MM/yyyy'}"/> - 
                                                        <t t-esc="lv.date_to" t-options="{'widget': 'date', 'format': 'dd/MM/yyyy'}"/>
                                                        <div class="small text-primary mt-1">
                                                            <i class="fa fa-clock-o me-1"/><t t-esc="lv.number_of_days"/> ngày
                                                        </div>
                                                    </td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-success btn-sm js_approve_leave me-1"
                                                                t-att-data-leave-id="lv.id"
                                                                t-att-data-employee-name="lv.employee_id.name"
                                                                t-att-data-leave-info="lv.holiday_status_id.name + ': ' + lv.date_from.strftime('%d/%m/%Y') + ' - ' + lv.date_to.strftime('%d/%m/%Y')">
                                                            <i class="fa fa-check"/> Duyệt
                                                        </button>
                                                        <button type="button" class="btn btn-outline-danger btn-sm js_reject_leave"
                                                                t-att-data-leave-id="lv.id">
                                                            <i class="fa fa-times"/> Từ chối
                                                        </button>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Pending Approval Requests Section -->
                        <t t-if="pending_requests">
                            <div class="social-card p-4 mb-4">
                                <h5 class="mb-3 text-primary">
                                    <i class="fa fa-file-text-o me-2"/>
                                    Yêu cầu phê duyệt (<t t-esc="len(pending_requests)"/>)
                                </h5>
                                <div class="list-group list-group-flush">
                                    <t t-foreach="pending_requests" t-as="req">
                                        <div class="list-group-item request-row" t-att-data-request-id="req.id">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">
                                                    <div class="d-flex align-items-center mb-1">
                                                        <span class="badge bg-secondary me-2" t-esc="req.category_id.name"/>
                                                        <strong t-esc="req.name"/>
                                                    </div>
                                                    <p class="text-muted mb-1 small">
                                                        <i class="fa fa-user me-1"/>
                                                        <t t-esc="req.request_owner_id.name"/>
                                                        <span class="mx-2">•</span>
                                                        <i class="fa fa-clock-o me-1"/>
                                                        <t t-esc="req.create_date" t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/>
                                                    </p>
                                                    <t t-if="req.reason">
                                                        <div class="small text-muted" style="max-width: 400px;">
                                                            <t t-raw="req.reason[:200]"/>
                                                            <t t-if="len(req.reason or '') > 200">...</t>
                                                        </div>
                                                    </t>
                                                    
                                                    <!-- Hiển thị thay đổi (nếu có) -->
                                                    <t t-set="changes" t-value="req.get_changes_summary()"/>
                                                    <t t-if="changes">
                                                            <div class="mt-2 p-2 bg-light rounded small border" style="max-width: 500px;">
                                                                <div class="fw-bold text-muted mb-1" style="font-size: 0.85rem;">
                                                                    <i class="fa fa-pencil-square-o me-1"/>Thay đổi đề xuất:
                                                                </div>
                                                                <ul class="list-unstyled mb-0 ms-2">
                                                                    <t t-foreach="changes" t-as="change">
                                                                        <li class="mb-1">
                                                                            <span class="fw-bold text-dark" t-esc="change['label']"/>: 
                                                                            <span class="text-decoration-line-through text-muted" t-esc="change['old']"/> 
                                                                            <i class="fa fa-long-arrow-right mx-1 text-primary"/> 
                                                                            <span class="text-success fw-bold" t-esc="change['new']"/>
                                                                        </li>
                                                                    </t>
                                                                </ul>
                                                            </div>
                                                    </t>
                                                    
                                                    <!-- Hiển thị đính kèm (nếu có) -->
                                                    <t t-set="attachments" t-value="req.env['ir.attachment'].sudo().search([
                                                        ('res_model', '=', 'approval.request'),
                                                        ('res_id', '=', req.id)
                                                    ])"/>
                                                    <t t-if="attachments">
                                                        <div class="mt-2 text-muted small">
                                                            <i class="fa fa-paperclip me-1"/> 
                                                            <strong>Đính kèm:</strong>
                                                            <ul class="list-inline mb-0 d-inline-block ms-1">
                                                                <t t-foreach="attachments" t-as="att">
                                                                    <li class="list-inline-item me-2">
                                                                        <a t-attf-href="/web/content/#{att.id}?download=true" target="_blank" class="text-decoration-none">
                                                                            <t t-esc="att.name"/>
                                                                        </a>
                                                                    </li>
                                                                </t>
                                                            </ul>
                                                        </div>
                                                    </t>
                                                    
                                                    <!-- Upload Form -->
                                                    <form action="/my/approvals/upload_attachment" method="post" enctype="multipart/form-data" class="mt-2">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <input type="hidden" name="request_id" t-att-value="req.id"/>
                                                        <div class="input-group input-group-sm" style="max-width: 300px;">
                                                            <input type="file" name="attachment_ids" multiple="multiple" class="form-control form-control-sm"/>
                                                            <button type="submit" class="btn btn-outline-secondary">
                                                                <i class="fa fa-upload"/>
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                                <div class="btn-group">
                                                    <button type="button" class="btn btn-success btn-sm js_approve_request"
                                                            t-att-data-request-id="req.id">
                                                        <i class="fa fa-check"/> Duyệt
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger btn-sm js_reject_request"
                                                            t-att-data-request-id="req.id">
                                                        <i class="fa fa-times"/> Từ chối
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Empty State -->
                        <t t-if="not pending_shifts and not pending_requests and not pending_leaves">
                            <div class="social-card p-5 text-center">
                                <i class="fa fa-check-circle text-success mb-3" style="font-size: 48px;"/>
                                <h5 class="text-muted">Không có yêu cầu chờ duyệt</h5>
                                <p class="text-muted small">Tất cả các yêu cầu từ nhân viên đã được xử lý.</p>
                            </div>
                        </t>
                    </div>
                    
                    <!-- Right Sidebar: Recently Processed -->
                    <div class="col-lg-4">
                        <div class="social-card p-3">
                            <h6 class="text-muted mb-3">
                                <i class="fa fa-history me-2"/>ĐÃ XỬ LÝ GẦN ĐÂY
                            </h6>
                            <t t-if="recent_processed">
                                <t t-foreach="recent_processed" t-as="req">
                                    <div class="d-flex align-items-start mb-3 pb-2 border-bottom">
                                        <div class="flex-grow-1">
                                            <div class="small fw-bold" t-esc="req.name"/>
                                            <div class="small text-muted">
                                                <t t-esc="req.request_owner_id.name"/>
                                            </div>
                                        </div>
                                        <span t-if="req.request_status == 'approved'" class="badge bg-success">
                                            <i class="fa fa-check"/> Đã duyệt
                                        </span>
                                        <span t-elif="req.request_status == 'refused'" class="badge bg-danger">
                                            <i class="fa fa-times"/> Từ chối
                                        </span>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <p class="text-muted small mb-0">Chưa có yêu cầu nào được xử lý.</p>
                            </t>
                        </div>
                        
                        <!-- Team Info -->
                        <div class="social-card p-3 mt-3">
                            <h6 class="text-muted mb-3">
                                <i class="fa fa-users me-2"/>NHÂN VIÊN CẤP DƯỚI
                            </h6>
                            <t t-if="subordinates">
                                <t t-foreach="subordinates[:5]" t-as="sub">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="avatar-sm rounded-circle bg-light text-secondary d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
                                            <i class="fa fa-user"/>
                                        </div>
                                        <span class="small" t-esc="sub.name"/>
                                    </div>
                                </t>
                                <t t-if="len(subordinates) > 5">
                                    <p class="text-muted small mb-0">
                                        và <t t-esc="len(subordinates) - 5"/> nhân viên khác...
                                    </p>
                                </t>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal Duyệt Nghỉ Phép & Chọn Người Thay Thế -->
            <div class="modal fade" id="leaveApprovalModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">
                                <i class="fa fa-check-circle me-2"/>Duyệt nghỉ phép
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <input type="hidden" id="modal_leave_id"/>
                            <div class="mb-4 text-center">
                                <p class="mb-1">Bạn đang chuẩn bị duyệt đơn nghỉ phép của:</p>
                                <h5 id="modal_employee_name" class="fw-bold text-success mb-0">---</h5>
                                <p id="modal_leave_info" class="text-muted small">---</p>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Chọn nhân viên thay thế (từ các store lân cận)</label>
                                <select id="replacement_employee_id" class="form-select">
                                    <option value="">-- Không có người thay thế --</option>
                                    <!-- Options populated via JS -->
                                </select>
                                <div class="form-text text-muted">
                                    <i class="fa fa-info-circle me-1"/>
                                    Danh sách gợi ý từ các cửa hàng bạn cùng quản lý.
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-light border-top-0">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="button" id="btn_confirm_leave_approval" class="btn btn-success px-4">
                                <i class="fa fa-check me-1"/>Xác nhận duyệt
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
