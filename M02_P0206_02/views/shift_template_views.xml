<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_workforce_shift_template_tree" model="ir.ui.view">
        <field name="name">workforce.shift.template.tree</field>
        <field name="model">workforce.shift.template</field>
        <field name="arch" type="xml">
            <list string="Shift Templates" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="start_hour" widget="float_time"/>
                <field name="end_hour" widget="float_time"/>
                <field name="duration" widget="float_time"/>
                <field name="store_id" optional="show"/>
                <field name="is_peak"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_workforce_shift_template_form" model="ir.ui.view">
        <field name="name">workforce.shift.template.form</field>
        <field name="model">workforce.shift.template</field>
        <field name="arch" type="xml">
            <form string="Shift Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_hour" widget="float_time"/>
                            <field name="end_hour" widget="float_time"/>
                        </group>
                        <group>
                            <field name="store_id"/>
                            <field name="is_peak"/>
                            <field name="is_active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_workforce_shift_template" model="ir.actions.act_window">
        <field name="name">Cấu hình Ca làm việc</field>
        <field name="res_model">workforce.shift.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo mẫu ca làm việc mới
            </p>
        </field>
    </record>
</odoo>
