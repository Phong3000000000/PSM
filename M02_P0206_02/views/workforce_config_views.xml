    <!-- Config Action -->
    <record id="action_workforce_store_config" model="ir.actions.act_window">
        <field name="name">Cấu hình Workforce</field>
        <field name="res_model">workforce.store.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo cấu hình Workforce cho cửa hàng
            </p>
            <p>
                Cấu hình các chỉ tiêu KPI như GCPCH (năng suất), L% (chi phí nhân sự) 
                và Trend Factor (hệ số điều chỉnh) cho từng cửa hàng.
            </p>
        </field>
    </record>
</odoo>
