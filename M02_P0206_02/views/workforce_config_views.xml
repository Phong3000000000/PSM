<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ===== WORKFORCE STORE CONFIG VIEWS ===== -->
    
    <!-- Config Form View -->
    <record id="view_workforce_store_config_form" model="ir.ui.view">
        <field name="name">workforce.store.config.form</field>
        <field name="model">workforce.store.config</field>
        <field name="arch" type="xml">
            <form string="Cấu hình Workforce">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" 
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"/>
                        </button>
                    </div>
                    <group>
                        <group string="Phạm vi áp dụng">
                            <field name="store_id"/>
                            <field name="period_id"/>
                        </group>
                        <group string="KPI Mục tiêu">
                            <field name="target_gcpch"/>
                            <field name="target_labor_cost" widget="percentage"/>
                        </group>
                    </group>
                    <group>
                        <group string="Điều chỉnh">
                            <field name="trend_factor"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Config List View -->
    <record id="view_workforce_store_config_list" model="ir.ui.view">
        <field name="name">workforce.store.config.list</field>
        <field name="model">workforce.store.config</field>
        <field name="arch" type="xml">
            <list string="Cấu hình Workforce">
                <field name="store_id"/>
                <field name="period_id"/>
                <field name="target_gcpch"/>
                <field name="target_labor_cost"/>
                <field name="trend_factor"/>
            </list>
        </field>
    </record>
    
