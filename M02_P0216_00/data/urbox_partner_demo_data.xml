<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Urbox Partner Demo Data with Logos -->
        <record id="partner_grab" model="urbox.partner">
            <field name="name">Grab</field>
            <field name="code">GRAB</field>
            <field name="description">Nền tảng giao thông và giao hàng hàng đầu Đông Nam Á</field>
            <field name="website">https://www.grab.com</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

        <record id="partner_shopee" model="urbox.partner">
            <field name="name">Shopee</field>
            <field name="code">SHOPEE</field>
            <field name="description">Sàn thương mại điện tử hàng đầu Việt Nam</field>
            <field name="website">https://shopee.vn</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

        <record id="partner_tch" model="urbox.partner">
            <field name="name">The Coffee House</field>
            <field name="code">TCH</field>
            <field name="description">Chuỗi cà phê hàng đầu Việt Nam</field>
            <field name="website">https://www.thecoffeehouse.com</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

        <record id="partner_cgv" model="urbox.partner">
            <field name="name">CGV Cinemas</field>
            <field name="code">CGV</field>
            <field name="description">Hệ thống rạp chiếu phim hàng đầu Việt Nam</field>
            <field name="website">https://www.cgv.vn</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

        <record id="partner_kfc" model="urbox.partner">
            <field name="name">KFC Vietnam</field>
            <field name="code">KFC</field>
            <field name="description">Chuỗi thức ăn nhanh quốc tế</field>
            <field name="website">https://kfcvietnam.com.vn</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

        <record id="partner_lotte" model="urbox.partner">
            <field name="name">Lotte Cinema</field>
            <field name="code">LOTTE</field>
            <field name="description">Hệ thống rạp chiếu phim Lotte tại Việt Nam</field>
            <field name="website">https://www.lottecinemavn.com</field>
            <field name="active">True</field>
            <field name="logo"></field>
        </record>

    </data>
</odoo>
