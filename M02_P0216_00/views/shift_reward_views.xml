        <field name="arch" type="xml">
            <search string="Search Rewards">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <filter string="EOTM" name="eotm" domain="[('reward_type', '=', 'eotm')]"/>
                <filter string="EOTQ" name="eotq" domain="[('reward_type', '=', 'eotq')]"/>
                <group string="Group By">
                    <filter string="Loại" name="group_type" context="{'group_by': 'reward_type'}"/>
                    <filter string="Chi nhánh" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Ngày" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>
