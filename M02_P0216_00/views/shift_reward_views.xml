    <!-- Reward Action -->
    <record id="action_shift_reward" model="ir.actions.act_window">
        <field name="name">Danh sách Khen thưởng</field>
        <field name="res_model">shift.reward</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo bản ghi khen thưởng mới
            </p>
            <p>
                Hệ thống sẽ dựa trên điểm trung bình post-shift để vinh danh nhân viên tiêu biểu nhất của tháng/quý.
            </p>
        </field>
    </record>

    <!-- Reward Menu (Parent) -->
    <menuitem id="menu_shift_reward"
              name="Khen thưởng (EOTM/EOTQ)"
              parent="menu_shift_evaluation_root"
              sequence="30"/>
    
    <!-- Submenu: Danh sách Khen thưởng -->
    <menuitem id="menu_shift_reward_list"
              name="Danh sách Khen thưởng"
              parent="menu_shift_reward"
              action="action_shift_reward"
              sequence="10"/>
    
    <!-- Submenu: Cấp điểm -->
    <!-- <menuitem id="menu_point_grant"
              name="Cấp điểm"
              parent="menu_shift_reward"
              action="action_point_grant"
              sequence="20"/> -->

</odoo>
