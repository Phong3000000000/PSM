<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reward Tree View -->
    <record id="view_shift_reward_tree" model="ir.ui.view">
        <field name="name">shift.reward.tree</field>
        <field name="model">shift.reward</field>
        <field name="arch" type="xml">
            <list string="Khen thưởng" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'">
                <field name="name"/>
                <field name="reward_type"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <field name="score" widget="float"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- Reward Form View -->
    <record id="view_shift_reward_form" model="ir.ui.view">
        <field name="name">shift.reward.form</field>
        <field name="model">shift.reward</field>
        <field name="arch" type="xml">
            <form string="Khen thưởng">
                <header>
                    <button name="%(action_report_shift_reward_certificate)d" string="In chứng nhận" type="action" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_grant_points" string="Cấp điểm (100đ/NV)" type="object" class="btn-warning" invisible="state != 'confirmed' or is_granted"/>
                    <button name="action_confirm" string="Xác nhận" type="object" class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Đặt về nháp" type="object" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Đã cấp điểm" bg_color="bg-success" invisible="not is_granted"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                            <field name="is_granted" invisible="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="reward_type" readonly="state == 'confirmed'"/>
                            <field name="date" readonly="state == 'confirmed'"/>
                            <field name="company_id" readonly="state == 'confirmed'"/>
                        </group>
                        <group string="Kết quả">
                            <field name="employee_id" readonly="1"/>
                            <field name="score" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Điểm trung bình nhân viên" name="lines">
                            <field name="reward_line_ids" readonly="1">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="average_score" widget="float"/>
                                    <field name="reward_point" widget="float"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Reward Search View -->
