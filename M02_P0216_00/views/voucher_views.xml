<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Voucher Generator Form (from wizard) -->
    <record id="view_voucher_generator_form" model="ir.ui.view">
        <field name="name">voucher.generator.form</field>
        <field name="model">voucher.generator</field>
        <field name="arch" type="xml">
            <form string="Tạo Voucher Hàng Loạt">
                <group>
                    <group>
                        <field name="denomination"/>
                        <field name="quantity"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="point_required"/>
                        <field name="state"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate" string="Tạo Voucher" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_voucher_generator" model="ir.actions.act_window">
        <field name="name">Tạo Voucher Hàng Loạt</field>
        <field name="res_model">voucher.generator</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Voucher Views -->
    <record id="view_voucher_voucher_tree" model="ir.ui.view">
        <field name="name">voucher.voucher.tree</field>
        <field name="model">voucher.voucher</field>
        <field name="arch" type="xml">
            <list string="Danh sách Voucher" create="0">
                <header>
                    <button name="%(action_voucher_generator)d" string="Tạo Voucher" type="action" class="btn-primary" display="always"/>
                </header>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="denomination"/>
                <field name="value" widget="monetary"/>
                <field name="point_required"/>
                <field name="quantity"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-muted="state == 'expired'"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_voucher_voucher_form" model="ir.ui.view">
        <field name="name">voucher.voucher.form</field>
        <field name="model">voucher.voucher</field>
        <field name="arch" type="xml">
            <form string="Voucher">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên voucher..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id"/>
                            <field name="denomination"/>
                            <field name="value" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="point_required"/>
                            <field name="quantity"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Voucher Redeem History Views -->
    <record id="view_voucher_redeem_tree" model="ir.ui.view">
        <field name="name">voucher.redeem.tree</field>
        <field name="model">voucher.redeem</field>
        <field name="arch" type="xml">
            <list string="Lịch sử đổi Voucher" delete="0" create="0">
                <field name="redeem_date"/>
                <field name="employee_id"/>
                <field name="voucher_id"/>
                <field name="point_used"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_voucher_voucher" model="ir.actions.act_window">
        <field name="name">Quản lý Voucher</field>
        <field name="res_model">voucher.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo voucher mới
            </p>
        </field>
    </record>

    <record id="action_voucher_redeem" model="ir.actions.act_window">
        <field name="name">Lịch sử đổi Voucher</field>
        <field name="res_model">voucher.redeem</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có lịch sử đổi voucher nào
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_voucher_root"
              name="Voucher"
              parent="M02_P0216_00.menu_shift_evaluation_root"
              sequence="30"/>

    <menuitem id="menu_voucher_voucher"
              name="Danh sách Voucher"
              parent="menu_voucher_root"
              action="action_voucher_voucher"
              sequence="10"/>

    <menuitem id="menu_voucher_redeem"
              name="Lịch sử đổi"
              parent="menu_voucher_root"
              action="action_voucher_redeem"
              sequence="20"/>

    <menuitem id="menu_voucher_generator"
              name="Tạo Voucher"
              parent="menu_voucher_root"
              action="action_voucher_generator"
              sequence="15"/>

</odoo>
