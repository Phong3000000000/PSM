<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Company Form View -->
    <record id="view_company_form_shift_evaluation" model="ir.ui.view">
        <field name="name">res.company.form.shift.evaluation</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Shift Evaluations" name="shift_evaluations">
                    <div class="oe_button_box" name="button_box_shift">
                        <button name="action_open_all_evaluations" string="Quản lý tất cả" type="object" class="oe_link" icon="fa-list"/>
                    </div>
                    <field name="shift_evaluation_ids" mode="list" context="{'search_default_group_by_date': 1}">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="shift"/>
                            <field name="mic_id"/>
                            <field name="employee_count" string="Số NV"/>
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="state" widget="badge"/>
                            <button name="action_open_post_shift" string="Chấm điểm" type="object" icon="fa-star"/>
                            <button name="action_view_detail" string="Chi tiết" type="object" icon="fa-eye"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


</odoo>
