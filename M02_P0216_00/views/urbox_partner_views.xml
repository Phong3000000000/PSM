<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Urbox Partner Tree View -->
    <record id="view_urbox_partner_tree" model="ir.ui.view">
        <field name="name">urbox.partner.tree</field>
        <field name="model">urbox.partner</field>
        <field name="arch" type="xml">
            <list string="Đối tác Urbox">
                <field name="name"/>
                <field name="code"/>
                <field name="website"/>
                <field name="voucher_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Urbox Partner Form View -->
    <record id="view_urbox_partner_form" model="ir.ui.view">
        <field name="name">urbox.partner.form</field>
        <field name="model">urbox.partner</field>
        <field name="arch" type="xml">
            <form string="Đối tác Urbox">
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên đối tác..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="website" widget="url"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="voucher_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="description" placeholder="Mô tả về đối tác..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Urbox Partner Kanban View -->
    <record id="view_urbox_partner_kanban" model="ir.ui.view">
        <field name="name">urbox.partner.kanban</field>
        <field name="model">urbox.partner</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="logo"/>
                <field name="voucher_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="logo" widget="image" class="o_image_64_cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <i class="fa fa-ticket"/> <field name="voucher_count"/> vouchers
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Urbox Partner Action -->
    <record id="action_urbox_partner" model="ir.actions.act_window">
        <field name="name">Đối tác Urbox</field>
        <field name="res_model">urbox.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo đối tác Urbox mới
            </p>
            <p>
                Quản lý danh sách các đối tác cung cấp voucher.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_urbox_partner"
              name="Đối tác Urbox"
              parent="menu_voucher_root"
              action="action_urbox_partner"
              sequence="25"/>

</odoo>
