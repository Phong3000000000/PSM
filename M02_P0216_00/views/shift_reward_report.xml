<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_shift_reward_certificate" model="ir.actions.report">
        <field name="name">Certificate of Appreciation</field>
        <field name="model">shift.reward</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">M02_P0216_00.report_shift_reward_certificate</field>
        <field name="report_file">M02_P0216_00.report_shift_reward_certificate</field>
        <field name="print_report_name">'Certificate - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_shift_reward"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_shift_reward_certificate">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="border: 10px solid #7851a9; padding: 20px; height: 1000px; text-align: center; position: relative;">
                        <!-- Watermark/Background decoration could go here -->
                        
                        <div style="margin-top: 50px;">
                            <h1 style="font-family: 'Great Vibes', cursive; font-size: 60px; color: #7851a9;">Certificate of Appreciation</h1>
                            <h3 style="font-size: 24px; margin-top: 20px; color: #555;">This certificate is proudly presented to</h3>
                        </div>

                        <div style="margin-top: 40px;">
                            <h2 t-field="o.employee_id.name" style="font-family: 'Pinyon Script', cursive; font-size: 50px; border-bottom: 2px solid #7851a9; display: inline-block; padding-bottom: 10px; min-width: 400px;"/>
                        </div>

                        <div style="margin-top: 30px; font-size: 20px; color: #555;">
                            <p>For outstanding performance and dedication as</p>
                            <h3 style="color: #7851a9; font-size: 30px; margin: 20px 0;">
                                <span t-if="o.reward_type == 'eotm'">Employee of the Month</span>
                                <span t-if="o.reward_type == 'eotq'">Employee of the Quarter</span>
                            </h3>
                            <p>
                                <span t-if="o.reward_type == 'eotm'">Month: <span t-field="o.date" t-options='{"widget": "date", "format": "MM/yyyy"}'/></span>
                                <span t-if="o.reward_type == 'eotq'">
                                    <t t-set="quarter" t-value="(o.date.month - 1) // 3 + 1"/>
                                    Quarter: <t t-esc="quarter"/>/<span t-field="o.date" t-options='{"widget": "date", "format": "yyyy"}'/>
                                </span>
                            </p>
                        </div>

                        <div style="margin-top: 100px; display: flex; justify-content: space-around; font-size: 18px;">
                            <div style="text-align: center;">
                                <div style="border-top: 1px solid #000; padding-top: 10px; width: 200px; margin: 0 auto;">
                                    <span t-field="o.date"/>
                                </div>
                                <p>Date</p>
                            </div>
                            <div style="text-align: center;">
                                <div style="border-top: 1px solid #000; padding-top: 10px; width: 200px; margin: 0 auto;">
                                    <!-- Manager Signature Placeholder -->
                                </div>
                                <p>Manager Signature</p>
                            </div>
                        </div>
                        
                        <div style="position: absolute; bottom: 20px; width: 100%; text-align: center; color: #999; font-size: 12px;">
                            <span t-field="o.company_id.name"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
