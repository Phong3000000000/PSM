    <!-- Inject submenu into App thưởng in portal_custom -->
    <template id="portal_rewards_submenu" inherit_id="portal_custom.portal_my_home_inherit">
        <xpath expr="//a[@href='/my/rewards']" position="replace">
            <!-- App thưởng - Expandable Menu -->
            <a role="button" data-bs-toggle="collapse" data-bs-target="#rewardsSubMenu" class="sidebar-link">
                <div class="app-icon-wrapper me-3" style="background: #e1bee7; color: #8e24aa;">
                    <i class="fa fa-gift" />
                </div>
                <span class="flex-grow-1">App thưởng</span>
                <i class="fa fa-chevron-down" style="font-size: 12px; color: #65676b;" />
            </a>
            <!-- Rewards Submenu -->
            <div id="rewardsSubMenu" class="collapse">
                <div class="ms-4 border-start ps-2" style="border-color: #e4e6eb !important;">
                    <a href="/my/eotq" class="sidebar-link py-2">
                        <i class="fa fa-star text-warning me-2" style="font-size: 14px;" />
                        <span style="font-size: 14px;">EOTQ</span>
                    </a>
                    <a href="/my/vouchers" class="sidebar-link py-2">
                        <i class="fa fa-ticket text-success me-2" style="font-size: 14px;" />
                        <span style="font-size: 14px;">Đổi Voucher</span>
                    </a>
                    <a href="/my/vouchers/history" class="sidebar-link py-2">
                        <i class="fa fa-history text-info me-2" style="font-size: 14px;" />
                        <span style="font-size: 14px;">Voucher của tôi</span>
                    </a>
                    <a href="/my/shift_evaluations" class="sidebar-link py-2">
                        <i class="fa fa-check-circle text-primary me-2" style="font-size: 14px;" />
                        <span style="font-size: 14px;">Chấm điểm (MIC)</span>
                    </a>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
