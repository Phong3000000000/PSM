<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Department Form View -->
    <record id="view_department_form_shift_evaluation" model="ir.ui.view">
        <field name="name">hr.department.form.shift.evaluation</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="Shift Evaluations" name="shift_evaluations">
                        <div class="oe_button_box" name="button_box_shift">
                            <button name="action_open_all_evaluations" string="Quản lý tất cả" type="object" class="oe_link" icon="fa-list"/>
                        </div>
                        <field name="shift_evaluation_ids" mode="list">
                            <list editable="bottom">
                                <field name="date"/>
                                <field name="shift"/>
                                <field name="mic_id"/>
                                <field name="employee_count" string="Số NV"/>
                                <field name="employee_ids" widget="many2many_tags"/>
                                <field name="state" widget="badge"/>
                                <button name="action_open_post_shift" string="Chấm điểm" type="object" icon="fa-star"/>
                                <button name="action_view_detail" string="Chi tiết" type="object" icon="fa-eye"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>


</odoo>
