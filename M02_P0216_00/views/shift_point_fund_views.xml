<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shift_point_fund_tree" model="ir.ui.view">
        <field name="name">shift.point.fund.tree</field>
        <field name="model">shift.point.fund</field>
        <field name="arch" type="xml">
            <list string="Kho điểm">
                <header>
                    <button name="action_generate_funds" string="Tạo kho điểm hàng loạt" type="object" class="btn-primary" display="always"/>
                </header>
                <field name="name"/>
                <field name="fund_type"/>
                <field name="company_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="score" widget="float"/>
            </list>
        </field>
    </record>

    <record id="action_generate_funds_server" model="ir.actions.server">
        <field name="name">Cập nhật kho điểm hàng loạt</field>
        <field name="model_id" ref="model_shift_point_fund"/>
        <field name="binding_model_id" ref="model_shift_point_fund"/>
        <field name="state">code</field>
        <field name="code">
            action = model.action_generate_funds()
        </field>
    </record>

    <record id="view_shift_point_fund_form" model="ir.ui.view">
        <field name="name">shift.point.fund.form</field>
        <field name="model">shift.point.fund</field>
        <field name="arch" type="xml">
            <form string="Kho điểm">
                <!-- <header>
                    <button name="action_open_grant_form" string="Cấp điểm" type="object" class="btn-primary" invisible="fund_type != 'department'"/>
                </header> -->
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên kho điểm..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_type"/>
                            <field name="company_id" invisible="fund_type != 'department'"/>
                            <field name="department_id" invisible="fund_type != 'department'"/>
                        </group>
                        <group>
                            <field name="score"/>
                        </group>
                    </group>
                    <notebook invisible="fund_type not in ['department']">
                        <page string="Danh sách nhân viên">
                            <field name="employee_ids" readonly="1" nolabel="1">
                                <list string="Nhân viên" create="0" delete="0">
                                    <field name="name"/>
                                    <field name="job_id"/>
                                    <field name="department_id"/>
                                    <field name="company_id"/>
                                    <field name="work_email"/>
                                    <button name="action_grant_points_from_fund" string="Cấp điểm" type="object" class="btn-primary btn-sm" context="{'fund_id': parent.id}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shift_point_fund" model="ir.actions.act_window">
        <field name="name">Kho điểm</field>
        <field name="res_model">shift.point.fund</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'group_by': 'fund_type'}</field>
    </record>

    <!-- Parent Menu (Container) -->
    <menuitem id="menu_shift_point_fund_root"
              name="Kho điểm"
              parent="menu_shift_evaluation_root"
              sequence="40"/>

    <!-- Child Menu: List View -->
    <menuitem id="menu_shift_point_fund"
              name="Danh sách"
              parent="menu_shift_point_fund_root"
              action="action_shift_point_fund"
              sequence="10"/>

    <!-- Child Menu: Bulk Create Action -->
    <!-- <menuitem id="menu_action_generate_funds"
              name="Tạo kho điểm hàng loạt"
              parent="menu_shift_point_fund_root"
              action="action_generate_funds_server"
              sequence="20"/> -->

</odoo>