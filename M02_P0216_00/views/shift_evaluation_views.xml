<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_shift_evaluation_tree" model="ir.ui.view">
        <field name="name">shift.evaluation.tree</field>
        <field name="model">shift.evaluation</field>
        <field name="arch" type="xml">
            <list string="Shift Evaluations" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="date"/>
                <field name="shift"/>
                <field name="mic_id"/>
                <field name="employee_count"/>  
                <field name="company_id"/>  
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'"/>
                
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shift_evaluation_form" model="ir.ui.view">
        <field name="name">shift.evaluation.form</field>
        <field name="model">shift.evaluation</field>
        <field name="arch" type="xml">
            <form string="Shift Evaluation">
                <header>
                    <button name="action_start" string="Bắt đầu" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Hoàn thành" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Đặt về nháp" type="object" invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="date"/>
                            <field name="shift"/>
                        </group>
                        <group>
                            <field name="mic_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Nhân viên &amp; Chấm điểm" name="employees">
                            <group string="Chọn nhân viên">
                                <field name="employee_ids" widget="many2many_tags" placeholder="Chọn nhân viên tham gia ca..."/>
                            </group>
                            <separator string="Danh sách chấm điểm"/>
                            <field name="post_shift_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="employee_id" readonly="1" force_save="1"/>
                                    <field name="score"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_shift_evaluation_search" model="ir.ui.view">
        <field name="name">shift.evaluation.search</field>
        <field name="model">shift.evaluation</field>
        <field name="arch" type="xml">
            <search string="Search Shift Evaluations">
                <field name="date"/>
                <field name="department_id"/>
                <field name="mic_id"/>
                <field name="shift"/>
                <filter string="Sáng" name="morning" domain="[('shift', '=', 'morning')]"/>
                <filter string="Chiều" name="afternoon" domain="[('shift', '=', 'afternoon')]"/>
                <filter string="Tối" name="evening" domain="[('shift', '=', 'evening')]"/>
                <separator/>
                <filter string="Nháp" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Đang xử lý" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Hoàn thành" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Ngày" name="group_date" context="{'group_by': 'date:day'}"/>
                <filter string="Phòng ban" name="group_department" context="{'group_by': 'department_id'}"/>
                <filter string="MIC" name="group_mic" context="{'group_by': 'mic_id'}"/>
                <filter string="Ca làm" name="group_shift" context="{'group_by': 'shift'}"/>
                <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shift_evaluation" model="ir.actions.act_window">
        <field name="name">Shift Evaluations</field>
        <field name="res_model">shift.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_date': 1}</field>
        <field name="search_view_id" ref="view_shift_evaluation_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo ca làm đầu tiên
            </p>
            <p>
                Quản lý ca làm việc với MIC và nhân viên.
            </p>
        </field>
    </record>

    <!-- Root Menu - lands on Shift Evaluations list -->
    <menuitem id="menu_shift_evaluation_root" 
              name="Khen thưởng" 
              action="action_shift_evaluation"
              web_icon="M02_P0216_00,static/description/icon.png"
              sequence="10"/>

    <!-- Submenu -->
    <menuitem id="menu_shift_evaluation" 
              name="Danh sách Shift Evaluations" 
              parent="menu_shift_evaluation_root"
              action="action_shift_evaluation" 
              sequence="20"/>

</odoo>
